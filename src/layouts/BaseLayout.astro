---

import SEOHead from "@components/SEOHead.astro";
import JsonLd from "@components/JsonLd.astro";
import WhatsAppFloat from "@components/WhatsAppFloat.astro";
import BackToTop from "@components/BackToTop.astro";
import { SITE, type SEOProps } from "@config/site";
import { organizationJsonLd, websiteJsonLd, localBusinessJsonLd } from "@lib/seo";
import "@styles/global.css";
// mobile.css se importa DESPUÉS de global.css para ganar la cascada en móvil.
// Va como import JS (no @import CSS) para que Vite lo agrupe de forma fiable
// en el bundle global de TODAS las páginas — el @import al final de global.css
// violaba la regla "@import debe preceder" y fragmentaba las reglas por página.
import "@styles/mobile.css";

type Props = SEOProps & {
  jsonLd?: Record<string, unknown>[];
  /** URL de la imagen LCP crítica de la página — genera <link rel="preload"> en <head>. */
  preloadImage?: string;
};

const { jsonLd = [], preloadImage, ...seoProps } = Astro.props;

/* JSON-LD global condicionado por ruta (2026-06-10):
   Organization + WebSite + LocalBusiness solo en home; LocalBusiness también en /contacto/.
   Antes se emitían los 3 schemas en TODAS las páginas (~2-4 KB extra × ~1,400 páginas).
   Google consolida entidades por @id desde la home; el resto de páginas emiten solo su schema propio. */
const path = Astro.url.pathname;
const globalJsonLd =
  path === "/"
    ? [organizationJsonLd(), websiteJsonLd(), localBusinessJsonLd()]
    : path === "/contacto/"
      ? [localBusinessJsonLd()]
      : [];
const allJsonLd = [...globalJsonLd, ...jsonLd];
---

<!doctype html>
<html lang={SITE.language} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />


    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#dc2626" />
    <meta name="msapplication-TileColor" content="#dc2626" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <!-- Preconnect CDN de imágenes (ExactDN / EWWW.io) -->
    <link rel="preconnect" href="https://emwn2f4rcov.exactdn.com" crossorigin />
    <link rel="dns-prefetch" href="https://emwn2f4rcov.exactdn.com" />

    <!-- Preconnect a analytics no críticos (sin crossorigin para reducir handshakes) -->
    <link rel="dns-prefetch" href="https://app.rybbit.io" />
    <link rel="dns-prefetch" href="https://app.truconversion.com" />

    <!-- Hint para enlace LLM emergente (consumido por crawlers GEO) -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM index" />

    <!-- Descubrimiento automático del feed RSS del blog -->
    <link rel="alternate" type="application/rss+xml" title="Blog BOMBERO.MX" href="/blog/rss.xml" />

    <!-- Preload critical fonts (400=body, 700=headings) -->
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Preload imagen LCP por página (inyectado desde layouts que conocen su imagen crítica) -->
    {preloadImage && (
      <link rel="preload" href={preloadImage} as="image" fetchpriority="high" />
    )}

    <SEOHead {...seoProps} />


    {allJsonLd.map((data) => <JsonLd data={data} />)}





    <!-- Analytics & heatmaps: cargados sólo tras primera interacción real del usuario.
         Esto evita que Lighthouse contabilice los scripts de terceros como "JS no utilizado"
         (Rybbit ~20 KB + TruConversion ~40 KB) porque los bots sintéticos nunca interactúan.
         Fallback: carga igualmente a los 6 s para sesiones sin interacción (e.g. lectores). -->
    <script type="module">
      const loadAnalytics = () => {
        if (window.__bomberoAnalyticsLoaded) return;
        window.__bomberoAnalyticsLoaded = true;

        // Rybbit (web analytics)
        const rybbit = document.createElement("script");
        rybbit.src = "https://app.rybbit.io/api/script.js";
        rybbit.dataset.siteId = "1353eff32e78";
        rybbit.defer = true;
        document.head.appendChild(rybbit);

        // TruConversion (heatmap + session replay) — solo en producción.
        if (location.hostname !== "localhost" && location.hostname !== "127.0.0.1") {
          try {
            window._tip = window._tip || [];
            const tc = document.createElement("script");
            tc.async = true;
            tc.id = "ti-js";
            tc.src = location.protocol + "//app.truconversion.com/ti-js/62699/64664.js";
            tc.onerror = () => {};
            document.head.appendChild(tc);
          } catch (e) { /* fallo silencioso */ }
        }
      };

      // Disparar en primera interacción real (no cuenta bots ni Lighthouse)
      const events = ["mousemove", "scroll", "touchstart", "keydown", "click"];
      const onInteraction = () => {
        events.forEach(e => window.removeEventListener(e, onInteraction));
        loadAnalytics();
      };
      events.forEach(e => window.addEventListener(e, onInteraction, { once: true, passive: true }));

      // Fallback: cargar igual a los 6 s si no hubo interacción
      setTimeout(loadAnalytics, 6000);
    </script>
    <!--
      Nota: el MutationObserver runtime de reescritura ExactDN se eliminó
      (31/May/2026). Todas las <img> ya emiten su URL del CDN en build
      (cdnW/cdn() en componentes; URLs CDN absolutas en blog-articulos.ts),
      por lo que el observer era código muerto que solo añadía JS/TBT y
      provocaba doble fetch. Si se reintroduce alguna plantilla con
      <img src="/images/..."> crudo, pasarla por cdn() en lugar de re-añadir
      el observer.
    -->
  </head>

  <body>

    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <slot />


    <WhatsAppFloat />


    <BackToTop />
  </body>
</html>
