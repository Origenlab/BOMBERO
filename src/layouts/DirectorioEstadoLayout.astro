---

import PageLayout from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import StationCard from "@components/StationCard.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import FAQDirectorio from "@components/directorio/FAQDirectorio.astro";
import FAQQuote from "@components/FAQQuote.astro";
import DirectorioSearch from "@components/directorio/DirectorioSearch.astro";
import MunicipiosPhonesTable from "@components/directorio/MunicipiosPhonesTable.astro";
import QuickNav from "@components/QuickNav.astro";
import VerifiedBadge from "@components/directorio/VerifiedBadge.astro";
import EmergencyNumbersBar from "@components/directorio/EmergencyNumbersBar.astro";
import StateDeepLinks from "@components/directorio/StateDeepLinks.astro";
import { DIRECTORIO_VERIFICADO_ISO, DIRECTORIO_VERIFICADO_LEGIBLE } from "@data/directorio-stats";
import { cdnW } from "@utils/cdn";
import HeroSection from "@components/HeroSection.astro";


interface EstacionData {
  nombreCorto: string;
  slug: string;
  direccion: string;
  colonia?: string;
  municipio?: string;
  ciudad?: string;
  telefono?: string;
  servicios?: string[];
  horario?: string;
}

interface EppCard {
  image: string;
  imageAlt: string;
  badge: string;
  title: string;
  text: string;       // puede contener HTML con <strong>
  href: string;
  linkLabel: string;
}

interface GalleryImage {
  src: string;
  alt: string;
  label: string;
}

interface HeroThumb {
  src: string;
  alt: string;
  label: string;
}

interface EmergencyNumber {
  number: string;
  label: string;
}

interface Region {
  nombre: string;
  desc: string;
}

interface EstadoVecino {
  nombre: string;
  slug: string;
}

interface Props {

  estado: string;               // "Baja California"
  sigla: string;                // "BC"
  slug: string;                 // "baja-california"
  description: string;
  keywords?: string[];
  canonical: string;
  jsonLd?: Record<string, unknown>[];


  totalEstaciones: number;
  totalMunicipios: number;
  habitantes: string;           // "3.8M+"


  heroDesc: string;             // HTML (solo inner — sin <p> wrapper)
  heroImage: string;
  heroImageAlt: string;
  heroCaption: string;
  heroThumbs: [HeroThumb, HeroThumb, HeroThumb];  // exactamente 3


  galleryImages: [GalleryImage, GalleryImage, GalleryImage, GalleryImage]; // 4


  emergencyNumbers: EmergencyNumber[];


  estaciones: EstacionData[];
  stationImages: string[];


  municipios: string[];
  regiones: Region[];
  estadosVecinos: EstadoVecino[];


  eppCards: [EppCard, EppCard, EppCard, EppCard];  // exactamente 4


  ctaTitle: string;
  ctaDesc: string;
  ctaBtnText: string;
  ctaBtnHref?: string;
}

const {
  estado, sigla, slug, description, keywords, canonical, jsonLd,
  totalEstaciones, totalMunicipios, habitantes,
  heroDesc, heroImage, heroImageAlt, heroCaption, heroThumbs,
  galleryImages,
  emergencyNumbers,
  estaciones, stationImages,
  municipios, regiones, estadosVecinos,
  eppCards,
  ctaTitle, ctaDesc, ctaBtnText, ctaBtnHref = "/cotizar/",
} = Astro.props;


const heroImageCdn = cdnW(heroImage, 800);
const heroThumbsCdn = heroThumbs.map(t => ({ ...t, src: cdnW(t.src, 400) }));
const galleryImagesCdn = galleryImages.map(g => ({ ...g, src: cdnW(g.src, 500) }));
const stationImagesCdn = stationImages.map(s => cdnW(s, 400));
const eppCardsCdn = eppCards.map(c => ({ ...c, image: cdnW(c.image, 400) }));


const toAnchor = (s: string) =>
  s.toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/á/g, 'a').replace(/é/g, 'e')
    .replace(/í/g, 'i').replace(/ó/g, 'o')
    .replace(/ú/g, 'u').replace(/ñ/g, 'n');

const title = `Bomberos en ${estado} — ${totalEstaciones} estaciones | teléfonos directos`;

// ItemList real de estaciones (GEO): cada estación como FireStation enlazada
const estacionesItemList = estaciones.map((e, i) => ({
  "@type": "ListItem",
  position: i + 1,
  item: {
    "@type": "FireStation",
    name: e.nombreCorto,
    ...(e.telefono ? { telephone: e.telefono } : {}),
    url: `https://bombero.mx/directorio/${slug}/${e.slug}/`,
    areaServed: e.municipio ?? e.ciudad ?? estado,
  },
}));

// Schema Place + AdministrativeArea para refuerzo GEO/Local
const placeJsonLd = {
  "@context": "https://schema.org",
  "@type": "AdministrativeArea",
  name: estado,
  url: canonical,
  containedInPlace: {
    "@type": "Country",
    name: "México",
    sameAs: "https://es.wikipedia.org/wiki/M%C3%A9xico",
  },
  containsPlace: {
    "@type": "ItemList",
    name: `Estaciones de Bomberos en ${estado}`,
    numberOfItems: totalEstaciones,
    itemListElement: estacionesItemList,
  },
  dateModified: DIRECTORIO_VERIFICADO_ISO,
};

// Organización del cuerpo estatal (GEO/E-E-A-T)
const govJsonLd = {
  "@context": "https://schema.org",
  "@type": "GovernmentOrganization",
  name: `H. Cuerpo de Bomberos de ${estado}`,
  url: canonical,
  areaServed: { "@type": "AdministrativeArea", name: estado },
  numberOfEmployees: undefined,
  knowsAbout: [
    "Combate de incendios",
    "Rescate urbano",
    "Atención prehospitalaria",
    "Materiales peligrosos (HAZMAT)",
  ],
  publisher: {
    "@type": "Organization",
    name: "BOMBERO.MX",
    url: "https://bombero.mx/",
  },
};

const allJsonLd = [...(jsonLd ?? []), placeJsonLd, govJsonLd];
---

<PageLayout
  title={title}
  description={description}
  keywords={keywords}
  canonical={canonical}
  image={`/api/og/estado/${slug}.svg`}
  modifiedTime={DIRECTORIO_VERIFICADO_ISO}
  jsonLd={allJsonLd}
>


  <Breadcrumb items={[
    { label: "Directorio", href: "/directorio/" },
    { label: estado },
  ]} />


  <HeroSection
    badge={`${sigla} · Directorio de Bomberos`}
    title={`Estaciones de Bomberos en <span class="hero__title-highlight">${estado}</span>`}
    subtitle="Directorio verificado de estaciones activas, teléfonos directos y cobertura municipal."
  >
    <div slot="left-extra">
      <DirectorioSearch placeholder={`Buscar estación o municipio en ${estado}…`} />
      <div class="de-hero__stats">
        <div class="de-hero__stat">
          <span class="de-hero__stat-number">{totalEstaciones}</span>
          <span class="de-hero__stat-label">Estaciones</span>
        </div>
        <div class="de-hero__stat">
          <span class="de-hero__stat-number">{totalMunicipios}</span>
          <span class="de-hero__stat-label">Municipios</span>
        </div>
        <div class="de-hero__stat">
          <span class="de-hero__stat-number">24/7</span>
          <span class="de-hero__stat-label">Servicio</span>
        </div>
        <div class="de-hero__stat">
          <span class="de-hero__stat-number">{habitantes}</span>
          <span class="de-hero__stat-label">Habitantes</span>
        </div>
      </div>
    </div>
    <div slot="right" class="de-hero__visual">
      <div class="de-hero__visual-main">
        <img
          src={heroImageCdn}
          alt={heroImageAlt}
          width="800" height="450"
          loading="eager" decoding="async"
        />
        <span class="de-hero__visual-caption">{heroCaption}</span>
      </div>
      <div class="de-hero__visual-row">
        {heroThumbsCdn.map((thumb) => (
          <div class="de-hero__visual-thumb">
            <img
              src={thumb.src}
              alt={thumb.alt}
              width="400" height="225"
              loading="eager" decoding="async"
            />
            <span>{thumb.label}</span>
          </div>
        ))}
      </div>
    </div>
  </HeroSection>


  <QuickNav pool="estado" count={7} />

  <EmergencyNumbersBar
    estado={estado}
    numbers={emergencyNumbers}
    ctaHref="#listado-estaciones"
    ctaLabel="Ver todas las estaciones"
  />


  <section class="de-gallery">
    <div class="container">
      <div class="de-gallery__grid">
        {galleryImagesCdn.map((img) => (
          <div class="de-gallery__item">
            <img
              src={img.src}
              alt={img.alt}
              width="500" height="312"
              loading="lazy" decoding="async"
            />
            <div class="de-gallery__item-label">
              <span>{img.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <section id="listado-estaciones" class="de-main">
    <div class="container">
      <div class="de-main__grid">


        <div class="de-main__content">
          <nav class="de-toc" aria-label="Índice de la página">
            <span class="de-toc__label">En esta página</span>
            <ul class="de-toc__list">
              <li><a href="#listado-estaciones">Estaciones</a></li>
              <li><a href="#tabla-estaciones">Tabla comparativa</a></li>
              <li><a href="#municipios-telefonos">Municipios</a></li>
              <li><a href="#equipo-epp">Equipo EPP</a></li>
              <li><a href="#preguntas-estado">Preguntas</a></li>
            </ul>
          </nav>

          <SectionHeader
            label="Directorio Completo"
            title={`${totalEstaciones} estaciones verificadas — H. Cuerpo de Bomberos de ${estado}`}
            description={`Información de contacto actualizada de todas las estaciones del H. Cuerpo de Bomberos en ${estado}. Selecciona una estación para ver sus datos de contacto, servicios y zonas de cobertura.`}
          />

          <div class="de-stations-grid">
            {estaciones.map((estacion, i) => (
              <StationCard
                nombre={estacion.nombreCorto}
                slug={estacion.slug}
                direccion={`${estacion.direccion}${estacion.colonia ? ', ' + estacion.colonia : ''}`}
                alcaldia={estacion.municipio || estacion.ciudad || ''}
                telefono={estacion.telefono}
                servicios={estacion.servicios}
                horario={estacion.horario}
                image={stationImagesCdn[i % stationImagesCdn.length]}
                baseUrl={`/directorio/${slug}/`}
              />
            ))}
          </div>


          <article class="de-table-section" id="tabla-estaciones">
            <h2 class="de-table-section__title">Tabla Comparativa de Estaciones de Bomberos en {estado}</h2>
            <p class="de-table-section__intro">
              Resumen de las <strong>{totalEstaciones} estaciones</strong> del directorio en {estado}: municipio,
              teléfono directo y servicios destacados. En cualquier emergencia, el <strong>911</strong> coordina
              el despacho de la unidad más cercana.
            </p>
            <div class="de-table-wrap">
              <table class="de-table">
                <thead>
                  <tr>
                    <th scope="col">Estación</th>
                    <th scope="col">Municipio / Ciudad</th>
                    <th scope="col">Teléfono</th>
                    <th scope="col">Servicios destacados</th>
                    <th scope="col">Ficha</th>
                  </tr>
                </thead>
                <tbody>
                  {estaciones.map((e) => (
                    <tr>
                      <td data-label="Estación">{e.nombreCorto}</td>
                      <td data-label="Municipio">{e.municipio ?? e.ciudad ?? estado}</td>
                      <td data-label="Teléfono">
                        {e.telefono ? <a href={`tel:${e.telefono.replace(/\s/g, '')}`}>{e.telefono}</a> : '—'}
                      </td>
                      <td data-label="Servicios">{(e.servicios ?? []).slice(0, 2).join(', ') || 'Emergencias 24/7'}</td>
                      <td data-label="Ficha"><a href={`/directorio/${slug}/${e.slug}/`}>Ver</a></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>

          <div class="de-seo">
            <slot name="seo" />
          </div>
        </div>


        <aside class="de-sidebar">


          <div class="de-sidebar__card">
            <h4>Filtrar por Municipio</h4>
            <ul class="de-sidebar__municipios">
              {municipios.map((municipio) => (
                <li>
                  <a href={`#${toAnchor(municipio)}`}>
                    <span class="de-sidebar__bullet"></span>
                    <span>{municipio}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>


          <div class="de-sidebar__card de-sidebar__card--emergency">
            <h4>Teléfonos de Emergencia</h4>
            <div class="de-sidebar__emergency-list">
              {emergencyNumbers.map((item) => (
                <div class="de-sidebar__emergency-item">
                  <span class="de-sidebar__emergency-number">{item.number}</span>
                  <span class="de-sidebar__emergency-label">{item.label}</span>
                </div>
              ))}
            </div>
          </div>


          <div class="de-sidebar__card">
            <h4>Regiones del Estado</h4>
            <ul class="de-sidebar__regiones">
              {regiones.map((region) => (
                <li>
                  <span class="de-sidebar__region-name">{region.nombre}</span>
                  <span class="de-sidebar__region-desc">{region.desc}</span>
                </li>
              ))}
            </ul>
          </div>


          <div class="de-sidebar__card">
            <h4>Estados Vecinos</h4>
            <ul class="de-sidebar__states">
              {estadosVecinos.map((estado) => (
                <li>
                  <a href={`/directorio/${estado.slug}/`}>
                    <span>{estado.nombre}</span>
                    <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>


          <div class="de-sidebar__card de-sidebar__card--cta">
            <h4>¿Equipas una Estación en {sigla}?</h4>
            <p>Somos distribuidores de equipo certificado NFPA para cuerpos de bomberos en todo {estado}</p>
            <a href="/cotizar/" class="de-sidebar__cta-btn">Solicitar Cotización</a>
          </div>


          <div class="de-sidebar__card">
            <h4>Equipo para Bomberos</h4>
            <ul class="de-sidebar__products">
              <li><a href="/productos/trajes-para-bomberos/">Trajes Estructurales NFPA</a></li>
              <li><a href="/productos/cascos-para-bomberos/">Cascos de Bombero</a></li>
              <li><a href="/productos/guantes-para-bomberos/">Guantes para Bombero</a></li>
              <li><a href="/productos/botas-para-bomberos/">Botas para Bombero</a></li>
            </ul>
            <a href="/productos/" class="de-sidebar__link">
              Ver catálogo completo
              <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>


          <div class="de-sidebar__card">
            <a href="/directorio/" class="de-sidebar__back">
              <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
              </svg>
              <span>Ver todos los estados</span>
            </a>
          </div>


          <div class="de-sidebar__card">
            <h4>Contacto BOMBERO.MX</h4>
            <ul class="de-sidebar__contact">
              <li><a href="tel:+525570081816">55 7008 1816</a></li>
              <li><a href="https://wa.me/525570081816">WhatsApp</a></li>
              <li><a href="mailto:ventas@bombero.mx">ventas@bombero.mx</a></li>
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>


  <section class="de-epp" id="equipo-epp">
    <div class="container">
      <SectionHeader
        label="EPP Certificado NFPA"
        title="Completa tu Equipo de Protección"
      >
        <p>El traje estructural NFPA 1971 trabaja como parte de un sistema. Distribuimos equipo certificado directamente a los cuerpos de bomberos de <strong>{estado}</strong>. Todos los equipos cumplen la misma edición de norma y están disponibles en stock inmediato.</p>
        <p>Desde cascos y guantes estructurales hasta equipos SCBA y extintores certificados NOM, cada pieza del catálogo está disponible para licitación gubernamental con ficha técnica y certificado de laboratorio incluidos.</p>
      </SectionHeader>

      <div class="de-epp__grid">
        {eppCardsCdn.map((card) => (
          <article class="de-epp__card">
            <a href={card.href} class="de-epp__card-image">
              <img
                src={card.image}
                alt={card.imageAlt}
                width="400" height="267"
                loading="lazy" decoding="async"
              />
              <span class="de-epp__card-badge">{card.badge}</span>
            </a>
            <div class="de-epp__card-content">
              <h3 class="de-epp__card-title">{card.title}</h3>
              <p class="de-epp__card-text" set:html={card.text} />
              <a href={card.href} class="de-epp__card-link">
                {card.linkLabel}
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>


  <StateDeepLinks
    estadoSlug={slug}
    estadoNombre={estado}
    capital={estado}
    estadosVecinos={estadosVecinos}
  />

  <div id="municipios-telefonos">
    <MunicipiosPhonesTable estado={estado} estaciones={estaciones} />
  </div>

  <div id="preguntas-estado">
    <FAQDirectorio
      scope="estado"
      estado={estado}
      totalEstaciones={totalEstaciones}
    />
  </div>

  <VerifiedBadge
    estado={estado}
    fecha={DIRECTORIO_VERIFICADO_LEGIBLE}
    totalEstaciones={totalEstaciones}
  />

  <FAQQuote
    title="Equipar a los bomberos de este estado — todo lo que necesitas saber"
    description="Lo que preguntan jefes de cuerpo, directores de Protección Civil y responsables de adquisiciones sobre cómo adquirir equipo NFPA certificado para bomberos municipales en México."
    items={[
      {
        question: "¿Cuánto cuesta equipar a los bomberos de un municipio y qué presupuesto necesito gestionar?",
        answer: "El costo por bombero operativo con EPP básico certificado NFPA: traje estructural NFPA 1971 + casco + guantes + botas + capucha Nomex = $35,000–$70,000 MXN. SCBA NFPA 1981 por equipo = $50,000–$150,000 MXN adicional. Para una estación de 15–20 bomberos con EPP completo + 8–10 SCBA: presupuesto total de $1,000,000–$2,200,000 MXN aproximadamente. Para municipios con presupuesto limitado, diseñamos un plan escalonado: SCBA y trajes primero (protegen la vida), luego cascos, guantes y botas. Solicita cotización y te damos el desglose exacto según el número de bomberos de tu cuerpo.",
      },
      {
        question: "¿Más del 70% de los cuerpos municipales de México operan sin EPP certificado — qué fondos existen para resolverlo?",
        answer: "Los fondos disponibles para adquisición de equipo para bomberos municipales incluyen: FORTASEG/FASP (Fondo de Aportaciones para la Seguridad Pública) — puede financiar EPP para cuerpos de bomberos municipales incluidos en el programa de diagnóstico de necesidades. FISE (Fondo de Infraestructura Social Estatal) — para infraestructura de Protección Civil incluyendo equipamiento crítico. Presupuesto municipal propio en la partida de 'Seguridad Pública y Protección Civil'. Algunos estados tienen programas específicos de dotación de EPP para bomberos. Nuestros asesores orientan sobre cuál fondo aplica para cada municipio y qué documentación se requiere — sin costo.",
      },
      {
        question: "¿Cómo redacto las especificaciones técnicas correctas para una licitación de EPP?",
        answer: "El error más frecuente es especificar 'equipo para bomberos' sin referencia a la norma NFPA y edición vigente — esto permite el ingreso de equipo no certificado que gana por precio bajo. La especificación correcta indica: norma NFPA específica (ej: 'traje estructural NFPA 1971 edición 2018 o posterior'), exige certificado de laboratorio acreditado (UL, Intertek o SEI) por número de lote (no declaración del fabricante), y describe los parámetros técnicos clave (TPP mínimo 35 cal/cm², THL mínimo 205 W/m² para trajes; presión de cilindro y duración para SCBA). Preparamos el texto completo de especificación técnica para cada partida sin costo para procesos activos.",
      },
      {
        question: "¿Cuánto tarda en llegar el equipo a este estado y cómo funciona el envío?",
        answer: "EPP estándar en inventario (trajes tallas estándar, cascos, guantes, botas, capuchas): 3–5 días hábiles desde la confirmación del pedido, vía paquetería certificada con seguro de envío incluido. SCBA y herramientas hidráulicas de extricación: 2–4 semanas según configuración y cantidad. Para licitaciones con fecha de entrega comprometida en las bases, coordinamos el cronograma desde el proceso de adjudicación para garantizar el cumplimiento. Para pedidos urgentes por equipo dañado en operación, evaluamos opciones de envío express.",
      },
      {
        question: "¿Pueden verificar si el equipo actual del cuerpo de bomberos necesita renovarse?",
        answer: "Sí. Realizamos auditoría de EPP sin costo. Evaluamos el inventario existente contra criterios NFPA 1851 (trajes, cascos, botas, guantes, capuchas) y NFPA 1852 (SCBA): fecha de fabricación en etiqueta, estado visual según criterios de retiro, historial de exposición y condición de cada pieza. El resultado es un reporte con tres categorías: retiro obligatorio inmediato, equipo que necesita reparación, y equipo que puede continuar en servicio con indicación de hasta cuándo. Este reporte es el documento que justifica la partida presupuestal de renovación ante autoridades.",
      },
      {
        question: "¿Ofrecen precios preferenciales para cuerpos de bomberos municipales?",
        answer: "Sí. Precios institucionales para H. Cuerpos de Bomberos municipales y estatales, Protección Civil y dependencias de gobierno en los 32 estados. El precio preferencial varía según el volumen total del pedido (número de bomberos a equipar) — no según el tipo de adquisición (directa o licitación). Para acceder al precio institucional, indica al solicitar cotización que es para un cuerpo de bomberos municipal y el número total de personal a equipar.",
      },
      {
        question: "¿Pueden ser dados de alta como proveedores y emitir CFDI 4.0 para gobierno?",
        answer: "Sí a ambas. Emitimos CFDI 4.0 a nombre de dependencias municipales, estatales y federales con RFC correcto para régimen de gobierno. Estamos dados de alta en CompraNet para dependencias federales. Para municipios que requieren alta en su sistema de proveedores local, coordinamos el proceso con toda la documentación necesaria (RFC, IMSS, constancias fiscales, cartas de distribución autorizada, acreditación de experiencia) sin costo adicional y en los tiempos que el proceso requiera.",
      },
      {
        question: "¿Cómo contacto a un asesor que conozca la situación operativa de este estado?",
        answer: "Por WhatsApp al 55 7008 1816 (Lunes–Viernes 9:00–18:00 hrs, Sábados 9:00–14:00 hrs). Menciona el estado, municipio y la situación específica (tipo de equipo, número de bomberos, si es para licitación o compra directa, si hay urgencia operativa). Con esa información conectamos con el asesor que conoce los proveedores, fondos y procesos de adquisición del estado correspondiente — no con un ejecutivo de ventas genérico.",
      },
    ]}
  />

  <CTABanner
    title={ctaTitle}
    desc={ctaDesc}
    btnText={ctaBtnText}
    btnHref={ctaBtnHref}
    whatsapp={true}
  />

</PageLayout>

