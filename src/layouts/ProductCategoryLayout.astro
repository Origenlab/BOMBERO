---
/**
 * ProductCategoryLayout.astro — Master de páginas L3 de categoría de producto.
 * ──────────────────────────────────────────────────────────────────────────
 * Encapsula el "chrome" idéntico en las 16 categorías:
 *   Breadcrumb · Hero · QuickNav · CTABar · grid 2 columnas (main + sidebar)
 *   · WhyChooseUs · CTABanner   y TODO el CSS (src/styles/product-l3.css).
 *
 * La página solo aporta: datos SEO, textos del hero, datos del sidebar,
 * imágenes de WhyChooseUs y el CONTENIDO principal (paneles) vía <slot/>.
 *
 * Reemplaza la copia de ~1660 líneas por categoría. Master aprobado: trajes.
 */
import PageLayout from "@layouts/PageLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import QuickNav from "@components/QuickNav.astro";
import CTABar from "@components/CTABar.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import CTABanner from "@components/CTABanner.astro";
import ProductSidebar from "@components/ProductSidebar.astro";
import type { SEOProps } from "@config/site";
import "@styles/product-l3.css";

type SeoBlock = { title: string; html: string };
type CTA = { href: string; label: string };

interface Props extends SEOProps {
  jsonLd?: Record<string, unknown>[];
  breadcrumb: { label: string; href?: string }[];

  heroBadge: string;
  /** HTML — usa <span class="hero__title-highlight">…</span> para la palabra destacada */
  heroTitle: string;
  heroSubtitle: string;
  heroPrimary?: CTA;
  heroSecondary?: CTA;
  heroSeoBlocks: [SeoBlock, SeoBlock];

  ctaBarQuote: string;

  /** Props del sidebar (ver ProductSidebar.astro) */
  sidebar: Record<string, unknown>;

  whyImages: string[];
}

const {
  jsonLd,
  breadcrumb,
  heroBadge,
  heroTitle,
  heroSubtitle,
  heroPrimary = { href: "#catalogo", label: "Ver catálogo" },
  heroSecondary = { href: "/cotizar/", label: "Cotizar ahora" },
  heroSeoBlocks,
  ctaBarQuote,
  sidebar,
  whyImages,
  ...seoProps
} = Astro.props;
---

<PageLayout {...seoProps} brand={false} jsonLd={jsonLd} quickNav={false}>

  <Breadcrumb items={breadcrumb} />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          {heroBadge}
        </div>
        <h1 class="hero__title" set:html={heroTitle} />
        <p class="hero__subtitle">{heroSubtitle}</p>
        <div class="hero__actions">
          <a href={heroPrimary.href} class="hero__btn hero__btn--primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="1" ry="1"/>
            </svg>
            {heroPrimary.label}
          </a>
          <a href={heroSecondary.href} class="hero__btn hero__btn--secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            {heroSecondary.label}
          </a>
        </div>
      </div>

      <div class="hero__seo">
        {heroSeoBlocks.map((b) => (
          <div class="hero__seo-block">
            <h2 class="hero__seo-title">{b.title}</h2>
            <p class="hero__seo-text" set:html={b.html} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuickNav pool="categoria" count={7} />
  <CTABar quote={ctaBarQuote} />

  <!-- ═══ LAYOUT 2 COLUMNAS ═══ -->
  <div class="page-layout">
    <div class="page-layout__inner">
      <div class="page-main">
        <slot />
      </div>
      <ProductSidebar {...(sidebar as any)} />
    </div>
  </div>

  <!-- ═══ FULL WIDTH ═══ -->
  <WhyChooseUs images={whyImages} />
  <CTABanner />

</PageLayout>
