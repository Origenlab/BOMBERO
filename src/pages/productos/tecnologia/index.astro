  },
];

// ─── FAQs ────────────────────────────────────────────────────────────────────
const faqs = [
  {
    question: "¿Qué es una cámara termográfica TIC y por qué es crítica en combate de incendios?",
    answer: "La TIC (Thermal Imaging Camera) detecta radiación infrarroja y la convierte en imagen de temperatura — permite al bombero ver en cero visibilidad por humo. Sus aplicaciones operativas críticas son: localizar víctimas inconscientes que no pueden responder a llamados, identificar puntos calientes en paredes y techos que indican riesgo de colapso inminente, y guiar al equipo de salida en un edificio con humo total. La NFPA 1801 establece los requisitos mínimos de certificación para TICs en servicio de emergencia.",
  },
  {
    question: "¿Qué resolución térmica debe tener una TIC para uso en bomberos y qué dice la NFPA 1801?",
    answer: "La NFPA 1801 exige resolución mínima de 320×240 píxeles y sensibilidad térmica (NETD) ≤ 40 mK para detectar diferencias de temperatura menores a la sensación corporal humana. Las TICs de 640×480 píxeles ofrecen mayor detalle para identificar víctimas en posiciones difíciles o evaluar daño estructural. Los modelos de referencia como el FLIR K2 (320×240, uso básico) y el MSA Evolution 6000 (384×288, premium con más robustez IP67) definen el rango de inversión para un cuerpo de bomberos.",
  },
  {
    question: "¿Cuál es la diferencia entre un detector de 4 gases y uno de 6 gases para operaciones HAZMAT?",
    answer: "El detector de 4 gases estándar monitorea simultáneamente: oxígeno (O2 — déficit/exceso), LEL (gases explosivos), monóxido de carbono (CO) y sulfuro de hidrógeno (H2S). El detector de 6 gases agrega CO2 y un sensor PID para VOCs (compuestos orgánicos volátiles) que detecta cientos de solventes y vapores con una sola célula. Para espacios confinados urbanos, el detector de 4 gases es suficiente. Para escenas HAZMAT con químicos industriales desconocidos o refinerías, el sensor PID del modelo de 6 gases es indispensable para identificar el agente.",
  },
  {
    question: "¿Qué unidades de concentración usa el detector de gases y qué valores representan peligro?",
    answer: "Los detectores multigas usan: % vol para O2 (valor normal 20.9 %; alarma en < 19.5 % o > 23.5 %); % LEL para gases explosivos (alarma al 10 % del LEL, valor peligroso al 25 % LEL); ppm para CO (IDLH 1,200 ppm, alarma baja a 35 ppm) y H2S (IDLH 50 ppm, alarma baja a 1 ppm). El concepto IDLH (Immediately Dangerous to Life or Health) define el nivel máximo de exposición sin EPP de respiración: por encima del IDLH se requiere SCBA obligatoriamente.",
  },
  {
    question: "¿Con qué frecuencia se calibra un detector de gases y qué implica la calibración?",
    answer: "Los detectores multigas requieren: verificación de respuesta (bump test) antes de cada uso — exposición a gas de concentración conocida para confirmar que los sensores responden; calibración completa mensual con gases patrón certificados para ajustar los valores de respuesta; y sustitución de sensores según vida útil del fabricante (los sensores electroquímicos de CO y H2S tienen vida útil de 2–3 años). Un detector no calibrado puede dar falsos negativos — indicar que la atmósfera es segura cuando no lo es.",
  },
  {
    question: "¿Qué autonomía de batería debe tener una TIC para cumplir la NFPA 1801?",
    answer: "La NFPA 1801 exige autonomía mínima de 4 horas de operación continua bajo condiciones de temperatura normales. En operaciones reales con exposición a calor extremo, la batería puede reducir su autonomía. Los modelos premium como el MSA Evolution 6000 tienen batería intercambiable en caliente — el bombero puede cambiar la batería sin apagar la cámara, continuando la operación sin interrupción. La prueba de caída desde 2 metros es otro requisito crítico de la NFPA 1801.",
  },
  {
    question: "¿Los drones de emergencia requieren certificación especial para operar en México?",
    answer: "Sí. En México, la Agencia Federal de Aviación Civil (AFAC) requiere que los operadores de drones de más de 250 g estén registrados y que los drones de categoría avanzada (operaciones sobre personas o en zonas controladas) tengan autorización específica. Para operaciones de emergencia, los cuerpos de bomberos y protección civil pueden tramitar autorizaciones especiales ante la AFAC para operar en zonas restringidas durante incidentes activos. Los modelos DJI Mavic 3 Enterprise y Autel Evo II Pro cumplen con los requisitos técnicos para estos trámites.",
  },
  {
    question: "¿Qué protocolo de comunicaciones APCO P25 usan los cuerpos de bomberos en México?",
    answer: "El protocolo APCO P25 (Project 25) es el estándar de comunicaciones digitales para seguridad pública adoptado en EUA, México y Latinoamérica. En México, el sistema de radiocomunicación del CENACOM (Centro Nacional de Comunicaciones) y varios sistemas estatales operan en P25 Fase 1 (FDMA). Las radiobases Motorola APX y Kenwood TK son compatibles con estos sistemas. La interoperabilidad entre bomberos, policía y protección civil — crítica en emergencias masivas — requiere que todos los cuerpos operen en el mismo protocolo y banda de frecuencia.",
  },
];

// ─── Schema.org ──────────────────────────────────────────────────────────────
const CANONICAL = "/productos/tecnologia/";
const productSchema = productSchemaComplete({
  name: "Tecnología para Bomberos — TIC NFPA 1801, Drones, Radio P25, Multi-Gas | BOMBERO.MX",
  description: "Tecnología profesional para bomberos en México. Cámaras termográficas TIC FLIR NFPA 1801, drones de emergencia, radios P25 NFPA 1221, detectores multi-gas MSA, compresores de aire NFPA 1852 y sistemas de localización indoor. Envío a 32 estados.",
  image: "/images/directorio/detector-multigas-hazmat-01.avif",
  url: CANONICAL,
  category: "Tecnología para Bomberos",
  features: ["NFPA 1801", "NFPA 1221", "NFPA 1852", "APCO P25", "FLIR", "MSA Altair"],
  certifications: ["NFPA 1801", "NFPA 1221", "NFPA 1852", "ATEX", "UL"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Tecnología para Bomberos", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];
---

<PageLayout
  quickNav={false}
  title="Tecnología para Bomberos México | TIC NFPA 1801 | FLIR | Drones | Radio P25 | BOMBERO.MX"
  description="Tecnología profesional para bomberos en México. Cámaras TIC FLIR NFPA 1801, drones de emergencia, radios digitales P25 NFPA 1221, detectores multi-gas MSA Altair, compresores SCBA NFPA 1852. Asesoría técnica. Envío a 32 estados. Cotiza para licitación."
  canonical={CANONICAL}
  jsonLd={jsonLdSchemas}
  keywords={[
    "cámara termográfica para bomberos México",
    "TIC bomberos NFPA 1801",
    "FLIR bomberos México",
    "drones para incendios forestales",
    "radio digital bomberos P25",
    "detector de gases bomberos",
    "MSA Altair México",
    "tecnología bomberos México",
    "cámara térmica incendio estructural",
    "compresor aire respirable SCBA",
    "radio Motorola APX bomberos México",
    "sistema localización bomberos",
    "monitor multi-gas espacios confinados",
    "FLIR K2 México",
    "radio P25 NFPA 1221",
    "drones DJI emergencias México",
