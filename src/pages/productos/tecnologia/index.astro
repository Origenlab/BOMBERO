import FAQ           from "@components/FAQ.astro";
import Breadcrumb    from "@components/Breadcrumb.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

// ─── Catálogo Tecnología para Bomberos ───────────────────────────────────────
const productos = [
