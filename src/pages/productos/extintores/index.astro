  },
  {
    id: "clase-k",
    nombre: "Extintores Clase K (Cocinas Comerciales)",
    slug: "/productos/extintores/extintores-clase-k-cocinas-comerciales/",
    badge: "NOM-100 / UL Listed",
    badgeColor: "fire",
    imagen: "/images/extintores/extintor-clase-k-cocina-comercial-01.avif",
    descripcion:
      "Extintores Clase K para incendios de aceite y grasa caliente. Obligatorio en cocinas comerciales. Agente saponificante que emulsiona grasas y preiene reencendido. Cumple NOM-100-STPS-1994 y UL Listed. Activación segura con manija de bajo perfil.",
    caracteristicas: [
