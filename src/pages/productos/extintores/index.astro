---

import PageLayout from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQ from "@components/FAQ.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@data/site";
import { canonicalURL, productSchemaComplete, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const productos = [
  {
    id: "pqs",
    nombre: "Extintores PQS (Polvo Químico Seco)",
    slug: "/productos/extintores/extintores-pqs-polvo-quimico-seco/",
    badge: "NOM-100-STPS",
    badgeColor: "ember",
    imagen: "/images/extintores/extintor-pqs-polvo-quimico-seco-01.avif",
    descripcion:
      "Extintores de polvo químico seco para uso múltiple. Efectivos en incendios Clase A, B y C. Cumple norma NOM-100-STPS-1994 para México. Ideales para oficinas, vehículos, industrias y comercios. Presurización con nitrógeno para confiabilidad operativa.",
    caracteristicas: [
      "Polvo químico seco multiuso (Clase A, B, C)",
      "Presurización con nitrógeno segura",
      "Cumple NOM-100-STPS-1994 (México) y NFPA 10",
      "Manómetro de presión integrado",
      "Disponible en capacidades 1 kg, 5 kg, 10 kg y 23 kg",
    ],
    aplicacion: "Oficinas · Vehículos · Comercios · Plantas industriales · Depósitos",
  },
  {
    id: "co2",
    nombre: "Extintores CO2 Dióxido de Carbono",
    slug: "/productos/extintores/extintores-co2-dioxido-carbono/",
    badge: "NOM-100 / NFPA 10",
    badgeColor: "fire",
    imagen: "/images/extintores/extintor-co2-dioxido-carbono-01.avif",
    descripcion:
      "Extintores CO2 para incendios Clase B y C. Sin residuos ni corrosión. Aplicación en equipos electrónicos, cuartos de servidores y laboratorios. Cumple NOM-100-STPS-1994. Descarga rápida y limpia con tubo de extensión flexible.",
    caracteristicas: [
      "Dióxido de carbono sin residuos (Clase B, C)",
      "No deja corrosión ni contaminación",
      "Tubo de extensión con boquilla cónica",
      "Cumple NOM-100-STPS-1994 y NFPA 10",
      "Capacidades 2 kg, 5 kg, 10 kg y 20 kg",
    ],
    aplicacion: "Cuartos de servidores · Laboratorios · Equipos electrónicos · Centros de datos",
  },
  {
    id: "agua",
    nombre: "Extintores de Agua Presurizada",
    slug: "/productos/extintores/extintores-agua-presurizada/",
    badge: "NOM-100-STPS",
    badgeColor: "smoke",
    imagen: "/images/extintores/extintor-agua-presurizada-01.avif",
    descripcion:
      "Extintores de agua presurizada para incendios Clase A. Acción refrescante superior. Cumple NOM-100-STPS-1994. Aplicación en estructuras de madera, papel, textiles y combustibles sólidos. Seguridad operativa con presión controlada.",
    caracteristicas: [
      "Agua desmineralizada presurizada (Clase A)",
      "Acción refrescante y penetrante",
      "Cumple NOM-100-STPS-1994 (México) y NFPA 10",
      "Presión regulada con nitrógeno",
      "Disponible 9 kg, 18 kg y 27 kg",
    ],
    aplicacion: "Estructuras de madera · Papelerías · Textiles · Combustibles sólidos · Bodegas",
  },
  {
    id: "halotron",
    nombre: "Extintores Halotron-I (Halón Alternativo)",
    slug: "/productos/extintores/extintores-halotron-i-halon-alternativo/",
    badge: "NFPA 10 / UL Listed",
    badgeColor: "ember",
    imagen: "/images/extintores/extintor-halotron-i-01.avif",
    descripcion:
      "Extintores Halotron-I sustituto de halón para Clase A, B y C. Baja toxicidad, no conductivo. Aplicación en aviónica, telecomunicaciones y equipos sensibles. Certified UL Listed. Descarga rápida sin dejar residuos perjudiciales.",
    caracteristicas: [
      "Halotron-I sustituto ecológico de halón (Clase A, B, C)",
      "Baja toxicidad y no conductivo",
      "UL Listed certificado internacionalmente",
      "Compatible con electrónica y equipos sensibles",
      "Capacidades 2.5 kg y 5.7 kg",
    ],
    aplicacion: "Aviónica · Telecomunicaciones · Equipos sensitivos · Laboratorios especializados",
  },
  {
    id: "clase-k",
    nombre: "Extintores Clase K (Cocinas Comerciales)",
    slug: "/productos/extintores/extintores-clase-k-cocinas-comerciales/",
    badge: "NOM-100 / UL Listed",
    badgeColor: "fire",
    imagen: "/images/extintores/extintor-clase-k-cocina-comercial-01.avif",
    descripcion:
      "Extintores Clase K para incendios de aceite y grasa caliente. Obligatorio en cocinas comerciales. Agente saponificante que emulsiona grasas y preiene reencendido. Cumple NOM-100-STPS-1994 y UL Listed. Activación segura con manija de bajo perfil.",
    caracteristicas: [
      "Agente saponificante para grasa caliente (Clase K)",
      "Previnción de reencendido de aceites",
      "Cumple NOM-100-STPS-1994 y UL Listed",
      "Activación segura sin riesgo de salpicadura",
      "Capacidades 2 kg y 6 kg para cocinas",
    ],
    aplicacion: "Cocinas comerciales · Restaurantes · Comedores industriales · Hoteles · Cafeterías",
  },
  {
    id: "gabinetes",
    nombre: "Gabinetes Contra Incendio Montados",
    slug: "/productos/extintores/gabinetes-contra-incendio-montados/",
    badge: "NOM-100-STPS",
    badgeColor: "smoke",
    imagen: "/images/extintores/gabinete-contra-incendio-extintor-01.avif",
    descripcion:
      "Gabinetes para montaje de extintores en pared. Construcción en acero o aluminio con puerta de cristal de fácil apertura. Señalización y acceso rápido para emergencias. Cumple normas NOM-100-STPS-1994. Modelos para extintores 5 kg, 10 kg y 23 kg.",
    caracteristicas: [
      "Estructura acero/aluminio de alta durabilidad",
      "Puerta de cristal templado transparente",
      "Señalización de incendio integrada",
      "Acceso rápido y fácil durante emergencias",
      "Compatibles con diferentes tamaños de extintores",
    ],
    aplicacion: "Edificios comerciales · Industrias · Hospitales · Escuelas · Centros de distribución",
  },
];


const CANONICAL = "/productos/extintores/";
const TITLE = "Extintores México NOM-100-STPS";
const DESCRIPTION = "Extintores certificados NOM-100-STPS México: PQS, CO2, agua, Halotron, Clase K y gabinetes. Venta y distribución a los 32 estados. Asesoría técnica sin costo. ¡Cotiza ahora!";

const productSchema = productSchemaComplete({
  name: TITLE,
  description: DESCRIPTION,
  image: productos[0].imagen ?? "/images/directorio/estacion-bomberos-mexico-01.avif",
  url: CANONICAL,
  category: "Extintores Contra Incendio",
  features: ["NOM-100-STPS", "NFPA 10", "UL Listed", "PQS", "CO2", "Halotron", "Clase K"],
  certifications: ["NOM-100-STPS-1994", "NFPA 10", "UL Listed"],
});

const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Extintores", url: CANONICAL },
]);

const jsonLdSchemas = [productSchema, breadcrumbSchema];

---

<PageLayout
  title="Extintores México NOM-100 | PQS, CO2, Halotron, Clase K | BOMBERO.MX"
  description="Extintores certificados NOM-100-STPS-1994: PQS multiuso, CO2, agua, Halotron-I, Clase K para cocinas y gabinetes. Distribución a 32 estados. Asesoría técnica. ¡Cotiza!"
  keywords={[
    "extintores México",
    "extintor PQS polvo químico",
    "extintor CO2 dióxido carbono",
    "extintor agua presurizada",
    "extintor Halotron-I",
    "extintor Clase K cocina",
    "gabinetes contra incendio",
    "extintores NOM-100-STPS",
    "extintores NFPA 10",
    "extintores certificados México",
    "comprar extintores México",
    "distribuidor extintores",
  ]}
  type="website"
  canonical={CANONICAL}
  jsonLd={jsonLdSchemas}
>

  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
    { label: "Extintores" },
  ]} />




  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          6 Tipos de Extintores · Certificados NOM-100-STPS
        </div>
        <h1 class="hero__title">
          Extintores contra
          <span class="hero__title-highlight">Incendio</span>
          Certificados NOM-100
        </h1>
        <p class="hero__subtitle">
          Extintores certificados NOM-100-STPS-1994 para incendios Clase A, B, C y K. PQS multiuso,
          CO2, agua, Halotron-I, extintores para cocinas comerciales y gabinetes montados. Distribución
          a los 32 estados de México con asesoría técnica sin costo.
        </p>
      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Distribuidor Autorizado de Extintores Certificados en México</h2>
          <p class="hero__seo-text">
            En <strong>BOMBERO.MX</strong> somos distribuidor autorizado de <strong>extintores certificados NOM-100-STPS-1994</strong> en toda la República Mexicana. Nuestro catálogo incluye <strong>extintores PQS (polvo químico seco)</strong> multiuso, <strong>extintores CO2</strong> para equipos electrónicos, <strong>extintores de agua presurizada</strong>, <strong>Halotron-I</strong> sustituto de halón, <strong>extintores Clase K</strong> para cocinas comerciales y <strong>gabinetes contra incendio</strong>. Complementa con <a href="/productos/cascos-para-bomberos/" style="color: var(--color-fire-400); text-decoration: underline;">cascos de bombero NFPA</a>, <a href="/productos/trajes-para-bomberos/" style="color: var(--color-fire-400); text-decoration: underline;">trajes certificados</a> y equipo contra incendios para protección integral.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Extintores para Todo Tipo de Incendio: Clase A, B, C y K</h2>
          <p class="hero__seo-text">
            Cada <strong>extintor contra incendio</strong> cumple normativas mexicanas e internacionales: <strong>NOM-100-STPS-1994</strong> en México, <strong>NFPA 10</strong> en Estados Unidos y <strong>UL Listed</strong> para modelos especializados. Los <strong>extintores PQS</strong> ofrecen protección multiuso para Clase A, B, C; los <strong>CO2</strong> para equipos sensibles sin residuos; los <strong>Clase K</strong> son obligatorios en cocinas comerciales; y los <strong>gabinetes contra incendio</strong> garantizan acceso rápido en emergencias. Proveemos documentación técnica completa para licitaciones públicas en los <strong>32 estados de México</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTABar quote="Cotizar Extintores" />




  <section class="section productos" id="catalogo">
    <div class="container">
      <SectionHeader
        label="Catálogo de Extintores Contra Incendio"
        title="6 Tipos de Extintores"
        description="Desde polvo químico seco multiuso hasta extintores Clase K para cocinas comerciales. Cada extintor está certificado para su aplicación operativa específica."
      >
        <p>
          Un <strong>extintor contra incendio</strong> es el primer sistema de protección inmediata frente a amago de incendio. En BOMBERO.MX seleccionamos únicamente <strong>extintores certificados NOM-100-STPS</strong> que superan los requerimientos mínimos y son compatibles con sistemas de protección integral en <a href="/productos/cascos-para-bomberos/">cascos de bombero</a>, <a href="/productos/trajes-para-bomberos/">trajes</a> y <strong>equipo contra incendios</strong> para evacuación segura.
        </p>
        <p>
          Todos nuestros <strong>extintores PQS, CO2, agua, Halotron-I y Clase K</strong> incluyen fichas técnicas completas, certificados de laboratorio acreditado y señalización obligatoria. Para máxima efectividad, el <strong>extintor</strong> debe estar acesible, inspeccionado anualmente según NOM-100-STPS, y complementado con <a href="/productos/gabinetes-contra-incendio/">gabinetes de montaje</a>, rutas de evacuación claras y <a href="/productos/cascos-para-bomberos/">cascos certificados NFPA</a> para respuesta rápida en emergencias.
        </p>
      </SectionHeader>

      <div class="productos__grid">
        {productos.map((producto) => (
          <ProductCard {...producto} altSuffix="Extintor certificado NOM-100-STPS" />
        ))}
      </div>
    </div>
  </section>




  <section class="section section--dark specs">
    <div class="container">
      <SectionHeader
        label="Tecnología y Materiales"
        title="Agentes Extintos, Cilindros y Sistemas de Presurización"
        description="Los extintores modernos utilizan agentes específicos para cada clase de incendio. Cilindros de acero de alta resistencia con sistemas de presurización segura garantizan efectividad y durabilidad."
      >
        <p>
          Los <strong>extintores PQS (polvo químico seco)</strong> contienen polvo de fosfato de amonio o bicarbonato sódico presurizado con nitrógeno para máxima efectividad en Clase A, B, C. Los <strong>extintores CO2</strong> descarga dióxido de carbono limpio sin residuos, ideal para <a href="/productos/cascos-para-bomberos/" style="color: white; text-decoration: underline;">protección de equipos sensibles</a>. Los <strong>extintores Clase K</strong> contienen agente saponificante que emulsiona grasas calientes y previene reencendido en cocinas comerciales. Los <strong>gabinetes contra incendio</strong> facilitan montaje en pared con acceso rápido durante emergencias según protocolos de <a href="/productos/trajes-para-bomberos/" style="color: white; text-decoration: underline;">respuesta de bomberos</a>.
        </p>
        <p>
          Todos nuestros <strong>extintores NOM-100-STPS</strong> incluyen cilindros de acero laminado en frío, manómetro de presión calibrado, válvula de seguridad, manguera flexible y distribuidor. Certificados por laboratorios acreditados con papelería completa para <strong>licitaciones gubernamentales</strong> en toda la República Mexicana. Inspección y recarga anual obligatoria según norma NOM-100-STPS-1994.
        </p>
      </SectionHeader>
      <div class="specs__grid">
        <CategoryCard
          title="Agentes Extintores Específicos"
          icon="shield"
          image="/images/extintores/extintor-polvo-quimico-detalle-agente-01.avif"
          description="Polvo químico seco (PQS) para Clase A, B, C. Dióxido de carbono (CO2) sin residuos. Agua presurizada para Clase A. Halotron-I sustituto ecológico de halón. Agente saponificante Clase K para grasas calientes. Nitrógeno de presurización certificado."
        />
        <CategoryCard
          title="Certificaciones y Normativas"
          icon="certificate"
          image="/images/extintores/extintor-certificacion-nom-estudio-02.avif"
          description="NOM-100-STPS-1994 (México) obligatoria para todos los extintores. NFPA 10 (Estados Unidos) para estándares internacionales. UL Listed para modelos Halotron-I y Clase K. Inspección anual y recarga obligatoria. Documentación para licitaciones públicas."
        />
        <CategoryCard
          title="Aplicaciones Operativas"
          icon="users"
          image="/images/extintores/extintor-uso-combate-fuego-proteccion-03.avif"
          description="Edificios comerciales e industriales, vehículos, depósitos, cocinas comerciales, laboratorios, cuartos de servidores, centros de datos. Protección civil estatal y federal. Cuerpos de bomberos municipales y estatales en toda la República Mexicana."
        />
      </div>
    </div>
  </section>




  <section class="section comparativa">
    <div class="container">
      <SectionHeader
        label="Tabla Comparativa"
        title="¿Qué Extintor Necesitas?"
        description="Compara los 6 tipos de extintores según su agente, aplicación, clases de incendio y normativa para seleccionar el equipo correcto."
      >
        <p>
          La elección del <strong>extintor contra incendio</strong> correcto depende del tipo de incendio predominante: el <strong>extintor PQS multiuso</strong> es el estándar para edificios comerciales e industriales (Clase A, B, C); el <strong>CO2</strong> para protección de equipos electrónicos sin residuos; el <strong>agua presurizada</strong> para estructuras de madera y combustibles sólidos (Clase A); el <strong>Halotron-I</strong> para aviónica y telecomunicaciones; el <strong>Clase K</strong> es obligatorio en cocinas comerciales (grasas y aceites calientes). Los <strong>gabinetes contra incendio</strong> garantizan acceso inmediato y visibilidad clara en emergencias.
        </p>
        <p>
          En <strong>BOMBERO.MX</strong> asesoramos sin costo a tu corporación para seleccionar los <strong>extintores certificados NOM-100-STPS</strong> adecuados según riesgo operativo y normativa local. Elaboramos especificaciones técnicas para <strong>sistemas de protección contra incendios completos</strong> en <strong>licitaciones públicas</strong> de los 32 estados de México.
        </p>
      </SectionHeader>
      <div class="comparativa__wrapper">
        <table class="comparativa__table">
          <thead>
            <tr>
              <th>Extintor</th>
              <th>Agente / Norma</th>
              <th>Clases de Incendio</th>
              <th>Aplicación</th>
              <th>Capacidades</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>PQS Multiuso</strong></td>
              <td><span class="cert-chip cert-chip--ember">Polvo / NOM-100</span></td>
              <td>Clase A, B, C</td>
              <td>Edificios, vehículos, comercios, industrias</td>
              <td>1, 5, 10, 23 kg</td>
            </tr>
            <tr>
              <td><strong>CO2</strong></td>
              <td><span class="cert-chip cert-chip--fire">Dióxido / NFPA 10</span></td>
              <td>Clase B, C</td>
              <td>Servidores, laboratorios, electrónica sensitiva</td>
              <td>2, 5, 10, 20 kg</td>
            </tr>
            <tr>
              <td><strong>Agua Presurizada</strong></td>
              <td><span class="cert-chip cert-chip--smoke">Agua / NOM-100</span></td>
              <td>Clase A</td>
              <td>Madera, papel, textiles, combustibles sólidos</td>
              <td>9, 18, 27 kg</td>
            </tr>
            <tr>
              <td><strong>Halotron-I</strong></td>
              <td><span class="cert-chip cert-chip--ember">Halotron / UL Listed</span></td>
              <td>Clase A, B, C</td>
              <td>Aviónica, telecomunicaciones, equipos sensibles</td>
              <td>2.5, 5.7 kg</td>
            </tr>
            <tr>
              <td><strong>Clase K</strong></td>
              <td><span class="cert-chip cert-chip--fire">Saponificante / UL Listed</span></td>
              <td>Clase K (Grasas)</td>
              <td>Cocinas comerciales, restaurantes, hoteles</td>
              <td>2, 6 kg</td>
            </tr>
            <tr>
              <td><strong>Gabinetes</strong></td>
              <td><span class="cert-chip cert-chip--smoke">Acero/Aluminio / NOM-100</span></td>
              <td>Montaje de cualquier tipo</td>
              <td>Pared, interior, acceso rápido, señalización</td>
              <td>5, 10, 23 kg</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>




  <WhyChooseUs images={[
    "/images/extintores/extintor-pqs-polvo-quimico-seco-02.avif",
    "/images/extintores/extintor-co2-dioxido-carbono-02.avif",
    "/images/extintores/extintor-agua-presurizada-02.avif",
    "/images/extintores/extintor-halotron-i-02.avif",
    "/images/extintores/extintor-clase-k-cocina-comercial-02.avif",
    "/images/extintores/gabinete-contra-incendio-extintor-02.avif",
  ]} />




  <FAQ />




  <section class="section relacionados">
    <div class="container">
      <SectionHeader
        label="Equipo Complementario"
        title="Sistema de Protección Contra Incendios Integral"
        description="El extintor es el primer sistema de control. Complementa con equipo de respuesta, evacuación y protección personal certificado."
      >
        <p>
          Un <strong>sistema de protección contra incendios completo</strong> requiere <strong>extintores estratégicamente ubicados</strong>, <a href="/productos/cascos-para-bomberos/">cascos certificados NFPA</a> para respuesta segura, <a href="/productos/trajes-para-bomberos/">trajes de bombero</a> con resistencia térmica, <strong>gabinetes de montaje visible</strong>, rutas de evacuación claras, señalización obligatoria y personal entrenado en NOM-100-STPS. El <strong>extintor PQS multiuso</strong> es el estándar inicial; complementa con <strong>CO2 en cuartos de servidores</strong> y <strong>Clase K en cocinas comerciales</strong>.
        </p>
        <p>
          En <strong>BOMBERO.MX</strong> equipamos tu infraestructura con todo el sistema de <strong>protección contra incendios de una sola fuente</strong>: <strong>extintores certificados NOM-100-STPS</strong>, <a href="/productos/cascos-para-bomberos/">cascos NFPA</a>, <a href="/productos/trajes-para-bomberos/">trajes de emergencia</a>, <strong>gabinetes contra incendio</strong> y asesoría técnica sin costo. Disponibilidad inmediata para los 32 estados de México.
        </p>
      </SectionHeader>
      <div class="rel__grid">
        <CategoryCard
          title="Cascos para Bombero"
          icon="shield"
          image="/images/cascos-para-bomberos/casco-bombero-estructural-nfpa-1971-modelo-frontal-01.avif"
          href="/productos/cascos-para-bomberos/"
          buttonText="Cascos para Bombero"
          items={[
            { label: "Casco Estructural NFPA 1971", href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
            { label: "Casco Forestal NFPA 1977", href: "/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/" },
            { label: "Casco ARFF Aeroportuario", href: "/productos/cascos-para-bomberos/casco-arff-aeroportuario/" },
            { label: "Casco Rescate Técnico NFPA 1951", href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
          ]}
        />
        <CategoryCard
          title="Trajes para Bombero"
          icon="uniform"
          image="/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif"
          href="/productos/trajes-para-bomberos/"
          buttonText="Trajes para Bombero"
          items={[
