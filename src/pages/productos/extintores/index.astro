    aplicacion: "Oficinas · Vehículos · Comercios · Plantas industriales · Depósitos",
  },
  {
    id: "co2",
    nombre: "Extintores CO2 Dióxido de Carbono",
    slug: "/productos/extintores/extintores-co2-dioxido-carbono/",
    badge: "NOM-100 / NFPA 10",
    badgeColor: "fire",
    imagen: "/images/extintores/extintor-co2-dioxido-carbono-01.avif",
    descripcion:
      "Extintores CO2 para incendios Clase B y C. Sin residuos ni corrosión. Aplicación en equipos electrónicos, cuartos de servidores y laboratorios. Cumple NOM-100-STPS-1994. Descarga rápida y limpia con tubo de extensión flexible.",
    caracteristicas: [
      "Dióxido de carbono sin residuos (Clase B, C)",
      "No deja corrosión ni contaminación",
      "Tubo de extensión con boquilla cónica",
      "Cumple NOM-100-STPS-1994 y NFPA 10",
      "Capacidades 2 kg, 5 kg, 10 kg y 20 kg",
    ],
    aplicacion: "Cuartos de servidores · Laboratorios · Equipos electrónicos · Centros de datos",
  },
  {
    id: "agua",
    nombre: "Extintores de Agua Presurizada",
    slug: "/productos/extintores/extintores-agua-presurizada/",
    badge: "NOM-100-STPS",
    badgeColor: "smoke",
    imagen: "/images/extintores/extintor-agua-presurizada-01.avif",
    descripcion:
      "Extintores de agua presurizada para incendios Clase A. Acción refrescante superior. Cumple NOM-100-STPS-1994. Aplicación en estructuras de madera, papel, textiles y combustibles sólidos. Seguridad operativa con presión controlada.",
    caracteristicas: [
      "Agua desmineralizada presurizada (Clase A)",
      "Acción refrescante y penetrante",
      "Cumple NOM-100-STPS-1994 (México) y NFPA 10",
      "Presión regulada con nitrógeno",
      "Disponible 9 kg, 18 kg y 27 kg",
    ],
    aplicacion: "Estructuras de madera · Papelerías · Textiles · Combustibles sólidos · Bodegas",
  },
  {
    id: "halotron",
    nombre: "Extintores Halotron-I (Halón Alternativo)",
    slug: "/productos/extintores/extintores-halotron-i-halon-alternativo/",
    badge: "NFPA 10 / UL Listed",
    badgeColor: "ember",
    imagen: "/images/extintores/extintor-halotron-i-01.avif",
    descripcion:
      "Extintores Halotron-I sustituto de halón para Clase A, B y C. Baja toxicidad, no conductivo. Aplicación en aviónica, telecomunicaciones y equipos sensibles. Certified UL Listed. Descarga rápida sin dejar residuos perjudiciales.",
