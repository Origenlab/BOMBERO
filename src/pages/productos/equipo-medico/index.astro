---
import PageLayout    from "@layouts/PageLayout.astro";
import QuickNav from "@components/QuickNav.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner     from "@components/CTABanner.astro";
import CTABar        from "@components/CTABar.astro";
import CategoryCard  from "@components/CategoryCard.astro";
import ProductCard   from "@components/ProductCard.astro";
import FAQ           from "@components/FAQ.astro";
import Breadcrumb    from "@components/Breadcrumb.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

// ─── Catálogo Equipo Médico / EMS ─────────────────────────────────────────────
const productos = [
  {
    id: "camilla-rescate-plegable",
    nombre: "Camilla de Rescate Plegable — Aluminio / SKED para Bomberos y EMS",
    slug: "/productos/equipo-medico/",
    badge: "NFPA 1999",
    badgeColor: "fire" as const,
    imagen: "/images/directorio/pick-up-bomberos-forestal-01.avif",
    descripcion:
      "La camilla de rescate es el equipo de traslado de víctimas más importante del paramédico y del bombero-rescatista. Las camillas para servicios de emergencia deben soportar el peso del paciente más el equipo de soporte vital bajo condiciones de transporte físico intenso (subir escaleras, cruzar escombros, izaje vertical). La camilla plegable de aluminio tipo cuchara se separa en dos mitades para introducirse bajo el paciente sin moverlo, crucial en víctimas con posible lesión de columna. La SKED (camilla de polietileno flexible) es la estándar para evacuación en espacios confinados y rescate vertical.",
    caracteristicas: [
      "Capacidad de carga: hasta 180 kg — para pacientes bariátricos con equipo de soporte",
      "Camilla tipo cuchara (scoop): se separa en dos mitades — mínimo movimiento del paciente",
      "Material: aluminio aeronáutico 6061 T6 — ligero (9 kg) y resistente a la corrosión",
      "Plegado en acordeón: 4 posiciones de ajuste en longitud (150-200 cm)",
      "Rieles laterales de acero inoxidable: puntos de sujeción para cintas de inmovilización",
      "Compatible con silla de ruedas de emergencia, collarín y inmovilizador de cabeza",
      "Certificación ISO 9001 y compatible con normativas NOM-237-SSA1 para traslado",
    ],
    aplicacion: "Traslado de pacientes en emergencias · Rescate vehicular · Rescate en altura (SKED) · Post-sismo · Espacios confinados · Evacuaciones masivas",
  },
  {
    id: "dea-desfibrilador",
    nombre: "DEA Desfibrilador Externo Automático — Philips HeartStart / ZOLL AED Plus",
    slug: "/productos/equipo-medico/",
    badge: "FDA / COFEPRIS",
    badgeColor: "fire" as const,
    imagen: "/images/directorio/camion-bomberos-rescate-01.avif",
    descripcion:
      "El Desfibrilador Externo Automático (DEA) es el dispositivo que más vidas salva en paros cardíacos. Cada minuto sin desfibrilación reduce la probabilidad de supervivencia en un 10%. El DEA analiza automáticamente el ritmo cardíaco y libera una descarga eléctrica solo cuando detecta una fibrilación ventricular —la arritmia reversible más común en paro cardíaco. Los modelos para bomberos y EMS profesional (AED Plus, HeartStart FRx) son resistentes a polvo y humedad (IP55), operan en temperaturas de -20°C a +60°C y guían al operador con instrucciones de voz paso a paso. No requiere entrenamiento médico para operar.",
    caracteristicas: [
      "Análisis automático del ritmo cardíaco — el dispositivo decide si descarga o no",
      "Descarga bifásica: 150-360 J según modelo — más efectiva que descarga monofásica",
      "Protección IP55: resistente a polvo y agua en condiciones de emergencia exterior",
      "Instrucciones de voz paso a paso: guía al socorrista incluso sin entrenamiento médico previo",
      "Batería de larga duración: hasta 5 años en standby o 200+ descargas sin reemplazar",
      "RCP guiada: metrónomo de ritmo y detector de profundidad de compresión (modelos avanzados)",
      "Registro ECG: almacena la grabación completa del evento para revisión médica posterior",
    ],
    aplicacion: "Paro cardíaco · Fibrilación ventricular · Primera respuesta de bomberos · Espacios públicos · Unidades móviles de EMS · Brigadas industriales de emergencia",
  },
  {
    id: "kit-trauma-bolsa-emergencia",
    nombre: "Kit de Trauma / IFAK — Bolsa de Emergencia para Bomberos y Paramédicos",
    slug: "/productos/equipo-medico/",
    badge: "TCCC / PHTLS",
    badgeColor: "fire" as const,
    imagen: "/images/directorio/equipo-rescate-completo-01.avif",
    descripcion:
      "El kit de trauma o IFAK (Individual First Aid Kit) para bomberos está diseñado para el control de hemorragias masivas y estabilización en el campo antes del traslado: las primeras intervenciones que salvan vidas en los primeros 10 minutos. Los componentes críticos del kit siguien el protocolo TCCC (Tactical Combat Casualty Care) adaptado a emergencias civiles: torniquete CAT o SOFTT-W, vendaje hemostático QuikClot o HemCon, sello torácico para neumotórax, y vía aérea nasofaríngea. Los bomberos deben tener acceso inmediato al IFAK individual y al kit de trauma de equipo en cada intervención.",
    caracteristicas: [
      "Torniquete CAT Gen7 o SOFTT-W: control de hemorragia de extremidades en < 30 segundos",
      "Vendaje hemostático QuikClot Combat Gauze: detiene hemorragias que no son compresibles",
      "Sello torácico Hyfin o Bolin: para neumotórax abierto y neumotórax a tensión",
      "Vía aérea nasofaríngea 28 Fr: para mantenimiento de vía aérea en inconscientes",
      "Marcador de tiempo: para registrar hora de aplicación del torniquete en la víctima",
      "Guantes de nitrilo × 4 pares: protección biológica del rescatista",
      "Bolsa MOLLE modular: se adjunta al chaleco o arnés del bombero para acceso inmediato",
    ],
    aplicacion: "Control de hemorragias masivas · Primeros auxilios avanzados · Emergencias con múltiples víctimas · Rescate vehicular · Accidentes industriales · Quemaduras",
  },
  {
    id: "inmovilizador-columna-kked",
    nombre: "Inmovilizador de Columna — KED / Chaleco de Extricación + Collarín",
    slug: "/productos/equipo-medico/",
    badge: "EMS Avanzado",
    badgeColor: "ember" as const,
    imagen: "/images/directorio/equipo-rescate-tecnico-01.avif",
    descripcion:
      "El inmovilizador de extricación KED (Kendrick Extrication Device) es el dispositivo de manejo de columna cervical y torácica estándar para el rescate vehicular. Permite extraer a una víctima sentada con posible lesión de columna del vehículo accidentado sin alinear ni mover la columna. El chaleco rígido sostiene la cabeza, el cuello y el tronco como una unidad durante la rotación y el traslado a la camilla. Se usa siempre en conjunto con collarín cervical rígido Philadelphia de talla correcta. La combinación KED + collarín + camilla de cuchara es el estándar de manejo de columna en rescate vehicular para EMS y bomberos.",
    caracteristicas: [
      "Chaleco de extricación KED: inmoviliza cabeza, cuello y tronco como una unidad",
      "Correas de sujeción de colores: codificadas por color para aplicación correcta y rápida",
      "Aletas de cabeza plegables: soportan lateralmente la cabeza sin presión en heridas del cuello",
      "Collarín cervical Philadelphia: talla ajustable S/M/L — aplicación en < 30 segundos",
      "Material: polietileno reforzado con madera multilaminada — rígido y radiotransparente",
      "Compatibilidad: se transfiere directamente a la camilla de cuchara sin mover al paciente",
      "Peso del sistema KED + collarín: < 2 kg — manejable dentro del habitáculo del vehículo",
    ],
    aplicacion: "Rescate vehicular con víctimas sentadas · Lesión cervical potencial · Extricación de vehículos volcados · Accidentes industriales con maquinaria · Primera respuesta EMS",
  },
  {
    id: "oxigeno-portatil-emergencias",
    nombre: "Kit de Oxígeno Portátil para Emergencias — Cilindro M9 + Mascarilla",
    slug: "/productos/equipo-medico/",
    badge: "EMS / BLS",
    badgeColor: "ember" as const,
    imagen: "/images/directorio/equipo-rescate-completo-01.avif",
    descripcion:
      "El suministro de oxígeno suplementario es una de las primeras intervenciones en múltiples emergencias: victimas de incendio con inhalación de humo (CO y CN), ahogados con hipoxia, pacientes con paro cardíaco en post-RCP y traumatizados con shock. El kit de oxígeno portátil para bomberos incluye el cilindro de aluminio M9 (520 L a 200 bar), regulador de caudal con toma DISS, mascarilla de no re-inhalación (NRM) con bolsa reservorio para FiO2 del 90-100%, y cánula nasal para flujos bajos. El conjunto pesa 3.8 kg y proporciona hasta 60 minutos de O2 al 100% para una víctima.",
    caracteristicas: [
      "Cilindro M9 de aluminio: 520 L · 200 bar · peso 3.8 kg — el más manejable para bomberos",
      "Regulador de caudal ajustable: 0 a 25 L/min — para NRM (15 L/min) y cánula (2-6 L/min)",
      "Mascarilla NRM con bolsa reservorio 1 L: FiO2 del 90-100% al 100% al 15 L/min",
      "Cánula nasal adulto/pediátrico: FiO2 36-44% a 2-6 L/min — para pacientes conscientes",
      "Bolsa porta-kit de lona Cordura 1000D con sujeción externa al SCBA o porta-equipo",
      "Válvula de seguridad de sobreresión: protección contra fallo del regulador",
      "Compatible con mascarilla de RCP y balón ambú para ventilación asistida",
    ],
    aplicacion: "Inhalación de humo en incendios · Intoxicación por CO · Post-RCP · Ahogamiento / hipoxia · Trauma con shock · Emergencias médicas en campo",
  },
  {
    id: "mochila-ems-bomberos",
    nombre: "Mochila EMS para Bomberos — Kit de Soporte Vital Básico Completo",
    slug: "/productos/equipo-medico/",
    badge: "BLS / SVB Completo",
    badgeColor: "smoke" as const,
    imagen: "/images/directorio/equipo-rescate-completo-01.avif",
    descripcion:
      "La mochila EMS (Emergency Medical Services) del bombero concentra todo el equipo de soporte vital básico (BLS/SVB) en una bolsa organizada y de acceso rápido. La organización modular por bolsillos de color permite al bombero-paramédico localizar cualquier elemento en segundos incluso bajo estrés extremo. El kit completo incluye: DEA o marcapasos externo, kit de vía aérea, kit de control de hemorragias, oxígeno portátil, kit de trauma y equipos de monitorización de signos vitales. La mochila resistente al agua de 60 L en nylon balístico 1000D distribuye el peso en dos rescatistas para llevarla en escenas con acceso difícil.",
    caracteristicas: [
      "Capacidad: 60 L — todo el equipo BLS en una sola mochila",
      "Bolsillos codificados por color: rojo (hemorragias), azul (vía aérea), amarillo (monitorización)",
      "Material: nylon balístico 1000D — resistente al desgarro en escenas con escombros",
      "Resistencia al agua IPX4: protección en lluvia intensa y operaciones de inundación",
      "Estructura rígida de espalda: mantiene la forma y facilita búsqueda de equipo bajo estrés",
      "Asas reforzadas dobles: para transporte rápido entre dos rescatistas",
      "Incluye: kit de vía aérea, control de hemorragias, oxigenoterapia, monitorización y trauma",
    ],
    aplicacion: "Primera respuesta de bomberos · Unidades de rescate médico · Brigadas industriales BLS · Protección civil · Eventos masivos · Atención pre-hospitalaria en campo",
  },
];

// ─── Tabla comparativa ───────────────────────────────────────────────────────
const comparativa = [
  {
    equipo: "DEA / Desfibrilador",
    norma: "FDA / COFEPRIS",
    uso: "Paro cardíaco",
    tiempo: "< 2 min de preparación",
    precio: "Desde $28,500 MXN",
    para: "Todo cuerpo de bomberos",
  },
  {
    equipo: "Kit de Trauma IFAK",
    norma: "TCCC / PHTLS",
    uso: "Control de hemorragia",
    tiempo: "< 30 seg torniquete",
    precio: "Desde $3,800 MXN",
    para: "Rescate vehicular e industrial",
  },
  {
    equipo: "Camilla Tipo Cuchara",
    norma: "ISO 9001 / NOM-237",
    uso: "Traslado de víctimas",
    tiempo: "< 3 min de preparación",
    precio: "Desde $7,200 MXN",
    para: "Todo tipo de rescate",
  },
  {
    equipo: "Kit de Oxígeno M9",
    norma: "NOM / EMS",
    uso: "Inhalación humo / hipoxia",
    tiempo: "< 1 min de preparación",
    precio: "Desde $9,500 MXN",
    para: "Incendios + rescate acuático",
  },
];

// ─── FAQs ────────────────────────────────────────────────────────────────────
const faqs = [
  {
    question: "¿Cuál es la diferencia entre un kit BLS y un kit ALS para bomberos respondientes?",
    answer: "El BLS (Soporte Vital Básico) incluye equipo para manejo de vía aérea básica, control de hemorragias, RCP, DEA/AED y oxigenoterapia suplementaria — el nivel mínimo que todo bombero debe manejar. El ALS (Soporte Vital Avanzado) agrega vía intravenosa, intubación endotraqueal, administración de medicamentos de emergencia, monitoreo de ECG y capnografía — requiere certificación de Técnico en Urgencias Médicas avanzado o paramédico. En México, la NFPA 1001 exige competencias de Primer Respondiente (BLS básico) como mínimo para todos los bomberos certificados.",
  },
  {
    question: "¿Cuál es la diferencia entre DEA (AED) y un desfibrilador manual para EMS?",
    answer: "El DEA (Desfibrilador Externo Automático) analiza el ritmo cardíaco automáticamente y solo permite la descarga cuando detecta fibrilación ventricular — diseñado para uso por cualquier persona sin entrenamiento médico avanzado. El desfibrilador manual requiere que el operador interprete el ritmo en el ECG y decida cuándo y con cuánta energía descargar — solo para paramédicos y médicos certificados. Para bomberos como Primer Respondiente, el DEA es el equipo correcto: no puede causar daño si se usa incorrectamente y salva vidas en el paro cardíaco con fibrilación.",
  },
  {
    question: "¿Qué dice la NOM-034 sobre el equipamiento mínimo de una unidad de atención médica de urgencias?",
    answer: "La NOM-034-SSA3-2013 (Regulación de sistemas de atención médica de urgencias) establece el equipo mínimo que deben tener las Unidades de Atención Médica Prehospitalaria (UAMP) en México según su nivel: básico (BLS: DEA, bolsa-válvula-mascarilla, equipo de oxígeno, kit de trauma básico), avanzado (ALS: todo lo anterior más monitor-desfibrilador, equipo de intubación, medicamentos de emergencia). Los bomberos-paramédicos que operan como primera respuesta médica deben equipar sus unidades conforme a la norma del nivel en que están certificados.",
  },
  {
    question: "¿Qué equipo mínimo debe tener cada unidad bomberil para respuesta médica?",
    answer: "Según la NFPA 1901 (Standard for Automotive Fire Apparatus) y las mejores prácticas de EMS prehospitalario, cada unidad de bomberos debe tener como mínimo: DEA/AED operativo, kit de control de hemorragias (torniquetes CAT, vendajes hemostáticos QuikClot, apósitos de presión), kit de vía aérea básica (mascarilla bolsa-válvula, cánulas orofaríngeas, oxígeno portátil M9), camilla de transporte y collarín cervical de talla ajustable. Este equipamiento básico permite atender los tres tipos de muerte prevenible más comunes: hemorragia masiva, paro cardíaco y obstrucción de vía aérea.",
  },
  {
    question: "¿Cuál es la diferencia entre camilla de scoop (tipo cuchara) y camilla de vacío?",
    answer: "La camilla de scoop o tipo cuchara de aluminio se separa en dos mitades longitudinales para introducirse bajo el paciente sin moverlo lateralmente — ideal para víctimas con posible lesión de columna en rescate vehicular. La camilla de vacío (vacuum mattress) se moldea al contorno del cuerpo del paciente al extraerle el aire, inmovilizando la columna completa desde la cabeza hasta los pies — es la más eficaz para fracturas de columna, pelvis y extremidades múltiples, pero más voluminosa. El KED (Kendrick Extrication Device) se usa primero para extraer a la víctima del vehículo, y luego se transfiere a la camilla de cuchara.",
  },
  {
    question: "¿Cómo se manejan los materiales biocontaminados en una emergencia médica?",
    answer: "El protocolo de precauciones universales exige: guantes de nitrilo en toda intervención con fluidos corporales, mascarilla si hay riesgo de aerosoles, y gafas o careta cuando hay riesgo de salpicaduras a ojos. Los residuos biológicos (vendajes, guantes usados, catéteres) deben depositarse en bolsas de bioseguridad rojas o en contenedor rígido para punzocortantes (sharps). El equipo contaminado (camilla, bolsa EMS) se descontamina con solución de cloro al 1:10 o desinfectante de nivel intermedio. En México, la NOM-087-SEMARNAT regula el manejo de residuos peligrosos biológico-infecciosos (RPBI).",
  },
  {
    question: "¿Qué nivel de certificación médica deben tener los bomberos en México según la NFPA 1001?",
    answer: "La NFPA 1001 (Standard for Fire Fighter Professional Qualifications) exige que todo bombero certificado tenga como mínimo competencias de Primer Respondiente en Emergencias Médicas (EMR/First Responder): RCP de adulto/niño/lactante, uso del DEA, control de hemorragias, manejo de vía aérea básica y evaluación primaria del paciente. El curso de 16–24 horas de Primer Respondiente y el curso de RCP/DEA son el punto de partida mínimo. Muchos cuerpos de bomberos en México certifican a su personal como TUM (Técnico en Urgencias Médicas) básico o avanzado.",
  },
  {
    question: "¿Con qué frecuencia debe calibrarse y revisarse el DEA de una unidad de bomberos?",
    answer: "El mantenimiento del DEA incluye: verificación visual diaria (indicador de estado, batería, fecha de vencimiento de los parches), verificación funcional mensual según el checklist del fabricante (muchos modelos realizan autodiagnóstico automático), y sustitución de batería y parches según la fecha de vencimiento marcada (generalmente cada 2–5 años para la batería y 2 años para los parches). La NFPA 1 y las guías AHA (American Heart Association) recomiendan un programa documentado de mantenimiento de DEA. Un DEA con batería vencida o parches caducados no será funcional en el momento de la emergencia.",
  },
];

// ─── Schema.org ──────────────────────────────────────────────────────────────
const CANONICAL = "/productos/equipo-medico/";
const productSchema = productSchemaComplete({
  name: "Equipo Médico EMS para Bomberos México — DEA, Kit Trauma, Camilla, Oxígeno",
  description: "Equipo médico EMS certificado para bomberos en México. DEA desfibriladores, kits de trauma TCCC, camillas de rescate, inmovilizadores KED y kits de oxígeno portátil. ZOLL, Philips, Ferno. Cotiza para licitación. Envío a 32 estados.",
  image: "/images/directorio/pick-up-bomberos-forestal-01.avif",
  url: CANONICAL,
  category: "Equipo Médico / EMS — BLS y Rescate",
  features: ["DEA / AED", "TCCC", "NFPA 1999", "BLS / SVB", "EMS Avanzado"],
  certifications: ["FDA", "COFEPRIS", "NOM-237-SSA1", "ISO 9001"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Equipo Médico / EMS", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];
---

<PageLayout
  quickNav={false}
  title="Equipo Médico EMS para Bomberos México | DEA | Kit Trauma | Camilla de Rescate | BOMBERO.MX"
  description="Equipo médico EMS certificado para bomberos en México. DEA desfibriladores Philips/ZOLL, kits de trauma TCCC/IFAK, camillas de rescate, inmovilizadores KED y oxígeno portátil. Cotización para licitación. Envío a 32 estados."
  canonical={CANONICAL}
  jsonLd={jsonLdSchemas}
  keywords={[
    "equipo médico bomberos México",
    "DEA desfibrilador bomberos",
    "AED bomberos México",
    "kit trauma bomberos TCCC",
    "IFAK bomberos México",
    "camilla rescate bomberos",
    "equipo EMS bomberos México",
    "inmovilizador KED rescate vehicular",
    "oxígeno portátil emergencias bomberos",
    "mochila EMS bomberos",
    "Philips HeartStart México",
    "ZOLL AED bomberos",
    "equipo soporte vital básico bomberos",
    "BLS bomberos México",
    "equipo paramédico bomberos",
    "torniquete CAT bomberos México",
  ]}
  type="website"
>

  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
    { label: "Equipo Médico / EMS" },
  ]} />

  <!-- ════════════════════ HERO ════════════════════ -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          FDA / COFEPRIS · TCCC · BLS / SVB · NOM-237-SSA1 · Soporte Vital
        </div>
        <h1 class="hero__title">
          <span class="hero__title-highlight">Equipo Médico</span>
          EMS para Bomberos<br />en México
        </h1>
        <p class="hero__subtitle">
          DEA desfibriladores, kits de trauma TCCC/IFAK, camillas de extricación, inmovilizadores KED
          y oxígeno portátil. El equipo de soporte vital básico que los bomberos necesitan para salvar
          vidas en los primeros 10 minutos. Certificado FDA / COFEPRIS. Asesoría técnica para
          cuerpos de bomberos y protección civil en los 32 estados.
        </p>

      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Distribuidores de Equipo Médico EMS para Bomberos en México</h2>
          <p class="hero__seo-text">
            <strong>BOMBERO.MX</strong> distribuye <strong>equipo médico EMS certificado</strong> para cuerpos de bomberos, protección civil y brigadas de emergencia en los 32 estados de México. Comercializamos las marcas líderes: <strong>Philips HeartStart</strong>, <strong>ZOLL AED Plus</strong> y <strong>Ferno</strong> para camillas. Los bomberos son los primeros respondientes en más del <strong>60% de las emergencias médicas</strong> en México. El equipo médico EMS es tan crítico como el <a href="/productos/scba/" style="color: var(--color-fire-400); text-decoration: underline;">SCBA NFPA 1981</a> o el <a href="/productos/trajes-para-bomberos/" style="color: var(--color-fire-400); text-decoration: underline;">traje estructural NFPA 1971</a>.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">¿Por Qué los Bomberos Necesitan Equipo Médico Certificado?</h2>
          <p class="hero__seo-text">
            En México, muchos municipios no cuentan con servicio de ambulancia dedicado — el cuerpo de bomberos es la única unidad con capacidad de respuesta rápida. Un DEA de calidad hospitalaria versus uno recreativo puede significar la diferencia entre un ritmo desfibrilado a tiempo o un paro irreversible. La certificación <strong>FDA / COFEPRIS</strong> garantiza que el equipo ha superado pruebas clínicas de eficacia. Complementa el equipo médico con <a href="/productos/rescate-acuatico/" style="color: var(--color-fire-400); text-decoration: underline;">equipo de rescate acuático NFPA 1952</a> para atención de hipotermia en rescates en agua.
          </p>
        </div>
      </div>
    </div>
  </section>
  <QuickNav pool="categoria" count={7} />

  <CTABar quote="Cotizar Equipo Médico EMS para mi Cuerpo de Bomberos" />

  <!-- ════════════════════ CATÁLOGO ════════════════════ -->
  <section class="section productos" id="catalogo">
    <div class="container">
      <SectionHeader
        label="Catálogo — Equipo Médico EMS Certificado para Bomberos"
