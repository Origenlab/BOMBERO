  transition: border-color .2s, transform .2s;
}
.sector-card:hover { border-color: rgba(220,38,38,.4); transform: translateY(-2px); }
.sector-card__icon { font-size: 2rem; margin-bottom: 1rem; }
.sector-card h3 { font-size: 1rem; font-weight: 700; color: var(--color-smoke-900); margin-bottom: .625rem; }
.sector-card p { font-size: .875rem; line-height: 1.7; color: var(--color-smoke-600); margin: 0; }
</style>
