// ─── FAQs ────────────────────────────────────────────────────────────────────
const faqs = [
  {
    question: "¿Por qué los bomberos necesitan equipo médico EMS?",
    answer: "Los bomberos modernos son, en la gran mayoría de los cuerpos de bomberos en México y el mundo, los primeros respondientes en casi cualquier emergencia médica: paros cardíacos, accidentes viales, caídas, quemaduras y traumatismos. En muchos municipios mexicanos, el cuerpo de bomberos es la única unidad de emergencia con capacidad de respuesta en menos de 10 minutos. La regla 'platinum 10 minutes' del trauma establece que las primeras intervenciones en los primeros 10 minutos post-trauma son las que determinan la supervivencia. Esto hace que el equipo médico básico —DEA, kit de trauma, inmovilizador de columna y oxígeno— sea tan crítico para un bombero como sus herramientas de extinción.",
  },
  {
    question: "¿Qué certificación médica necesitan los bomberos para usar este equipo?",
    answer: "En México, los niveles de certificación médica para bomberos van desde el Primer Respondiente (RCP/DEA básico, 16 horas) hasta el Técnico en Urgencias Médicas (TUM) y el Paramédico. El Primer Respondiente puede operar el DEA, aplicar torniquete, RCP y primeros auxilios básicos. El TUM avanzado puede establecer vías intravenosas, administrar medicamentos de emergencia y manejar la vía aérea avanzada. La NFPA 1001 (estándar de competencias del bombero) exige competencias médicas de Primer Respondiente como mínimo para todos los bomberos. El curso de TCCC (Tactical Combat Casualty Care) adaptado para bomberos civiles da las competencias para el kit de trauma completo. BOMBERO.MX puede orientar sobre instituciones que ofrecen estos cursos en México.",
  },
  {
    question: "¿Qué es el protocolo TCCC y cómo se aplica en bomberos civiles?",
    answer: "El TCCC (Tactical Combat Casualty Care) es el protocolo de atención de trauma desarrollado por las fuerzas armadas de EUA basado en las causas de muerte prevenibles en combate: hemorragia masiva de extremidades (torniquete), neumotórax a tensión (sello torácico) y obstrucción de vía aérea. Adaptado para bomberos civiles como TECC (Tactical Emergency Casualty Care), el protocolo prioriza en esta secuencia: (1) Control de hemorragia masiva con torniquete o presión directa; (2) Permeabilidad de vía aérea; (3) Tratamiento de neumotórax abierto; (4) Hipotermia (mantas térmicas); (5) Traslado rápido para intervención quirúrgica. El kit IFAK para bomberos está organizado exactamente en este orden de prioridad.",
  },
  {
    question: "¿Cómo se usa correctamente un DEA sin entrenamiento médico?",
    answer: "El DEA está diseñado específicamente para ser usado por cualquier persona sin entrenamiento médico. El proceso es: (1) Encender el DEA — las instrucciones de voz comienzan inmediatamente; (2) Conectar los electrodos al pecho desnudo del paciente como indican los diagramas en las pegatinas de los parches; (3) Alejarse del paciente mientras el DEA analiza el ritmo — el dispositivo indicará si se debe o no descargar; (4) Presionar el botón de descarga solo cuando el DEA lo indica y nadie toca al paciente; (5) Continuar la RCP hasta que el DEA indique volver a analizar. El DEA nunca descarga si no detecta fibrilación ventricular — no puede hacer daño si se usa incorrectamente. La única decisión del socorrista es comenzar la RCP y activar el DEA. Los modelos para bomberos como el ZOLL AED Plus incluyen retroalimentación en tiempo real sobre la calidad de las compresiones.",
  },
  {
    question: "¿Cuánto tiempo proporciona el cilindro de oxígeno M9 en una emergencia?",
    answer: "El cilindro M9 contiene 520 litros de oxígeno a 200 bar. La duración depende del flujo seleccionado: A 15 litros por minuto (mascarilla de no re-inhalación para una víctima con hipoxia severa): aproximadamente 34 minutos. A 10 litros por minuto (mascarilla con bolsa para hipoxia moderada): aproximadamente 52 minutos. A 4 litros por minuto (cánula nasal para paciente consciente con hipoxia leve): aproximadamente 130 minutos. A 2 litros por minuto (cánula para mantenimiento): aproximadamente 260 minutos. En una emergencia real donde el bombero llega antes de la ambulancia, 34 minutos de O2 al 100% es suficiente para estabilizar a la víctima de inhalación de humo hasta que llegue el servicio médico avanzado. Para operaciones más largas, se recomienda el cilindro D (425 L) o el cilindro E (680 L) en la unidad vehicular.",
  },
  {
    question: "¿Qué diferencia hay entre el KED y el collarín cervical?",
    answer: "El collarín cervical (Philadelphia o tipo rígido) inmoviliza específicamente la columna cervical (cuello) al limitar la flexión y extensión de C1-C7. Es la primera intervención de inmovilización que se aplica antes de mover al paciente. Sin embargo, el collarín solo protege el cuello — el tronco y la columna torácica siguen expuestos al movimiento durante la extricación del vehículo. El KED (Kendrick Extrication Device) es el chaleco de inmovilización que protege toda la columna desde la cabeza hasta el sacro durante la extricación de una víctima sentada en el vehículo. Funciona inmovilizando el tronco entero al asiento y permitiendo la rotación controlada del paciente (pivoteo) para extraerlo sin doblar la columna. El protocolo correcto es: (1) Aplicar collarín mientras la víctima sigue en el asiento; (2) Aplicar KED encima del collarín; (3) Extraer al paciente con control de cabeza; (4) Transferir a camilla de cuchara; (5) Retirar KED solo cuando el paciente está inmovilizado en la camilla.",
  },
  {
    question: "¿Qué equipo médico mínimo debe tener cada unidad de bomberos?",
    answer: "El equipo médico mínimo de una unidad de bomberos (Engine / autobomba) según las recomendaciones de la NFPA 1901 y los estándares operativos de cuerpos de bomberos modernos incluye: DEA o desfibrilador manual × 1 por unidad; Oxígeno portátil con mascarillas adulto/pediátrico × 1; Kit de trauma/control de hemorragias con torniquetes × según número de bomberos en la unidad; Bolsa de vía aérea con ambú y cánulas de Guedel × 1; Camilla de extricación o SKED × 1; Collarín cervical en tallas S/M/L × 1 set; Tabla espinal larga × 1; Tensiómetro, estetoscopio y oxímetro de pulso × 1 set; Kit de quemaduras (apósitos hidrogel y mantas) × 1. El costo de este kit básico completo para una unidad oscila entre $45,000 y $90,000 MXN según marcas y modelos. BOMBERO.MX cotiza el kit completo para una o toda la flota del cuerpo de bomberos.",
  },
];

// ─── Schema.org ──────────────────────────────────────────────────────────────
const CANONICAL = "/productos/equipo-medico/";
const productSchema = productSchemaComplete({
  name: "Equipo Médico EMS para Bomberos México — DEA, Kit Trauma, Camilla, Oxígeno",
  description: "Equipo médico EMS certificado para bomberos en México. DEA desfibriladores, kits de trauma TCCC, camillas de rescate, inmovilizadores KED y kits de oxígeno portátil. ZOLL, Philips, Ferno. Cotiza para licitación. Envío a 32 estados.",
  image: "/images/directorio/camilla-rescate-emergencias-01.avif",
  url: CANONICAL,
  category: "Equipo Médico / EMS — BLS y Rescate",
  features: ["DEA / AED", "TCCC", "NFPA 1999", "BLS / SVB", "EMS Avanzado"],
  certifications: ["FDA", "COFEPRIS", "NOM-237-SSA1", "ISO 9001"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Equipo Médico / EMS", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];
