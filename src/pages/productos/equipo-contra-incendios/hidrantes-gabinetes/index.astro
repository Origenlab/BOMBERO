const faqs = [
  {
    q: "¿Qué norma rige los gabinetes de manguera contra incendios en México?",
    a: "Los <strong>gabinetes de manguera contra incendios (GMC)</strong> en México deben cumplir la <strong>NOM-002-STPS-2010</strong> — Condiciones de Seguridad para Prevención y Protección contra Incendios. Adicionalmente, la <strong>NFPA 14</strong> es la norma de referencia técnica internacional que aplican protección civil y aseguradoras. Los proyectos de edificaciones nuevas en CDMX también deben cumplir el RCDF (Reglamento de Construcción del Distrito Federal).",
  },
  {
    q: "¿Cuál es la diferencia entre un GMC Clase I, II y III?",
    a: "Un <strong>GMC Clase I</strong> solo tiene una toma de 2½\" sin manguera — es solo para el cuerpo de bomberos con su propio equipo. El <strong>Clase II</strong> tiene manguera de 1½\" semirígida lista para uso de ocupantes entrenados. El <strong>Clase III</strong> es la combinación de ambas: tiene la toma de 2½\" para bomberos y la manguera de 1½\" para el personal de emergencia del edificio. Es el más completo y el más recomendado por la <strong>NFPA 14</strong>.",
  },
  {
    q: "¿Cada cuántos metros se instalan los hidrantes de columna seca en una instalación industrial?",
    a: "La <strong>NFPA 1</strong> y la <strong>NFPA 24</strong> recomiendan que ningún punto de la edificación esté a más de <strong>60 metros</strong> de un hidrante medido por vías accesibles para el equipo de bomberos. En zonas de alto riesgo industrial (PEMEX, petroquímica, plantas de proceso) se reduce a 45 metros. El espaciado final depende del caudal disponible en la red, el tipo de riesgo y los requerimientos de la aseguradora.",
  },
  {
    q: "¿Qué es una conexión siamesa y por qué es obligatoria?",
    a: "Una <strong>conexión siamesa</strong> es un punto de entrada exterior que permite a los bomberos inyectar agua presurizada desde su unidad de bombeo al sistema interior del edificio (sprinklers, GMC, red interna). Es obligatoria en México para <strong>edificios de 5 pisos o más</strong> según el RCDF de CDMX y para cualquier edificio con sistema de rociadores NFPA 13. Debe estar visible desde la vía pública, señalizada y libre de obstáculos.",
  },
  {
    q: "¿Los gabinetes y hidrantes requieren mantenimiento periódico?",
    a: "Sí. La <strong>NOM-002-STPS-2010</strong> exige inspección mensual visual y prueba funcional semestral. La <strong>NFPA 25</strong> (<em>Standard for Inspection, Testing, and Maintenance of Water-Based Fire Protection Systems</em>) establece: inspección visual trimestral, prueba de flujo anual y prueba hidrostática cada 5 años. Las empresas certificadas en México ofrecen contratos de mantenimiento preventivo y correctivo.",
  },
  {
    q: "¿BOMBERO.MX vende solo los equipos o también hace instalación?",
    a: "<strong>BOMBERO.MX</strong> es el distribuidor de los equipos: gabinetes GMC, hidrantes de columna seca y pared, conexiones siamesas, mangueras, boquillas y accesorios certificados. Para la instalación trabajamos con una red de instaladores certificados NFPA en toda la República. Contáctanos y te conectamos con el instalador certificado más cercano a tu proyecto.",
  },
  {
    q: "¿Cuáles son los tiempos de entrega de gabinetes e hidrantes?",
    a: "Equipos estándar en inventario: <strong>2–5 días hábiles</strong> en CDMX y zona metropolitana, 5–10 días al resto de la República. Equipos especiales (hidrantes de especificación no estándar, gabinetes personalizados o grandes cantidades para proyectos): 4–8 semanas de tiempo de fabricación. Contacta a nuestro equipo para un programa de entrega específico para tu proyecto.",
  },
  {
    q: "¿Los hidrantes y gabinetes de BOMBERO.MX están certificados UL/FM?",
    a: "Sí. Distribuimos hidrantes y gabinetes con certificación <strong>UL Listed</strong> (Underwriters Laboratories) y aprobación <strong>FM Global</strong> cuando se requiere. Esta doble certificación es indispensable para proyectos con aseguradoras que operan bajo estándares internacionales (Lloyd's, AXA XL, FM Global). Solicita los certificados con tu cotización.",
  },
];

