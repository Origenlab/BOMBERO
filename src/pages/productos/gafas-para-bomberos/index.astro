  jsonLd={jsonLdSchemas}
  keywords={[
    "gafas para bomberos",
    "goggle bombero NFPA 1971",
    "protección visual bombero",
    "gafas seguridad antiimpacto bombero",
    "goggle sellado bombero México",
    "gafas bombero ANSI Z87.1",
    "protección ocular bombero certificada",
    "goggle rescate bombero",
    "EPP visual bombero México",
    "comprar gafas bombero México",
    "goggle policarbonato bombero",
    "gafas bombero rescate extricacion",
  ]}
  type="website"
>

  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
