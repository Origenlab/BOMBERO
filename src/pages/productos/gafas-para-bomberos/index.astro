---

import PageLayout from "@layouts/PageLayout.astro";
import QuickNav from "@components/QuickNav.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQQuote from "@components/FAQQuote.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

const productos = [
  {
    id: "goggle",
    nombre: "Goggle de Bombero",
    slug: "/productos/gafas-para-bomberos/goggle/",
    badge: "NFPA 1971 / ANSI Z87.1",
    badgeColor: "ember",
    imagen: "/images/gafas-para-bomberos/goggle-sellado-bombero-proteccion-ocular-nfpa-01.avif",
    descripcion:
      "Goggle de protección ocular total para combate de incendios estructurales y operaciones de rescate. Marco sellado con ventilación indirecta, lente policarbonato resistente a impactos, salpicaduras y calor radiante. Compatible con casco NFPA 1971 y máscara SCBA. Certificado NFPA 1971 y ANSI Z87.1.",
    caracteristicas: [
      "Marco sellado con ventilación indirecta antiempañante",
      "Lente policarbonato antirayado resistente a impacto balistico",
      "Protección frente a calor radiante y salpicaduras",
      "Compatible con casco NFPA 1971 y máscara SCBA",
      "Certificado NFPA 1971 / ANSI Z87.1 / EN 166",
    ],
    aplicacion: "Incendio estructural · Rescate urbano · Operaciones con partículas y salpicaduras",
  },
  {
    id: "seguridad",
    nombre: "Gafas de Seguridad Antiimpacto",
    slug: "/productos/gafas-para-bomberos/seguridad/",
    badge: "ANSI Z87.1",
    badgeColor: "fire",
    imagen: "/images/gafas-para-bomberos/gafas-seguridad-bombero-proteccion-ocular-nfpa-01.avif",
    descripcion:
      "Gafas de perfil bajo para operaciones de rescate técnico, extricación vehicular y trabajo en espacios confinados donde el uso de goggle resulta incómodo. Lente policarbonato con protección UV y antiempañante. Montura flexible que se adapta bajo el casco de rescate. Certificadas ANSI Z87.1 y EN 166.",
    caracteristicas: [
      "Lente policarbonato envolvente de alta resistencia al impacto",
      "Tratamiento antiempañante y protección UV 400",
      "Montura flexible con arcos antideslizantes",
      "Perfil ultra bajo compatible con casco de rescate NFPA 1951",
      "Certificadas ANSI Z87.1 / EN 166 (edición vigente)",
    ],
    aplicacion: "Rescate vehicular · Extricación · Espacios confinados · Operaciones en altura",
  },
];


const CANONICAL = "/productos/gafas-para-bomberos/";
const productSchema = productSchemaComplete({
  name: "Gafas para Bomberos NFPA",
  description: "Gafas y goggles para bombero certificados NFPA 1971 y ANSI Z87.1. Goggle sellado antiimpacto y gafas de seguridad para rescate. Envío a los 32 estados de México.",
  image: productos[0].imagen ?? "/images/directorio/estacion-bomberos-mexico-01.avif",
  url: CANONICAL,
  category: "Gafas de Bombero",
  features: ["NFPA 1971", "ANSI Z87.1", "EN 166", "Anti-empañante", "Policarbonato"],
  certifications: ["NFPA 1971", "ANSI Z87.1", "EN 166"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Gafas para Bomberos", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];

const gafasFaqs = [
  {
    question: "¿Para qué sirven las gafas de bombero si el casco ya tiene visor?",
    answer: "El visor del casco NFPA 1971 no está diseñado para operaciones de rescate técnico, sobrehaul (overhaul) ni situaciones donde el bombero necesita agacharse, rodar o trabajar boca arriba — en esas posiciones el visor puede abrirse y dejar los ojos expuestos. Las gafas de seguridad certificadas ANSI Z87.1+ sellan los ojos perimetralmente contra partículas, salpicaduras y fragmentos en operaciones post-incendio, demolición controlada, extricación vehicular y overhaul. Adicionalmente, cuando un bombero trabaja sin casco (en zona segura, en el exterior del vehículo, en operaciones médicas), las gafas son la única protección ocular disponible. Son el componente más olvidado del EPP y uno de los más críticos para prevenir lesiones oculares que pueden ser permanentes.",
  },
  {
    question: "¿Qué norma certifica las gafas y goggles de bombero?",
    answer: "Las gafas de protección para bomberos se certifican bajo ANSI Z87.1 (American National Standard for Occupational and Educational Personal Eye and Face Protection Devices) — la versión más reciente es ANSI/ISEA Z87.1-2020. La marca ANSI Z87.1+ (con el signo \"+\") indica que superan los requisitos básicos con resistencia a impactos de alta velocidad. Para bomberos, la NFPA 1971 edición 2018 incluye requisitos de protección ocular como parte del conjunto completo, aunque las gafas se certifican separadamente bajo ANSI Z87.1. En México, la NOM-017-STPS-2024 exige protección ocular en zonas con riesgo de proyectiles o salpicaduras — una gafa ANSI Z87.1+ cumple este requisito también para brigadas industriales.",
  },
  {
    question: "¿Goggle sellado o gafas de montura ligera? ¿Cuál elegir para bomberos?",
    answer: "Los goggles de sellado perimetral (tipo ocular cerrado, con espuma de sellado alrededor del marco) dan protección total contra partículas, vapores y salpicaduras: ideales para overhaul con humo residual, demolición, rescate en espacios con mucho polvo y operaciones HAZMAT de baja intensidad química. Las gafas de montura ligera (tipo policarbonato con protección lateral) dan mayor campo visual, mejor transpirabilidad y mayor comodidad en uso prolongado: ideales para operaciones en exteriores, guardia en estación, rescate vehicular. Para un cuerpo de bomberos completo, la combinación ideal es: visor del casco para combate activo + goggle sellado para overhaul/demolición + gafas de seguridad para operaciones en zona segura.",
  },
  {
    question: "¿Las gafas anti-vaho son realmente necesarias en operaciones de bomberos?",
    answer: "Sí — el empañamiento es uno de los problemas más frecuentes reportados en operaciones. Al salir de un espacio caliente con humo a un entorno más frío, o al exponerse a vapor de agua durante el ataque con líneas, el empañamiento de las gafas puede ser inmediato y total, dejando al bombero sin visibilidad en segundos. Los goggles anti-vaho (con recubrimiento de capa anti-condensación en la superficie interior de la lente) reducen el tiempo de empañamiento de segundos a varios minutos. Para operaciones en espacios cerrados o con vapores de agua, el anti-vaho es un requisito, no un lujo. Los recubrimientos anti-vaho se degradan con el uso y el tiempo — verificar periódicamente la efectividad.",
  },
  {
    question: "¿Las gafas de bombero son compatibles con quien usa lentes de prescripción?",
    answer: "Existen dos soluciones. OTG (Over The Glasses): goggles de mayor profundidad de cámara diseñados para usarse sobre anteojos de prescripción — solución más simple y económica, compatible con la mayoría de armazones. Lente graduado insertable: algunos modelos de goggles de alta gama (fabricantes como Bollé, MSA Sightgard) permiten insertar un lente de prescripción interno, dando mayor sellado y mejor campo visual sin usar doble armazón. En licitaciones para cuerpos de bomberos, siempre hacer el levantamiento de cuántos bomberos usan prescripción y especificar \"gafas tipo OTG para uso sobre anteojos de prescripción\" para esos casos.",
  },
  {
    question: "¿Cuánto cuestan las gafas y goggles certificados para bomberos en México?",
    answer: "Gafas de seguridad ANSI Z87.1+ de montura ligera: $200–$600 MXN. Goggles de sellado tipo overhaul: $600–$1,800 MXN. Goggles anti-vaho premium con recubrimiento permanente (no degradable con lavados): $1,200–$3,000 MXN. Gafas para bombero forestal con lente ahumado (protección UV en campo abierto): $400–$900 MXN. El precio del par de gafas es el componente más accesible de todo el EPP — no hay justificación operativa ni económica para que algún bombero trabaje sin protección ocular certificada.",
  },
  {
    question: "¿Cada cuánto hay que cambiar las lentes de las gafas?",
    answer: "Las lentes de policarbonato de las gafas de bombero se deterioran por: rayones acumulados (reducen la claridad y crean puntos de falla ante impacto), exposición a UV prolongada (amarillamiento del policarbonato), impactos que producen tensiones internas no visibles, y degradación del recubrimiento anti-vaho. Una lente con rayones visibles que interfieran con la visión periférica debe reemplazarse. La mayoría de los fabricantes (Bollé, MSA, Honeywell) ofrecen lentes de repuesto a precio accesible — reemplazar el lente es más económico que reemplazar el goggle completo. Inspección recomendada cada 6 meses en uso operativo activo.",
  },
  {
    question: "¿Pueden incluir las gafas en la cotización institucional de EPP completo?",
    answer: "Sí, de hecho es lo recomendado. Al cotizar el EPP completo para un cuerpo de bomberos, incluimos: gafas de seguridad ANSI Z87.1+ para uso general + goggles de sellado para overhaul por cada bombero operativo. Esto permite presentar una sola licitación con partida de EPP completo en lugar de procesos separados. Para la especificación técnica correcta: \"gafas de protección ocular certificadas ANSI/ISEA Z87.1-2020, lente de policarbonato resistente a impacto de alta velocidad (marcación +), con protección lateral integrada, para uso en operaciones de overhaul y rescate técnico, incluyendo variante OTG para usuarios con prescripción.\" Entregamos el texto sin costo.",
  },
];
---

<PageLayout
