---
/**
 * [...slug].astro — Ruta dinámica de /productos/ (2 fuentes)
 * ──────────────────────────────────────────────────────────────────
 * 1. COLECCIÓN `productos` (2026-06-10): páginas de variante L5 desde
 *    src/content/productos/<cat>/<sub>/<variante>.json, renderizadas
 *    con ProductoLayout. El id de la entrada es el slug de la URL.
 *    Migración: node scripts/extract-producto-data.mjs <categoria>
 * 2. PLACEHOLDERS legacy (noindex): slugs antiguos en actualización.
 *
 * Las páginas .astro estáticas siempre tienen precedencia sobre esta ruta.
 */
import { getCollection, type CollectionEntry } from "astro:content";
import ProductoLayout from "@layouts/ProductoLayout.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQQuote from "@components/FAQQuote.astro";
import CTABanner from "@components/CTABanner.astro";

type ProductoRuta = {
  slug: string;
  nombre: string;
};

export async function getStaticPaths() {
  // 1. Variantes de producto desde la colección
  const productos = await getCollection("productos");
  const rutasProducto = productos.map((p) => ({
    params: { slug: p.id },
    props: { producto: p.data },
  }));
  return [...rutasProducto, ...legacyPaths()];
}

// Exportada porque Astro extrae getStaticPaths a un scope separado del frontmatter
export function legacyPaths() {
  const rutas: ProductoRuta[] = [
    { slug: "epp-bomberos", nombre: "EPP Bomberos" },
    { slug: "trajes", nombre: "Trajes" },
    { slug: "trajes/estructural", nombre: "Trajes Estructurales" },
    { slug: "trajes/forestal", nombre: "Trajes Forestales" },
    { slug: "trajes/arff", nombre: "Trajes ARFF" },
    { slug: "trajes/aproximacion", nombre: "Trajes de Aproximación" },
    { slug: "trajes/hazmat", nombre: "Trajes HAZMAT" },
    { slug: "cascos", nombre: "Cascos" },
    { slug: "cascos/estructural", nombre: "Cascos Estructurales" },
    { slug: "cascos/forestal", nombre: "Cascos Forestales" },
    { slug: "cascos/rescate", nombre: "Cascos de Rescate" },
    { slug: "cascos/accesorios", nombre: "Accesorios para Cascos" },
    { slug: "guantes-botas", nombre: "Guantes y Botas" },
    { slug: "botas", nombre: "Botas" },
    { slug: "botas/estructural", nombre: "Botas Estructurales" },
    { slug: "botas/caucho", nombre: "Botas de Caucho" },
    { slug: "botas/forestal", nombre: "Botas Forestales" },
    { slug: "guantes", nombre: "Guantes" },
    { slug: "guantes/estructurales", nombre: "Guantes Estructurales" },
    { slug: "guantes/rescate", nombre: "Guantes de Rescate" },
    { slug: "guantes/hazmat", nombre: "Guantes HAZMAT" },
    { slug: "guantes/forestales", nombre: "Guantes Forestales" },
    { slug: "capuchas", nombre: "Capuchas" },
    { slug: "gafas", nombre: "Gafas" },
    // scba, herramientas-rescate, tecnologia, forestales y rescate-acuatico
    // tienen página estática dedicada (precedencia) — quitados 2026-06-10:
    // generarlos aquí duplicaba el build de cada uno sin efecto en el output.
    // equipo-contra-incendios, extintores y hazmat también tienen página dedicada.
    { slug: "buceo", nombre: "Equipos de Buceo" },
  ];

  return rutas.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item, producto } = Astro.props as {
  item?: ProductoRuta;
  producto?: CollectionEntry<"productos">["data"];
};
---

{producto && <ProductoLayout {...producto} />}

{item && (
<PageLayout
  title={`${item.nombre} | Catálogo en Actualización`}
  description={`Estamos preparando la ficha técnica de ${item.nombre} con especificaciones, comparativos y opciones de cotización.`}
  noindex={true}
  canonical={`https://bombero.mx/productos/${item.slug}/`}
>
  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
    { label: item.nombre },
  ]} />

  <CTABar quote={`Cotizar ${item.nombre}`} />

  <section class="section products-placeholder">
    <div class="container container--narrow">
      <h1>{item.nombre}</h1>
      <p>
        Esta categoría está en actualización editorial.
        Próximamente publicaremos información técnica detallada,
        aplicaciones recomendadas y guías de selección por riesgo operativo.
      </p>
      <a class="products-link" href="/cotizar/">Solicitar cotización</a>
    </div>
  </section>

  <WhyChooseUs />
  <FAQQuote
    title="Preguntas frecuentes sobre este producto"
    description="Todo lo que necesitas saber antes de adquirir equipo certificado NFPA — selección, certificaciones, envíos y documentación para licitaciones."
    items={[
      {
        question: "¿Este producto cuenta con certificación NFPA vigente?",
        answer: "Sí. Todos los productos de nuestro catálogo cuentan con certificación de laboratorio acreditado vigente según la norma NFPA aplicable. Incluimos ficha técnica y certificado de laboratorio en cada pedido — documentación esencial para auditorías internas, Protección Civil y procesos de licitación.",
      },
      {
        question: "¿Cómo solicito cotización de este producto?",
        answer: "Usa el formulario de esta página o escríbenos por WhatsApp al 55 7008 1816 con la cantidad y modelo de interés. Respondemos en menos de 24 hrs con precio, disponibilidad y tiempo de entrega. Sin compromiso de compra.",
      },
      {
        question: "¿Tienen stock disponible para entrega inmediata?",
        answer: "Mantenemos inventario permanente en CDMX de los modelos y tallas de mayor rotación. Para equipo especializado o configuraciones específicas, el tiempo de entrega varía entre 2 y 4 semanas. Al solicitar cotización te confirmamos disponibilidad exacta.",
      },
      {
        question: "¿Realizan envíos a toda la República Mexicana?",
        answer: "Sí, a los 32 estados con seguro de envío incluido. CDMX y Zona Metropolitana: entrega express en 24-48 hrs. Resto del país: 3-5 días hábiles. Para pedidos institucionales coordinamos entrega directa en cuartel, almacén o instalación.",
      },
      {
        question: "¿Pueden preparar documentación para licitación pública?",
        answer: "Sí. Entregamos: especificaciones técnicas por partida en términos de norma (no de marca), fichas técnicas, certificados de laboratorio NFPA vigentes, carta de distribución autorizada del fabricante y propuesta económica en el formato requerido. Sin costo para licitaciones en proceso activo.",
      },
      {
        question: "¿Ofrecen precios preferenciales para cuerpos de bomberos y gobierno?",
        answer: "Sí. Contamos con tabla de precios institucionales para H. Cuerpos de Bomberos, Protección Civil y dependencias de gobierno. El precio varía según volumen. Indica al solicitar cotización que es para uso institucional.",
      },
      {
        question: "¿El producto incluye garantía?",
        answer: "Sí. Todo el equipo incluye garantía de fabricante. Los períodos varían por categoría: 2 años en herramientas y cascos, 1 año en electrónicos y SCBA (sujeto a mantenimiento certificado), vida útil certificada en trajes de protección según NFPA 1851. Entregamos tarjeta de garantía con número de serie en cada pedido.",
      },
      {
        question: "¿Brindan asesoría técnica para elegir el modelo correcto?",
        answer: "Sí, sin costo y sin compromiso de compra. Escríbenos describiendo el tipo de operación, número de usuarios, riesgo predominante y presupuesto disponible. Nuestros asesores técnicos te recomiendan el modelo específico que mejor cumple los requisitos NFPA para tu aplicación.",
      },
    ]}
  />
  <CTABanner />

  {/* is:inline dentro de la rama placeholder: así estas reglas NO se
      inyectan en las páginas de producto de la colección (HTML idéntico). */}
  <style is:inline>
    .products-placeholder h1 {
      margin: 0 0 var(--space-4);
    }

    .products-placeholder p {
      margin: 0 0 var(--space-4);
      color: var(--color-smoke-700);
      line-height: 1.7;
    }

    .products-link {
      color: var(--color-fire-700);
      text-decoration: none;
      font-weight: 600;
    }

    .products-link:hover {
      text-decoration: underline;
    }
  </style>
</PageLayout>
)}
