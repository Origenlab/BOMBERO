---
import PageLayout    from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner     from "@components/CTABanner.astro";
import CTABar        from "@components/CTABar.astro";
import CategoryCard  from "@components/CategoryCard.astro";
import ProductCard   from "@components/ProductCard.astro";
import FAQ           from "@components/FAQ.astro";
import Breadcrumb    from "@components/Breadcrumb.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

// ─── Productos de la categoría Forestales ───────────────────────────────────
const productos = [
  {
    id: "traje-forestal",
    nombre: "Traje Forestal NFPA 1977",
    slug: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/",
    badge: "NFPA 1977",
    badgeColor: "fire" as const,
    imagen: "/images/trajes-para-bombero/traje-bombero-detalle-chaqueton-incendio-campo-01.avif",
    descripcion:
      "El traje estándar para combate de incendios forestales en México. Fabricado en tejido Nomex® ultraligero con resistencia inherente a la llama. No requiere tratamiento FR — la protección nunca se lava ni se desgasta. Diseñado para jornadas prolongadas en terreno accidentado y condiciones de calor extremo.",
    caracteristicas: [
      "Tejido Nomex® IIIA ultraligero — protección inherente, no tratada",
      "Peso total: < 400 g/m² para máxima movilidad en campo",
      "Alta transpirabilidad: control térmico en operaciones largas",
      "Diseño con múltiples bolsas funcionales y refuerzos en rodillas",
      "Certificado NFPA 1977 (edición vigente) con ficha técnica",
      "Bandas retroreflectivas para visibilidad en humo y penumbra",
    ],
    aplicacion: "Combate directo forestal · Quemas controladas · Interface urbano-rural · Montes y sierra",
  },
  {
    id: "casco-forestal",
    nombre: "Casco Forestal NFPA 1977",
    slug: "/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/",
    badge: "NFPA 1977",
    badgeColor: "fire" as const,
    imagen: "/images/trajes-para-bombero/bombera-profesional-traje-estructural-estacion-04.avif",
    descripcion:
      "Casco certificado NFPA 1977 para bomberos forestales. Diseño ligero con ventilación activa para trabajo físico intenso. Incluye protección facial y ocular con visor retráctil. Compatible con radio y linterna frontal para operaciones nocturnas o de baja visibilidad por humo.",
    caracteristicas: [
      "Certificado NFPA 1977 — resistencia al impacto y penetración",
      "Peso optimizado: < 550 g para reducir fatiga en turnos largos",
      "Sistema de ventilación activa — control de temperatura craneal",
      "Visor facial retráctil con protección UV",
      "Compatible con orejeras auditivas y radio de comunicaciones",
      "Suspensión ajustable con forro lavable extraíble",
    ],
    aplicacion: "Incendio forestal · Brigadas aéreas · Quemas prescritas · Rescate en monte",
  },
  {
    id: "botas-forestales",
    nombre: "Botas Forestales NFPA 1977",
    slug: "/productos/botas-para-bomberos/forestal/",
    badge: "NFPA 1977",
    badgeColor: "smoke" as const,
    imagen: "/images/trajes-para-bombero/bombera-profesional-traje-estructural-estacion-01.avif",
    descripcion:
      "Bota forestal de cuero completo o material sintético FR para bomberos de campo. Suela Vibram® con agarre extremo en terreno lodoso, rocoso e irregular. Resistente a brasas y superficies carbonizadas. Diseño que permite usar plantillas ortoédicas para jornadas de 12–24 horas.",
    caracteristicas: [
      "Cuero de cuero completo tratado con aceite FR o material sintético ignífugo",
      "Suela Vibram® resistente a temperatura hasta 300°C",
      "Puntera de composite no metálica — compatible con entornos eléctricos",
