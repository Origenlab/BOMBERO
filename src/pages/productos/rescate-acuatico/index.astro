  image: "/images/productos/producto-equipo-rescate-acuatico.avif",
  url: CANONICAL,
  category: "Rescate Acuático — NFPA 1952",
  features: ["NFPA 1952", "EN 1385", "Swift Water Rescue", "USCG Tipo III", "IRB"],
  certifications: ["NFPA 1952", "EN 1385", "CE EN 395"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Rescate Acuático", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];
