---

import PageLayout from "@layouts/PageLayout.astro";
import QuickNav from "@components/QuickNav.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQ from "@components/FAQ.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

const productos = [
  {
    id: "estructural",
    nombre: "Casco Estructural NFPA 1971",
    slug: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/",
    badge: "NFPA 1971",
    badgeColor: "ember",
    imagen: "/images/cascos-para-bomberos/casco-bombero-estructural-premium-nfpa-1971.avif",
    descripcion:
      "Protección craneal máxima para combate de incendios estructurales. Shell termoplástico de alto impacto o material compuesto. Resistencia térmica sostenida hasta 500°F (260°C) con sistema de retención de 4–6 puntos.",
    caracteristicas: [
      "Shell termoplástico ABS o material compuesto certificado",
      "Protección térmica hasta 500°F (260°C) sostenida",
      "Sistema de retención ajustable de 4 o 6 puntos",
      "Compatible con SCBA de cara completa NFPA 1981",
      "Certificado NFPA 1971 (edición vigente)",
    ],
    aplicacion: "Incendio estructural · Rescate urbano · Operaciones interiores · Flash-over",
  },
  {
    id: "forestal",
    nombre: "Casco Forestal NFPA 1977",
    slug: "/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/",
    badge: "NFPA 1977",
    badgeColor: "fire",
    imagen: "/images/cascos-para-bomberos/casco-bombero-forestal-profesional-nfpa-1977.avif",
    descripcion:
      "Ultraligero y ventilado para jornadas prolongadas en campo abierto. Peso inferior a 450 g con ventilación activa y protección facial mesh anti-chispas. Compatible con protección auditiva y visor facial.",
    caracteristicas: [
      "Peso ultraligero < 450 g para uso prolongado",
      "Ventilación activa superior para clima cálido",
      "Protección facial mesh anti-chispas integrada",
      "Compatible con protección auditiva y comunicaciones",
      "Certificado NFPA 1977 (edición vigente)",
    ],
    aplicacion: "Incendio forestal · Quemas controladas · Interface urbano-rural · Brigadas",
  },
  {
    id: "arff",
    nombre: "Casco ARFF Aeroportuario",
    slug: "/productos/cascos-para-bomberos/casco-arff-aeroportuario/",
    badge: "NFPA 1971 / EN 443",
    badgeColor: "ember",
    imagen: "/images/cascos-para-bomberos/casco-bombero-arff-aeroportuario-01.avif",
    descripcion:
      "Diseñado para soportar radiación extrema de combustibles de aviación (jet fuel). Visor dorado metalizado anti-radiación, protección auditiva reforzada y compatibilidad con sistemas de comunicación aeronáuticos.",
    caracteristicas: [
      "Visor de policarbonato dorado anti-radiación térmica extrema",
      "Protección superior frente a jet fuel y combustibles de aviación",
      "Cumple NFPA 1971 / EN 443 / ICAO Annex 14",
      "Compatible con sistema de comunicación en frecuencias ICAO",
      "Reflectividad mejorada para operaciones nocturnas",
    ],
    aplicacion: "Aeropuertos · Pistas de aterrizaje · Emergencias aeronáuticas · ARFF",
  },
  {
    id: "rescate",
    nombre: "Casco de Rescate Técnico NFPA 1951",
    slug: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/",
    badge: "NFPA 1951",
    badgeColor: "smoke",
    imagen: "/images/cascos-para-bomberos/casco-bombero-rescate-tecnico-nfpa-1951.avif",
    descripcion:
      "Protección superior contra impactos laterales, penetración y aplastamiento para operaciones de rescate técnico y USAR. Compatible con arneses de altura, lámparas y cámaras de inspección.",
    caracteristicas: [
      "Protección de impacto lateral y vertical certificada NFPA 1951",
      "Resistencia a penetración de escombros superior",
      "Ranuras de cuatro puntos para lámpara, cámara y accesorios",
      "Compatible con arnés de escalada, rapel y rescate vertical",
      "Certificado NFPA 1951 (edición vigente)",
    ],
    aplicacion: "Rescate técnico · USAR · Espacios confinados · Rescate vertical · Extricación",
  },
  {
    id: "hazmat",
    nombre: "Casco HAZMAT Químico",
    slug: "/productos/cascos-para-bomberos/casco-hazmat-quimico/",
    badge: "NFPA 1991 / 1992",
    badgeColor: "smoke",
    imagen: "/images/cascos-para-bomberos/casco-bombero-hazmat-quimico-01.avif",
    descripcion:
      "Protección integral para operaciones con materiales peligrosos. Compatible con trajes HAZMAT encapsulados Nivel A y B. Resistente a vapores químicos, ácidos y salpicaduras de productos peligrosos.",
    caracteristicas: [
      "Compatible con traje HAZMAT encapsulado Nivel A y B",
      "Shell resistente a vapores químicos, ácidos y álcalis",
      "Visor panorámico de policarbonato con visibilidad 180°",
      "Sistema de ventilación de presión positiva para SCBA interno",
      "Certificado NFPA 1991 / NFPA 1992 / EN 943",
    ],
    aplicacion: "HAZMAT · Derrames químicos · Atmósferas IDLH · Nivel A/B · CBRN",
  },
  {
    id: "industrial",
    nombre: "Casco de Brigada Industrial",
    slug: "/productos/cascos-para-bomberos/casco-brigada-industrial/",
    badge: "Multi-norma",
    badgeColor: "fire",
    imagen: "/images/cascos-para-bomberos/casco-bombero-brigada-industrial-01.avif",
    descripcion:
      "Versatilidad de uso para brigadas industriales en petroquímica, refinerías y complejos de manufactura con riesgo de incendio. Diseño modular con accesorios intercambiables y sistema de identificación de brigada.",
    caracteristicas: [
      "Diseño modular con accesorios y visores intercambiables",
      "Certificación dual compatible con NFPA 1971 y NFPA 1977",
      "Sistema de identificación de brigada por color y etiquetado",
      "Compatible con protección facial y auditiva integrada",
      "Ideal para adquisiciones de volumen en sector industrial",
    ],
    aplicacion: "Brigadas industriales · Petroquímica · Refinerías · Corporativos",
  },
] as const;


const CANONICAL = "/productos/cascos-para-bomberos/";
const productSchema = productSchemaComplete({
  name: "Cascos para Bomberos NFPA",
  description: "Cascos de bombero certificados NFPA 1971, 1977 y 1951. Casco Estructural, Forestal, ARFF Aeroportuario, Rescate Técnico, HAZMAT y Brigada Industrial con envío a los 32 estados de México.",
  image: productos[0].imagen ?? "/images/directorio/estacion-bomberos-mexico-01.avif",
  url: CANONICAL,
  category: "Cascos de Bombero",
  features: ["NFPA 1971", "NFPA 1977", "NFPA 1951", "HAZMAT", "ARFF"],
  certifications: ["NFPA 1971", "NFPA 1977", "NFPA 1951", "EN 443"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Cascos para Bomberos", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];

const cascosFaqs = [
  {
    question: "¿Cuál es la diferencia entre un casco NFPA 1971 y uno NFPA 1977?",
    answer: "El casco estructural NFPA 1971 está diseñado para soportar temperaturas de hasta 260°C de forma sostenida, tiene ala posterior extendida para desviar agua y escombros del cuello, sistema de retención de 4 puntos que no se suelta ante impactos, y visor de policarbonato de alta resistencia térmica — pesa entre 700 y 900 g. El casco forestal NFPA 1977 pesa menos de 450 g: en campo abierto la prioridad es ventilación y movilidad sobre el aislamiento térmico extremo; la visera es más corta y no tiene el ala posterior del estructural. Usar un casco NFPA 1977 en un incendio estructural equivale a usar traje forestal en un edificio: no cumple los requisitos térmicos de esa operación.",
  },
  {
    question: "¿Bullard o Cairns? ¿Cuál casco es mejor para un cuerpo de bomberos en México?",
    answer: "Bullard y Cairns (MSA) son las dos marcas de referencia mundial — la elección depende más de la operación que del nombre. Bullard FX (fibra de vidrio): bajo centro de gravedad, sistema patentado Sure-Lock®, muy resistente a químicos y abrasión; el LTX es termoplástico, más ligero, más económico. Cairns Invader 664: liberación de carcasa patentada para situaciones de enganche (crítica en rescate técnico), amplia gama de tallas, historial probado con departamentos FDNY y CAL FIRE. El Cairns 1836 (2025) es el modelo de referencia actual de MSA para Latinoamérica. Para cuerpos que hacen mucho rescate técnico, el sistema anti-enganche de Cairns es una ventaja operativa real; para uso estructural intenso, ambas son equivalentes en protección certificada.",
  },
  {
    question: "¿Termoplástico o fibra de vidrio? ¿Cuál carcasa elegir?",
    answer: "La carcasa termoplástica (ABS reforzado, como el Bullard LTX o Cairns 660) es más económica, absorbe mejor los impactos de baja velocidad, es más ligera y más fácil de reemplazar; tiene menor resistencia química. La carcasa de fibra de vidrio (como el Bullard FX o Cairns Invader 664 Composite) pesa un poco más pero es significativamente más rígida, más resistente a impactos de alta energía (caída de escombros estructurales), no se astilla ante impacto térmico extremo, y dura más ante exposición química. Para brigadas industriales con exposición a químicos, la fibra de vidrio es preferible. Para bomberos estructurales de alto ritmo operativo, ambas cumplen — el factor decisivo suele ser el peso y el precio.",
  },
  {
    question: "¿Cuántos años dura un casco de bombero y cuándo hay que cambiarlo?",
    answer: "La NFPA 1851 establece vida útil máxima de 10 años desde fabricación para cascos estructurales. La fecha de fabricación está moldeada en el interior del casco (día/mes/año) — si el casco no tiene esta marca, debe retirarse. Retiro obligatorio inmediato por: grietas visibles en la carcasa, daño en el sistema de retención interior, exposición a químicos que no se pueden identificar, exposición al fuego donde el casco fue sometido a calor extremo, y cualquier impacto de alta energía aunque no haya daño visible. Un casco que \"se ve bien\" después de 12 años no necesariamente cumple ya los requisitos de resistencia — la carcasa envejece y pierde propiedades mecánicas.",
  },
  {
    question: "¿El casco de bombero incluye protección para el cuello y la cara?",
    answer: "El casco estructural NFPA 1971 incluye: visor facial de policarbonato (protección contra partículas, salpicaduras y calor radiante), ala posterior extendida que desvía agua y escombros sobre el cuello, y en algunos modelos protector de nuca articulado. Sin embargo, el casco deja expuestas las zonas de cuello, mentón, orejas y la piel entre el borde de la máscara SCBA y el casco — esas zonas las cubre la capucha ignífuga (Nomex o PBI). El sistema completo de protección de cabeza y cuello requiere: casco NFPA 1971 + capucha certificada NFPA 1971 + máscara de cara completa del SCBA. Omitir la capucha deja al bombero con zonas expuestas al calor que representan entre el 25 y el 35% del área total de la cabeza.",
  },
  {
    question: "¿Cuánto cuesta un casco de bombero certificado NFPA en México?",
    answer: "Los rangos según tipo: casco estructural NFPA 1971 termoplástico (Bullard LTX, Cairns 660): $4,500–$7,000 MXN; casco estructural fibra de vidrio (Bullard FX, Cairns Invader 664): $7,000–$12,000 MXN; casco forestal NFPA 1977: $2,500–$5,000 MXN; casco ARFF aeroportuario: $18,000–$35,000 MXN (lleva visor dorado antirradiación). Los precios varían según configuración (color, sistema de retención, accesorios de montaje para linternas). Solicita cotización para precio exacto según modelo y cantidad.",
  },
  {
    question: "¿Qué tipo de casco usa la brigada ARFF de un aeropuerto?",
    answer: "Las brigadas ARFF (Aircraft Rescue and Firefighting) usan un casco estructural reforzado con visor dorado (recubierto de óxido de estaño o similar) que refleja la radiación infrarroja de la combustión de jet fuel — que arde a temperaturas que funden un visor de policarbonato estándar en segundos. El casco ARFF cumple NFPA 1971 con requisitos adicionales de la FAA (AC 150/5210-6) para aeropuertos certificados en México bajo jurisdicción de la DGAC. También requiere mayor protección lateral y un sistema de retención más robusto ante los vientos de propulsión a reacción. Para aeropuertos comerciales en México, la DGAC exige que el personal de ARFF cuente con equipo específico certificado — contacta para cotización ARFF completa.",
  },
  {
    question: "¿El casco es compatible con el SCBA y sistemas de comunicación?",
    answer: "La compatibilidad entre casco y SCBA es crítica: la máscara de cara completa del SCBA debe sellar correctamente sin interferencia con el sistema de retención del casco. Los modelos más usados en México (MSA G1, Scott Air-Pak, Honeywell) son compatibles con la mayoría de cascos NFPA 1971 de Bullard y Cairns en configuración estándar — pero siempre debe verificarse con el fit test específico de máscara (NFPA 1981 y OSHA 29 CFR 1910.134). Para sistemas de comunicación integrados, los cascos Bullard y Cairns tienen rieles frontales compatibles con la mayoría de linternas y cámaras TIC. Al cotizar, especifica si necesitas compatibilidad con modelo específico de SCBA.",
  },
];

---

<PageLayout
  quickNav={false}
  title="Cascos para Bomberos NFPA | Bullard · MSA · Cairns — BOMBERO.MX"
  description="Cascos de bombero certificados NFPA 1971, NFPA 1977 y NFPA 1951. Casco Estructural, Forestal, ARFF, Rescate Técnico, HAZMAT y Brigada Industrial. Bullard, MSA y Cairns con envío a los 32 estados de México."
  canonical={CANONICAL}
  jsonLd={jsonLdSchemas}
  keywords={[
    "cascos de bombero",
    "casco estructural NFPA 1971",
    "casco forestal NFPA 1977",
    "casco rescate técnico NFPA 1951",
    "casco HAZMAT bombero",
    "casco ARFF aeroportuario",
    "casco Bullard bombero México",
    "casco Cairns MSA bombero",
    "casco bombero certificado NFPA",
    "equipo de protección personal bomberos",
    "comprar casco bombero México",
    "casco termoplástico bombero",
  ]}
  type="website"
>

  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
    { label: "Cascos de Bombero" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          6 Tipos de Casco · Certificados NFPA
        </div>
        <h1 class="hero__title">
          Cascos para
          <span class="hero__title-highlight">Bomberos</span>
          Certificados NFPA
        </h1>
        <p class="hero__subtitle">
          Cascos estructurales NFPA 1971, forestales NFPA 1977, ARFF, Rescate Técnico NFPA 1951 y HAZMAT. Bullard · MSA · Cairns · Ficha técnica incluida · Envío a 32 estados.
        </p>
        <div class="hero__actions">
          <a href="#catalogo" class="hero__btn hero__btn--primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1" ry="1"/></svg>
            Ver catálogo
          </a>
          <a href="/cotizar/" class="hero__btn hero__btn--secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Cotizar ahora
          </a>
        </div>
      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Cascos NFPA 1971 y 1977 — Bullard, Cairns y MSA en México</h2>
          <p class="hero__seo-text">
            Distribuimos las tres marcas de referencia en México: <strong>Bullard</strong>, <strong>Cairns</strong> y <strong>MSA</strong>. Cada casco en nuestro catálogo supera los requisitos mínimos de <strong>NFPA 1971, 1977 o 1951</strong> según su aplicación. Stock disponible para entrega inmediata a los <strong>32 estados</strong> con certificado de laboratorio acreditado incluido y ficha técnica lista para <strong>licitaciones públicas</strong>.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">El casco correcto define la supervivencia en flash-over — asesoría técnica sin costo</h2>
          <p class="hero__seo-text">
            Un <strong>casco estructural NFPA 1971</strong> no es equipo opcional: es el único elemento que protege la cabeza del bombero ante un flash-over. En BOMBERO.MX especificamos el casco adecuado para cada tipo de operación — estructural, forestal, rescate técnico, HAZMAT o aeroportuario — y lo entregamos con <strong>documentación completa para licitaciones</strong> en los <strong>32 estados de México</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav pool="categoria" count={7} />
  <CTABar quote="Cotizar Cascos de Bombero" />

  <!-- ═══════════════════════════════════════════════════════ LAYOUT SIDEBAR -->
  <div class="page-layout">
    <div class="page-layout__inner">

      <!-- ─── MAIN CONTENT ─── -->
      <main class="page-main">

        <!-- Catálogo -->
        <section class="content-panel" id="catalogo">
          <SectionHeader
            label="Catálogo de Cascos para Bomberos"
            title="6 Tipos de Casco de Bombero"
            description="Desde combate estructural hasta operaciones de rescate técnico y materiales peligrosos. Cada casco está diseñado y certificado para el entorno operativo más exigente."
          >
            <p>
              El <strong>casco de bombero</strong> es el primer elemento crítico del EPP: protege contra impactos, penetración, calor radiante y electricidad. En BOMBERO.MX seleccionamos únicamente <strong>cascos certificados NFPA</strong> que superan los requerimientos mínimos de cada norma y son compatibles con nuestros <a href="/productos/trajes-para-bomberos/">trajes para bombero</a> y <a href="/productos/botas-para-bomberos/">botas certificadas NFPA</a>.
            </p>
            <p>
              Todos nuestros <strong>cascos estructurales NFPA 1971</strong>, forestales, ARFF, de rescate técnico y HAZMAT incluyen fichas técnicas completas y certificados de laboratorio acreditado. Para un <strong>sistema de protección integral</strong>, combina el casco con <a href="/productos/trajes-para-bomberos/">traje NFPA certificado</a>, <a href="/productos/guantes-para-bomberos/">guantes</a> y <a href="/productos/botas-para-bomberos/">botas de bombero</a> del mismo estándar.
            </p>
          </SectionHeader>

          <div class="productos__grid">
            {productos.map((producto) => (
              <ProductCard {...producto} altSuffix="Casco de bombero certificado NFPA" />
            ))}
          </div>
        </section>

        <!-- Tecnología / Specs (dark panel) -->
        <section class="content-panel content-panel--dark" id="tecnologia">
          <SectionHeader
            label="Tecnología y Materiales"
            title="Materiales, Certificaciones y Aplicaciones"
            description="Los mejores cascos de bombero del mundo combinan materiales termoplásticos de alto impacto con sistemas de suspensión de ingeniería que distribuyen la energía de golpe y mantienen la estabilidad en operaciones de alta exigencia."
          >
            <p>
              Los <strong>cascos estructurales NFPA 1971</strong> combinan un shell de termoplástico ABS o material compuesto (fibra de vidrio/Kevlar®), sistema de suspensión de 4 o 6 puntos y visor retráctil de policarbonato que protege frente a llamas, calor radiante y esquirlas. Para protección integral, el casco estructural debe usarse con <a href="/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/" class="dark-link">traje estructural NFPA 1971</a>, <a href="/productos/capuchas-para-bomberos/" class="dark-link">capucha de protección</a> y <a href="/productos/botas-para-bomberos/estructural/" class="dark-link">botas estructurales de cuero</a>.
            </p>
            <p>
              Los <strong>cascos forestales NFPA 1977</strong> priorizan el peso inferior a 450 g y la ventilación activa para jornadas prolongadas en campo. Se complementan con <a href="/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/" class="dark-link">traje forestal NFPA 1977</a> y <a href="/productos/botas-para-bomberos/forestal/" class="dark-link">botas forestales ligeras</a>. Todos nuestros cascos incluyen certificados de laboratorio acreditado y fichas técnicas para <strong>licitaciones gubernamentales</strong> en los <strong>32 estados de México</strong>.
            </p>
          </SectionHeader>
          <div class="specs__grid">
            <CategoryCard
              title="Materiales de Alta Resistencia"
              icon="shield"
              image="/images/cascos-para-bomberos/detalle-casco-arff-visor-dorado.avif"
              description="Termoplástico ABS y policarbonato para resistencia superior al impacto y temperatura. Material compuesto de fibra de vidrio y Kevlar® en modelos estructurales premium y de rescate técnico. Sistemas de suspensión de 4 y 6 puntos con dial fit para ajuste bajo guantes."
            />
            <CategoryCard
              title="Certificaciones Internacionales"
              icon="certificate"
              image="/images/cascos-para-bomberos/casco-bombero-estudio-dramatico-perfil-02.avif"
              description="NFPA 1971 para cascos estructurales, NFPA 1977 para forestales, NFPA 1951 para rescate técnico y NFPA 1991/1992 para HAZMAT. Normas europeas EN 443 y EN 16473. Documentación de laboratorio acreditado NVLAP lista para licitaciones en los 32 estados de México."
            />
            <CategoryCard
              title="Aplicaciones y Operaciones"
              icon="users"
              image="/images/cascos-para-bomberos/casco-bombero-combate-incendio-proteccion-03.avif"
              description="Cuerpos de bomberos municipales y estatales, brigadas industriales y petroquímicas, bomberos aeroportuarios ARFF, equipos USAR de rescate técnico, protección civil estatal y federal en toda la República Mexicana."
            />
          </div>
        </section>

        <!-- Tabla Comparativa -->
        <section class="content-panel" id="comparativa">
          <SectionHeader
            label="Tabla Comparativa"
            title="¿Qué Casco de Bombero Necesitas?"
            description="Compara los 6 tipos de cascos según norma, aplicación, peso y material para seleccionar el equipo correcto para tu tipo de operación."
