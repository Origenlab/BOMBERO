// ─── FAQs ────────────────────────────────────────────────────────────────────
const faqs = [
  {
    question: "¿Qué norma NFPA regula el equipo de rescate vertical para bomberos?",
    answer: "La NFPA 1983 (Standard on Life Safety Rope and Equipment for Emergency Services) es la norma que regula todo el equipo de rescate en altura para bomberos y servicios de emergencia: cuerdas, arneses, mosquetones, poleas, bloqueadores y descendedores. Establece tres clases de cuerda según la carga: Escape (uso personal de emergencia — solo el rescatista), Operaciones Generales (el rescatista + una víctima) y Técnica (cargas múltiples o mayores). En México, los cuerpos de bomberos que realizan rescate técnico deben certificar su equipo bajo NFPA 1983. El equipo se complementa con la NFPA 1951 (equipo de protección para rescate técnico) y la NFPA 1006 (competencias del rescatista técnico).",
  },
  {
    question: "¿Qué diferencia hay entre un arnés de trabajo en altura y uno de rescate NFPA 1983?",
    answer: "Un arnés de trabajo en altura convencional (CE EN 361) está diseñado para proteger a un trabajador en caso de caída — soporta la carga del propio trabajador durante la caída y en la suspensión posterior. Un arnés de rescate NFPA 1983 Clase III cumple requisitos adicionales: (1) soporta la carga combinada del rescatista más una víctima en bajada controlada; (2) incluye puntos de anclaje adicionales (ventral, lateral) para posicionamiento en trabajo; (3) tiene sistemas de liberación rápida de emergencia; (4) debe superar pruebas de resistencia de 18 kN en el anclaje dorsal; y (5) es compatible con sistemas de polipasto para izaje de víctimas. Para un bombero que realiza rescate vertical profesional, solo el arnés NFPA 1983 Clase III es adecuado.",
  },
  {
    question: "¿Cuándo se debe reemplazar el equipo de rescate vertical?",
    answer: "La vida útil del equipo de rescate vertical depende del tipo de equipo y las condiciones de uso. Según las recomendaciones NFPA 1983 y los fabricantes: (1) Cuerdas: retiro inmediato tras cualquier caída de factor > 1, evidencia de daño, exposición a productos químicos o calor superior a 70°C. Vida útil máxima de 10 años desde fabricación aunque no se hayan usado. (2) Arneses y cintas: mismo criterio — retiro tras caída o daño visible. Inspección anual por técnico certificado. Vida máxima 10 años. (3) Mosquetones y hardware metálico: retiro si muestran deformación, corrosión profunda, grietas o funcionamiento deficiente del cierre. No tienen vida útil fija pero deben inspeccionarse antes de cada uso. (4) Bloqueadores y poleas: revisión semestral por técnico. Cambio de rodillos y resortes según indicación del fabricante. Todo el equipo de rescate debe tener tarjeta de vida y registro de inspecciones.",
  },
  {
    question: "¿Qué es el sistema de línea de seguridad (belay) y es obligatorio en México?",
    answer: "El sistema de línea de seguridad (belay) consiste en una segunda cuerda y dispositivo independiente del sistema principal de descenso, que opera en paralelo y cuya única función es detener la bajada si el sistema principal falla o el rescatista pierde el control. En operaciones de rescate técnico profesional, la norma NFPA 1983 y los estándares operativos de NFPA 1006 exigen sistemas de doble cuerda: la cuerda de trabajo (por donde baja el rescatista o la víctima) y la cuerda de seguridad (belay), manejada por un segundo rescatista en la cima. En México, si bien no existe una norma nacional que obligue explícitamente el sistema de belay, las estaciones de bomberos que siguen estándares NFPA como referencia operativa lo aplican como política interna. BOMBERO.MX asesora sobre la configuración completa de sistemas de doble cuerda.",
  },
  {
    question: "¿Cuánto cuesta equipar a un equipo de rescate vertical de 4 rescatistas?",
    answer: "El costo de equipar un equipo básico de rescate vertical de 4 rescatistas en México incluye: Arneses NFPA 1983 Clase III × 4 = $34,000–48,000 MXN; Cuerdas de rescate 12.5 mm × 50 m × 4 = $16,800–24,000 MXN; Descendedores autobloqueantes × 4 = $15,200–22,000 MXN; Kit de polipasto 3:1 y 6:1 (compartido por equipo) = $9,500–18,000 MXN; Mosquetones de rescate (10-12 piezas) = $6,000–12,000 MXN; Bolsas de rescate y accesorios = $4,000–8,000 MXN. Total estimado: $85,000–132,000 MXN para el kit básico de 4 rescatistas. El kit no incluye equipo de protección personal individual (EPP) como traje de rescate técnico NFPA 1951, casco de rescate ni guantes. BOMBERO.MX emite cotización con especificaciones NFPA para licitación municipal.",
  },
  {
    question: "¿El equipo de rescate vertical sirve también para rescate en espacios confinados?",
    answer: "Sí, con matices importantes. El sistema de cuerdas, arneses y polipasto NFPA 1983 es el mismo que se usa en rescate en espacios confinados para el izaje de víctimas o rescatistas desde silos, fosas, tanques y ductos verticales. Sin embargo, el rescate en espacios confinados requiere equipo adicional específico: (1) Trípode de acceso: soporte estructural sobre la abertura de entrada que ancla el sistema de polipasto y permite el izaje sin que el rescatista de apoyo esté expuesto al espacio; (2) Monitor de atmósfera: detector de gases multiparámetro (O2, LEL, CO, H2S) para verificar que la atmósfera del espacio no es IDLH antes de entrar; (3) SCBA NFPA 1981: para el rescatista que entra a rescatar en atmósferas deficientes de oxígeno o con vapores tóxicos. BOMBERO.MX provee el kit completo de rescate en espacios confinados como solución integral.",
  },
  {
    question: "¿Cuáles son las marcas de referencia en equipo de rescate vertical para bomberos?",
    answer: "Las marcas líderes mundiales en equipo de rescate vertical certificado para bomberos son: (1) Petzl (Francia): referencia global en arneses, descendedores y sistemas de rescate técnico. Línea Rescue y Vertex para bomberos. (2) CMC Rescue (EUA): especialistas en rescate técnico y USAR. Sus sistemas de polipasto son el estándar en muchos cuerpos de bomberos de EUA y México. (3) Beal (Francia): cuerdas de rescate kernmantle de alta gama, certificación NFPA 1983. (4) Mammut (Suiza): cuerdas de rescate con tecnología Protect Coating para resistencia a agua. (5) Sterling Rope (EUA): cuerdas de rescate de alta tenacidad con certificación NFPA 1983. (6) Kong (Italia): mosquetones y hardware de rescate de alta resistencia. (7) Harken Industrial: sistemas de polipasto de bajo fricción para rescate industrial. BOMBERO.MX distribuye las principales marcas. Contáctenos para disponibilidad y cotización.",
  },
];

// ─── Schema.org ──────────────────────────────────────────────────────────────
const CANONICAL = "/productos/rescate-vertical/";
const productSchema = productSchemaComplete({
  name: "Equipo de Rescate Vertical para Bomberos — Arneses NFPA 1983, Cuerdas, Polipasto",
  description: "Equipo de rescate vertical certificado NFPA 1983 para bomberos en México. Arneses de rescate, cuerdas técnicas 12.5 mm, descendedores autobloqueantes, polipastos 3:1/6:1 y mosquetones de rescate. Petzl, CMC Rescue, Beal. Cotiza para licitación.",
  image: "/images/productos/producto-arnes-rescate-vertical.avif",
  url: CANONICAL,
  category: "Rescate Vertical y Arneses — NFPA 1983",
  features: ["NFPA 1983", "NFPA 1951", "NFPA 1006", "CE EN 361", "Rescate en Altura"],
  certifications: ["NFPA 1983", "NFPA 1951", "CE EN 361", "CE EN 341"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Rescate Vertical y Arneses", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];
