  jsonLd={jsonLdSchemas}
  keywords={[
    "rescate vertical bomberos México",
    "arnés de rescate NFPA 1983",
    "cuerdas de rescate bomberos",
    "equipo rescate en altura bomberos",
    "polipasto rescate bomberos",
    "sistema descendedor bomberos",
    "NFPA 1983 equipo rescate",
    "kit rescate vertical bomberos México",
    "arnés bombero altura",
    "Petzl bomberos México",
    "CMC Rescue México",
    "rescate técnico bomberos",
    "cuerdas NFPA 1983",
    "mosquetones rescate bomberos",
