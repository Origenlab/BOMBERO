  {
    title: "Capuchas y Protección Visual",
    icon: "shield",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-02.avif",
    href: "/productos/capuchas-para-bomberos/",
    buttonText: "Capuchas y Gafas",
    items: [
      { label: "Capucha Nomex® Estructural",  href: "/productos/capuchas-para-bomberos/nomex/" },
      { label: "Capucha Particulada PM2.5",  href: "/productos/capuchas-para-bomberos/particulada/" },
    ],
  },
  {
    title: "Guantes para Bombero",
    icon: "glove",
    image: "/images/trajes-para-bombero/chaqueton-bombero-goretex-sistema-3-capas-detalle-02.avif",
    href: "/productos/guantes-para-bomberos/",
    buttonText: "Guantes NFPA",
    items: [
      { label: "Guantes Estructurales NFPA 1971",  href: "/productos/guantes-para-bomberos/estructurales/" },
      { label: "Guantes de Rescate / Extricación", href: "/productos/guantes-para-bomberos/rescate/" },
    ],
  },
];
const faqs: { q: string; a: string }[] = [
  {
    q: "¿Cuál es la diferencia entre NFPA 1951 y NFPA 1971?",
    a: "<strong>NFPA 1971</strong> certifica el traje estructural para incendio, con sistema de tres capas y alta protección térmica. <strong>NFPA 1951</strong> certifica el conjunto para rescate técnico: prioriza resistencia a abrasión, corte y patógenos, con menor aislamiento térmico y mucho mayor THL. No son intercambiables.",
  },
  {
    q: "¿Sirve para combatir incendios?",
    a: "No. El conjunto <strong>NFPA 1951</strong> no sustituye al traje estructural en interior estructural ni en exposición directa a llama. Su alcance certificado es rescate técnico, extricación y operaciones USAR.",
  },
  {
    q: "¿Protege contra patógenos en sangre?",
    a: "El alcance de <strong>NFPA 1951</strong> incluye requisitos de barrera frente a patógenos transmitidos por sangre y fluidos corporales, relevantes en extricación vehicular. La configuración específica se detalla en la hoja de datos técnicos de cada lote.",
  },
];

---

<CategoriaLayout
  title="Traje de Rescate Técnico NFPA 1951 | México"
  description="Traje de bombero para rescate técnico y extricación vehicular NFPA 1951. Ligeros, alta movilidad y reforzados contra la abrasión intensa."
  keywords={[
    "traje rescate técnico NFPA 1951",
    "traje extricación vehicular",
    "traje USAR México",
    "traje rescate vertical bombero",
    "traje bombero anticorte",
    "comprar traje rescate NFPA 1951",
    "traje bombero certificado NFPA 1951",
    "EPP rescate técnico",
  ]}
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "Rescate Técnico NFPA 1951" },
  ]}
  heroBadge="Ligero y Resistente · Rescate NFPA 1951"
  heroTitle="Rescate Técnico"
  heroTitleHighlight="NFPA 1951"
  heroSubtitle="Traje especializado para operaciones extricación vehicular, USAR y rescate vertical. Mucho más ligero que un estructural y diseñado para soportar roces intensos."
  heroSeoBlocks={[
    {
      title: "NFPA 1951: por qué el rescate técnico no usa traje estructural",
      text: "El <strong>traje de rescate técnico NFPA 1951</strong> responde a un perfil de riesgo distinto al del incendio estructural: metal cortado, vidrio, escombro y patógenos transmitidos por sangre, con el calor directo como amenaza secundaria. Por eso se minimiza la barrera térmica en favor de <strong>protección contra abrasión y corte</strong> y de un <strong>THL muy alto</strong>. Cada unidad incluye certificado de laboratorio acreditado ISO/IEC 17025 y número de lote trazable.",
    },
    {
      title: "Extricación, USAR y rescate vertical",
      text: "En extricación vehicular y búsqueda y rescate urbano el operador trabaja en espacios confinados durante periodos largos. Un conjunto <strong>NFPA 1951</strong> pesa considerablemente menos que un estructural <strong>NFPA 1971</strong> y disipa mejor el calor metabólico, reduciendo la fatiga en maniobras sostenidas.",
    },
  ]}
  ctaBarQuote="Cotizar Trajes de Rescate Técnico"
  productosLabel="Rescate Técnico NFPA 1951"
  productosTitle="Características para USAR"
  productosDesc="Por qué un traje de bombero no siempre necesita ser térmico extremo."
  productosContent="<p>Líder en protección al corte en emergencias mecánicas.</p>"
  productoCards={productoCards}
  productosAltSuffix="Rescate Técnico"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
