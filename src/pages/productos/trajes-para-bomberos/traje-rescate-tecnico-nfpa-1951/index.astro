    items: [
      { label: "Casco Estructural NFPA 1971", href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
      { label: "Casco de Rescate NFPA 1951",  href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
