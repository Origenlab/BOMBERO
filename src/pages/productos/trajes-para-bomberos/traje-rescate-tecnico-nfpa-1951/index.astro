---
import CategoriaLayout from "@layouts/CategoriaLayout.astro";

const SLUG  = "/productos/trajes-para-bomberos/traje-rescate-tecnico-nfpa-1951/";
const IMAGE_BASE = "/images/trajes-para-bombero";

const IMAGES = {
  hero: `${IMAGE_BASE}/traje-bombero-rescate-tecnico-nfpa-1951.avif`,
  sistema3Capas: `${IMAGE_BASE}/traje-bombero-detalle-material-nomex-resistencia-01.avif`,
  capaExterior: `${IMAGE_BASE}/traje-bombero-detalle-chaqueton-incendio-campo-01.avif`,
  membranaGoreTex: `${IMAGE_BASE}/traje-bombero-incendio-materiales-proteccion-termica-01.avif`,
  acolchadoTermico: `${IMAGE_BASE}/traje-bombero-vista-posterior-chaqueton-bandas-01.avif`,
  altaVisibilidad: `${IMAGE_BASE}/traje-bombero-combate-incendio-manguera-proteccion-01.avif`,
  disenoErgonomico: `${IMAGE_BASE}/traje-bombero-estacion-exterior-cuerpo-completo-01.avif`,
};

const productoCards = [
  {
    nombre: "Rescate Técnico — Máxima Agilidad",
    slug: SLUG + "#agilidad",
    badge: "Ligero",
    badgeColor: "smoke" as const,
    imagen: IMAGES.disenoErgonomico,
    descripcion: "Diseñado para arrastrarse en espacios confinados, escalar o intervenir en colapsos estructurales sin las gruesas barreras térmicas pesadas de un traje de incendio estructural.",
    caracteristicas: ["Diseño de capa sencilla o doble fina", "Libertad de movimiento 360", "Integración con arnés de extracción"],
    aplicacion: "Extricación y USAR",
  },
  {
    nombre: "Rescate Técnico — Resistencia Extrema a la Abrasión",
    slug: SLUG + "#abrasion",
    badge: "Punzocortantes",
    badgeColor: "ember" as const,
    imagen: IMAGES.capaExterior,
    descripcion: "Equipado con amplios paneles de reforzamiento Kevlar® / Nomex® para proteger frente al roce con metales cortantes (autos prensados) y hormigón rugoso sin romperse.",
    caracteristicas: ["Rodilleras y coderas ultra robustas", "Resistencia superior al desgarro (Tear Strength)", "Protección contra fluidos biológicos"],
    aplicacion: "Intervención vehicular (Jaws of Life)",
  },
];

const specsCards = [
  {
    title: "Tecnología Especializada",
    icon: "shield",
    description: "En el mundo del rescate técnico, maniobrar metales afilados en túneles pequeños es el estrés principal. El calor directo es secundario. Por esto eliminamos la pesada barrera térmica estructural en favor del blindaje anti-corte en zonas vitales.",
  },
  {
    title: "Cumplimiento NFPA 1951",
    icon: "certificate",
    description: "Cumple estrictamente con la Normativa NFPA 1951 de conjunto de protección para elementos de rescate técnico y táctico urbano.",
  },
];

const tablaHeaders = ["Especificación", "Detalle"];
const tablaRows = [
  { cells: [{ text: "Certificación Principal" }, { text: "NFPA 1951", chip: "smoke" as const }] },
  { cells: [{ text: "Protección Dominante" }, { text: "Abrasión y patógenos" }] },
  { cells: [{ text: "Capas de Aislamiento" }, { text: "Minimizadas para altísimo THL" }] },
];

const relacionadoCards = [];
const faqs = [];

---

<CategoriaLayout
  title="Traje de Rescate Técnico NFPA 1951 | BOMBERO.MX"
  description="Traje de bombero para rescate técnico y extricación vehicular NFPA 1951. Ligeros, alta movilidad y reforzados contra la abrasión intensa."
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "Rescate Técnico NFPA 1951" },
  ]}
  heroBadge="Ligero y Resistente · Rescate NFPA 1951"
  heroTitle="Rescate Técnico"
  heroTitleHighlight="NFPA 1951"
  heroSubtitle="Traje especializado para operaciones extricación vehicular, USAR y rescate vertical. Mucho más ligero que un estructural y diseñado para soportar roces intensos."
  heroSeoBlocks={[]}
  ctaBarQuote="Cotizar Trajes de Rescate Técnico"
  productosLabel="Rescate Técnico NFPA 1951"
  productosTitle="Características para USAR"
  productosDesc="Por qué un traje de bombero no siempre necesita ser térmico extremo."
  productosContent="<p>Líder en protección al corte en emergencias mecánicas.</p>"
  productoCards={productoCards}
  productosAltSuffix="Rescate Técnico"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
