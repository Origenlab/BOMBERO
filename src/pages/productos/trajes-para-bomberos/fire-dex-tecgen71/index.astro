---
import CategoriaLayout from "@layouts/CategoriaLayout.astro";

const SLUG  = "/productos/trajes-para-bomberos/fire-dex-tecgen71/";
const IMAGE_BASE = "/images/trajes-para-bombero";

const IMAGES = {
  hero: `${IMAGE_BASE}/traje-bombero-estructural-fire-dex-tecgen71.avif`,
  sistema3Capas: `${IMAGE_BASE}/traje-bombero-detalle-material-nomex-resistencia-01.avif`,
  capaExterior: `${IMAGE_BASE}/traje-bombero-detalle-chaqueton-incendio-campo-01.avif`,
  membranaGoreTex: `${IMAGE_BASE}/traje-bombero-incendio-materiales-proteccion-termica-01.avif`,
  acolchadoTermico: `${IMAGE_BASE}/traje-bombero-vista-posterior-chaqueton-bandas-01.avif`,
  altaVisibilidad: `${IMAGE_BASE}/traje-bombero-combate-incendio-manguera-proteccion-01.avif`,
  disenoErgonomico: `${IMAGE_BASE}/traje-bombero-estacion-exterior-cuerpo-completo-01.avif`,
};

const productoCards = [
  {
    nombre: "Fire-Dex TECGEN71® — Tejido Avanzado",
    slug: SLUG + "#tejido",
    badge: "Ultra Ligero",
    badgeColor: "smoke" as const,
    imagen: IMAGES.sistema3Capas,
    descripcion: "La capa exterior TECGEN71 revoluciona el peso del EPP, incrementando exponencialmente los niveles de THL (pérdida total de calor) para reducir la fatiga metabólica.",
    caracteristicas: ["Material TECGEN71 exclusivo", "Extremadamente ligero y resistente", "Protección TPP superior a 35"],
    aplicacion: "Combate estructural en altas temperaturas",
  },
  {
    nombre: "Fire-Dex FXR — Movilidad ActiveFlex",
    slug: SLUG + "#activeflex",
    badge: "FXR Design",
    badgeColor: "fire" as const,
    imagen: IMAGES.disenoErgonomico,
    descripcion: "El modelo FXR integra páneles activos que se estiran y adaptan, lo que da como resultado el traje tradicional menos restrictivo del mercado actual.",
    caracteristicas: ["Cortes FXR ergonómicos", "Bolsillos optimizados para guantes", "Protección en rodillas"],
    aplicacion: "Combate ofensivo y rescate dinámico",
  },
];

const specsCards = [
  {
    title: "Ligereza Incomparable",
    icon: "shield",
    description: "Fire-Dex prioriza la reducción del estrés fisiológico al diseñar el equipo estructural más ligero y transpirable, reduciendo en gramos críticos la carga total.",
  },
  {
    title: "Cumplimiento NFPA",
    icon: "certificate",
    description: "Completamente certificado NFPA 1971. El TECGEN71 no sacrifica TPP por THL, manteniendo ambos a niveles excepcionalmente altos de seguridad.",
  },
];

const tablaHeaders = ["Especificación", "Detalle"];
const tablaRows = [
  { cells: [{ text: "Certificación Principal" }, { text: "NFPA 1971", chip: "ember" as const }] },
  { cells: [{ text: "Capa Exterior" }, { text: "TECGEN71®" }] },
  { cells: [{ text: "Enfoque principal" }, { text: "Reducción de estrés térmico" }] },
];

const relacionadoCards: { title: string; icon?: string; image?: string; href: string; buttonText: string; description?: string; items?: { label: string; href: string }[] }[] = [
  {
    title: "Otros Trajes Estructurales NFPA 1971",
    icon: "shield",
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-31.avif",
    href: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/",
    buttonText: "Ver Trajes Estructurales",
    items: [
      { label: "Globe G-XTREME", href: "/productos/trajes-para-bomberos/globe-g-xtreme/" },
      { label: "Innotex ENERGY", href: "/productos/trajes-para-bomberos/innotex-energy/" },
      { label: "LION V-Force", href: "/productos/trajes-para-bomberos/lion-v-force/" },
    ],
  },
  {
    title: "Cascos para Bombero",
    icon: "helmet",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-01.avif",
    href: "/productos/cascos-para-bomberos/",
    buttonText: "Cascos NFPA 1971",
    items: [
      { label: "Casco Estructural NFPA 1971", href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
      { label: "Casco de Rescate NFPA 1951",  href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
    ],
  },
  {
    title: "Capuchas y Protección Visual",
    icon: "shield",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-02.avif",
    href: "/productos/capuchas-para-bomberos/",
    buttonText: "Capuchas y Gafas",
    items: [
      { label: "Capucha Nomex® Estructural",  href: "/productos/capuchas-para-bomberos/nomex/" },
      { label: "Capucha Particulada PM2.5",  href: "/productos/capuchas-para-bomberos/particulada/" },
    ],
  },
  {
    title: "Guantes para Bombero",
    icon: "glove",
    image: "/images/trajes-para-bombero/chaqueton-bombero-goretex-sistema-3-capas-detalle-02.avif",
    href: "/productos/guantes-para-bomberos/",
    buttonText: "Guantes NFPA",
    items: [
      { label: "Guantes Estructurales NFPA 1971",  href: "/productos/guantes-para-bomberos/estructurales/" },
      { label: "Guantes de Rescate / Extricación", href: "/productos/guantes-para-bomberos/rescate/" },
    ],
  },
];
const faqs: { q: string; a: string }[] = [
  {
    q: "¿Qué norma certifica el Fire-Dex TECGEN71?",
    a: "Se certifica bajo NFPA 1971 en su edición vigente, que fija los requisitos mínimos de protección térmica (TPP), resistencia a la llama, barrera de humedad y resistencia a líquidos peligrosos. Cada traje se entrega con certificado de laboratorio acreditado ISO/IEC 17025.",
  },
  {
    q: "¿Qué lo diferencia de un traje estructural convencional?",
    a: "La capa exterior TECGEN71, orientada a reducir peso y aumentar transpirabilidad manteniendo el cumplimiento NFPA 1971. El objetivo de diseño es bajar el estrés térmico acumulado en operaciones prolongadas.",
  },
  {
    q: "¿Manejan tallas y configuraciones a medida?",
    a: "Sí. El conjunto se especifica por talla, longitud de chaquetón y configuración de barrera de humedad y liner térmico. Solicita cotización indicando número de elementos y uso operativo previsto.",
  },
];

---

<CategoriaLayout
  title="Traje Bombero Fire-Dex TECGEN71 NFPA 1971 | México"
  description="Traje de bombero estructural Fire-Dex TECGEN71 certificado NFPA 1971. El traje más ligero y transpirable para reducción de fatiga."
  keywords={[
    "traje bombero Fire-Dex TECGEN71",
    "Fire-Dex TECGEN71 México",
    "traje bombero ligero NFPA 1971",
    "traje bombero transpirable",
    "traje estructural bajo estrés térmico",
    "comprar traje Fire-Dex México",
    "traje bombero certificado NFPA 1971",
    "EPP bombero estructural",
  ]}
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "Fire-Dex TECGEN71" },
  ]}
  heroBadge="Reducción de Estrés Térmico · Fire-Dex"
  heroTitle="Fire-Dex TECGEN71®"
  heroTitleHighlight="NFPA 1971"
  heroSubtitle="La revolución en reducción de peso. Utiliza la exclusiva capa exterior TECGEN71, ofreciendo un récord de transpirabilidad y balance térmico inigualable."
  heroSeoBlocks={[
    {
      title: "Fire-Dex TECGEN71: capa exterior ligera bajo NFPA 1971",
      text: "El <strong>Fire-Dex TECGEN71</strong> es un traje estructural certificado <strong>NFPA 1971</strong> cuyo diferenciador es la capa exterior TECGEN71, formulada para reducir el peso del conjunto y elevar la transpirabilidad sin salir del alcance de la norma. Cada unidad distribuida se entrega con <strong>certificado de laboratorio acreditado ISO/IEC 17025</strong>, número de lote trazable y hoja de datos técnicos — documentación requerida en licitaciones públicas municipales y estatales.",
    },
    {
      title: "Por qué importa el estrés térmico",
      text: "La fatiga por calor es una causa documentada de incidentes en operaciones prolongadas. Un conjunto más ligero y con mayor <strong>THL (Total Heat Loss)</strong> reduce la carga fisiológica acumulada durante el turno. Esta ficha resume las características del TECGEN71 para que puedas <strong>especificar y cotizar</strong> el modelo correcto para tu estación o brigada.",
    },
  ]}
  ctaBarQuote="Cotizar Traje Fire-Dex"
  productosLabel="Fire-Dex TECGEN71"
  productosTitle="Características TECGEN71"
  productosDesc="Conoce lo que hace a este traje la revolución del mercado."
  productosContent="<p>Líder en prevención de golpes de calor.</p>"
  productoCards={productoCards}
  productosAltSuffix="Fire-Dex TECGEN71"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
