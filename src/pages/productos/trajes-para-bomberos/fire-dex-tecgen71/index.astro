---
import CategoriaLayout from "@layouts/CategoriaLayout.astro";

const SLUG  = "/productos/trajes-para-bomberos/fire-dex-tecgen71/";
const IMAGE_BASE = "/images/trajes-para-bombero";

const IMAGES = {
  hero: `${IMAGE_BASE}/traje-bombero-estructural-fire-dex-tecgen71.avif`,
  sistema3Capas: `${IMAGE_BASE}/traje-bombero-detalle-material-nomex-resistencia-01.avif`,
  capaExterior: `${IMAGE_BASE}/traje-bombero-detalle-chaqueton-incendio-campo-01.avif`,
  membranaGoreTex: `${IMAGE_BASE}/traje-bombero-incendio-materiales-proteccion-termica-01.avif`,
  acolchadoTermico: `${IMAGE_BASE}/traje-bombero-vista-posterior-chaqueton-bandas-01.avif`,
  altaVisibilidad: `${IMAGE_BASE}/traje-bombero-combate-incendio-manguera-proteccion-01.avif`,
  disenoErgonomico: `${IMAGE_BASE}/traje-bombero-estacion-exterior-cuerpo-completo-01.avif`,
};

const productoCards = [
  {
    nombre: "Fire-Dex TECGEN71® — Tejido Avanzado",
    slug: SLUG + "#tejido",
    badge: "Ultra Ligero",
    badgeColor: "smoke" as const,
    imagen: IMAGES.sistema3Capas,
    descripcion: "La capa exterior TECGEN71 revoluciona el peso del EPP, incrementando exponencialmente los niveles de THL (pérdida total de calor) para reducir la fatiga metabólica.",
    caracteristicas: ["Material TECGEN71 exclusivo", "Extremadamente ligero y resistente", "Protección TPP superior a 35"],
    aplicacion: "Combate estructural en altas temperaturas",
  },
  {
    nombre: "Fire-Dex FXR — Movilidad ActiveFlex",
    slug: SLUG + "#activeflex",
    badge: "FXR Design",
    badgeColor: "fire" as const,
    imagen: IMAGES.disenoErgonomico,
    descripcion: "El modelo FXR integra páneles activos que se estiran y adaptan, lo que da como resultado el traje tradicional menos restrictivo del mercado actual.",
    caracteristicas: ["Cortes FXR ergonómicos", "Bolsillos optimizados para guantes", "Protección en rodillas"],
    aplicacion: "Combate ofensivo y rescate dinámico",
  },
];

const specsCards = [
  {
    title: "Ligereza Incomparable",
    icon: "shield",
    description: "Fire-Dex prioriza la reducción del estrés fisiológico al diseñar el equipo estructural más ligero y transpirable, reduciendo en gramos críticos la carga total.",
  },
  {
    title: "Cumplimiento NFPA",
    icon: "certificate",
    description: "Completamente certificado NFPA 1971. El TECGEN71 no sacrifica TPP por THL, manteniendo ambos a niveles excepcionalmente altos de seguridad.",
  },
];

const tablaHeaders = ["Especificación", "Detalle"];
const tablaRows = [
  { cells: [{ text: "Certificación Principal" }, { text: "NFPA 1971", chip: "ember" as const }] },
  { cells: [{ text: "Capa Exterior" }, { text: "TECGEN71®" }] },
  { cells: [{ text: "Enfoque principal" }, { text: "Reducción de estrés térmico" }] },
];

const relacionadoCards = [];
const faqs = [];

---

<CategoriaLayout
  title="Traje Bombero Fire-Dex TECGEN71 | BOMBERO.MX"
  description="Traje de bombero estructural Fire-Dex TECGEN71 certificado NFPA 1971. El traje más ligero y transpirable para reducción de fatiga."
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "Fire-Dex TECGEN71" },
  ]}
  heroBadge="Reducción de Estrés Térmico · Fire-Dex"
  heroTitle="Fire-Dex TECGEN71®"
  heroTitleHighlight="NFPA 1971"
  heroSubtitle="La revolución en reducción de peso. Utiliza la exclusiva capa exterior TECGEN71, ofreciendo un récord de transpirabilidad y balance térmico inigualable."
  heroSeoBlocks={[]}
  ctaBarQuote="Cotizar Traje Fire-Dex"
  productosLabel="Fire-Dex TECGEN71"
  productosTitle="Características TECGEN71"
  productosDesc="Conoce lo que hace a este traje la revolución del mercado."
  productosContent="<p>Líder en prevención de golpes de calor.</p>"
  productoCards={productoCards}
  productosAltSuffix="Fire-Dex TECGEN71"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
