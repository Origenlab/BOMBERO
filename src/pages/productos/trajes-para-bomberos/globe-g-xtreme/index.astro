---
import CategoriaLayout from "@layouts/CategoriaLayout.astro";

const SLUG  = "/productos/trajes-para-bomberos/globe-g-xtreme/";
const IMAGE_BASE = "/images/trajes-para-bombero";

const IMAGES = {
  hero: `${IMAGE_BASE}/traje-bombero-estructural-globe-g-xtreme-01.avif`,
  sistema3Capas: `${IMAGE_BASE}/traje-bombero-detalle-material-nomex-resistencia-01.avif`,
  capaExterior: `${IMAGE_BASE}/traje-bombero-detalle-chaqueton-incendio-campo-01.avif`,
  membranaGoreTex: `${IMAGE_BASE}/traje-bombero-incendio-materiales-proteccion-termica-01.avif`,
  acolchadoTermico: `${IMAGE_BASE}/traje-bombero-vista-posterior-chaqueton-bandas-01.avif`,
  altaVisibilidad: `${IMAGE_BASE}/traje-bombero-combate-incendio-manguera-proteccion-01.avif`,
  disenoErgonomico: `${IMAGE_BASE}/traje-bombero-estacion-exterior-cuerpo-completo-01.avif`,
};

const productoCards = [
  {
    nombre: "Globe G-XTREME® — Diseño Ergonómico",
    slug: SLUG + "#ergonomia",
    badge: "Active Posture",
    badgeColor: "fire" as const,
    imagen: IMAGES.disenoErgonomico,
    descripcion: "El G-XTREME® fue el primer traje diseñado específicamente en torno a la biomecánica del bombero en acción. Reduce la energía necesaria para moverse.",
    caracteristicas: ["Active Posture Design™", "Rodillas y codos preformados", "Sin restricción de movimiento"],
    aplicacion: "Combate estructural",
  },
  {
    nombre: "Globe G-XTREME® — Sistema de Capas",
    slug: SLUG + "#capas",
    badge: "NFPA 1971",
    badgeColor: "ember" as const,
    imagen: IMAGES.sistema3Capas,
    descripcion: "Equipado con materiales de vanguardia que superan los estándares TPP y THL requeridos por la NFPA 1971.",
    caracteristicas: ["Capa Exterior a elección (PBI/Nomex)", "Barrera Gore-Tex®", "Liner de baja fricción"],
    aplicacion: "Alta protección térmica",
  },
];

const specsCards = [
  {
    title: "Ergonomía de Ropa Deportiva",
    icon: "shield",
    description: "Globe redefinió la industria introduciendo cortes que emulan la ropa deportiva de alto rendimiento. Resultados: Menor estrés térmico y rango de movimiento extremo.",
  },
  {
    title: "Cumplimiento NFPA",
    icon: "certificate",
    description: "Garantizado bajo la rigurosa norma NFPA 1971 para el combate de incendios estructurales y operaciones de proximidad.",
  },
];

const tablaHeaders = ["Especificación", "Detalle"];
const tablaRows = [
  { cells: [{ text: "Certificación Principal" }, { text: "NFPA 1971", chip: "ember" as const }] },
  { cells: [{ text: "Diseño Biomecánico" }, { text: "Active Posture Design™" }] },
  { cells: [{ text: "Refuerzos" }, { text: "Kevlar® / Arashield®" }] },
];

const relacionadoCards: { title: string; icon?: string; image?: string; href: string; buttonText: string; description?: string; items?: { label: string; href: string }[] }[] = [
  {
    title: "Otros Trajes Estructurales NFPA 1971",
    icon: "shield",
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-31.avif",
    href: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/",
    buttonText: "Ver Trajes Estructurales",
    items: [
      { label: "Fire-Dex TECGEN71", href: "/productos/trajes-para-bomberos/fire-dex-tecgen71/" },
      { label: "Innotex ENERGY", href: "/productos/trajes-para-bomberos/innotex-energy/" },
      { label: "LION V-Force", href: "/productos/trajes-para-bomberos/lion-v-force/" },
    ],
  },
  {
    title: "Cascos para Bombero",
    icon: "helmet",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-01.avif",
    href: "/productos/cascos-para-bomberos/",
    buttonText: "Cascos NFPA 1971",
    items: [
      { label: "Casco Estructural NFPA 1971", href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
      { label: "Casco de Rescate NFPA 1951",  href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
    ],
  },
  {
    title: "Capuchas y Protección Visual",
    icon: "shield",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-02.avif",
    href: "/productos/capuchas-para-bomberos/",
    buttonText: "Capuchas y Gafas",
    items: [
      { label: "Capucha Nomex® Estructural",  href: "/productos/capuchas-para-bomberos/nomex/" },
      { label: "Capucha Particulada PM2.5",  href: "/productos/capuchas-para-bomberos/particulada/" },
    ],
  },
  {
    title: "Guantes para Bombero",
    icon: "glove",
    image: "/images/trajes-para-bombero/chaqueton-bombero-goretex-sistema-3-capas-detalle-02.avif",
    href: "/productos/guantes-para-bomberos/",
    buttonText: "Guantes NFPA",
    items: [
      { label: "Guantes Estructurales NFPA 1971",  href: "/productos/guantes-para-bomberos/estructurales/" },
      { label: "Guantes de Rescate / Extricación", href: "/productos/guantes-para-bomberos/rescate/" },
    ],
  },
];
const faqs: { q: string; a: string }[] = [
  {
    q: "¿Qué norma certifica el Globe G-XTREME?",
    a: "Se certifica bajo <strong>NFPA 1971</strong> en su edición vigente: protección térmica (TPP), resistencia a la llama, barrera de humedad y resistencia a líquidos peligrosos. Se entrega con certificado de laboratorio acreditado ISO/IEC 17025.",
  },
  {
    q: "¿Qué es el Active Posture Design?",
    a: "Es el sistema de patronaje de Globe que corta el traje según la <strong>postura de trabajo</strong> del bombero — brazos al frente, torso flexionado — en lugar de la postura en reposo. Reduce el exceso de tela y la resistencia del conjunto al movimiento.",
  },
  {
    q: "¿Qué refuerzos incluye?",
    a: "Refuerzos de <strong>Kevlar</strong> y <strong>Arashield</strong> en las zonas de mayor abrasión: hombros, codos y rodillas. La configuración exacta se define en la cotización según el uso operativo.",
  },
];

---

<CategoriaLayout
  title="Traje Bombero Globe G-XTREME NFPA 1971 | México"
  description="Traje de bombero estructural Globe G-XTREME certificado NFPA 1971. La máxima movilidad y ajuste deportivo del mercado."
  keywords={[
    "traje bombero Globe G-XTREME",
    "Globe G-XTREME México",
    "traje bombero ergonómico NFPA 1971",
    "Active Posture Design Globe",
    "traje estructural alta movilidad",
    "comprar traje Globe México",
    "traje bombero certificado NFPA 1971",
    "EPP bombero estructural",
  ]}
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "Globe G-XTREME" },
  ]}
  heroBadge="Premium Ergonómico · Globe G-XTREME"
  heroTitle="Globe G-XTREME®"
  heroTitleHighlight="NFPA 1971"
  heroSubtitle="El diseño de traje estructural más avanzado del mundo. El G-XTREME® incorpora el sistema Active Posture Design™ para adaptarse al bombero como ropa deportiva."
  heroSeoBlocks={[
    {
      title: "Globe G-XTREME: Active Posture Design bajo NFPA 1971",
      text: "El <strong>Globe G-XTREME</strong> es un traje estructural certificado <strong>NFPA 1971</strong> construido sobre el sistema <strong>Active Posture Design</strong>: patronaje que sigue la postura de trabajo del bombero en lugar de la posición en reposo. Los refuerzos en zonas de desgaste usan Kevlar y Arashield. Cada unidad se entrega con <strong>certificado ISO/IEC 17025</strong>, número de lote trazable y hoja de datos técnicos.",
    },
    {
      title: "Movilidad como variable de seguridad",
      text: "El rango de movimiento no es una comodidad: condiciona la velocidad de escalada, arrastre y extricación con el conjunto puesto. Un patronaje ergonómico reduce el gasto energético por movimiento repetido, lo que se traduce en <strong>menor fatiga al final del turno</strong>.",
    },
  ]}
  ctaBarQuote="Cotizar Traje Globe G-XTREME"
  productosLabel="Globe G-XTREME"
  productosTitle="Características G-XTREME"
  productosDesc="Conoce lo que hace a este traje la elección de miles de bomberos profesionales."
  productosContent="<p>Líder en ergonomía estructural.</p>"
  productoCards={productoCards}
  productosAltSuffix="Globe G-XTREME"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
