---
import CategoriaLayout from "@layouts/CategoriaLayout.astro";

const SLUG  = "/productos/trajes-para-bomberos/innotex-energy/";
const IMAGE_BASE = "/images/trajes-para-bombero";

const IMAGES = {
  hero: `${IMAGE_BASE}/traje-bombero-estructural-innotex-energy.avif`,
  sistema3Capas: `${IMAGE_BASE}/traje-bombero-detalle-material-nomex-resistencia-01.avif`,
  capaExterior: `${IMAGE_BASE}/traje-bombero-detalle-chaqueton-incendio-campo-01.avif`,
  membranaGoreTex: `${IMAGE_BASE}/traje-bombero-incendio-materiales-proteccion-termica-01.avif`,
  acolchadoTermico: `${IMAGE_BASE}/traje-bombero-vista-posterior-chaqueton-bandas-01.avif`,
  altaVisibilidad: `${IMAGE_BASE}/traje-bombero-combate-incendio-manguera-proteccion-01.avif`,
  disenoErgonomico: `${IMAGE_BASE}/traje-bombero-estacion-exterior-cuerpo-completo-01.avif`,
};

const productoCards = [
  {
    nombre: "Innotex ENERGY™ — Full Motion Design",
    slug: SLUG + "#full-motion",
    badge: "Energía Eficiente",
    badgeColor: "ember" as const,
    imagen: IMAGES.disenoErgonomico,
    descripcion: "FMD (Full Motion Design) de Innotex reduce de manera medible la inversión calórica necesaria para moverse en el lugar de la emergencia.",
    caracteristicas: ["Diseño en manga continua (sin hombro estático)", "Refuerzos poliméricos protectores", "Costuras Airflow 3D"],
    aplicacion: "Combate táctico y urbano",
  },
  {
    nombre: "Innotex ENERGY™ — Estética y Visibilidad",
    slug: SLUG + "#visibilidad",
    badge: "Táctico Dual",
    badgeColor: "smoke" as const,
    imagen: IMAGES.altaVisibilidad,
    descripcion: "Diseños avanzados dual-tone (Gray Man táctico o Gold/Black) complementados con líneas reflectantes verticales para diferenciación y modernidad extremas.",
    caracteristicas: ["Diseño estético agresivo", "Cortes asimétricos para movilidad", "Tiradores de rescate integrados de alta resistencia"],
    aplicacion: "Alta visibilidad en emergencias intensas",
  },
];

const specsCards = [
  {
    title: "Innovación Táctica",
    icon: "shield",
    description: "La línea ENERGY traslada el corte agresivo táctico al campo de los bomberos estructurales, ofreciendo protección superior con el menor coeficiente de arrastre de vestimenta.",
  },
  {
    title: "Cumplimiento NFPA",
    icon: "certificate",
    description: "Rigurosamente probado para superar la norma NFPA 1971 y las especificaciones modernas internacionales.",
  },
];

const tablaHeaders = ["Especificación", "Detalle"];
const tablaRows = [
  { cells: [{ text: "Certificación Principal" }, { text: "NFPA 1971", chip: "ember" as const }] },
  { cells: [{ text: "Biomecánica" }, { text: "Full Motion Design (Pivote Central)" }] },
  { cells: [{ text: "Perfil visual" }, { text: "Estética Dual-tone vertical" }] },
];

const relacionadoCards: { title: string; icon?: string; image?: string; href: string; buttonText: string; description?: string; items?: { label: string; href: string }[] }[] = [
  {
    title: "Otros Trajes Estructurales NFPA 1971",
    icon: "shield",
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-31.avif",
    href: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/",
    buttonText: "Ver Trajes Estructurales",
    items: [
      { label: "Fire-Dex TECGEN71", href: "/productos/trajes-para-bomberos/fire-dex-tecgen71/" },
      { label: "Globe G-XTREME", href: "/productos/trajes-para-bomberos/globe-g-xtreme/" },
      { label: "LION V-Force", href: "/productos/trajes-para-bomberos/lion-v-force/" },
    ],
  },
  {
    title: "Cascos para Bombero",
    icon: "helmet",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-01.avif",
    href: "/productos/cascos-para-bomberos/",
    buttonText: "Cascos NFPA 1971",
    items: [
      { label: "Casco Estructural NFPA 1971", href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
      { label: "Casco de Rescate NFPA 1951",  href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
    ],
  },
  {
    title: "Capuchas y Protección Visual",
    icon: "shield",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-02.avif",
    href: "/productos/capuchas-para-bomberos/",
    buttonText: "Capuchas y Gafas",
    items: [
      { label: "Capucha Nomex® Estructural",  href: "/productos/capuchas-para-bomberos/nomex/" },
      { label: "Capucha Particulada PM2.5",  href: "/productos/capuchas-para-bomberos/particulada/" },
    ],
  },
  {
    title: "Guantes para Bombero",
    icon: "glove",
    image: "/images/trajes-para-bombero/chaqueton-bombero-goretex-sistema-3-capas-detalle-02.avif",
    href: "/productos/guantes-para-bomberos/",
    buttonText: "Guantes NFPA",
    items: [
      { label: "Guantes Estructurales NFPA 1971",  href: "/productos/guantes-para-bomberos/estructurales/" },
      { label: "Guantes de Rescate / Extricación", href: "/productos/guantes-para-bomberos/rescate/" },
    ],
  },
];
const faqs: { q: string; a: string }[] = [
  {
    q: "¿Qué norma certifica el Innotex ENERGY?",
    a: "Se certifica bajo <strong>NFPA 1971</strong> en su edición vigente: protección térmica (TPP), resistencia a la llama, barrera de humedad y resistencia a líquidos peligrosos. Incluye certificado de laboratorio acreditado ISO/IEC 17025.",
  },
  {
    q: "¿Qué es el Full Motion Design?",
    a: "Es el sistema biomecánico de Innotex basado en un <strong>pivote central</strong> que permite rotación de hombro y cadera sin arrastrar el resto del conjunto, reduciendo la resistencia del traje al movimiento.",
  },
  {
    q: "¿El patrón reflectante cumple la norma?",
    a: "Si. La superficie y disposición del material retrorreflectante forman parte del alcance certificado <strong>NFPA 1971</strong>; la estética dual-tone vertical es una configuración dentro de ese alcance, no una excepción a él.",
  },
];

---

<CategoriaLayout
  title="Traje Bombero Innotex ENERGY NFPA 1971 | México"
  description="Traje de bombero estructural Innotex ENERGY certificado NFPA 1971. La revolución visual biomecánica para el combate táctico."
  keywords={[
    "traje bombero Innotex ENERGY",
    "Innotex ENERGY México",
    "traje bombero Full Motion",
    "traje estructural táctico NFPA 1971",
    "traje bombero biomecánico",
    "comprar traje Innotex México",
    "traje bombero certificado NFPA 1971",
    "EPP bombero estructural",
  ]}
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "Innotex ENERGY" },
  ]}
  heroBadge="Innovación Táctica · Innotex ENERGY"
  heroTitle="Innotex ENERGY™"
  heroTitleHighlight="NFPA 1971"
  heroSubtitle="Integración total entre biomecánica y protección. El modelo ENERGY™ incluye tecnología Full Motion y patrones reflectantes únicos."
  heroSeoBlocks={[
    {
      title: "Innotex ENERGY: Full Motion Design bajo NFPA 1971",
      text: "El <strong>Innotex ENERGY</strong> es un traje estructural certificado <strong>NFPA 1971</strong> que integra la tecnología <strong>Full Motion</strong> — pivote central en hombros y cadera — con un perfil visual dual-tone vertical. Cada unidad se entrega con <strong>certificado de laboratorio acreditado ISO/IEC 17025</strong>, número de lote trazable y hoja de datos técnicos para expediente de licitación.",
    },
    {
      title: "Biomecánica y visibilidad en escena",
      text: "El pivote central redistribuye la tensión del conjunto durante el arrastre y la escalada. El patrón reflectante vertical mejora el reconocimiento de la silueta en escena con humo denso, donde las bandas horizontales se fragmentan visualmente.",
    },
  ]}
  ctaBarQuote="Cotizar Traje Innotex"
  productosLabel="Innotex ENERGY"
  productosTitle="Características Innotex"
  productosDesc="Conoce lo que hace a este traje la opción número uno en modernidad."
  productosContent="<p>Líder en innovación y estética.</p>"
  productoCards={productoCards}
  productosAltSuffix="Innotex ENERGY"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
