    slug: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/",
    badge: "NFPA 1971",
    badgeColor: "ember",
    imagen: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    descripcion:
      "Sistema 3 capas NFPA 1971 con exterior Nomex®/PBI®, barrera Gore-Tex® y liner térmico. TPP ≥ 35 cal/cm² para combate de incendios estructurales.",
    caracteristicas: [
      "Capa exterior: Nomex® o PBI® certificada",
      "Barrera Gore-Tex® o equivalente NFPA",
      "Protección térmica TPP ≥ 35 cal/cm²",
      "Bandas retroreflectivas SOLAS clase 2",
      "Certificado NFPA 1971 (edición vigente)",
    ],
    aplicacion: "Incendio estructural · Rescate urbano · Colapso de estructuras",
  },
  {
    id: "forestal",
    nombre: "Traje Forestal NFPA 1977",
    slug: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/",
    badge: "NFPA 1977",
    badgeColor: "fire",
    imagen: "/images/trajes-para-bombero/bombera-profesional-traje-estructural-estacion-01.avif",
    descripcion:
      "Diseño ultraligero para incendios forestales e interface. Nomex® &lt;400 g/m² con alta transpirabilidad y resistencia inherente a la llama.",
    caracteristicas: [
      "Tejido Nomex® ultraligero (<400 g/m²)",
      "Alta transpirabilidad para trabajo físico intenso",
      "Resistencia a la llama inherente (no tratada)",
      "Compatible con equipo de mochila forestal",
      "Certificado NFPA 1977 (edición vigente)",
    ],
    aplicacion: "Incendio forestal · Quemas controladas · Interface urbano-rural",
  },
  {
    id: "arff",
    nombre: "Traje ARFF Aeroportuario",
    slug: "/productos/trajes-para-bomberos/traje-arff-aeroportuario/",
    badge: "NFPA 1971 / EN 1486",
    badgeColor: "ember",
    imagen: "/images/trajes-para-bombero/bunker-gear-bombero-camion-estacion-02.avif",
    descripcion:
      "Protección de proximidad para bomberos aeroportuarios (ARFF). Exterior aluminizado de alta reflectividad resistente a jet fuel y radiación extrema.",
    caracteristicas: [
      "Capa exterior aluminizada de alta reflectividad",
      "Protección frente a jet fuel y combustibles de aviación",
      "Cumple NFPA 1971 / EN 1486 / ICAO Annex 14",
      "Rango de protección: hasta 1000°C de radiación",
      "Sistema de cierre rápido para emergencias",
    ],
    aplicacion: "Aeropuertos · Pistas de aterrizaje · Emergencias aeronáuticas",
  },
  {
    id: "aproximacion",
    nombre: "Traje de Aproximación",
    slug: "/productos/trajes-para-bomberos/traje-aproximacion/",
    badge: "Alta Temperatura",
    badgeColor: "fire",
    imagen: "/images/trajes-para-bombero/traje-bombero-incendio-materiales-proteccion-termica-01.avif",
    descripcion:
      "Para operaciones en alta radiación térmica: petroquímica, fundiciones y metales fundidos. Exterior aluminizado ≥ 90% de reflexión, protección hasta 982°C radial.",
    caracteristicas: [
      "Capa exterior aluminizada reflectiva ≥ 90%",
      "Protección continua hasta 150°C ambiente",
      "Protección radial hasta 1,800°F (982°C)",
      "Visor de vidrio con recubrimiento metálico dorado",
      "Compatible con SCBA autónomo externo",
    ],
    aplicacion: "Petroquímica · Fundiciones · Derrame de metales fundidos",
  },
  {
    id: "hazmat",
    nombre: "Traje HAZMAT",
    slug: "/productos/trajes-para-bomberos/traje-hazmat/",
    badge: "NFPA 1991 / 1992",
    badgeColor: "smoke",
    imagen: "/images/trajes-para-bombero/traje-bombero-retrato-traje-oscuro-proteccion-01.avif",
    descripcion:
      "Encapsulamiento total nivel A/B para materiales peligrosos. Resistente a más de 200 productos químicos. Certificado NFPA 1991/1992 y EN 943.",
    caracteristicas: [
      "Nivel A: encapsulamiento total hermético",
      "Nivel B: traje splash-proof con SCBA externo",
      "Resistente a más de 200 productos químicos",
      "Certificado NFPA 1991 / NFPA 1992 / EN 943",
