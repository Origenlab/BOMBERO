---

import PageLayout from "@layouts/PageLayout.astro";
import QuickNav from "@components/QuickNav.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQQuote from "@components/FAQQuote.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

const productos = [
  {
    id: "estructural",
    nombre: "Traje Estructural NFPA 1971",
    slug: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/",
    badge: "NFPA 1971",
    badgeColor: "ember",
    imagen: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    descripcion:
      "Sistema 3 capas NFPA 1971 con exterior Nomex®/PBI®, barrera Gore-Tex® y liner térmico. TPP ≥ 35 cal/cm² para combate de incendios estructurales.",
    caracteristicas: [
      "Capa exterior: Nomex® o PBI® certificada",
      "Barrera Gore-Tex® o equivalente NFPA",
      "Protección térmica TPP ≥ 35 cal/cm²",
      "Bandas retroreflectivas SOLAS clase 2",
      "Certificado NFPA 1971 (edición vigente)",
    ],
    aplicacion: "Incendio estructural · Rescate urbano · Colapso de estructuras",
  },
  {
    id: "forestal",
    nombre: "Traje Forestal NFPA 1977",
    slug: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/",
    badge: "NFPA 1977",
    badgeColor: "fire",
    imagen: "/images/trajes-para-bombero/bombera-profesional-traje-estructural-estacion-01.avif",
    descripcion:
      "Diseño ultraligero para incendios forestales e interface. Nomex® &lt;400 g/m² con alta transpirabilidad y resistencia inherente a la llama.",
    caracteristicas: [
      "Tejido Nomex® ultraligero (<400 g/m²)",
      "Alta transpirabilidad para trabajo físico intenso",
      "Resistencia a la llama inherente (no tratada)",
      "Compatible con equipo de mochila forestal",
      "Certificado NFPA 1977 (edición vigente)",
    ],
    aplicacion: "Incendio forestal · Quemas controladas · Interface urbano-rural",
  },
  {
    id: "arff",
    nombre: "Traje ARFF Aeroportuario",
    slug: "/productos/trajes-para-bomberos/traje-arff-aeroportuario/",
    badge: "NFPA 1971 / EN 1486",
    badgeColor: "ember",
    imagen: "/images/trajes-para-bombero/bunker-gear-bombero-camion-estacion-02.avif",
    descripcion:
      "Protección de proximidad para bomberos aeroportuarios (ARFF). Exterior aluminizado de alta reflectividad resistente a jet fuel y radiación extrema.",
    caracteristicas: [
      "Capa exterior aluminizada de alta reflectividad",
      "Protección frente a jet fuel y combustibles de aviación",
      "Cumple NFPA 1971 / EN 1486 / ICAO Annex 14",
      "Rango de protección: hasta 1000°C de radiación",
      "Sistema de cierre rápido para emergencias",
    ],
    aplicacion: "Aeropuertos · Pistas de aterrizaje · Emergencias aeronáuticas",
  },
  {
    id: "aproximacion",
    nombre: "Traje de Aproximación",
    slug: "/productos/trajes-para-bomberos/traje-aproximacion/",
    badge: "Alta Temperatura",
    badgeColor: "fire",
    imagen: "/images/trajes-para-bombero/traje-bombero-incendio-materiales-proteccion-termica-01.avif",
    descripcion:
      "Para operaciones en alta radiación térmica: petroquímica, fundiciones y metales fundidos. Exterior aluminizado ≥ 90% de reflexión, protección hasta 982°C radial.",
    caracteristicas: [
      "Capa exterior aluminizada reflectiva ≥ 90%",
      "Protección continua hasta 150°C ambiente",
      "Protección radial hasta 1,800°F (982°C)",
      "Visor de vidrio con recubrimiento metálico dorado",
      "Compatible con SCBA autónomo externo",
    ],
    aplicacion: "Petroquímica · Fundiciones · Derrame de metales fundidos",
  },
  {
    id: "hazmat",
    nombre: "Traje HAZMAT",
    slug: "/productos/trajes-para-bomberos/traje-hazmat/",
    badge: "NFPA 1991 / 1992",
    badgeColor: "smoke",
    imagen: "/images/trajes-para-bombero/traje-bombero-retrato-traje-oscuro-proteccion-01.avif",
    descripcion:
      "Encapsulamiento total nivel A/B para materiales peligrosos. Resistente a más de 200 productos químicos. Certificado NFPA 1991/1992 y EN 943.",
    caracteristicas: [
      "Nivel A: encapsulamiento total hermético",
      "Nivel B: traje splash-proof con SCBA externo",
      "Resistente a más de 200 productos químicos",
      "Certificado NFPA 1991 / NFPA 1992 / EN 943",
      "Pruebas de permeación química según ASTM F1001",
    ],
    aplicacion: "HAZMAT · Derrame químico · Incidentes con materiales peligrosos",
  },
] as const;


const CANONICAL = "/productos/trajes-para-bomberos/";
const productSchema = productSchemaComplete({
  name: "Trajes para Bomberos NFPA",
  description: "Trajes de bombero certificados NFPA 1971 y 1977. Traje Estructural, Forestal, ARFF Aeroportuario, Aproximación y HAZMAT con envío a los 32 estados de México.",
  image: productos[0].imagen ?? "/images/directorio/estacion-bomberos-mexico-01.avif",
  url: CANONICAL,
  category: "Trajes de Bombero",
  features: ["NFPA 1971", "NFPA 1977", "NFPA 1991", "ARFF", "HAZMAT"],
  certifications: ["NFPA 1971", "NFPA 1977", "NFPA 1991", "EN 469"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Trajes para Bomberos", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema, breadcrumbSchema];

const trajesFaqs = [
  {
    question: "¿Cuál es la diferencia entre un traje NFPA 1971 y uno NFPA 1977?",
    answer: "El traje NFPA 1971 es para incendio estructural: tiene 3 capas (exterior, barrera de vapor Gore-Tex® y liner térmico) con TPP mínimo de 35 cal/cm². Pesa entre 2.5 y 3.5 kg. El traje NFPA 1977 es para incendio forestal: prioriza ligereza (<400 g/m²) y transpirabilidad para jornadas prolongadas. Un traje forestal jamás debe usarse en un incendio estructural — su protección térmica es insuficiente para ese entorno.",
  },
  {
    question: "¿Qué significa TPP 35 cal/cm² en un traje estructural?",
    answer: "El TPP (Thermal Protective Performance) mide la energía térmica que el sistema completo del traje bloquea antes de que ocurra una quemadura de segundo grado en la piel del portador. Un TPP de 35 cal/cm² es el mínimo requerido por NFPA 1971. Un TPP de 45 o 50 cal/cm² ofrece mayor protección para exposiciones más prolongadas o intensas. A mayor TPP, mayor protección, pero también mayor peso y menor THL (transpirabilidad).",
  },
  {
    question: "¿Qué es el THL y por qué afecta la seguridad del bombero?",
    answer: "El THL (Total Heat Loss) mide la capacidad del traje de disipar el calor corporal del bombero. Un THL mayor a 205 W/m² (mínimo NFPA 1971) indica que el traje permite suficiente evaporación del sudor para evitar el golpe de calor. Un THL bajo significa que el calor corporal queda atrapado, aumentando el riesgo de colapso por calor — una de las principales causas de muerte de bomberos en operaciones. El balance TPP-THL es la decisión técnica más importante al seleccionar un traje.",
  },
  {
    question: "¿Cuánto dura un traje de bombero certificado NFPA 1971?",
    answer: "La NFPA 1851 (Standard on Selection, Care, and Maintenance of Structural Fire Fighting Ensembles) establece la vida útil máxima del traje estructural: 10 años desde la fecha de fabricación o cuando el traje ya no supere las pruebas de evaluación avanzada. En uso activo intenso, muchos trajes se retiran antes de los 7–8 años. La fecha de fabricación debe estar etiquetada en el interior del traje. Un traje fuera de vida útil no puede usarse en operaciones, incluso si parece estar en buen estado visual.",
  },
  {
    question: "¿Qué materiales se usan en los trajes estructurales de mejor desempeño?",
    answer: "Los materiales más avanzados son: capa exterior en Nomex® Nano o PBI® Matrix para mayor resistencia térmica con menor peso; barrera de vapor en Gore-Tex® Crosstech® para impermeabilidad y transpirabilidad superior; liner térmico en Caldura® E89 o PBI Gold® para máxima protección con mínimo peso. Los trajes de gama alta usan PBI Gold® en la capa exterior — el material que no arde, no se derrite y no se rompe, aunque sea el más costoso.",
  },
  {
    question: "¿Los trajes de bombero se pueden lavar en casa?",
    answer: "No. Los trajes certificados NFPA 1971 deben lavarse únicamente en instalaciones de lavado certificadas conforme a la NFPA 1851 usando detergentes y temperaturas específicas que no dañen la barrera de vapor ni el liner térmico. El lavado incorrecto puede degradar permanentemente las propiedades FR del material exterior o dañar la barrera Gore-Tex®. Los cuerpos de bomberos deben contar con un contrato de mantenimiento de ropa de protección o instalar su propia lavadora de uso exclusivo para EPP.",
  },
  {
    question: "¿Los trajes para bomberos incluyen reflectivos?",
    answer: "Sí. La NFPA 1971 exige bandas reflectivas SOLAS Clase 2 en cantidad y distribución específicas para garantizar visibilidad de 360° en condiciones de baja visibilidad (humo, penumbra). Las bandas deben ser de al menos 50 mm de ancho y distribuirse en torso, mangas y piernas conforme a los patrones definidos en la norma. La reflectividad debe mantenerse después de 25 ciclos de limpieza — es parte de las pruebas de certificación.",
  },
  {
    question: "¿Cómo sé cuál traje necesita mi cuerpo de bomberos?",
    answer: "La selección depende del tipo de operaciones predominantes de tu cuerpo: si el riesgo es estructural (edificios, departamentos, industria), el traje NFPA 1971 de 3 capas es el correcto. Si el riesgo es forestal o interfaz urbano-forestal, el NFPA 1977. Para aeropuertos, el ARFF NFPA 1971/FAA-H-7083. Para materiales peligrosos, el HAZMAT NFPA 1991/1992. Para instalaciones industriales con riesgo de explosión y flash fire, considera el traje de aproximación. En BOMBERO.MX hacemos la especificación técnica sin costo.",
  },
];

---

<PageLayout
  quickNav={false}
  title="Trajes para Bomberos NFPA | BOMBERO.MX"
  description="Trajes de bombero certificados NFPA 1971 y 1977. Traje Estructural, Forestal, ARFF Aeroportuario, Aproximación y HAZMAT con envío a los 32 estados de México. Asesoría técnica sin costo. ¡Cotiza ahora!"
  canonical={CANONICAL}
  jsonLd={jsonLdSchemas}
  keywords={[
    "trajes de bombero",
    "traje estructural NFPA 1971",
    "traje forestal NFPA 1977",
    "traje HAZMAT bombero",
    "traje ARFF aeroportuario",
    "traje de aproximación bomberos",
    "equipo de protección personal bomberos",
    "EPP bomberos México",
    "traje Nomex bombero",
    "traje PBI bombero",
    "comprar traje bombero México",
    "traje bombero certificado",
  ]}
  type="website"
>

  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
    { label: "Trajes de Bombero" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          5 Tipos de Trajes · Certificados NFPA
        </div>
        <h1 class="hero__title">
          Trajes para
          <span class="hero__title-highlight">Bomberos</span>
          Certificados NFPA
        </h1>
        <p class="hero__subtitle">
          Trajes estructurales NFPA 1971, forestales NFPA 1977, ARFF, Aproximación y HAZMAT. Certificados · Con ficha técnica · Envío a 32 estados.
        </p>
        <div class="hero__actions">
          <a href="#catalogo" class="hero__btn hero__btn--primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="1" ry="1"/>
            </svg>
            Ver catálogo
          </a>
          <a href="/cotizar/" class="hero__btn hero__btn--secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Cotizar ahora
          </a>
        </div>
      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Trajes para Bomberos NFPA 1971 y 1977 — Globe, Honeywell y MSA en México</h2>
          <p class="hero__seo-text">
            Distribuimos trajes de bombero con <strong>certificación NFPA 1971</strong> (estructural), <strong>NFPA 1977</strong> (forestal), NFPA 1991/1992 (HAZMAT) y trajes de aproximación para petroquímica. Cada traje incluye ficha técnica completa, certificado de laboratorio acreditado y documentación lista para <strong>licitaciones públicas</strong> en los <strong>32 estados de México</strong>. Marcas: <strong>Globe</strong>, <strong>Honeywell</strong>, <strong>MSA</strong> y fabricantes certificados NFPA.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">El traje correcto define la supervivencia — asesoría técnica sin costo</h2>
          <p class="hero__seo-text">
            Un <strong>traje estructural NFPA 1971</strong> con <strong>TPP ≥ 35 cal/cm²</strong> y barrera <strong>Gore-Tex®</strong> no es opcional en combate de incendios en edificios: es el único equipo que protege al bombero del flash-over. En BOMBERO.MX especificamos el sistema completo — traje, <a href="/productos/cascos-para-bomberos/" class="hero__link">casco certificado</a>, <a href="/productos/botas-para-bomberos/" class="hero__link">botas NFPA</a> y guantes — para cada tipo de operación, con <strong>asesoría técnica sin costo</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav pool="categoria" count={7} />
  <CTABar quote="Cotizar Trajes de Bombero" />

  <!-- ═══════════════════════════════════════════════════════ LAYOUT SIDEBAR -->
  <div class="page-layout">
    <div class="page-layout__inner">

      <!-- ─── MAIN CONTENT ─── -->
      <main class="page-main">

        <!-- Catálogo -->
        <section class="content-panel" id="catalogo">
          <SectionHeader
            label="Catálogo de Trajes para Bomberos"
            title="5 Tipos de Trajes de Bombero"
            description="Desde combate estructural hasta operaciones con materiales peligrosos. Cada traje está diseñado para el entorno operativo más exigente."
          >
            <p>
              Un <strong>traje de bombero</strong> no es simplemente ropa de protección: es un sistema integrado de múltiples capas que debe equilibrar <strong>protección térmica, resistencia química, movilidad y durabilidad</strong>. En BOMBERO.MX seleccionamos únicamente trajes que superan los requerimientos mínimos de la norma NFPA aplicable.
            </p>
            <p>
              Todos nuestros <strong>trajes estructurales NFPA 1971</strong>, forestales, ARFF y HAZMAT incluyen fichas técnicas completas y certificados de laboratorio. Para un <strong>sistema de protección completo</strong>, combina el traje con <a href="/productos/cascos-para-bomberos/">casco NFPA certificado</a>, guantes estructurales y <a href="/productos/botas-para-bomberos/">botas de cuero o caucho</a> según la operación.
            </p>
          </SectionHeader>

          <div class="productos__grid">
            {productos.map((producto) => (
              <ProductCard {...producto} altSuffix="Traje de bombero certificado" />
            ))}
          </div>
        </section>

        <!-- Tecnología / Specs (dark panel) -->
        <section class="content-panel content-panel--dark" id="tecnologia">
          <SectionHeader
            label="Tecnología y Materiales"
            title="Materiales, Certificaciones y Aplicaciones"
            description="Los mejores trajes de bombero del mundo se fabrican con materiales de alto rendimiento que ofrecen protección inherente sin comprometer la movilidad ni la comodidad del operativo."
          >
            <p>
              Los <strong>trajes estructurales NFPA 1971</strong> combinan capa exterior de Nomex® o PBI Gold®, barrera de humedad Gore-Tex® y capa térmica en un sistema de tres capas que protege frente a llamas directas y calor radiante. Para protección completa, el traje estructural debe usarse con <a href="/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" class="dark-link">casco estructural NFPA 1971</a> y <a href="/productos/botas-para-bomberos/estructural/" class="dark-link">botas estructurales de cuero</a>. Los <strong>trajes forestales NFPA 1977</strong> priorizan el tejido ultraligero y la transpirabilidad para operaciones prolongadas en campo.
            </p>
            <p>
              Todos nuestros <strong>trajes de bombero</strong> incluyen certificados de laboratorio acreditado y fichas técnicas completas listas para <strong>licitaciones gubernamentales</strong>. Compatibles con <a href="/productos/cascos-para-bomberos/" class="dark-link">cascos certificados NFPA</a> y <a href="/productos/botas-para-bomberos/" class="dark-link">botas de bombero</a> de nuestro catálogo para equipar tu cuerpo de bomberos con un solo proveedor en los <strong>32 estados de México</strong>.
            </p>
          </SectionHeader>
          <div class="specs__grid">
            <CategoryCard
              title="Materiales de Alta Protección"
              icon="shield"
              image="/images/trajes-para-bombero/traje-bombero-detalle-material-nomex-resistencia-01.avif"
              description="Nomex® IIIA y PBI Gold® para resistencia inherente a la llama y estabilidad térmica máxima. Kevlar® para resistencia al corte y punción. Gore-Tex® como barrera de humedad certificada. Materiales aluminizados para reflexión de radiación extrema."
            />
            <CategoryCard
              title="Certificaciones Internacionales"
              icon="certificate"
              image="/images/trajes-para-bombero/traje-bombero-vista-posterior-certificacion-nfpa-01.avif"
              description="NFPA 1971 para trajes estructurales, NFPA 1977 para forestales, NFPA 1991 y 1992 para HAZMAT. Normas europeas EN 469 y EN 943. Documentación completa de laboratorio lista para licitaciones en los 32 estados de México."
            />
            <CategoryCard
              title="Aplicaciones y Operaciones"
              icon="users"
              image="/images/trajes-para-bombero/traje-bombero-equipo-estacion-hombre-mujer-01.avif"
              description="Cuerpos de bomberos municipales y estatales, brigadas industriales y petroquímicas, bomberos aeroportuarios ARFF, protección civil estatal y federal, y brigadas de emergencias especiales en toda la República Mexicana."
            />
          </div>
        </section>

        <!-- Tabla Comparativa -->
        <section class="content-panel" id="comparativa">
          <SectionHeader
            label="Tabla Comparativa"
            title="¿Qué Traje de Bombero Necesitas?"
            description="Compara los 5 tipos de trajes según su norma, aplicación y nivel de protección para elegir el equipo correcto."
          >
            <p>
              La elección del <strong>traje de bombero</strong> correcto depende del riesgo predominante: el <strong>traje estructural NFPA 1971</strong> es el estándar para incendios de edificios y debe usarse con <a href="/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/">casco estructural</a> y <a href="/productos/botas-para-bomberos/estructural/">botas de cuero NFPA 1971</a>. El <strong>forestal NFPA 1977</strong> para trabajo en campo se complementa con <a href="/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/">casco forestal ligero</a> y <a href="/productos/botas-para-bomberos/forestal/">botas forestales</a>. El <strong>traje HAZMAT NFPA 1991/1992</strong> requiere <a href="/productos/botas-para-bomberos/caucho/">botas de caucho químico</a> y <a href="/productos/cascos-para-bomberos/casco-hazmat-quimico/">casco HAZMAT</a> para protección completa.
            </p>
            <p>
              En <strong>BOMBERO.MX</strong> asesoramos sin costo a tu corporación para seleccionar el traje, casco y botas adecuados según el tipo de riesgo. Elaboramos especificaciones técnicas de <strong>sistemas EPP completos</strong> para <strong>licitaciones públicas</strong> en toda la República Mexicana.
            </p>
          </SectionHeader>
          <div class="comparativa__wrapper">
            <table class="comparativa__table">
              <thead>
                <tr>
                  <th>Traje</th>
                  <th>Norma Principal</th>
                  <th>Aplicación</th>
                  <th>Protección Térmica</th>
                  <th>Material Exterior</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Estructural</strong></td>
                  <td><span class="cert-chip cert-chip--ember">NFPA 1971</span></td>
                  <td>Incendio estructural, colapso, rescate urbano</td>
                  <td>Alto — TPP ≥ 35 cal/cm²</td>
                  <td>Nomex® / PBI Gold®</td>
                </tr>
                <tr>
                  <td><strong>Forestal</strong></td>
                  <td><span class="cert-chip cert-chip--fire">NFPA 1977</span></td>
                  <td>Incendio forestal, interface, quemas controladas</td>
                  <td>Medio — Alta transpirabilidad</td>
                  <td>Nomex® ligero</td>
                </tr>
                <tr>
                  <td><strong>ARFF Aeroportuario</strong></td>
                  <td><span class="cert-chip cert-chip--ember">NFPA 1971 / EN 1486</span></td>
                  <td>Emergencias aeronáuticas, combustibles de aviación</td>
                  <td>Muy alto — Aluminizado reflectivo</td>
                  <td>Aluminizado + Nomex®</td>
                </tr>
                <tr>
                  <td><strong>Aproximación</strong></td>
                  <td><span class="cert-chip cert-chip--fire">Alta Temperatura</span></td>
                  <td>Petroquímica, fundiciones, metales fundidos</td>
                  <td>Extremo — hasta 982°C radial</td>
                  <td>Aluminizado ≥ 90% reflexión</td>
                </tr>
                <tr>
                  <td><strong>HAZMAT</strong></td>
                  <td><span class="cert-chip cert-chip--smoke">NFPA 1991 / 1992</span></td>
                  <td>Materiales peligrosos, derrames químicos, CBRN</td>
                  <td>Especial — Encapsulamiento total</td>
                  <td>Polímero químicamente inerte</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- FAQ -->
        <section class="content-panel content-panel--faq" id="faq">
          <FAQQuote
            items={trajesFaqs}
            title="Preguntas Frecuentes — Trajes para Bomberos"
            description="Resolvemos las dudas más frecuentes sobre normas NFPA, materiales, TPP, vida útil y selección de trajes de bombero en México."
          />
        </section>

        <!-- Relacionados -->
        <section class="content-panel" id="complementario">
          <SectionHeader
            label="Equipo Complementario"
            title="Completa tu EPP de Bombero"
            description="El traje es solo el comienzo. Equipa a tu personal con el sistema de protección completo."
          >
            <p>
