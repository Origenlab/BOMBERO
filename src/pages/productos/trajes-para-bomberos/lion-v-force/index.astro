---
import CategoriaLayout from "@layouts/CategoriaLayout.astro";

const SLUG  = "/productos/trajes-para-bomberos/lion-v-force/";
const IMAGE_BASE = "/images/trajes-para-bombero";

const IMAGES = {
  hero: `${IMAGE_BASE}/traje-bombero-estructural-lion-v-force-01.avif`,
  sistema3Capas: `${IMAGE_BASE}/traje-bombero-detalle-material-nomex-resistencia-01.avif`,
  capaExterior: `${IMAGE_BASE}/traje-bombero-detalle-chaqueton-incendio-campo-01.avif`,
  membranaGoreTex: `${IMAGE_BASE}/traje-bombero-incendio-materiales-proteccion-termica-01.avif`,
  acolchadoTermico: `${IMAGE_BASE}/traje-bombero-vista-posterior-chaqueton-bandas-01.avif`,
  altaVisibilidad: `${IMAGE_BASE}/traje-bombero-combate-incendio-manguera-proteccion-01.avif`,
  disenoErgonomico: `${IMAGE_BASE}/traje-bombero-estacion-exterior-cuerpo-completo-01.avif`,
};

const productoCards = [
  {
    nombre: "LION V-Force® — V-Fit Design",
    slug: SLUG + "#vfit",
    badge: "V-Fit™",
    badgeColor: "fire" as const,
    imagen: IMAGES.disenoErgonomico,
    descripcion: "Cortes anatómicos exclusivos que siguen la forma de tu cuerpo flexionándose donde deben hacerlo, minimizando el exceso de tela.",
    caracteristicas: ["Diseño V-Fit™ en codos y rodillas", "Bi-swing en zona de hombros", "Construcción libre de abultamientos"],
    aplicacion: "Combate estructural prolongado",
  },
  {
    nombre: "LION V-Force® — RedZone (Opcional)",
    slug: SLUG + "#redzone",
    badge: "Protección Partículas",
    badgeColor: "smoke" as const,
    imagen: IMAGES.sistema3Capas,
    descripcion: "Configurable con el paquete de control de partículas RedZone™ de LION, diseñado para sellar las zonas vulnerables de la interfaz del EPP.",
    caracteristicas: ["Sello contra partículas carcinógenas", "Compatible con guantes V-Force", "Protección extra en muñecas y tobillos"],
    aplicacion: "Gestión de riesgos a la salud del bombero",
  },
];

const specsCards = [
  {
    title: "Cortes V-Fit",
    icon: "shield",
    description: "Las rodillas y hombros contorneados están diseñados para una libertad de movimiento incomparable, permitiendo escalar, gatear y alcanzar sin resistencia del traje.",
  },
  {
    title: "Cumplimiento NFPA",
    icon: "certificate",
    description: "Supera sólidamente la norma NFPA 1971 con las configuraciones más avanzadas de TPP y THL.",
  },
];

const tablaHeaders = ["Especificación", "Detalle"];
const tablaRows = [
  { cells: [{ text: "Certificación Principal" }, { text: "NFPA 1971", chip: "ember" as const }] },
  { cells: [{ text: "Diseño Estructural" }, { text: "V-Fit™ Anatómico" }] },
  { cells: [{ text: "Refuerzos" }, { text: "Polímeros antidesgaste LION" }] },
];

const relacionadoCards = [];
const faqs = [];

---

<CategoriaLayout
  title="Traje Bombero LION V-Force | BOMBERO.MX"
  description="Traje de bombero estructural LION V-Force certificado NFPA 1971. Máxima flexibilidad y diseño anatómico."
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "LION V-Force" },
  ]}
  heroBadge="Máxima Flexibilidad · LION V-Force"
  heroTitle="LION V-Force®"
  heroTitleHighlight="NFPA 1971"
  heroSubtitle="Diseñado para moverse contigo, no contra ti. El V-Force® utiliza cortes anatómicos y pliegues estratégicos para eliminar el volumen innecesario innecesario."
  heroSeoBlocks={[]}
  ctaBarQuote="Cotizar Traje LION V-Force"
  productosLabel="LION V-Force"
  productosTitle="Características V-Force"
  productosDesc="Conoce lo que hace a este traje la elección de los bomberos de combate."
  productosContent="<p>Líder en diseño anatómico.</p>"
  productoCards={productoCards}
  productosAltSuffix="LION V-Force"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
