---
import CategoriaLayout from "@layouts/CategoriaLayout.astro";

const SLUG  = "/productos/trajes-para-bomberos/lion-v-force/";
const IMAGE_BASE = "/images/trajes-para-bombero";

const IMAGES = {
  hero: `${IMAGE_BASE}/traje-bombero-estructural-lion-v-force-01.avif`,
  sistema3Capas: `${IMAGE_BASE}/traje-bombero-detalle-material-nomex-resistencia-01.avif`,
  capaExterior: `${IMAGE_BASE}/traje-bombero-detalle-chaqueton-incendio-campo-01.avif`,
  membranaGoreTex: `${IMAGE_BASE}/traje-bombero-incendio-materiales-proteccion-termica-01.avif`,
  acolchadoTermico: `${IMAGE_BASE}/traje-bombero-vista-posterior-chaqueton-bandas-01.avif`,
  altaVisibilidad: `${IMAGE_BASE}/traje-bombero-combate-incendio-manguera-proteccion-01.avif`,
  disenoErgonomico: `${IMAGE_BASE}/traje-bombero-estacion-exterior-cuerpo-completo-01.avif`,
};

const productoCards = [
  {
    nombre: "LION V-Force® — V-Fit Design",
    slug: SLUG + "#vfit",
    badge: "V-Fit™",
    badgeColor: "fire" as const,
    imagen: IMAGES.disenoErgonomico,
    descripcion: "Cortes anatómicos exclusivos que siguen la forma de tu cuerpo flexionándose donde deben hacerlo, minimizando el exceso de tela.",
    caracteristicas: ["Diseño V-Fit™ en codos y rodillas", "Bi-swing en zona de hombros", "Construcción libre de abultamientos"],
    aplicacion: "Combate estructural prolongado",
  },
  {
    nombre: "LION V-Force® — RedZone (Opcional)",
    slug: SLUG + "#redzone",
    badge: "Protección Partículas",
    badgeColor: "smoke" as const,
    imagen: IMAGES.sistema3Capas,
    descripcion: "Configurable con el paquete de control de partículas RedZone™ de LION, diseñado para sellar las zonas vulnerables de la interfaz del EPP.",
    caracteristicas: ["Sello contra partículas carcinógenas", "Compatible con guantes V-Force", "Protección extra en muñecas y tobillos"],
    aplicacion: "Gestión de riesgos a la salud del bombero",
  },
];

const specsCards = [
  {
    title: "Cortes V-Fit",
    icon: "shield",
    description: "Las rodillas y hombros contorneados están diseñados para una libertad de movimiento incomparable, permitiendo escalar, gatear y alcanzar sin resistencia del traje.",
  },
  {
    title: "Cumplimiento NFPA",
    icon: "certificate",
    description: "Supera sólidamente la norma NFPA 1971 con las configuraciones más avanzadas de TPP y THL.",
  },
];

const tablaHeaders = ["Especificación", "Detalle"];
const tablaRows = [
  { cells: [{ text: "Certificación Principal" }, { text: "NFPA 1971", chip: "ember" as const }] },
  { cells: [{ text: "Diseño Estructural" }, { text: "V-Fit™ Anatómico" }] },
  { cells: [{ text: "Refuerzos" }, { text: "Polímeros antidesgaste LION" }] },
];

const relacionadoCards: { title: string; icon?: string; image?: string; href: string; buttonText: string; description?: string; items?: { label: string; href: string }[] }[] = [
  {
    title: "Otros Trajes Estructurales NFPA 1971",
    icon: "shield",
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-31.avif",
    href: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/",
    buttonText: "Ver Trajes Estructurales",
    items: [
      { label: "Fire-Dex TECGEN71", href: "/productos/trajes-para-bomberos/fire-dex-tecgen71/" },
      { label: "Globe G-XTREME", href: "/productos/trajes-para-bomberos/globe-g-xtreme/" },
      { label: "Innotex ENERGY", href: "/productos/trajes-para-bomberos/innotex-energy/" },
    ],
  },
  {
    title: "Cascos para Bombero",
    icon: "helmet",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-01.avif",
    href: "/productos/cascos-para-bomberos/",
    buttonText: "Cascos NFPA 1971",
    items: [
      { label: "Casco Estructural NFPA 1971", href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
      { label: "Casco de Rescate NFPA 1951",  href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
    ],
  },
  {
    title: "Capuchas y Protección Visual",
    icon: "shield",
    image: "/images/trajes-para-bombero/bombera-profesional-casco-mano-estudio-02.avif",
    href: "/productos/capuchas-para-bomberos/",
    buttonText: "Capuchas y Gafas",
    items: [
      { label: "Capucha Nomex® Estructural",  href: "/productos/capuchas-para-bomberos/nomex/" },
      { label: "Capucha Particulada PM2.5",  href: "/productos/capuchas-para-bomberos/particulada/" },
    ],
  },
  {
    title: "Guantes para Bombero",
    icon: "glove",
    image: "/images/trajes-para-bombero/chaqueton-bombero-goretex-sistema-3-capas-detalle-02.avif",
    href: "/productos/guantes-para-bomberos/",
    buttonText: "Guantes NFPA",
    items: [
      { label: "Guantes Estructurales NFPA 1971",  href: "/productos/guantes-para-bomberos/estructurales/" },
      { label: "Guantes de Rescate / Extricación", href: "/productos/guantes-para-bomberos/rescate/" },
    ],
  },
];
const faqs: { q: string; a: string }[] = [
  {
    q: "¿Qué norma certifica el LION V-Force?",
    a: "Se certifica bajo <strong>NFPA 1971</strong> en su edición vigente: protección térmica (TPP), resistencia a la llama, barrera de humedad y resistencia a líquidos peligrosos. Se entrega con certificado de laboratorio acreditado ISO/IEC 17025.",
  },
  {
    q: "¿Qué son los cortes V-Fit?",
    a: "Es el patronaje de LION que contornea <strong>codos, rodillas y hombros</strong> siguiendo la articulación, con bi-swing en la zona de hombros. Permite escalar, gatear y alcanzar con menor resistencia del conjunto.",
  },
  {
    q: "¿Qué agrega el paquete RedZone?",
    a: "<strong>RedZone</strong> es el paquete opcional de control de partículas de LION: sella las interfaces del EPP (muñecas, tobillos, cuello) para limitar el ingreso de partículas de combustión. Se especifica al momento de cotizar.",
  },
];

---

<CategoriaLayout
  title="Traje Bombero LION V-Force NFPA 1971 | México"
  description="Traje de bombero estructural LION V-Force certificado NFPA 1971. Máxima flexibilidad y diseño anatómico."
  keywords={[
    "traje bombero LION V-Force",
    "LION V-Force México",
    "traje bombero V-Fit",
    "LION RedZone control de partículas",
    "traje estructural alta flexibilidad",
    "comprar traje LION México",
    "traje bombero certificado NFPA 1971",
    "EPP bombero estructural",
  ]}
  type="product"
  canonical={SLUG}
  image={IMAGES.hero}
  breadcrumb={[
    { label: "Inicio", href: "/" },
    { label: "Trajes", href: "/productos/trajes-para-bomberos/" },
    { label: "LION V-Force" },
  ]}
  heroBadge="Máxima Flexibilidad · LION V-Force"
  heroTitle="LION V-Force®"
  heroTitleHighlight="NFPA 1971"
  heroSubtitle="Diseñado para moverse contigo, no contra ti. El V-Force® utiliza cortes anatómicos y pliegues estratégicos para eliminar el volumen innecesario."
  heroSeoBlocks={[
    {
      title: "LION V-Force: cortes V-Fit bajo NFPA 1971",
      text: "El <strong>LION V-Force</strong> es un traje estructural certificado <strong>NFPA 1971</strong> con cortes <strong>V-Fit</strong> en codos y rodillas y bi-swing en hombros, orientados a eliminar el abultamiento que frena el movimiento. Se configura opcionalmente con el paquete <strong>RedZone</strong> de control de partículas. Cada unidad incluye certificado de laboratorio acreditado ISO/IEC 17025, número de lote trazable y hoja de datos técnicos.",
    },
    {
      title: "Control de partículas y salud del bombero",
      text: "La exposición a partículas de combustión en la interfaz del EPP — muñecas, tobillos, cuello — es un riesgo de salud a largo plazo reconocido en el sector. El paquete <strong>RedZone</strong> sella esas zonas vulnerables como configuración adicional del mismo traje certificado.",
    },
  ]}
  ctaBarQuote="Cotizar Traje LION V-Force"
  productosLabel="LION V-Force"
  productosTitle="Características V-Force"
  productosDesc="Conoce lo que hace a este traje la elección de los bomberos de combate."
  productosContent="<p>Líder en diseño anatómico.</p>"
  productoCards={productoCards}
  productosAltSuffix="LION V-Force"
  specsTitle="Especificaciones Técnicas"
  specsDesc="Máximo rendimiento en la escena."
  specsContent=""
  specsCards={specsCards}
  comparativaTitle="Detalles del Producto"
  comparativaDesc="Resumen técnico."
  comparativaContent=""
  tablaHeaders={tablaHeaders}
  tablaRows={tablaRows}
  relacionadosTitle="Equipo Complementario"
  relacionadosDesc=""
  relacionadosContent=""
  relacionadoCards={relacionadoCards}
  faqs={faqs}
/>
