        <!-- ── CTA mid-catálogo ── -->
        <div class="catalogo__cta-mid">
          <div class="cta-mid__inner">
            <p class="cta-mid__label">¿Encontraste lo que necesitas?</p>
            <h3 class="cta-mid__title">Recibe tu cotización en menos de 24 horas</h3>
            <p class="cta-mid__desc">Sin compromiso. Nuestro equipo técnico te asesora y te envía precios con fichas técnicas NFPA.</p>
