---

import PageLayout from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import CTABanner from "@components/CTABanner.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import FAQ from "@components/FAQ.astro";
import { breadcrumbJsonLd } from "@utils/seo";

// Schema.org: BreadcrumbList + CollectionPage
const productosJsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "https://bombero.mx/" },
    { name: "Productos", url: "https://bombero.mx/productos/" },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Catálogo de Equipo para Bomberos",
    description: "Catálogo completo de equipo certificado NFPA para bomberos en México. 13 categorías, más de 500 productos.",
    url: "https://bombero.mx/productos/",
    mainEntity: {
      "@type": "ItemList",
      name: "Categorías de Equipo para Bomberos",
      numberOfItems: 13,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Trajes para Bomberos", url: "https://bombero.mx/productos/trajes-para-bomberos/" },
        { "@type": "ListItem", position: 2, name: "Cascos para Bomberos", url: "https://bombero.mx/productos/cascos-para-bomberos/" },
        { "@type": "ListItem", position: 3, name: "Guantes para Bomberos", url: "https://bombero.mx/productos/guantes-para-bomberos/" },
        { "@type": "ListItem", position: 4, name: "Botas para Bomberos", url: "https://bombero.mx/productos/botas-para-bomberos/" },
        { "@type": "ListItem", position: 5, name: "SCBA", url: "https://bombero.mx/productos/scba/" },
        { "@type": "ListItem", position: 6, name: "Extintores", url: "https://bombero.mx/productos/extintores/" },
        { "@type": "ListItem", position: 7, name: "Equipo Contra Incendios", url: "https://bombero.mx/productos/equipo-contra-incendios/" },
        { "@type": "ListItem", position: 8, name: "HAZMAT", url: "https://bombero.mx/productos/hazmat/" },
        { "@type": "ListItem", position: 9, name: "Herramientas de Rescate", url: "https://bombero.mx/productos/herramientas-rescate/" },
        { "@type": "ListItem", position: 10, name: "Capuchas para Bomberos", url: "https://bombero.mx/productos/capuchas-para-bomberos/" },
        { "@type": "ListItem", position: 11, name: "Gafas para Bomberos", url: "https://bombero.mx/productos/gafas-para-bomberos/" },
        { "@type": "ListItem", position: 12, name: "Tecnología", url: "https://bombero.mx/productos/tecnologia/" },
        { "@type": "ListItem", position: 13, name: "Equipos Forestales", url: "https://bombero.mx/productos/forestales/" },
      ],
    },
  },
];
---

<PageLayout
  title="Catálogo Equipo Bomberos | 500+ Productos NFPA | BOMBERO.MX"
  description="Catálogo completo de equipo para bomberos en México. Trajes NFPA 1971, cascos, guantes, botas, SCBA, extintores y herramientas de rescate certificados. 13 categorías. Envío a los 32 estados."
  keywords={[
    "equipo para bomberos México",
    "venta equipo bomberos",
    "catálogo EPP bomberos",
    "equipo certificado NFPA México",
    "trajes bombero NFPA 1971",
    "SCBA bomberos México",
    "herramientas rescate bomberos",
    "extintores certificados México",
    "casco bombero certificado",
    "guantes bombero NFPA",
    "equipo proteccion personal bomberos",
  ]}
  type="website"
  canonical="https://bombero.mx/productos/"
  jsonLd={productosJsonLd}
>

  <Breadcrumb items={[{ label: "Productos" }]} />




  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">

        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          Distribuidores Autorizados · Certificaciones NFPA Vigentes
        </div>

        <h1 class="hero__title">
          Equipo para Bomberos
          <span class="hero__title-highlight">Certificado NFPA</span>
          en México
        </h1>

        <p class="hero__subtitle">
          El catálogo más completo de equipo de protección personal y herramientas
          para bomberos en México. Más de 500 productos certificados con asesoría
          técnica especializada y envío a los 32 estados.
        </p>

      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Distribuidor Autorizado de Equipo para Bomberos #1 en México</h2>
          <p class="hero__seo-text">
            En <strong>BOMBERO.MX</strong> somos el distribuidor autorizado líder de
            <strong>equipo de protección personal para bomberos</strong> en toda la República
            Mexicana. Proveemos a cuerpos de bomberos municipales, brigadas industriales,
            aeropuertos, petroquímicas y protección civil con <strong>equipo certificado NFPA</strong>,
            fichas técnicas completas y soporte post-venta permanente.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">13 Categorías de EPP para Cada Tipo de Operación</h2>
          <p class="hero__seo-text">
            Nuestro catálogo abarca las <strong>13 categorías de EPP</strong> que un cuerpo de
            bomberos necesita: desde <strong>trajes estructurales NFPA 1971</strong> y
            <strong>equipos SCBA certificados</strong>, hasta herramientas hidráulicas de rescate,
            cámaras térmicas y sistemas de extinción. Todo disponible en México con
            <strong>entrega express a los 32 estados</strong>.
          </p>
        </div>
      </div>
    </div>
  </section>




  <CTABar />




  <section class="catalogo section" id="epp">
    <div class="container">
      <SectionHeader
        label="Equipo de Protección Personal"
        title="EPP para Bomberos — 6 Categorías"
        description="La primera línea de defensa del bombero. Trajes, cascos, guantes, botas, capuchas y gafas certificados NFPA para cada tipo de operación."
      >
        <p>
          El <strong>equipo de protección personal (EPP) para bomberos</strong> es el sistema
          integrado que protege al elemento de primera respuesta en cada intervención. En
          <strong>BOMBERO.MX</strong> ofrecemos <strong>trajes estructurales NFPA 1971,
          cascos certificados, guantes, botas, capuchas y gafas</strong> fabricados con
          materiales de ingeniería como <strong>Nomex®, PBI Gold®, Kevlar® y Gore-Tex®</strong>.
        </p>
        <p>
          Cada pieza incluye ficha técnica y certificados de laboratorio. Asesoramos sin costo en
          la selección del <strong>sistema EPP completo</strong> para tu estación, brigada o
          proceso de licitación gubernamental.
        </p>
      </SectionHeader>

      <div class="catalogo__grid">

        <CategoryCard
          title="Trajes de Bombero"
          badge="5 productos"
          image="/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif"
          href="/productos/trajes-para-bomberos/"
          buttonText="Ver Trajes"
          description="Trajes estructurales, forestales, ARFF y HAZMAT con certificación NFPA 1971 / 1977. Nomex®, PBI Gold® y materiales Gore-Tex®."
          items={[
            { label: "Traje Estructural NFPA 1971", href: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/" },
            { label: "Traje Forestal NFPA 1977", href: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/" },
            { label: "Traje ARFF Aeroportuario", href: "/productos/trajes-para-bomberos/traje-arff-aeroportuario/" },
            { label: "Traje de Aproximación", href: "/productos/trajes-para-bomberos/traje-aproximacion/" },
            { label: "Traje HAZMAT Nivel A / B", href: "/productos/trajes-para-bomberos/traje-hazmat/" },
          ]}
        />

        <CategoryCard
          title="Cascos para Bomberos"
          badge="6 productos"
          image="/images/cascos-para-bomberos/casco-bombero-profesional-01.avif"
          href="/productos/cascos-para-bomberos/"
          buttonText="Ver Cascos"
          description="Cascos estructurales, forestales, ARFF y rescate técnico. Certificación NFPA 1971 / 1977 / 1951. Termoplástico y material compuesto."
          items={[
            { label: "Casco Estructural NFPA 1971", href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
            { label: "Casco Forestal NFPA 1977", href: "/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/" },
            { label: "Casco de Rescate NFPA 1951", href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
            { label: "Casco HAZMAT Químico", href: "/productos/cascos-para-bomberos/casco-hazmat-quimico/" },
          ]}
        />

        <CategoryCard
          title="SCBA — Respiración Autónoma"
          badge="3 productos"
          image="/images/directorio/equipo-scba-aparato-respiratorio-01.avif"
          href="/productos/scba/"
          buttonText="Ver SCBA"
          description="Aparatos de respiración autónoma certificados NFPA 1981. Cilindros 30 y 45 min, máscaras panorámicas y sistemas de alarma PASS."
          items={[
            { label: "SCBA 30 minutos NFPA 1981", href: "/productos/scba/" },
            { label: "SCBA 45 minutos NFPA 1981", href: "/productos/scba/" },
            { label: "Máscara Panorámica + Cilindro", href: "/productos/scba/" },
          ]}
        />

        <CategoryCard
          title="Guantes para Bomberos"
          badge="4 productos"
          image="/images/guantes-para-bomberos/guante-bombero-producto-par-cuero-kevlar-01.avif"
          href="/productos/guantes-para-bomberos/"
          buttonText="Ver Guantes"
          description="Guantes estructurales Kevlar®, forestales Nomex®, de rescate anticorte y HAZMAT resistentes a químicos. NFPA 1971 / EN 388."
          items={[
            { label: "Guantes Estructurales NFPA 1971", href: "/productos/guantes-para-bomberos/estructurales/" },
            { label: "Guantes de Rescate / Extricación", href: "/productos/guantes-para-bomberos/rescate/" },
            { label: "Guantes HAZMAT", href: "/productos/guantes-para-bomberos/hazmat/" },
            { label: "Guantes Forestales", href: "/productos/guantes-para-bomberos/forestales/" },
          ]}
        />

        <CategoryCard
          title="Botas para Bomberos"
          badge="3 productos"
          image="/images/botas-para-bomberos/bota-bombero-producto-caucho-par-estudio-04.avif"
          href="/productos/botas-para-bomberos/"
          buttonText="Ver Botas"
          description="Botas estructurales de cuero, caucho HAZMAT y forestales con suela Vibram®. Puntera composite, impermeables y resistentes al calor."
          items={[
            { label: "Bota Estructural — Cuero NFPA 1971", href: "/productos/botas-para-bomberos/estructural/" },
            { label: "Bota de Caucho HAZMAT", href: "/productos/botas-para-bomberos/caucho/" },
            { label: "Bota Forestal NFPA 1977", href: "/productos/botas-para-bomberos/forestal/" },
          ]}
        />

        <CategoryCard
          title="Equipo Forestal"
          badge="5 productos"
          image="/images/directorio/camion-forestal-bomberos-01.avif"
          href="/productos/forestales/"
          buttonText="Ver Equipo Forestal"
          description="Equipo certificado NFPA 1977 y CONAFOR para brigadas contra incendios forestales: fustas, mochilas, herramientas y protección completa."
          items={[
            { label: "Traje Forestal NFPA 1977", href: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/" },
            { label: "Casco Forestal NFPA 1977", href: "/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/" },
            { label: "Guantes Forestales Nomex®", href: "/productos/guantes-para-bomberos/forestales/" },
            { label: "Bota Forestal Vibram®", href: "/productos/botas-para-bomberos/forestal/" },
          ]}
        />

        <CategoryCard
          title="Herramientas de Rescate"
          badge="4 productos"
          image="/images/directorio/herramientas-bomberos-rescate-01.avif"
          href="/productos/herramientas-rescate/"
          buttonText="Ver Herramientas"
          description="Herramientas hidráulicas Jaws of Life®, equipos USAR, cizallas de rescate vehicular y sets completos certificados NFPA 1936."
          items={[
            { label: "Cizalla Hidráulica de Rescate", href: "/productos/herramientas-rescate/" },
            { label: "Expansor / Separador USAR", href: "/productos/herramientas-rescate/" },
            { label: "Combo Cizalla + Expansor", href: "/productos/herramientas-rescate/" },
            { label: "Herramientas Manuales Rescate", href: "/productos/herramientas-rescate/" },
          ]}
        />

        <CategoryCard
          title="Tecnología y Detección"
          badge="3 productos"
          image="/images/directorio/detector-multigas-hazmat-01.avif"
          href="/productos/tecnologia/"
          buttonText="Ver Tecnología"
          description="Detectores multigas, drones de reconocimiento, cámaras termográficas, TIC y sistemas de comunicación para operaciones tácticas."
          items={[
            { label: "Cámara Termográfica TIC", href: "/productos/tecnologia/" },
            { label: "Detector de Gas Multigas", href: "/productos/tecnologia/" },
            { label: "Dron de Reconocimiento", href: "/productos/tecnologia/" },
          ]}
        />

        <CategoryCard
          title="Capuchas y Monjas"
          badge="3 productos"
          image="/images/capucha-para-bombero/capucha-bombero-producto-pbi-gold-estudio-frontal-01.avif"
          href="/productos/capuchas-para-bomberos/"
          buttonText="Ver Capuchas"
          description="Capuchas Nomex®, PBI Gold® y con protección particulada certificadas NFPA 1971. Protección del cuello y zona facial al 360°."
          items={[
            { label: "Capucha Nomex®", href: "/productos/capuchas-para-bomberos/nomex/" },
            { label: "Capucha PBI Gold®", href: "/productos/capuchas-para-bomberos/pbi/" },
            { label: "Capucha Protección Particulada", href: "/productos/capuchas-para-bomberos/particulada/" },
          ]}
        />

        <CategoryCard
          title="Gafas y Protección Visual"
          badge="2 productos"
          image="/images/gafas-para-bomberos/gafas-bombero-producto-goggle-lente-espejo-premium-01.avif"
          href="/productos/gafas-para-bomberos/"
          buttonText="Ver Gafas"
          description="Goggles de bombero antipolvo, antiesquirlas y antiimpacto. Compatibles con SCBA y cascos NFPA. Lentes espejo y policarbonato ANSI Z87.1."
          items={[
            { label: "Goggle de Bombero Premium", href: "/productos/gafas-para-bomberos/goggle/" },
            { label: "Gafas de Seguridad Antiimpacto", href: "/productos/gafas-para-bomberos/seguridad/" },
          ]}
        />

        <CategoryCard
          title="Extintores"
          badge="4 productos"
          image="/images/directorio/extintor-polvo-quimico-01.avif"
          href="/productos/extintores/"
          buttonText="Ver Extintores"
          description="Extintores certificados NOM-100 en todas las clases: PQS, CO₂, espuma AFFF y halotron. Para industria, vehículos y uso doméstico."
          items={[
            { label: "Extintor PQS — Polvo Químico Seco", href: "/productos/extintores/" },
            { label: "Extintor CO₂ — Dióxido de Carbono", href: "/productos/extintores/" },
            { label: "Extintor Espuma AFFF", href: "/productos/extintores/" },
            { label: "Extintor Halotron — Limpio", href: "/productos/extintores/" },
          ]}
        />

        <CategoryCard
          title="HAZMAT y CBRN"
          badge="3 productos"
          image="/images/directorio/equipo-hazmat-materiales-peligrosos-01.avif"
          href="/productos/hazmat/"
          buttonText="Ver HAZMAT"
          description="Trajes Nivel A y B, equipos de descontaminación y protección CBRN para respuesta a materiales peligrosos y emergencias químicas."
          items={[
            { label: "Traje HAZMAT Nivel A Encapsulado", href: "/productos/trajes-para-bomberos/traje-hazmat/nivel-a/" },
            { label: "Traje HAZMAT Nivel B", href: "/productos/trajes-para-bomberos/traje-hazmat/nivel-b/" },
            { label: "Kit Descontaminación Rápida", href: "/productos/hazmat/" },
          ]}
        />

        <CategoryCard
          title="Equipo Contra Incendios"
          badge="4 productos"
          image="/images/directorio/autobomba-panel-bombeo-conexiones-manguera-01.avif"
          href="/productos/equipo-contra-incendios/"
          buttonText="Ver Equipo ECI"
          description="Mangueras contra incendio, lanzas de ataque, gabinetes y accesorios para sistemas fijos y vehículos autobomba. Certificados NOM y NFPA."
          items={[
            { label: "Manguera contra Incendio NFPA", href: "/productos/equipo-contra-incendios/" },
            { label: "Lanza de Ataque Ajustable", href: "/productos/equipo-contra-incendios/" },
            { label: "Gabinete contra Incendio NOM", href: "/productos/equipo-contra-incendios/" },
            { label: "Hidrante y Accesorios", href: "/productos/equipo-contra-incendios/" },
          ]}
        />

      </div>
    </div>
  </section>




  <WhyChooseUs images={[
    "/images/directorio/bombero-equipo-completo-guardia-01.avif",
    "/images/directorio/casco-bombero-bullard-amarillo-visor-01.avif",
    "/images/directorio/brigada-bomberos-capacitacion-01.avif",
    "/images/directorio/lockers-rojos-estacion-bomberos-01.avif",
    "/images/directorio/camion-bomberos-moderno-01.avif",
    "/images/directorio/centro-mando-bomberos-01.avif",
  ]} />




  <FAQ />




  <CTABanner />

</PageLayout>

<style>

  .hero {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--color-smoke-950);
    overflow: hidden;
    padding: var(--space-16) 0;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(220, 38, 38, 0.15), transparent),
      radial-gradient(ellipse 60% 50% at 0% 50%, rgba(249, 115, 22, 0.1), transparent),
      radial-gradient(ellipse 60% 50% at 100% 80%, rgba(220, 38, 38, 0.08), transparent);
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .hero__glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.4;
  }
  .hero__glow--1 { top: -200px; right: -100px; background: var(--color-ember-600); }
  .hero__glow--2 { bottom: -200px; left: -100px; background: var(--color-fire-600); }

  .hero__container {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    padding-block: var(--space-8);
  }

  .hero__content {
    color: var(--color-text-on-dark);
  }


  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: rgba(220, 38, 38, 0.15);
    border: 1px solid rgba(220, 38, 38, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-fire-400);
    margin-bottom: var(--space-6);
  }

  .hero__badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-ember-500);
    border-radius: 50%;
  }
  .hero__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-6);
    letter-spacing: var(--tracking-tight);
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .hero__title-highlight {
    background: var(--gradient-fire);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
  }

  .hero__subtitle {
    font-size: var(--text-xl);
    color: var(--color-smoke-300);
    line-height: var(--leading-relaxed);
    max-width: 540px;
    margin-bottom: var(--space-8);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .hero__stat { display: flex; flex-direction: column; gap: 2px; }
  .hero__stat-number { font-size: var(--text-2xl); font-weight: 800; color: white; line-height: 1; }
  .hero__stat-label { font-size: var(--text-xs); color: var(--color-smoke-400); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
  .hero__stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.1); }

  .hero__seo {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .hero__seo-block {
    padding: var(--space-4) 0;
  }

  .hero__seo-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-fire-400);
    margin-bottom: var(--space-4);
    line-height: var(--leading-tight);
  }

  .hero__seo-text {
    font-size: var(--text-base);
    color: var(--color-smoke-300);
    line-height: var(--leading-relaxed);
  }

  .hero__seo-text strong {
    color: #ffffff;
    font-weight: 600;
  }


  :global(.section-header__right p) {
    font-size: var(--text-base);
    color: var(--color-smoke-700);
    line-height: 1.8;
    margin: 0;
  }

  :global(.section-header__right strong) {
    color: var(--color-smoke-900);
    font-weight: 700;
  }




  .catalogo {
    background: var(--color-smoke-50);
  }

  .catalogo--alt {
    background: #ffffff;
  }

  .catalogo__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
