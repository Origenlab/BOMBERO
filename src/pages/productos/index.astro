---

import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import CTABanner from "@components/CTABanner.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import FAQQuote from "@components/FAQQuote.astro";
import HeroSection from "@components/HeroSection.astro";
import QuickNav from "@components/QuickNav.astro";

// Schema.org: CollectionPage (el BreadcrumbList lo emite el componente
// <Breadcrumb>; el inline duplicado se eliminó 2026-07-10)
const productosJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Catálogo de Equipo para Bomberos",
    description: "Catálogo completo de equipo certificado NFPA para bomberos en México. 16 categorías, más de 500 productos.",
    url: "https://bombero.mx/productos/",
    mainEntity: {
      "@type": "ItemList",
      name: "Categorías de Equipo para Bomberos",
      numberOfItems: 16,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Trajes para Bomberos", url: "https://bombero.mx/productos/trajes-para-bomberos/" },
        { "@type": "ListItem", position: 2, name: "Cascos para Bomberos", url: "https://bombero.mx/productos/cascos-para-bomberos/" },
        { "@type": "ListItem", position: 3, name: "Guantes para Bomberos", url: "https://bombero.mx/productos/guantes-para-bomberos/" },
        { "@type": "ListItem", position: 4, name: "Botas para Bomberos", url: "https://bombero.mx/productos/botas-para-bomberos/" },
        { "@type": "ListItem", position: 5, name: "SCBA", url: "https://bombero.mx/productos/scba/" },
        { "@type": "ListItem", position: 6, name: "Extintores", url: "https://bombero.mx/productos/extintores/" },
        { "@type": "ListItem", position: 7, name: "Equipo Contra Incendios", url: "https://bombero.mx/productos/equipo-contra-incendios/" },
        { "@type": "ListItem", position: 8, name: "HAZMAT", url: "https://bombero.mx/productos/hazmat/" },
        { "@type": "ListItem", position: 9, name: "Herramientas de Rescate", url: "https://bombero.mx/productos/herramientas-rescate/" },
        { "@type": "ListItem", position: 10, name: "Capuchas para Bomberos", url: "https://bombero.mx/productos/capuchas-para-bomberos/" },
        { "@type": "ListItem", position: 11, name: "Gafas para Bomberos", url: "https://bombero.mx/productos/gafas-para-bomberos/" },
        { "@type": "ListItem", position: 12, name: "Tecnología", url: "https://bombero.mx/productos/tecnologia/" },
        { "@type": "ListItem", position: 13, name: "Equipos Forestales", url: "https://bombero.mx/productos/forestales/" },
        { "@type": "ListItem", position: 14, name: "Rescate Vertical", url: "https://bombero.mx/productos/rescate-vertical/" },
        { "@type": "ListItem", position: 15, name: "Rescate Acuático", url: "https://bombero.mx/productos/rescate-acuatico/" },
        { "@type": "ListItem", position: 16, name: "Equipo Médico EMS", url: "https://bombero.mx/productos/equipo-medico/" },
      ],
    },
  },
];
---

<PageLayout
  quickNav={false}
  brand={false}
  title="Equipo para Bomberos | Catálogo EPP NFPA | Venta en México"
  description="Equipo para bomberos certificado NFPA en México. Catálogo EPP: trajes, SCBA, cascos, guantes y herramientas de rescate. Venta con envío a los 32 estados."
  keywords={[
    "equipo para bomberos México",
    "venta equipo bomberos",
    "catálogo EPP bomberos",
    "equipo certificado NFPA México",
    "trajes bombero NFPA 1971",
    "SCBA bomberos México",
    "herramientas rescate bomberos",
    "extintores certificados México",
    "casco bombero certificado",
    "guantes bombero NFPA",
    "equipo proteccion personal bomberos",
  ]}
  type="website"
  canonical="https://bombero.mx/productos/"
  jsonLd={productosJsonLd}
>

  <Breadcrumb items={[{ label: "Productos" }]} />




  <HeroSection
    badge="Distribuidores Autorizados · Certificaciones NFPA Vigentes"
    title={`Catálogo de Equipos para <span class="hero__title-highlight">Bomberos</span> en México`}
    subtitle="16 categorías, más de 500 referencias en inventario. Cada producto incluye certificado de laboratorio acreditado y ficha técnica lista para procesos de licitación."
    blocks={[
      { title: "Distribución directa de fabricantes — sin intermediarios ni mercado gris", text: "Distribución directa de MSA Safety, Honeywell, Globe Manufacturing, Bullard y Holmatro — los mismos fabricantes que certifican ante NFPA. Cada producto de este catálogo llega con certificado de laboratorio acreditado (UL, Intertek o SEI) por número de lote, no solo con una declaración del fabricante. Esa diferencia es la que importa cuando el equipo llega a campo." },
      { title: "Una fuente para cada tipo de operación — estructural, forestal, ARFF y HAZMAT", text: "Nuestro catálogo cubre las 16 categorías de EPP y herramientas que necesita un cuerpo de bomberos: desde <strong>trajes estructurales NFPA 1971</strong> y <strong>SCBA certificado</strong>, hasta herramientas hidráulicas de rescate vehicular, cámaras termográficas y sistemas de extinción. Todo disponible en México con entrega a los 32 estados." }
    ]}
  />

  <QuickNav pool="productos" count={7} />





  <CTABar />




  <section class="catalogo section" id="epp">
    <div class="container">
      <SectionHeader
        label="Equipo de Protección Personal"
        title="Equipo de Protección Personal — 6 Categorías Certificadas"
        description="La primera línea de defensa del bombero. Trajes, cascos, guantes, botas, capuchas y gafas certificados NFPA para cada tipo de operación."
      >
        <p>
          El EPP es el sistema integrado que pone una barrera entre el elemento de primera respuesta
          y el agente de riesgo — calor, llama, productos químicos o impactos mecánicos. Cada
          componente de esta sección cumple la norma que le corresponde: <strong>NFPA 1971</strong>
          para trajes y cascos estructurales, <strong>NFPA 1977</strong> para equipo forestal y
          <strong>NFPA 1981</strong> para SCBA. Los materiales — Nomex®, PBI Gold®, Kevlar® y
          Gore-Tex® — están especificados por norma, no elegidos comercialmente.
        </p>
        <p>
          Cada pieza incluye ficha técnica y certificado de laboratorio acreditado. Si tienes un
          proceso de licitación en marcha, redactamos las especificaciones técnicas por partida
          sin costo — incluyendo la edición de norma vigente que previene el ingreso de equipo
          no certificado.
        </p>
      </SectionHeader>

      <div class="catalogo__grid">

        <CategoryCard
          title="Trajes de Bombero"
          badge="5 productos"
          image="/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif"
          href="/productos/trajes-para-bomberos/"
          buttonText="Ver Trajes"
          description="Trajes estructurales, forestales, ARFF y HAZMAT con certificación NFPA 1971 / 1977. Nomex®, PBI Gold® y materiales Gore-Tex®."
