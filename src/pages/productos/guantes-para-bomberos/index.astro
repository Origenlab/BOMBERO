---

import PageLayout from "@layouts/PageLayout.astro";
import QuickNav from "@components/QuickNav.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQ from "@components/FAQ.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

const productos = [
  {
    id: "estructurales",
    nombre: "Guantes Estructurales NFPA 1971",
    slug: "/productos/guantes-para-bomberos/estructurales/",
    badge: "NFPA 1971",
    badgeColor: "ember",
    imagen: "/images/guantes-para-bomberos/guante-bombero-estructural-nfpa-1971-01.avif",
    descripcion:
      "Sistema de 3 capas certificado NFPA 1971 para combate de incendios estructurales. Capa exterior de cuero de vaqueta ≥ 2.2 mm o Kevlar® tejido, barrera de vapor Gore-Tex®/equivalente NFPA y forro térmico Nomex®/PBI® con puño extendido ≥ 4 pulgadas sobre la muñeca.",
    caracteristicas: [
      "Capa exterior: cuero vaqueta ≥ 2.2 mm o Kevlar® certificado",
      "Barrera de vapor Gore-Tex® o equivalente NFPA aprobado",
      "Forro térmico Nomex® IIIA o PBI Gold® según modelo",
      "Puño extendido ≥ 4 pulgadas — solapa con manga del traje",
      "Certificado NFPA 1971 con pruebas TPP, SHTM y resistencia a la llama",
    ],
    aplicacion: "Incendio estructural · Rescate urbano · Colapso de estructuras · Flash-over",
  },
  {
    id: "rescate",
    nombre: "Guantes de Rescate y Extricación NFPA 1951",
    slug: "/productos/guantes-para-bomberos/rescate/",
    badge: "NFPA 1951",
    badgeColor: "fire",
    imagen: "/images/guantes-para-bomberos/guante-bombero-estacion-colocacion-cuero-02.avif",
    descripcion:
      "Perfil ultrafino para máxima destreza táctil en rescate vehicular, extricación y espacios confinados. Protección anticorte nivel 4 (EN 388) en palma y dedos, antiperforación para vidrio y metal laminado. Refuerzos dobles en zonas de alta abrasión.",
    caracteristicas: [
      "Construcción delgada para sensibilidad táctil y manejo de herramienta hidráulica",
      "Protección anticorte nivel 4 (EN 388) en palma y zona de dedos",
      "Antiperforación certificada para vidrio laminado y metal cortante",
      "Refuerzos dobles en yema de índice, pulgar y zona de la palma",
      "Certificado NFPA 1951 / EN 388 · Compatible con guantes de interior",
    ],
    aplicacion: "Rescate vehicular · Extricación · Espacios confinados · USAR · Derrumbes",
  },
  {
    id: "hazmat",
    nombre: "Guantes HAZMAT para Materiales Peligrosos",
    slug: "/productos/guantes-para-bomberos/hazmat/",
    badge: "NFPA 1991",
    badgeColor: "smoke",
    imagen: "/images/guantes-para-bomberos/guante-bombero-producto-estructural-nomex-04.avif",
    descripcion:
      "Encapsulamiento total de manos para operaciones con materiales peligrosos. Disponibles en butilo (hidrocarburos y cetonas), neopreno (ácidos y bases) y Viton® (agentes agresivos CBRN). Largo extendido para sello hermético con manga del traje HAZMAT Nivel A y B.",
    caracteristicas: [
      "Butilo para hidrocarburos, cetonas y alcoholes — el más versátil",
      "Neopreno para ácidos fuertes, bases y solventes polares",
      "Viton® para agentes CBRN, tolueno y productos más agresivos",
      "Largo extendido ≥ 30 cm para solapado hermético con traje Nivel A",
      "Certificado NFPA 1991 / EN 374 — resistencia a +200 agentes químicos",
    ],
    aplicacion: "HAZMAT Nivel A/B · Derrame químico · CBRN · Agentes tóxicos industriales",
  },
  {
    id: "forestales",
    nombre: "Guantes Forestales NFPA 1977",
    slug: "/productos/guantes-para-bomberos/forestales/",
    badge: "NFPA 1977",
    badgeColor: "fire",
    imagen: "/images/guantes-para-bomberos/guante-bombero-producto-par-cuero-kevlar-04.avif",
    descripcion:
      "Ligeros y transpirables para jornadas prolongadas en campo abierto. Dorso de Nomex® ultraligero con resistencia inherente a la llama, palma de cuero de vaqueta para agarre y resistencia a la abrasión. Sin costuras interiores para máxima comodidad en uso continuo.",
    caracteristicas: [
      "Dorso de tejido Nomex® ultraligero — resistencia inherente sin tratamiento",
      "Palma de cuero de vaqueta para agarre firme y resistencia a abrasión",
      "Alta transpirabilidad para jornadas de operación prolongada en campo",
      "Sin costuras internas que generen puntos de presión",
      "Certificado NFPA 1977 — compatible con traje forestal y equipo de mochila",
    ],
    aplicacion: "Incendio forestal · Quemas controladas · Interface urbano-rural · Brigadas",
  },
] as const;


const CANONICAL = "/productos/guantes-para-bomberos/";
const productSchema = productSchemaComplete({
  name: "Guantes para Bomberos NFPA",
  description: "Guantes de bombero certificados NFPA 1971, 1951, 1991 y 1977. Guantes Estructurales cuero/Kevlar, Rescate y Extricación, HAZMAT butilo/neopreno y Forestales Nomex. Envío a los 32 estados de México.",
  image: productos[0].imagen ?? "/images/directorio/estacion-bomberos-mexico-01.avif",
  url: CANONICAL,
  category: "Guantes de Bombero",
  features: ["NFPA 1971", "NFPA 1977", "NFPA 1951", "NFPA 1991", "Kevlar", "Gore-Tex"],
  certifications: ["NFPA 1971", "NFPA 1977", "NFPA 1951", "NFPA 1991", "EN 388", "EN 374"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Guantes para Bomberos", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema];

const guantesFaqs = [
  {
    question: "¿Qué diferencia hay entre guantes estructurales NFPA 1971 y guantes de rescate NFPA 1951?",
    answer: "Los guantes estructurales NFPA 1971 priorizan la protección térmica máxima: capas de Nomex o Kevlar con forro aislante, impermeabilidad ante líquidos comunes y resistencia a la llama directa — sacrifican algo de destreza para dar máxima protección en combate de incendio. Los guantes de rescate técnico NFPA 1951 priorizan la destreza y resistencia a cortes: materiales como Kevlar, cuero técnico o materiales compuestos en zonas de alto riesgo, puntas de dedos reforzadas para manipular herramientas, mejores propiedades de agarre — protección térmica menor. Para un bombero estructural los NFPA 1971 son obligatorios en combate activo; los NFPA 1951 son complementarios para overhaul, rescate técnico vehicular y operaciones de búsqueda donde se necesita manipular objetos pequeños.",
  },
  {
    question: "¿Cuánto duran los guantes de bombero y cuándo hay que cambiarlos?",
    answer: "Los guantes de bombero no tienen vida útil fija por norma como los trajes (10 años), pero la NFPA 1851 exige inspección visual antes y después de cada uso. Retiro obligatorio inmediato por: grietas o desgarros en cualquier zona, pérdida de la impermeabilidad (si el interior se moja durante la operación), decoloración por exposición química, costuras sueltas en zonas de palma o dedos, y rigidez severa que impida el cierre completo de la mano. En condiciones de uso intenso (2–3 servicios semanales con exposición a llama), los guantes de calidad media duran 12–18 meses; los de calidad premium (Globe, Honeywell, MSA) pueden llegar a 3 años con mantenimiento correcto.",
  },
  {
    question: "¿Kevlar o Nomex? ¿Qué material es mejor en guantes para bomberos?",
    answer: "Kevlar® (p-aramida) tiene mayor resistencia a cortes y abrasión que el Nomex — clave cuando se manipulan cristales rotos, metal cortado o escombros durante extricación. Nomex® tiene mayor resistencia a la llama directa y mejor comportamiento térmico — no se derrite, no gotea. La solución que usan los mejores fabricantes es combinar ambos: dorso y palma en Kevlar para resistencia mecánica, forro interior en Nomex para protección térmica, con capa intermedia de membrana impermeable. Al especificar guantes para licitación, pide siempre que sean de \"Nomex y Kevlar certificados NFPA 1971\" — no solo \"material ignífugo\" que puede ser cualquier tejido tratado químicamente.",
  },
  {
    question: "¿Los guantes de bombero son impermeables?",
    answer: "Los guantes estructurales NFPA 1971 deben superar una prueba de resistencia a la penetración de líquidos — están diseñados para resistir agua y los \"líquidos comunes\" definidos por la norma (ácido de batería, espuma AFFF, gasolina, fluido hidráulico, anticongelante). Sin embargo, \"resistencia a la penetración\" no significa sumersión indefinida: en incendios con grandes cantidades de agua aplicada o en rescate acuático, el interior puede llegar a mojarse después de varios minutos de exposición. Para operaciones acuáticas, se usan guantes específicos de neopreno. La NFPA 1971 no cubre guantes para HAZMAT — para exposición química severa se usan guantes específicos de nivel A o B.",
  },
  {
    question: "¿Puedo usar los mismos guantes para incendio estructural y para HAZMAT?",
    answer: "No. Son protecciones diseñadas para riesgos incompatibles. Los guantes NFPA 1971 protegen contra calor, llama y abrasión pero NO están fabricados con materiales impermeables a agentes químicos específicos (ácidos concentrados, solventes, gases). Los guantes HAZMAT nivel A o B son de materiales como butilo, neopreno multicapa o laminados específicos resistentes al agente concreto — pero NO tienen protección térmica para llama directa. Un bombero respondiendo a un incidente HAZMAT con riesgo de ignición necesita guantes HAZMAT sobre guantes estructurales (doble capa) o guantes de especificación NFPA 1991 para trajes encapsulados — consulta con tu asesor de riesgo el protocolo correcto.",
  },
  {
    question: "¿Qué tallas hay disponibles y cómo se miden correctamente?",
    answer: "Los guantes NFPA 1971 de calidad profesional vienen en tallas S, M, L, XL y XXL basadas en la circunferencia de la palma (en cm o en pulgadas). La medición correcta: con cinta métrica, mide la circunferencia de la palma por el punto más ancho (excluyendo el pulgar), con la mano relajada. Un guante demasiado grande produce dobleces en los dedos que reducen la destreza; demasiado pequeño restringe la movilidad del puño y dificulta el sellado con la manga del traje. Para licitaciones institucionales, es imprescindible medir a cada bombero y especificar la distribución por talla — no pedir \"tallas promedio\", ya que en México hay gran variabilidad de talla entre el personal operativo.",
  },
  {
    question: "¿Cuánto cuestan los guantes de bombero NFPA 1971 en México?",
    answer: "Guantes estructurales NFPA 1971 básicos: $800–$1,500 MXN el par. Guantes de calidad media (Nomex+Kevlar, membrana impermeable): $1,500–$3,000 MXN. Guantes premium (Globe, Honeywell, MSA) con mayor destreza y durabilidad: $3,000–$5,500 MXN. Los guantes de rescate técnico NFPA 1951 cuestan similar: $1,200–$4,000 MXN según especificación. Los guantes HAZMAT (butilo o neopreno multicapa) tienen precios que van desde $500 hasta $4,000 MXN dependiendo del nivel de protección química. Solicita cotización por lote — a partir de 10 pares hay precios escalonados.",
  },
  {
    question: "¿Cómo se limpian correctamente los guantes después de un servicio?",
    answer: "La NFPA 1851 requiere limpieza rutinaria después de cada servicio con exposición al humo (contaminación por carcinógenos). Limpieza manual con agua tibia y cepillo suave con jabón neutro, especialmente en el interior. NO usar lavadora — el movimiento mecánico daña el forro interior y las costuras críticas. NO usar cloro ni solventes — destruyen las propiedades ignífugas. Después del lavado, dejar secar al aire en lugar ventilado alejado de luz solar directa — el calor directo degrada las fibras Nomex y Kevlar. Si los guantes estuvieron expuestos a agentes químicos desconocidos o a contaminantes potencialmente tóxicos, deben procesarse por un ISP certificado NFPA antes de reintegrarse al servicio.",
  },
];

---

<PageLayout
  quickNav={false}
  title="Guantes para Bomberos NFPA | Estructurales · Rescate · HAZMAT · Forestales — BOMBERO.MX"
  description="Guantes de bombero certificados NFPA 1971, 1951, 1991 y 1977. Guantes Estructurales cuero/Kevlar con Gore-Tex®, Rescate y Extricación anticorte nivel 4, HAZMAT butilo/neopreno/Viton® y Forestales Nomex®. Envío a los 32 estados de México."
  canonical={CANONICAL}
  jsonLd={jsonLdSchemas}
  keywords={[
    "guantes para bomberos",
    "guantes estructurales NFPA 1971",
    "guantes rescate extricación NFPA 1951",
    "guantes HAZMAT bombero NFPA 1991",
    "guantes forestales NFPA 1977",
    "guantes bombero Kevlar Gore-Tex",
    "guantes bombero certificados México",
    "guantes Nomex bombero",
    "protección manos bombero EPP",
    "guantes bombero Dragon Fire MSA",
    "comprar guantes bombero México",
    "guantes bombero licitación pública",
  ]}
  type="website"
>

  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
    { label: "Guantes para Bombero" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          4 Tipos de Guante · NFPA 1971 · 1951 · 1991 · 1977
        </div>
        <h1 class="hero__title">
          Guantes para
          <span class="hero__title-highlight">Bomberos</span>
          Certificados NFPA
        </h1>
        <p class="hero__subtitle">
          Guantes estructurales <strong>NFPA 1971</strong> cuero/Kevlar + Gore-Tex®, rescate/extricación <strong>NFPA 1951</strong>, HAZMAT butilo/neopreno y forestales <strong>NFPA 1977</strong>. Con ficha técnica y certificado de laboratorio · Envío a 32 estados.
        </p>
        <div class="hero__actions">
          <a href="#catalogo" class="hero__btn hero__btn--primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1" ry="1"/></svg>
            Ver catálogo
          </a>
          <a href="/cotizar/" class="hero__btn hero__btn--secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Cotizar ahora
          </a>
        </div>
      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Guantes NFPA 1971 y 1951 — Dragon Fire, Honeywell y MSA en México</h2>
          <p class="hero__seo-text">
            Distribuimos guantes estructurales <strong>NFPA 1971</strong> con dorso <strong>Kevlar® o cuero vaqueta ≥ 2.2 mm</strong>, barrera <strong>Gore-Tex® Crosstech®</strong> y forro <strong>PBI Gold® o Nomex®</strong>. También guantes de rescate <strong>NFPA 1951</strong> anticorte nivel 4, guantes <strong>HAZMAT NFPA 1991</strong> en butilo, neopreno y Viton®, y guantes forestales <strong>NFPA 1977</strong>. Cada modelo incluye certificado de laboratorio acreditado y ficha técnica para <strong>licitaciones en los 32 estados de México</strong>.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">El guante correcto por operación — la destreza táctil también salva vidas</h2>
          <p class="hero__seo-text">
            Un <strong>guante estructural NFPA 1971</strong> no puede reemplazar al guante de rescate en extricación vehicular, ni viceversa. El puño extendido ≥ 4 pulgadas debe solapar con la manga del <a href="/productos/trajes-para-bomberos/" class="hero__link">traje estructural NFPA 1971</a> para mantener la continuidad del EPP. En BOMBERO.MX especificamos el guante correcto para cada tipo de operación y entregamos el <strong>sistema EPP completo</strong> con <a href="/productos/cascos-para-bomberos/" class="hero__link">casco certificado</a>, <a href="/productos/capuchas-para-bomberos/" class="hero__link">capucha NFPA</a> y <a href="/productos/botas-para-bomberos/" class="hero__link">botas certificadas</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav pool="categoria" count={7} />
  <CTABar quote="Cotizar Guantes de Bombero" />

  <!-- ═══════════════════════════════════════════════════════ LAYOUT SIDEBAR -->
  <div class="page-layout">
    <div class="page-layout__inner">

      <!-- ─── MAIN CONTENT ─── -->
      <div class="page-main">

        <!-- Catálogo -->
        <section class="content-panel" id="catalogo">
          <SectionHeader
            label="Catálogo de Guantes para Bomberos"
            title="4 Tipos de Guantes de Bombero"
            description="El guante correcto depende del entorno operativo. Cada tipo está certificado para una función específica — ninguno puede sustituir al otro."
          >
            <p>
              Los <strong>guantes de bombero</strong> son el componente del EPP con mayor contacto directo con el peligro: manipulan herramienta hidráulica, líneas de manguera a presión, estructuras colapsadas, víctimas y agentes químicos. Seleccionar el guante correcto según la operación es crítico para la <strong>destreza táctil, protección térmica y supervivencia</strong>. En BOMBERO.MX distribuimos exclusivamente guantes que superan los requisitos vigentes de la norma NFPA aplicable a cada tipo de uso.
            </p>
            <p>
              Todos nuestros guantes incluyen fichas técnicas y certificados de laboratorio acreditado NVLAP. Son normativa y físicamente compatibles con el resto del catálogo: <a href="/productos/trajes-para-bomberos/">trajes Nomex® y PBI®</a>, <a href="/productos/cascos-para-bomberos/">cascos estructurales o forestales</a>, <a href="/productos/capuchas-para-bomberos/">capuchas de protección</a> y <a href="/productos/botas-para-bomberos/">botas certificadas NFPA</a>. El puño extendido del guante estructural está diseñado específicamente para solapar con la manga del traje y eliminar zonas desprotegidas.
            </p>
          </SectionHeader>

          <div class="productos__grid">
            {productos.map((producto) => (
              <ProductCard {...producto} altSuffix="Guante de bombero certificado NFPA" />
            ))}
          </div>
        </section>

        <!-- Tecnología / Specs (dark panel) -->
        <section class="content-panel content-panel--dark" id="tecnologia">
          <SectionHeader
            label="Tecnología y Materiales"
            title="Materiales, Certificaciones y Construcción"
            description="Los guantes de bombero de alto rendimiento combinan materiales de resistencia inherente, barreras de humedad certificadas y construcciones multicapa especializadas para cada tipo de riesgo operativo."
          >
            <p>
              Los <strong>guantes estructurales NFPA 1971</strong> funcionan como un sistema de tres capas donde cada una cumple una función específica: la capa exterior de cuero vaqueta ≥ 2.2 mm o <strong>Kevlar®</strong> tejido resiste la abrasión y la llama directa; la barrera de vapor <strong>Gore-Tex® Crosstech®</strong> previene la penetración de líquidos calientes; y el forro <strong>PBI Gold® o Nomex® IIIA</strong> absorbe el calor residual. Para protección integral, estos guantes deben usarse con <a href="/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/" class="dark-link">traje estructural NFPA 1971</a> y <a href="/productos/capuchas-para-bomberos/nomex/" class="dark-link">capucha Nomex® certificada</a>, solapando el puño ≥ 4 pulgadas con la manga del traje.
            </p>
            <p>
              Los <strong>guantes de rescate NFPA 1951</strong> usan Kevlar® reforzado con capas de gel antiimpacto y cuero laminado de alta resistencia al corte. Los <strong>guantes HAZMAT</strong> se fabrican en polímeros vulcanizados seleccionados según el agente químico específico — butilo para la mayoría de incidentes industriales, neopreno para ácidos y bases, Viton® para agentes CBRN. Todo el catálogo incluye fichas técnicas para <strong>licitaciones públicas</strong> en los <strong>32 estados de México</strong>.
            </p>
          </SectionHeader>
          <div class="specs__grid">
            <CategoryCard
              title="Materiales y Construcción"
              icon="shield"
              image="/images/guantes-para-bomberos/guante-bombero-producto-par-cuero-kevlar-01.avif"
              description="Cuero de vaqueta curtida al cromo (≥ 2.2 mm) y Kevlar® tejido para estructurales. Nomex® ultraligero para dorso forestal. Butilo, neopreno y Viton® para HAZMAT según agente químico. Gore-Tex® Crosstech® como barrera de vapor en guantes estructurales certificados."
            />
            <CategoryCard
              title="Certificaciones Internacionales"
              icon="certificate"
              image="/images/guantes-para-bomberos/guante-bombero-producto-par-cuero-kevlar-02.avif"
              description="NFPA 1971 para guantes estructurales con pruebas TPP, SHTM y resistencia a llama. NFPA 1977 para forestales. NFPA 1951 para rescate con anticorte EN 388. NFPA 1991/EN 374 para HAZMAT con pruebas de permeación química. Certificados de laboratorio acreditado NVLAP incluidos."
            />
            <CategoryCard
              title="Operaciones y Usuarios"
              icon="users"
              image="/images/guantes-para-bomberos/guante-bombero-combate-incendio-manguera-01.avif"
              description="Cuerpos de bomberos municipales y estatales, brigadas industriales y petroquímicas, equipos USAR de búsqueda y rescate técnico, equipos HAZMAT y CBRN, bomberos forestales y aeroportuarios ARFF en toda la República Mexicana."
            />
          </div>
        </section>

        <!-- Tabla Comparativa -->
        <section class="content-panel" id="comparativa">
          <SectionHeader
            label="Tabla Comparativa"
            title="¿Qué Guante de Bombero Necesitas?"
            description="Los 4 tipos de guante tienen funciones incompatibles entre sí. Compara norma, protección, destreza táctil y material para seleccionar el equipo correcto."
          >
            <p>
              La compatibilidad normativa del guante con el resto del EPP no es opcional: el <strong>guante estructural NFPA 1971</strong> se usa con <a href="/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/">traje estructural</a>, <a href="/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/">casco NFPA 1971</a>, <a href="/productos/capuchas-para-bomberos/nomex/">capucha Nomex®</a> y <a href="/productos/botas-para-bomberos/estructural/">botas de cuero certificadas</a>. El <strong>guante forestal NFPA 1977</strong> con <a href="/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/">traje forestal</a> y <a href="/productos/botas-para-bomberos/forestal/">botas forestales</a>. El <strong>guante HAZMAT NFPA 1991</strong> con <a href="/productos/trajes-para-bomberos/traje-hazmat/">traje encapsulado</a> y <a href="/productos/botas-para-bomberos/caucho/">botas de caucho químico</a>.
            </p>
            <p>
              En <strong>BOMBERO.MX</strong> elaboramos las especificaciones técnicas de <strong>sistemas EPP completos</strong> — guante, traje, capucha, casco y botas — para <strong>licitaciones públicas</strong> en toda la República Mexicana, sin costo para la institución.
            </p>
          </SectionHeader>
          <div class="comparativa__wrapper">
            <table class="comparativa__table">
              <thead>
                <tr>
                  <th>Guante</th>
                  <th>Norma</th>
