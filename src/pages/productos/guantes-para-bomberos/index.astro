  .hero__btn--primary:hover { background: var(--color-ember-500); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(220, 38, 38, 0.5); }
  .hero__btn--secondary { background: rgba(255,255,255,0.08); color: white; border: 1px solid rgba(255,255,255,0.15); backdrop-filter: blur(8px); }
  .hero__btn--secondary:hover { background: rgba(255,255,255,0.14); border-color: rgba(255,255,255,0.3); }
