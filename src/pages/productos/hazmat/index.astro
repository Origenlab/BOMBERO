---

import PageLayout from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQ from "@components/FAQ.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@data/site";
import { canonicalURL, productSchemaComplete, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const productos = [
  {
    id: "nivel-a",
    nombre: "Traje HAZMAT Nivel A Encapsulado",
    slug: "/productos/trajes-para-bomberos/traje-hazmat/nivel-a/",
    badge: "NFPA 1991",
    badgeColor: "ember",
    imagen: "/images/hazmat/traje-hazmat-nivel-a-encapsulado-01.avif",
    descripcion:
      "Protección máxima contra atmosferas IDLH con materiales químicos desconocidos. Traje totalmente encapsulado con cierre sellado y compatible con SCBA autónomo. Cumple NFPA 1991 para operaciones de máximo riesgo.",
    caracteristicas: [
      "Traje completamente encapsulado con sello hermético",
      "Fabricado en material multicapa resistente a vapores",
      "Compatible con SCBA autónomo presurizado",
      "Cierre con cremallera de doble confección",
      "Certificado NFPA 1991 (edición vigente)",
    ],
    aplicacion: "Derrames químicos desconocidos · Atmósferas IDLH · Nivel A encapsulado · Emergencias extremas",
  },
  {
    id: "nivel-b",
    nombre: "Traje HAZMAT Nivel B No Encapsulado",
    slug: "/productos/trajes-para-bomberos/traje-hazmat/nivel-b/",
    badge: "NFPA 1992",
    badgeColor: "fire",
    imagen: "/images/hazmat/traje-hazmat-nivel-b-no-encapsulado-01.avif",
