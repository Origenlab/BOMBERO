const CANONICAL = "/productos/hazmat/";
const TITLE = "Equipos HAZMAT Nivel A, B, C, D y Detectores";
const DESCRIPTION = "Equipos HAZMAT certificados NFPA 1991, 1992, 1994 y 472. Trajes Nivel A, B, C, D, detectores multigas y estaciones de descontaminación con envío a los 32 estados de México.";

const productSchema = productSchemaComplete({
  name: TITLE,
  description: DESCRIPTION,
  image: productos[0].imagen ?? "/images/directorio/descontaminacion-hazmat-01.avif",
  url: CANONICAL,
  category: "Equipos HAZMAT",
  features: ["NFPA 1991", "NFPA 1992", "NFPA 1994", "NFPA 472", "Detectores", "Descontaminación"],
  certifications: ["NFPA 1991", "NFPA 1992", "NFPA 1994", "NFPA 472"],
});

const breadcrumbSchema = breadcrumbJsonLd([
