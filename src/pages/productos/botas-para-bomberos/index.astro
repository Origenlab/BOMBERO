---

import PageLayout from "@layouts/PageLayout.astro";
import QuickNav from "@components/QuickNav.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import FAQ from "@components/FAQ.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABar from "@components/CTABar.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

const productos = [
  {
    id: "estructural",
    nombre: "Bota Estructural de Cuero NFPA 1971",
    slug: "/productos/botas-para-bomberos/estructural/",
    badge: "NFPA 1971",
    badgeColor: "ember",
    imagen: "/images/botas-para-bomberos/bota-bombero-estructural-nfpa-1971-01.avif",
    descripcion:
      "Estándar de oro para combate de incendios estructurales. Cuero de vaqueta de doble densidad (mín. 2.2 mm), puntera composite o acero 200 J, plantilla antiperforación EN 12568, suela de hule resistente a 300 °C e hidrocarburos. Membrana impermeable interna transpirable. Certificada NFPA 1971 edición vigente con certificado UL/Intertek por lote.",
    caracteristicas: [
      "Cuero de vaqueta doble densidad, grano completo ≥ 2.2 mm",
      "Puntera composite o acero de seguridad 200 J / 1 500 lb",
      "Plantilla antiperforación EN 12568 clase P5",
      "Suela hule resistente a calor 300 °C e hidrocarburos",
      "Membrana impermeable interna transpirable (GORE-TEX® o equiv.)",
      "Certificada NFPA 1971 — certificado UL/Intertek por número de lote",
    ],
    aplicacion: "Incendio estructural · Rescate urbano · Colapso de estructuras",
  },
  {
    id: "caucho",
    nombre: "Bota de Caucho Vulcanizado NFPA 1971 / 1991 (HAZMAT)",
    slug: "/productos/botas-para-bomberos/caucho/",
    badge: "NFPA 1971 / 1991",
    badgeColor: "smoke",
    imagen: "/images/botas-para-bomberos/bota-bombero-producto-caucho-par-estudio-01.avif",
    descripcion:
      "Bota de caucho vulcanizado de alta densidad para operaciones con agentes químicos, espuma AFFF, ácidos e hidrocarburos. Sin ninguna parte metálica interna (non-sparking): segura en atmósferas potencialmente explosivas. Resiste más de 200 agentes químicos industriales. Compatible con traje encapsulado HAZMAT Nivel A y B. Descontaminación inmediata con manguera.",
    caracteristicas: [
      "Caucho vulcanizado de alta densidad, construcción monolítica sin costuras",
      "100 % libre de partes metálicas — non-sparking, no magnético",
      "Resistente a ácidos, álcalis, solventes e hidrocarburos (> 200 agentes)",
      "Puntera composite de seguridad 200 J (no metálica)",
      "Certificada NFPA 1971 / NFPA 1991 / EN 13832 clases 1–3",
      "Descontaminación con agua o soluciones diluidas en < 30 segundos",
    ],
    aplicacion: "HAZMAT · Derrame químico · Materiales peligrosos · Inundaciones industriales",
  },
  {
    id: "forestal",
    nombre: "Bota Forestal para Bombero NFPA 1977",
    slug: "/productos/botas-para-bomberos/forestal/",
    badge: "NFPA 1977",
    badgeColor: "fire",
    imagen: "/images/botas-para-bomberos/bota-bombero-forestal-nfpa-1977-01.avif",
    descripcion:
      "Diseñada para movilidad, tracción y resistencia en terreno forestal e interface urbano-rural. Cuero ligero de vaqueta con tratamiento retardante de llama CPAI-84, suela Vibram® o equivalente con perfil profundo para pendientes, tobillo reforzado con soporte rígido y plantilla anatómica de amortiguación para jornadas de 8–16 horas. Certificada NFPA 1977 edición vigente.",
    caracteristicas: [
      "Cuero ligero de vaqueta con tratamiento retardante CPAI-84",
      "Suela Vibram® o equivalente — perfil lugs 5 mm para terreno irregular",
      "Refuerzo rígido de tobillo para prevenir esguinces en pendiente",
      "Plantilla anatómica de amortiguación para jornadas prolongadas",
      "Caña alta ≥ 20 cm con protector de tibia",
      "Certificada NFPA 1977 — incluye certificado de laboratorio por lote",
    ],
    aplicacion: "Incendio forestal · Interface urbano-rural · Quemas controladas · CONAFOR",
  },
];

const CANONICAL = "/productos/botas-para-bomberos/";
const productSchema = productSchemaComplete({
  name: "Botas para Bomberos NFPA — Estructural, Caucho HAZMAT y Forestal",
  description:
    "Botas de bombero certificadas NFPA 1971, 1991 y 1977. Bota estructural de cuero con puntera composite, bota de caucho vulcanizado HAZMAT y bota forestal Vibram®. Marcas: Haix, MSA Safety, Thorogood, Globe. Envío a los 32 estados de México.",
  image: productos[0].imagen ?? "/images/directorio/estacion-bomberos-mexico-01.avif",
  url: CANONICAL,
  category: "Botas de Bombero",
  features: [
    "NFPA 1971",
    "NFPA 1977",
    "NFPA 1991",
    "Puntera composite",
    "Gore-Tex impermeable",
    "Vibram",
    "Non-sparking",
  ],
  certifications: ["NFPA 1971", "NFPA 1977", "NFPA 1991", "EN ISO 20345", "EN 13832"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Botas para Bomberos", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema];

const botasFaqs = [
  {
    question: "¿Bota de cuero o bota de caucho para bomberos — cuál comprar?",
    answer:
      "La bota estructural de cuero NFPA 1971 es el estándar para combate en edificios: el cuero se amolda al pie con el uso, tiene excelente protección térmica conductiva, se seca más rápido que el caucho y es notablemente más cómoda en jornadas de 12+ horas. La bota de caucho es obligatoria para HAZMAT: superficie totalmente sellada, sin costuras que absorban agentes químicos, descontaminación en < 30 segundos con manguera. Para un bombero estructural, la bota de cuero NFPA 1971 es la elección correcta; para operaciones con productos químicos líquidos, la bota de caucho es imprescindible. Muchos cuerpos equipan ambas y determinan cuál usar según el tipo de incidente.",
  },
  {
    question: "¿La NFPA 1971 exige puntera de acero o composite en las botas de bombero?",
    answer:
      "La NFPA 1971 exige puntera de seguridad que soporte 200 J de impacto y 1 500 lb de compresión — lo cumplen tanto el acero como el composite. La diferencia práctica es significativa: la puntera de acero es más barata pero conduce calor (en un incendio prolongado el acero transmite temperatura al pie antes que el composite). La puntera composite (fibra de vidrio, policarbonato) no conduce calor ni corriente eléctrica, es invisible a rayos X y pesa menos. Para bomberos operativos con riesgo eléctrico, la puntera composite más suela dieléctrica es la opción correcta — y en licitaciones públicas es recomendable especificar 'puntera composite no metálica' para cumplir todos los escenarios.",
  },
  {
    question: "¿Cuánto dura una bota de bombero certificada NFPA y cuándo reemplazarla?",
    answer:
      "La NFPA 1851 no establece vida útil fija para botas (distinto a los 10 años de los trajes), pero exige inspección visual antes y después de cada servicio. Indicadores de retiro inmediato: suela con menos de 3 mm de relieve, cualquier separación entre suela y upper, grietas en la caña de cuero, puntera hundida o desplazada (indica impacto severo), pérdida verificable de impermeabilidad (interior húmedo en uso normal). En uso operativo intenso (1–2 servicios diarios), botas de calidad media duran 2–4 años; botas premium Haix o Weinbrenner certificadas NFPA pueden superar 5–7 años. El error más costoso: no reemplazar botas 'porque se ven bien por fuera' — puntera y plantilla antiperforación se degradan sin signos externos visibles.",
  },
  {
    question: "¿Cuánto cuestan las botas de bombero certificadas NFPA en México en 2025?",
    answer:
      "Precios orientativos (MXN, sin IVA): Botas de cuero NFPA 1971 básicas: $3 500–$6 000. Botas de cuero premium Haix / Weinbrenner certificadas NFPA: $7 000–$14 000. Botas de caucho HAZMAT NFPA 1971/1991: $2 500–$5 500. Botas forestales NFPA 1977 con suela Vibram: $4 000–$9 000. La diferencia de precio entre básica y premium se recupera en vida útil: una bota de $4 000 que dura 2 años cuesta más que una de $10 000 que dura 6 años. Para licitaciones, especifica tallas por persona medida en numeración US o EU — no tallas genéricas 'chico/mediano/grande'.",
  },
  {
    question: "¿Las botas de bombero tienen que ser impermeables según NFPA 1971?",
    answer:
      "La NFPA 1971 exige que las botas resistan penetración de líquidos definidos en la norma (agua, AFFF, ácido de batería diluido, gasolina): después de 5 min de exposición el interior debe permanecer seco. Las botas de cuero con membrana GORE-TEX® o equivalente cumplen esto; las botas de cuero sin membrana pueden ceder ante exposición prolongada. Para rescate acuático o inundaciones con agua sobre el tobillo se complementan con polainas de neopreno o se usan botas de caucho. En especificaciones de licitación indica siempre: 'bota de cuero NFPA 1971 con membrana impermeable interna transpirable certificada'.",
  },
  {
    question: "¿Qué altura mínima de caña exige la NFPA 1971 en las botas de bombero?",
    answer:
      "La NFPA 1971 exige caña mínima de 20 cm (8 pulgadas) medidos desde el piso hasta el borde superior — garantiza cobertura de tobillo y parte de pantorrilla para evitar que brasas, agua caliente y escombros entren por arriba. Las botas estructurales de calidad tienen 28–30 cm (11–12 pulgadas) de caña para mayor protección. Las botas de 15 cm (6 pulgadas) son válidas como calzado de estación pero explícitamente NO aceptadas para combate activo según NFPA 1971 — la norma es muy clara en este punto.",
  },
  {
    question: "¿La bota forestal NFPA 1977 es distinta a la estructural NFPA 1971?",
    answer:
      "Sí, son sustancialmente diferentes y no son intercambiables operativamente. La NFPA 1977 forestal: más ligera (300–500 g menos por bota), suela Vibram con tracción para pendientes, caña de cuero flexible para movilidad en caminatas largas, puede carecer de membrana impermeable (la transpirabilidad es prioritaria en campo). No cumple los requisitos de protección térmica conductiva de la NFPA 1971 estructural. Un cuerpo con operaciones duales (estructural + forestal) debe tener ambos tipos de bota por operario. Usar la bota forestal en un incendio estructural es equivalente a ir sin la protección mínima requerida por norma.",
  },
  {
    question: "¿Pueden preparar especificaciones técnicas de botas para licitación pública?",
    answer:
      "Sí, sin costo. La especificación correcta para CompraNet debe incluir: 'bota de cuero de vacuno de grano completo, certificada NFPA 1971 edición 2018 o posterior, puntera composite no metálica protección 200J/1500 lb, plantilla antiperforación clase P5 según EN 12568, suela de hule resistente a calor mínimo 300 °C en contacto y a hidrocarburos, caña mínima 20 cm, membrana impermeable interna transpirable, cierre cremallera lateral o pull-on con trabilla, certificado de laboratorio acreditado UL o Intertek por número de lote de producción, distribución de tallas conforme listado de personal adjunto en numeración US o EU'. Una especificación genérica de 'bota de seguridad para bombero' permite el ingreso de calzado industrial que no cumple NFPA 1971. Entregamos el texto completo listo para pegar en el anexo técnico.",
  },
];
---

<PageLayout
  quickNav={false}
  title="Botas para Bomberos NFPA | Estructural Cuero · Caucho HAZMAT · Forestal — BOMBERO.MX"
  description="Botas de bombero certificadas NFPA 1971, 1991 y 1977. Bota estructural de cuero con puntera composite, caucho vulcanizado HAZMAT y forestal Vibram®. Haix · MSA · Thorogood. Envío a 32 estados de México. Cotiza ahora."
  canonical={CANONICAL}
  jsonLd={jsonLdSchemas}
  keywords={[
    "botas para bomberos",
    "botas bombero NFPA 1971",
    "bota estructural bombero cuero",
    "bota caucho bombero HAZMAT",
    "bota forestal bombero NFPA 1977",
    "botas bombero certificadas México",
    "calzado protección bombero",
    "EPP pies bomberos México",
    "Haix bomberos México",
    "Thorogood botas bombero",
    "bota composite bombero",
    "comprar botas bombero México",
    "botas NFPA licitación México",
  ]}
  type="website"
>

  <Breadcrumb items={[
    { label: "Productos", href: "/productos/" },
    { label: "Botas para Bomberos" },
  ]} />

  <!-- ═══════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          3 Tipos · 18 Modelos · NFPA 1971 · 1991 · 1977
        </div>
        <h1 class="hero__title">
          Botas para
          <span class="hero__title-highlight">Bomberos</span>
          Certificadas NFPA
        </h1>
        <p class="hero__subtitle">
          Cuero de vaqueta, caucho vulcanizado HAZMAT y forestal Vibram®. Punteras composite, plantilla antiperforación y suela resistente a 300 °C. <strong>Haix · MSA · Thorogood · Globe.</strong>
        </p>
        <div class="hero__actions">
          <a href="#catalogo" class="hero__btn hero__btn--primary">Ver catálogo</a>
          <a href="/cotizar/" class="hero__btn hero__btn--secondary">Cotizar ahora</a>
        </div>
      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Botas para bomberos NFPA 1971 — Haix, MSA y Thorogood en México</h2>
          <p class="hero__seo-text">
            Distribuimos <strong>botas estructurales NFPA 1971</strong> de cuero de vaqueta con <strong>puntera composite o acero 200 J</strong>, bota de caucho vulcanizado para <strong>HAZMAT NFPA 1991</strong> y bota forestal <strong>NFPA 1977</strong> con suela Vibram®. Marcas: <strong>Haix</strong>, <strong>MSA Safety</strong>, <strong>Thorogood</strong> y <strong>Globe Manufacturing</strong>. Cada modelo incluye certificado de laboratorio UL/Intertek y ficha técnica lista para <strong>licitaciones CompraNet en los 32 estados de México</strong>.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">La bota correcta para cada operación — asesoría técnica sin costo</h2>
          <p class="hero__seo-text">
            Una <strong>bota estructural NFPA 1971</strong> de cuero protege contra calor seco, perforación y aplastamiento en incendios de edificios. La <strong>bota de caucho non-sparking</strong> es para HAZMAT: resiste > 200 agentes químicos y se descontamina en segundos. En <strong>BOMBERO.MX</strong> especificamos la bota adecuada para cada misión y equipamos tu corporación con el sistema EPP completo: <a class="hero__link" href="/productos/trajes-para-bomberos/">trajes NFPA</a>, <a class="hero__link" href="/productos/cascos-para-bomberos/">cascos certificados</a> y <a class="hero__link" href="/productos/guantes-para-bomberos/">guantes de protección</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <QuickNav pool="categoria" count={7} />
  <CTABar quote="Cotizar Botas de Bombero" />

  <!-- ═══════════════════════════════════════════════════
       TWO-COLUMN LAYOUT
  ═══════════════════════════════════════════════════ -->
  <div class="page-layout">
    <div class="page-layout__inner">

      <!-- ─── MAIN COLUMN ─────────────────────────── -->
      <main class="page-main">

        <!-- CATÁLOGO -->
        <section class="content-panel" id="catalogo">
          <SectionHeader
            label="Catálogo de Botas para Bomberos"
            title="3 Tipos de Bota — Un Sistema de Protección Completo"
            description="Desde combate estructural urbano hasta operaciones HAZMAT y terreno forestal. Cada bota está diseñada para el entorno operativo específico del bombero."
          >
            <p>
              Las <strong>botas de bombero</strong> soportan el mayor desgaste operativo del EPP: protegen contra calor radiante y conductivo, perforación, aplastamiento, resbalones en pisos mojados con espuma y exposición química. Elegir la bota correcta según el tipo de incidente es tan crítico como elegir el <a href="/productos/trajes-para-bomberos/">traje estructural</a> o el <a href="/productos/cascos-para-bomberos/">casco certificado NFPA</a> adecuado.
            </p>
            <p>
              Todas nuestras botas incluyen ficha técnica, certificado de laboratorio UL o Intertek por número de lote y asesoría para especificación en licitación. Tallas 24–32 (MX) disponibles en inventario.
            </p>
          </SectionHeader>
          <div class="productos__grid">
            {productos.map((producto) => (
              <ProductCard {...producto} altSuffix="Bota de bombero certificada NFPA" />
            ))}
          </div>
        </section>

        <!-- TECNOLOGÍA Y MATERIALES -->
        <section class="content-panel content-panel--dark" id="tecnologia">
          <SectionHeader
            label="Tecnología y Materiales"
            title="Ingeniería de Protección Podal para Bomberos"
            description="Cuero de vaqueta, caucho vulcanizado, membrana GORE-TEX® y suela Vibram®. Cada material cumple una función de protección específica según el riesgo operativo."
          >
            <p>
              Las <strong>botas estructurales NFPA 1971</strong> se fabrican con cuero de vaqueta de grano completo ≥ 2.2 mm que equilibra protección y transpirabilidad. La <strong>membrana impermeable interna</strong> (GORE-TEX® o equivalente) previene la penetración de agua, AFFF y ácido de batería sin sacrificar la evacuación de humedad del pie durante jornadas largas. Para protección completa, combina la bota con <a class="dark-link" href="/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/">traje estructural NFPA 1971</a>, <a class="dark-link" href="/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/">casco estructural</a> y <a class="dark-link" href="/productos/guantes-para-bomberos/estructurales/">guantes estructurales</a>.
            </p>
            <p>
              Las <strong>botas de caucho vulcanizado</strong> para HAZMAT tienen construcción monolítica sin costuras — no hay cavidades donde los agentes químicos puedan infiltrarse y acumularse. La <strong>bota forestal NFPA 1977</strong> prioriza la movilidad en terreno irregular: suela Vibram® con lugs de 5 mm para tracción en pendiente, caña flexible para caminatas de hasta 16 horas y tobillo reforzado para prevenir esguinces. Compatible con <a class="dark-link" href="/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/">traje forestal NFPA 1977</a> y <a class="dark-link" href="/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/">casco forestal ventilado</a>.
            </p>
          </SectionHeader>
          <div class="specs__grid">
            <div class="spec-card">
              <div class="spec-card__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20M4 20V10l8-6 8 6v10"/><path d="M8 20v-6h8v6"/></svg>
              </div>
              <h3 class="spec-card__title">Cuero Estructural</h3>
              <p class="spec-card__desc">Vaqueta de grano completo ≥ 2.2 mm, curtido al cromo, densidad doble. Resistencia al desgarro ≥ 80 N/mm² según EN ISO 3377. Tratamiento ignífugo superficial certificado.</p>
            </div>
            <div class="spec-card">
              <div class="spec-card__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
              </div>
              <h3 class="spec-card__title">Caucho Vulcanizado HAZMAT</h3>
              <p class="spec-card__desc">Construcción monolítica sin costuras. Resistencia química a > 200 agentes industriales. Sin partes metálicas (non-sparking). Descontaminación total en < 30 seg. EN 13832 clases 1–3.</p>
            </div>
            <div class="spec-card">
              <div class="spec-card__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
              </div>
              <h3 class="spec-card__title">Suela Vibram® Forestal</h3>
              <p class="spec-card__desc">Lugs de 5 mm para tracción en terreno irregular, pendientes y superficies mojadas. Resistencia al calor de contacto ≥ 300 °C. Compuesto natural anti-deslizamiento clase SRC.</p>
            </div>
            <div class="spec-card">
              <div class="spec-card__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h3 class="spec-card__title">Membrana Impermeable</h3>
              <p class="spec-card__desc">GORE-TEX® o membrana equivalente bicomponente: impermeable total a agua y agentes líquidos de NFPA 1971, transpirable para evacuación de humedad. Prueba de penetración 5 min sin filtración.</p>
            </div>
            <div class="spec-card">
              <div class="spec-card__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
              </div>
              <h3 class="spec-card__title">Puntera Composite</h3>
              <p class="spec-card__desc">Fibra de vidrio o policarbonato: 200 J de impacto y 1 500 lb de compresión. No conduce calor ni corriente. Invisible a rayos X. Recomendada sobre puntera de acero para bomberos operativos.</p>
            </div>
            <div class="spec-card">
              <div class="spec-card__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              </div>
              <h3 class="spec-card__title">Plantilla Antiperforación</h3>
              <p class="spec-card__desc">Clase P5 según EN 12568: resiste penetración de clavos y varillas con ≥ 1 100 N de fuerza. Acero inoxidable o composite textil flexible. Obligatoria en botas NFPA 1971 estructurales.</p>
            </div>
          </div>
        </section>

        <!-- COMPARATIVA -->
        <section class="content-panel" id="comparativa">
          <SectionHeader
            label="Tabla Comparativa"
            title="¿Qué Bota de Bombero Necesitas?"
            description="Compara los 3 tipos de bota por norma, aplicación, impermeabilidad y nivel de protección química para tomar la decisión correcta."
          >
            <p>
