---

import ProductCategoryLayout from "@layouts/ProductCategoryLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import FAQQuote from "@components/FAQQuote.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ProductCard from "@components/ProductCard.astro";
import ComparativaTable from "@components/ComparativaTable.astro";
import { productSchemaComplete, breadcrumbJsonLd } from "@utils/seo";

const productos = [
  {
    id: "estructural",
    nombre: "Bota Estructural de Cuero NFPA 1971",
    slug: "/productos/botas-para-bomberos/estructural/",
    badge: "NFPA 1971",
    badgeColor: "ember",
    imagen: "/images/botas-para-bomberos/bota-bombero-estructural-nfpa-1971-01.avif",
    descripcion:
      "Estándar de oro para combate de incendios estructurales. Cuero de vaqueta de doble densidad (mín. 2.2 mm), puntera composite o acero 200 J, plantilla antiperforación EN 12568, suela de hule resistente a 300 °C e hidrocarburos. Membrana impermeable interna transpirable. Certificada NFPA 1971 edición vigente con certificado UL/Intertek por lote.",
    caracteristicas: [
      "Cuero de vaqueta doble densidad, grano completo ≥ 2.2 mm",
      "Puntera composite o acero de seguridad 200 J / 1 500 lb",
      "Plantilla antiperforación EN 12568 clase P5",
      "Suela hule resistente a calor 300 °C e hidrocarburos",
      "Membrana impermeable interna transpirable (GORE-TEX® o equiv.)",
      "Certificada NFPA 1971 — certificado UL/Intertek por número de lote",
    ],
    aplicacion: "Incendio estructural · Rescate urbano · Colapso de estructuras",
  },
  {
    id: "caucho",
    nombre: "Bota de Caucho Vulcanizado NFPA 1971 / 1991 (HAZMAT)",
    slug: "/productos/botas-para-bomberos/caucho/",
    badge: "NFPA 1971 / 1991",
    badgeColor: "smoke",
    imagen: "/images/botas-para-bomberos/bota-bombero-producto-caucho-par-estudio-01.avif",
    descripcion:
      "Bota de caucho vulcanizado de alta densidad para operaciones con agentes químicos, espuma AFFF, ácidos e hidrocarburos. Sin ninguna parte metálica interna (non-sparking): segura en atmósferas potencialmente explosivas. Resiste más de 200 agentes químicos industriales. Compatible con traje encapsulado HAZMAT Nivel A y B. Descontaminación inmediata con manguera.",
    caracteristicas: [
      "Caucho vulcanizado de alta densidad, construcción monolítica sin costuras",
      "100 % libre de partes metálicas — non-sparking, no magnético",
      "Resistente a ácidos, álcalis, solventes e hidrocarburos (> 200 agentes)",
      "Puntera composite de seguridad 200 J (no metálica)",
      "Certificada NFPA 1971 / NFPA 1991 / EN 13832 clases 1–3",
      "Descontaminación con agua o soluciones diluidas en < 30 segundos",
    ],
    aplicacion: "HAZMAT · Derrame químico · Materiales peligrosos · Inundaciones industriales",
  },
  {
    id: "forestal",
    nombre: "Bota Forestal para Bombero NFPA 1977",
    slug: "/productos/botas-para-bomberos/forestal/",
    badge: "NFPA 1977",
    badgeColor: "fire",
    imagen: "/images/botas-para-bomberos/bota-bombero-forestal-nfpa-1977-01.avif",
    descripcion:
      "Diseñada para movilidad, tracción y resistencia en terreno forestal e interface urbano-rural. Cuero ligero de vaqueta con tratamiento retardante de llama CPAI-84, suela Vibram® o equivalente con perfil profundo para pendientes, tobillo reforzado con soporte rígido y plantilla anatómica de amortiguación para jornadas de 8–16 horas. Certificada NFPA 1977 edición vigente.",
    caracteristicas: [
      "Cuero ligero de vaqueta con tratamiento retardante CPAI-84",
      "Suela Vibram® o equivalente — perfil lugs 5 mm para terreno irregular",
      "Refuerzo rígido de tobillo para prevenir esguinces en pendiente",
      "Plantilla anatómica de amortiguación para jornadas prolongadas",
      "Caña alta ≥ 20 cm con protector de tibia",
      "Certificada NFPA 1977 — incluye certificado de laboratorio por lote",
    ],
    aplicacion: "Incendio forestal · Interface urbano-rural · Quemas controladas · CONAFOR",
  },
];

const CANONICAL = "/productos/botas-para-bomberos/";
const productSchema = productSchemaComplete({
  name: "Botas de Bombero NFPA 1971 — Haix, Thorogood y MSA",
  description:
    "Botas de bombero NFPA 1971 (estructurales), 1977 y 1991 (HAZMAT). Cuero vaqueta, caucho vulcanizado y suela 300 °C. Certificado por número de lote. 32 estados.",
  image: productos[0].imagen ?? "/images/directorio/estacion-bomberos-mexico-01.avif",
  url: CANONICAL,
  category: "Botas de Bombero",
  features: [
    "NFPA 1971",
    "NFPA 1977",
    "NFPA 1991",
    "Puntera composite",
    "Gore-Tex impermeable",
    "Vibram",
    "Non-sparking",
  ],
  certifications: ["NFPA 1971", "NFPA 1977", "NFPA 1991", "EN ISO 20345", "EN 13832"],
});
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos/" },
  { name: "Botas para Bomberos", url: CANONICAL },
]);
const jsonLdSchemas = [productSchema];

const botasFaqs = [
  {
    question: "¿Bota de cuero o bota de caucho para bomberos — cuál comprar?",
    answer:
      "La bota estructural de cuero NFPA 1971 es el estándar para combate en edificios: el cuero se amolda al pie con el uso, tiene excelente protección térmica conductiva, se seca más rápido que el caucho y es notablemente más cómoda en jornadas de 12+ horas. La bota de caucho es obligatoria para HAZMAT: superficie totalmente sellada, sin costuras que absorban agentes químicos, descontaminación en < 30 segundos con manguera. Para un bombero estructural, la bota de cuero NFPA 1971 es la elección correcta; para operaciones con productos químicos líquidos, la bota de caucho es imprescindible. Muchos cuerpos equipan ambas y determinan cuál usar según el tipo de incidente.",
  },
  {
    question: "¿La NFPA 1971 exige puntera de acero o composite en las botas de bombero?",
    answer:
      "La NFPA 1971 exige puntera de seguridad que soporte 200 J de impacto y 1 500 lb de compresión — lo cumplen tanto el acero como el composite. La diferencia práctica es significativa: la puntera de acero es más barata pero conduce calor (en un incendio prolongado el acero transmite temperatura al pie antes que el composite). La puntera composite (fibra de vidrio, policarbonato) no conduce calor ni corriente eléctrica, es invisible a rayos X y pesa menos. Para bomberos operativos con riesgo eléctrico, la puntera composite más suela dieléctrica es la opción correcta — y en licitaciones públicas es recomendable especificar 'puntera composite no metálica' para cumplir todos los escenarios.",
  },
  {
    question: "¿Cuánto dura una bota de bombero certificada NFPA y cuándo reemplazarla?",
    answer:
      "La NFPA 1851 no establece vida útil fija para botas (distinto a los 10 años de los trajes), pero exige inspección visual antes y después de cada servicio. Indicadores de retiro inmediato: suela con menos de 3 mm de relieve, cualquier separación entre suela y upper, grietas en la caña de cuero, puntera hundida o desplazada (indica impacto severo), pérdida verificable de impermeabilidad (interior húmedo en uso normal). En uso operativo intenso (1–2 servicios diarios), botas de calidad media duran 2–4 años; botas premium Haix o Weinbrenner certificadas NFPA pueden superar 5–7 años. El error más costoso: no reemplazar botas 'porque se ven bien por fuera' — puntera y plantilla antiperforación se degradan sin signos externos visibles.",
  },
  {
    question: "¿Cuánto cuestan las botas de bombero certificadas NFPA en México en 2025?",
    answer:
      "Precios orientativos (MXN, sin IVA): Botas de cuero NFPA 1971 básicas: $3 500–$6 000. Botas de cuero premium Haix / Weinbrenner certificadas NFPA: $7 000–$14 000. Botas de caucho HAZMAT NFPA 1971/1991: $2 500–$5 500. Botas forestales NFPA 1977 con suela Vibram: $4 000–$9 000. La diferencia de precio entre básica y premium se recupera en vida útil: una bota de $4 000 que dura 2 años cuesta más que una de $10 000 que dura 6 años. Para licitaciones, especifica tallas por persona medida en numeración US o EU — no tallas genéricas 'chico/mediano/grande'.",
  },
  {
    question: "¿Las botas de bombero tienen que ser impermeables según NFPA 1971?",
    answer:
      "La NFPA 1971 exige que las botas resistan penetración de líquidos definidos en la norma (agua, AFFF, ácido de batería diluido, gasolina): después de 5 min de exposición el interior debe permanecer seco. Las botas de cuero con membrana GORE-TEX® o equivalente cumplen esto; las botas de cuero sin membrana pueden ceder ante exposición prolongada. Para rescate acuático o inundaciones con agua sobre el tobillo se complementan con polainas de neopreno o se usan botas de caucho. En especificaciones de licitación indica siempre: 'bota de cuero NFPA 1971 con membrana impermeable interna transpirable certificada'.",
  },
  {
    question: "¿Qué altura mínima de caña exige la NFPA 1971 en las botas de bombero?",
    answer:
      "La NFPA 1971 exige caña mínima de 20 cm (8 pulgadas) medidos desde el piso hasta el borde superior — garantiza cobertura de tobillo y parte de pantorrilla para evitar que brasas, agua caliente y escombros entren por arriba. Las botas estructurales de calidad tienen 28–30 cm (11–12 pulgadas) de caña para mayor protección. Las botas de 15 cm (6 pulgadas) son válidas como calzado de estación pero explícitamente NO aceptadas para combate activo según NFPA 1971 — la norma es muy clara en este punto.",
  },
  {
    question: "¿La bota forestal NFPA 1977 es distinta a la estructural NFPA 1971?",
    answer:
      "Sí, son sustancialmente diferentes y no son intercambiables operativamente. La NFPA 1977 forestal: más ligera (300–500 g menos por bota), suela Vibram con tracción para pendientes, caña de cuero flexible para movilidad en caminatas largas, puede carecer de membrana impermeable (la transpirabilidad es prioritaria en campo). No cumple los requisitos de protección térmica conductiva de la NFPA 1971 estructural. Un cuerpo con operaciones duales (estructural + forestal) debe tener ambos tipos de bota por operario. Usar la bota forestal en un incendio estructural es equivalente a ir sin la protección mínima requerida por norma.",
  },
  {
    question: "¿Pueden preparar especificaciones técnicas de botas para licitación pública?",
    answer:
      "Sí, sin costo. La especificación correcta para CompraNet debe incluir: 'bota de cuero de vacuno de grano completo, certificada NFPA 1971 edición 2018 o posterior, puntera composite no metálica protección 200J/1500 lb, plantilla antiperforación clase P5 según EN 12568, suela de hule resistente a calor mínimo 300 °C en contacto y a hidrocarburos, caña mínima 20 cm, membrana impermeable interna transpirable, cierre cremallera lateral o pull-on con trabilla, certificado de laboratorio acreditado UL o Intertek por número de lote de producción, distribución de tallas conforme listado de personal adjunto en numeración US o EU'. Una especificación genérica de 'bota de seguridad para bombero' permite el ingreso de calzado industrial que no cumple NFPA 1971. Entregamos el texto completo listo para pegar en el anexo técnico.",
  },
];

// ─── Datos del sidebar (W1/W2/W3/W5/W6/W11 — los demás son compartidos) ───
const sidebar = {
  ariaLabel: "Navegación de botas de bombero",
  tiposTitle: "Tipos de Botas",
  tipos: [
    { href: "/productos/botas-para-bomberos/estructural/", label: "Estructural Cuero", badge: "NFPA 1971", badgeColor: "ember", dot: "ember", active: true },
    { href: "/productos/botas-para-bomberos/caucho/", label: "Caucho HAZMAT", badge: "NFPA 1991", badgeColor: "smoke", dot: "smoke" },
    { href: "/productos/botas-para-bomberos/forestal/", label: "Forestal", badge: "NFPA 1977", badgeColor: "fire", dot: "fire" },
  ],
  specs: [
    { value: "≥ 2.2", unit: "mm", label: "Cuero vaqueta" },
    { value: "300", unit: "°C", label: "Resistencia suela" },
    { value: "200", unit: "J", label: "Impacto puntera" },
    { value: "24–32", unit: "MX", label: "Tallas disponibles" },
  ],
  normas: [
    { code: "NFPA 1971", color: "ember", desc: "Calzado estructural — protección térmica y mecánica" },
    { code: "NFPA 1991", color: "smoke", desc: "Trajes y calzado para incidentes HAZMAT" },
    { code: "NFPA 1977", color: "fire", desc: "Calzado forestal — interfase y quemas controladas" },
    { code: "NFPA 1851", color: "neutral", desc: "Selección, cuidado y mantenimiento del EPP" },
    { code: "EN 13832", color: "neutral", desc: "Botas de caucho — resistencia química europea" },
  ],
  materiales: [
    { name: "Cuero vaqueta grano completo", desc: "Curtido al cromo, ≥ 2.2 mm, resistencia al desgarro ≥ 80 N/mm²" },
    { name: "Caucho vulcanizado", desc: "Alta densidad, monolítico sin costuras, non-sparking, EN 13832" },
    { name: "GORE-TEX® / Membrana equiv.", desc: "Impermeable a líquidos NFPA 1971, transpirable, prueba 5 min" },
    { name: "Suela Vibram® o equiv.", desc: "Resistencia al calor ≥ 300 °C, clase SRC antideslizamiento" },
  ],
  marcas: [
    { name: "Haix", sub: "Estructural cuero — referencia mundial NFPA" },
    { name: "Thorogood", sub: "Estructural y forestal — EUA, certificación NFPA" },
    { name: "MSA Safety", sub: "Caucho HAZMAT e industrial — estándar global" },
    { name: "Globe Manufacturing", sub: "Estructural cuero premium, larga vida útil" },
    { name: "Jolly Footwear", sub: "ARFF y forestal — norma EN certificada" },
  ],
  recursos: [
    { label: "Guía", text: "Botas para bomberos: guía de selección NFPA", href: "/blog/botas-para-bomberos-guia-nfpa/" },
    { label: "Norma", text: "NFPA 1971: guía técnica completa", href: "/blog/nfpa-1971-guia-completa/" },
    { label: "Cuidado", text: "Mantenimiento de equipo NFPA", href: "/blog/mantenimiento-equipo-nfpa-bomberos/" },
    { label: "Compra", text: "Cómo cotizar equipo municipal", href: "/blog/equipo-bomberos-municipal-como-cotizar/" },
  ],
  ctaText: "Elaboramos especificación técnica para CompraNet sin costo.",
  waMsg: "Hola, necesito cotizar botas para bomberos",
};

const whyImages = [
  "/images/botas-para-bomberos/bota-bombero-estructural-nfpa-1971-03.avif",
  "/images/botas-para-bomberos/bota-bombero-profesional-01.avif",
  "/images/botas-para-bomberos/bota-bombero-caucho-nfpa-1971-05.avif",
  "/images/botas-para-bomberos/bota-bombero-forestal-nfpa-1977-04.avif",
  "/images/botas-para-bomberos/bota-bombero-profesional-03.avif",
  "/images/botas-para-bomberos/bota-bombero-profesional-05.avif",
