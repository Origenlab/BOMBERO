---
/**
 * --- Pagina de Detalle de Estacion de Bomberos Zacatecas ---
 * Usa EstacionLayout para mantener consistencia con el resto del sitio
 */
import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesZacatecas, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-zacatecas";

// Generar rutas estaticas
export function getStaticPaths() {
  return estacionesZacatecas.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "Zacatecas",
  slug: "zacatecas",
  siglas: "ZAC",
  poblacion: "1.6 millones",
  municipios: 58,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Aguascalientes", slug: "aguascalientes" },
  { nombre: "San Luis Potosi", slug: "san-luis-potosi" },
  { nombre: "Durango", slug: "durango" },
  { nombre: "Jalisco", slug: "jalisco" },
  { nombre: "Coahuila", slug: "coahuila" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? "Zacatecas";

// Tarjetas EPP para la seccion de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Disenado para los bomberos de <strong>${ubicacion}</strong> que protegen la capital minera de Mexico. Certificacion NFPA para emergencias mineras, proteccion del Centro Historico UNESCO y rescate en minas.`,
    href: "/productos/trajes-para-bomberos",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificacion NFPA 1971 para operaciones en <strong>Zacatecas</strong>. Compatible con rescate en minas, emergencias en el Centro Historico Patrimonio UNESCO y operaciones en altitud.`,
    href: "/productos/cascos-para-bomberos",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia termica certificada para emergencias mineras en <strong>${ubicacion}</strong>. Prension segura para rescate en tuneles historicos, operaciones en altura y proteccion patrimonial.`,
    href: "/productos/guantes-para-bomberos",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el entorno de <strong>Zacatecas</strong>. Suela antiderrapante para tuneles mineros, calles empedradas del Centro Historico y terreno montanoso.`,
    href: "/productos/botas-para-bomberos",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <!-- Contenido SEO personalizado para Zacatecas -->
  <Fragment slot="seo-content">
    <h2>Bomberos en {ubicacion}, Zacatecas</h2>
    <p>
      La <strong>{estacion.nombreCorto ?? estacion.nombre}</strong> es parte del <strong>H. Cuerpo de Bomberos de {ubicacion}</strong>,
      institucion que protege a los mas de <strong>1.6 millones de zacatecanos</strong>. Esta estacion, ubicada en
      <strong>{estacion.direccion}</strong>, brinda atencion las 24 horas del dia,
      los 365 dias del ano.
    </p>
    <p>
      En caso de <strong>emergencia en {ubicacion}</strong>, marca el <strong>911</strong> o comunicate directamente
      a esta estacion al <strong>{estacion.telefono}</strong>. Los bomberos de Zacatecas estan capacitados para atender
      incendios estructurales, emergencias mineras, rescate en tuneles, proteccion de patrimonio historico
      y todo tipo de emergencias.
    </p>
    <h3>Zacatecas: Capital de la Plata</h3>
    <p>
      <strong>Zacatecas</strong> es conocida como "La Capital de la Plata" por su riqueza minera historica.
      El <strong>Centro Historico</strong> es <strong>Patrimonio de la Humanidad UNESCO</strong>, con su impresionante
      catedral barroca y arquitectura colonial. Las <strong>Minas del Eden</strong> son ahora atraccion turistica
      con tuneles subterraneos. El estado tiene <strong>5 Pueblos Magicos</strong> incluyendo Jerez y Sombrerete.
      <strong>Fresnillo</strong> es uno de los centros mineros mas productivos del mundo. Los bomberos tienen
      capacidades especializadas en rescate minero y proteccion de patrimonio historico.
    </p>
    <h3>Necesitas equipo certificado para bomberos?</h3>
    <p>
      En <strong><a href="/">BOMBERO.MX</a></strong> somos distribuidores autorizados de <strong>equipo para bomberos certificado NFPA</strong>.
      Equipamos estaciones en todo Zacatecas con <a href="/productos/trajes-para-bomberos">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos">cascos</a>, <a href="/productos/guantes-para-bomberos">guantes</a>,
      <a href="/productos/botas-para-bomberos">botas certificadas</a> y mas.
      <a href="/cotizar/">Solicita una cotizacion</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
