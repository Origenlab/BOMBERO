---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesQuintanaRoo, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-quintana-roo";

// Generar rutas estaticas
export function getStaticPaths() {
  return estacionesQuintanaRoo.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "Quintana Roo",
  slug: "quintana-roo",
  siglas: "QROO",
  poblacion: "1.9 millones",
  municipios: 11,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Yucatan", slug: "yucatan" },
  { nombre: "Campeche", slug: "campeche" },
  { nombre: "Tabasco", slug: "tabasco" },
  { nombre: "Ciudad de Mexico", slug: "ciudad-de-mexico" },
  { nombre: "Jalisco", slug: "jalisco" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? estacion.municipiosCubiertos?.[0] ?? "Quintana Roo";

// Tarjetas EPP para la seccion de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Disenado para los bomberos de <strong>${ubicacion}</strong> que protegen el destino turistico #1 de Latinoamerica. Certificacion NFPA para emergencias en zona hotelera, resorts de Riviera Maya y aeropuerto internacional de Cancun.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificacion NFPA 1971 para operaciones en <strong>Quintana Roo</strong>. Compatible con rescate acuatico en cenotes, playas del Caribe, y emergencias en cruceros del Puerto de Cozumel.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia termica certificada para emergencias hoteleras y rescate acuatico en <strong>${ubicacion}</strong>. Prension segura para operaciones en temporada de huracanes y proteccion de la Reserva Sian Ka'an UNESCO.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el entorno turistico de <strong>Quintana Roo</strong>. Suela antiderrapante para operaciones en hoteles, terminales de cruceros, aeropuerto y zonas arqueologicas como Tulum.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>

  <Fragment slot="seo-content">
    <h2>Bomberos en {estacion.municipio}, Quintana Roo</h2>
    <p>
      La <strong>{estacion.nombreCorto}</strong> es parte del <strong>H. Cuerpo de Bomberos de {estacion.municipio}</strong>,
      institución que protege a los más de <strong>1.9 millones de quintanarroenses</strong>. Esta estación, ubicada en
      <strong>{estacion.direccion}, {estacion.colonia}, {estacion.municipio}</strong>, brinda atención las 24 horas del día,
      los 365 días del año.
    </p>
    <p>
      En caso de <strong>emergencia en {estacion.municipio}</strong>, marca el <strong>911</strong> o comunícate directamente
      a esta estación al <strong>{estacion.telefono}</strong>. Los bomberos de Quintana Roo están capacitados para atender
      incendios estructurales y hoteleros, rescate acuático en playas y cenotes, emergencias en cruceros,
      respuesta a huracanes, HAZMAT y atención de emergencias turísticas.
    </p>
    <h3>Quintana Roo: El Caribe Mexicano</h3>
    <p>
      <strong>Quintana Roo</strong> es el destino turístico #1 de Latinoamérica, hogar de <strong>Cancún</strong>,
      <strong>Riviera Maya</strong>, <strong>Playa del Carmen</strong> y <strong>Tulum</strong>. El aeropuerto de Cancún
      recibe más de 25 millones de pasajeros anuales. El Puerto de <strong>Cozumel</strong> es el tercero más importante
      del mundo en cruceros. La <strong>Reserva de Sian Ka'an</strong> es Patrimonio UNESCO y el Gran Arrecife Maya
      es el segundo más grande del mundo. Los bomberos enfrentan retos únicos: rescate acuático, temporada de huracanes
      y protección de la infraestructura hotelera más grande de México.
    </p>
    <h3>¿Necesitas equipo certificado para bomberos?</h3>
    <p>
      En <strong><a href="/">BOMBERO.MX</a></strong> somos distribuidores autorizados de <strong>equipo para bomberos certificado NFPA</strong>.
      Equipamos estaciones en todo Quintana Roo con <a href="/productos/trajes-para-bomberos/">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>, <a href="/productos/guantes-para-bomberos/">guantes</a>,
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> y más.
      <a href="/cotizar/">Solicita una cotización</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
