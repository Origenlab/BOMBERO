---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesPuebla, getMunicipios } from "@data/estaciones-puebla";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

// Configuración del estado
const estado = "Puebla";
const sigla = "PUE";
const slug = "puebla";

const canonical = "https://bombero.mx/directorio/puebla/";

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const totalEstaciones = estacionesPuebla.length;
const totalMunicipios = getMunicipios().length;

// ── Comparativa regional ───────────────────────────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Metropolitana",
    municipios: ["Puebla Centro", "Puebla Norte", "Puebla Sur", "San Pedro Cholula", "Amozoc de Mota"],
    cobertura: "Total",
    chip: "total",
    perfil: "Centro Histórico UNESCO (2,619 edificios históricos), Gran Pirámide de Cholula, alta densidad y autopista México-Puebla."
  },
  {
    nombre: "Zona Industrial Automotriz",
    municipios: ["Cuautlancingo", "San José Chiapa", "Huejotzingo"],
    cobertura: "Total",
    chip: "total",
    perfil: "Planta Volkswagen (~317,000 veh/año), Audi México (~138,000 Q5/año). HAZMAT Nivel III activo 24/7."
  },
  {
    nombre: "Corredor Volcánico",
    municipios: ["Atlixco", "San Nicolás de los Ranchos", "Tochimilco"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Radio de 12 km de exclusión del Popocatépetl (5,426 msnm). Protocolo CENAPRED de evacuación coordinada."
  },
  {
    nombre: "Sierra Norte",
    municipios: ["Zacatlán", "Chignahuapan", "Cuetzalan", "Xicotepec"],
    cobertura: "Media",
    chip: "media",
    perfil: "4 Pueblos Mágicos, terracería en temporada de lluvias. Incendios forestales estiaje (nov–may)."
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesPuebla.filter((e) =>
    z.municipios.some((m) => (e.municipio ?? "").includes(m) || (e.ciudad ?? "").includes(m))
  );
  return {
    ...z,
    nEst: est.length,
    nPers: est.reduce((s, e) => s + (e.personal ?? 0), 0),
    nUni: est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ── Schemas estructurados ──────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio de ${totalEstaciones} estaciones de bomberos en Puebla. Capital industrial automotriz (VW, Audi), Centro Histórico UNESCO, monitoreo del Volcán Popocatépetl y Sierra Norte. Emergencias: 911.`,
  numberOfItems: estacionesPuebla.length,
  itemListElement: estacionesPuebla.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipiosCubiertos?.[0] || estado,
        addressRegion: estado,
        addressCountry: "MX"
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}`
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Puebla: estaciones, historia y servicios de emergencia",
  "description": "Guía del H. Cuerpo de Bomberos de Puebla: historia, infraestructura en la zona industrial automotriz (VW/Audi), Volcán Popocatépetl, Centro Histórico UNESCO y directorio de estaciones con teléfonos directos.",
  "about": [
    "H. Cuerpo de Bomberos de Puebla",
    "Protección Civil Puebla",
    "HAZMAT industria automotriz",
    "Volcán Popocatépetl",
    "Servicios de emergencia Puebla",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/puebla.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Puebla",
  "description": `Directorio verificado de ${totalEstaciones} estaciones de bomberos en Puebla, con teléfonos, cobertura, funciones e historia del H. Cuerpo de Bomberos de Puebla.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "H. Cuerpo de Bomberos de Puebla" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/puebla.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Puebla (≥10) ─────────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencias para llamar a los bomberos en Puebla?",
    a: `Marca el <strong>911</strong>, el número único de emergencias que opera las 24 horas en todo el estado. La Estación Central de Puebla tiene línea directa al <strong>(222) 309-9400</strong>. Para Tehuacán: <strong>(238) 382-0033</strong>. Para Cholula: <strong>(222) 247-0707</strong>. En la zona industrial automotriz (Volkswagen/Cuautlancingo), la línea de HAZMAT es <strong>(222) 303-8000</strong>.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Puebla?",
    a: `Este directorio reúne <strong>${totalEstaciones} estaciones de bomberos en Puebla</strong>, distribuidas en la zona metropolitana, el corredor industrial automotriz (VW y Audi), el corredor volcánico (zona del Popocatépetl), la Sierra Norte y el Valle de Tehuacán. La Estación Central es la sede del H. Cuerpo de Bomberos de Puebla, en Av. 25 Poniente 1502, Col. Volcanes.`,
  },
  {
    q: "¿Cuándo se fundaron los bomberos de Puebla?",
    a: `El primer cuerpo de bomberos de México se fundó el <strong>22 de agosto de 1873 en Veracruz</strong>; esa fecha se conmemora como el <strong>Día del Bombero</strong> en todo el país. En Puebla, el H. Cuerpo de Bomberos formalizó su estructura institucional durante el siglo XX y cuenta con varias décadas de servicio continuo. La estación de Tehuacán, por ejemplo, tiene más de 50 años de operación documentada.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque el <strong>22 de agosto de 1873</strong> se fundó en el puerto de Veracruz el <strong>primer cuerpo de bomberos de México</strong>. Desde entonces, esa fecha honra la labor de todos los bomberos del país, incluidos los de Puebla.`,
  },
  {
    q: "¿Los bomberos de Puebla atienden emergencias volcánicas del Popocatépetl?",
    a: `Sí. Las estaciones de <strong>Atlixco, San Nicolás de los Ranchos y Tochimilco</strong> están capacitadas para operar bajo el <strong>Semáforo de Alerta Volcánica del Popocatépetl</strong> (sistema CENAPRED). El radio de exclusión es de <strong>12 km</strong> del cráter. En Fase Amarilla 3 o superior, activan pre-posicionamiento de unidades y coordinación con Protección Civil de los 6 municipios en zona de mayor peligro, con una población de aproximadamente <strong>56,000 personas</strong>.`,
  },
  {
    q: "¿Hay bomberos especializados en HAZMAT para las plantas Volkswagen y Audi en Puebla?",
    a: `Sí. La <strong>Estación HAZMAT Cuautlancingo</strong> (Av. Volkswagen s/n, Zona Industrial) atiende emergencias en la planta Volkswagen de México (~317,000 vehículos al año). La <strong>Estación San José Chiapa</strong> cubre la planta Audi México (~138,000 Q5 al año). Ambas tienen capacidad <strong>HAZMAT Nivel III</strong>, trajes encapsulados Nivel A y detectores multigas para materiales como pinturas de base isocianato (MDI/TDI) usados en las líneas de pintura automotriz.`,
  },
  {
    q: "¿Qué pasó con los bomberos de Puebla en el sismo del 19 de septiembre de 2017?",
    a: `El <strong>sismo del 19 de septiembre de 2017</strong> (Mw 7.1, epicentro en el límite Puebla-Morelos, municipio de Chiautla de Tapia) dejó en Puebla <strong>45 muertos</strong>, afectaciones en <strong>115 municipios</strong> y más de <strong>31,000 inmuebles dañados</strong>, incluyendo 621 inmuebles históricos. Los bomberos de Puebla coordinaron con el Sistema Nacional de Protección Civil las labores de búsqueda y rescate urbano (USAR), apuntalamiento y evaluación de estructuras en los municipios más afectados del estado.`,
  },
  {
    q: "¿Cómo se protegen los edificios del Centro Histórico de Puebla en caso de incendio?",
    a: `El <strong>Centro Histórico de Puebla</strong> fue declarado Patrimonio de la Humanidad por la UNESCO el <strong>11 de diciembre de 1987</strong>. Comprende 391 manzanas con <strong>2,619 edificios de valor histórico</strong> construidos entre los siglos XVI y XIX, con muros de cantera gris y adobe. Los bomberos utilizan protocolos de <strong>ataque con niebla de agua a baja presión</strong> para evitar el colapso de muros de adobe y piedra; la coordinación con el <strong>INAH</strong> es obligatoria en cualquier intervención sobre edificios catalogados.`,
  },
  {
    q: "¿Los bomberos de Puebla atienden la Sierra Norte y Cuetzalan?",
    a: `Sí. Las estaciones de <strong>Zacatlán, Chignahuapan, Cuetzalan y Xicotepec</strong> cubren la Sierra Norte. Cuetzalan del Progreso está a 1,060 msnm con accesos de terracería que en temporada de lluvias (junio–octubre) son intransitables para vehículos de más de 3 toneladas. La estación opera con unidades <strong>4x4 ligeras</strong> y coordinación con brigadas forestales comunitarias. El tiempo de respuesta desde Xicotepec puede superar los 90 minutos en lluvias intensas.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en la autopista México-Puebla (150D)?",
    a: `La autopista México-Puebla (150D) registra más de <strong>80,000 vehículos diarios</strong>. Las estaciones de <strong>San Martín Texmelucan y Huejotzingo</strong> son las de respuesta primaria para rescate vehicular, extricación con herramienta hidráulica y emergencias con materiales peligrosos en transporte. El corredor también está cubierto por las estaciones de Amozoc en el tramo oriente.`,
  },
  {
    q: "¿Los bomberos de Puebla atienden la Zona Arqueológica de Cholula?",
    a: `Sí. La <strong>Estación de Bomberos Cholula</strong> (Av. Morelos 100, San Pedro Cholula, tel. (222) 247-0707) cubre la Gran Pirámide de Cholula —la mayor por volumen del mundo—, el Santuario de los Remedios y la zona universitaria de la UDLAP. El núcleo prehispánico es de tierra apisonada y relleno arqueológico; los protocolos limitan el uso de agua directa para no comprometer la estructura. Toda intervención con agente supresor requiere coordinación con el INAH.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en una zona cercana al Popocatépetl?",
    a: `Mantente informado a través del <strong>CENAPRED</strong> (cenapred.unam.mx) y del Semáforo de Alerta Volcánica. Ante caída de ceniza: <strong>cubre tinacos y depósitos de agua</strong>, usa cubrebocas con filtro P100, evita salir y cierra puertas y ventanas. Ten identificadas las <strong>rutas de evacuación</strong> y el punto de reunión de tu comunidad. En caso de emergencia, llama al <strong>911</strong>.`,
  },
];

