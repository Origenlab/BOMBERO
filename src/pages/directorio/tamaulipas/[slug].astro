---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesTamaulipas, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-tamaulipas";

// Generar rutas estaticas
export function getStaticPaths() {
  return estacionesTamaulipas.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "Tamaulipas",
  slug: "tamaulipas",
  siglas: "TAM",
  poblacion: "3.7 millones",
  municipios: 43,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Nuevo Leon", slug: "nuevo-leon" },
  { nombre: "San Luis Potosi", slug: "san-luis-potosi" },
  { nombre: "Veracruz", slug: "veracruz" },
  { nombre: "Coahuila", slug: "coahuila" },
  { nombre: "Ciudad de Mexico", slug: "ciudad-de-mexico" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? "Tamaulipas";

// Tarjetas EPP para la seccion de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Disenado para los bomberos de <strong>${ubicacion}</strong> que protegen la puerta de Mexico. Certificacion NFPA para emergencias industriales en maquiladoras, refineria Madero y puertos internacionales.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificacion NFPA 1971 para operaciones en <strong>Tamaulipas</strong>. Compatible con emergencias petroleras, rescate en huracanes y operaciones en puertos de Tampico y Altamira.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia termica y quimica certificada para emergencias industriales y petroleras en <strong>${ubicacion}</strong>. Prension segura para operaciones en refineria Madero y maquiladoras fronterizas.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el entorno de <strong>Tamaulipas</strong>. Suela antiderrapante para puertos, refineria, maquiladoras y operaciones en temporada de huracanes.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>

  <Fragment slot="seo-content">
    <h2>Bomberos en {estacion.municipio}, Tamaulipas</h2>
    <p>
      La <strong>{estacion.nombreCorto}</strong> es parte del <strong>H. Cuerpo de Bomberos de {estacion.municipio}</strong>,
      institución que protege a los más de <strong>3.7 millones de tamaulipecos</strong>. Esta estación, ubicada en
      <strong>{estacion.direccion}, {estacion.colonia}, {estacion.municipio}</strong>, brinda atención las 24 horas del día,
      los 365 días del año.
    </p>
    <p>
      En caso de <strong>emergencia en {estacion.municipio}</strong>, marca el <strong>911</strong> o comunícate directamente
      a esta estación al <strong>{estacion.telefono}</strong>. Los bomberos de Tamaulipas están capacitados para atender
      incendios estructurales e industriales, emergencias petroleras, rescate en huracanes, HAZMAT
      y todo tipo de emergencias.
    </p>
    <h3>Tamaulipas: La Puerta de México</h3>
    <p>
      <strong>Tamaulipas</strong> es la puerta de entrada a México, con importantes cruces fronterizos como
      <strong>Nuevo Laredo</strong>, <strong>Reynosa</strong> y <strong>Matamoros</strong>. La industria maquiladora
      es fundamental para la economía, junto con la <strong>Refinería Madero</strong> y los puertos de
      <strong>Tampico</strong> y <strong>Altamira</strong>. El estado enfrenta temporada de huracanes y emergencias
      industriales de alta complejidad. <strong>Ciudad Victoria</strong> es la capital y centro administrativo.
      Los bomberos tienen capacidades especializadas en HAZMAT, rescate acuático y emergencias fronterizas.
    </p>
    <h3>¿Necesitas equipo certificado para bomberos?</h3>
    <p>
      En <strong><a href="/">BOMBERO.MX</a></strong> somos distribuidores autorizados de <strong>equipo para bomberos certificado NFPA</strong>.
      Equipamos estaciones en todo Tamaulipas con <a href="/productos/trajes-para-bomberos/">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>, <a href="/productos/guantes-para-bomberos/">guantes</a>,
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> y más.
      <a href="/cotizar/">Solicita una cotización</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
