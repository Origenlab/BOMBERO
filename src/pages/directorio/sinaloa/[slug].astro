---
/**
 * --- Pagina de Detalle de Estacion de Bomberos Sinaloa ---
 * Usa EstacionLayout para mantener consistencia con el resto del sitio
 */
import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesSinaloa, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-sinaloa";

// Generar rutas estaticas
export function getStaticPaths() {
  return estacionesSinaloa.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "Sinaloa",
  slug: "sinaloa",
  siglas: "SIN",
  poblacion: "3.0 millones",
  municipios: 18,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Sonora", slug: "sonora" },
  { nombre: "Chihuahua", slug: "chihuahua" },
  { nombre: "Durango", slug: "durango" },
  { nombre: "Nayarit", slug: "nayarit" },
  { nombre: "Jalisco", slug: "jalisco" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? "Sinaloa";

// Tarjetas EPP para la seccion de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Disenado para los bomberos de <strong>${ubicacion}</strong> que protegen el granero de Mexico. Certificacion NFPA para emergencias agricolas, portuarias en Mazatlan y Topolobampo, y proteccion de la industria pesquera.`,
    href: "/productos/trajes-para-bomberos",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificacion NFPA 1971 para operaciones en <strong>Sinaloa</strong>. Compatible con rescate en playas de Mazatlan, emergencias en zonas agricolas del Valle de Culiacan y operaciones portuarias.`,
    href: "/productos/cascos-para-bomberos",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia termica certificada para emergencias agricolas e industriales en <strong>${ubicacion}</strong>. Prension segura para operaciones en el Puerto de Mazatlan y rescate en temporada de huracanes.`,
    href: "/productos/guantes-para-bomberos",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el entorno de <strong>Sinaloa</strong>. Suela antiderrapante para operaciones en puertos, campos agricolas, zonas turisticas de Mazatlan y centros historicos.`,
    href: "/productos/botas-para-bomberos",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <!-- Contenido SEO personalizado para Sinaloa -->
  <Fragment slot="seo-content">
    <h2>Bomberos en {ubicacion}, Sinaloa</h2>
    <p>
      La <strong>{estacion.nombreCorto ?? estacion.nombre}</strong> es parte del <strong>H. Cuerpo de Bomberos de {ubicacion}</strong>,
      institucion que protege a los mas de <strong>3 millones de sinaloenses</strong>. Esta estacion, ubicada en
      <strong>{estacion.direccion}</strong>, brinda atencion las 24 horas del dia,
      los 365 dias del ano.
    </p>
    <p>
      En caso de <strong>emergencia en {ubicacion}</strong>, marca el <strong>911</strong> o comunicate directamente
      a esta estacion al <strong>{estacion.telefono}</strong>. Los bomberos de Sinaloa estan capacitados para atender
      incendios estructurales y agricolas, emergencias portuarias, rescate acuatico, respuesta a huracanes
      y todo tipo de emergencias.
    </p>
    <h3>Sinaloa: El Granero de Mexico</h3>
    <p>
      <strong>Sinaloa</strong> es el principal productor agricola de Mexico, conocido como "El Granero de Mexico".
      <strong>Mazatlan</strong> es uno de los destinos turisticos mas importantes del Pacifico, con su historico
      Malecon y el Puerto de cruceros. <strong>Culiacan</strong> es la capital y centro comercial del estado.
      Los puertos de <strong>Topolobampo</strong> y <strong>Mazatlan</strong> son fundamentales para la exportacion agricola.
      Los bomberos enfrentan emergencias agricolas, incendios forestales, temporada de huracanes y emergencias turisticas.
    </p>
    <h3>Necesitas equipo certificado para bomberos?</h3>
    <p>
      En <strong><a href="/">BOMBERO.MX</a></strong> somos distribuidores autorizados de <strong>equipo para bomberos certificado NFPA</strong>.
      Equipamos estaciones en todo Sinaloa con <a href="/productos/trajes-para-bomberos">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos">cascos</a>, <a href="/productos/guantes-para-bomberos">guantes</a>,
      <a href="/productos/botas-para-bomberos">botas certificadas</a> y mas.
      <a href="/cotizar">Solicita una cotizacion</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
