---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesYucatan, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-yucatan";

// Generar rutas estáticas
export function getStaticPaths() {
  return estacionesYucatan.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "Yucatán",
  slug: "yucatan",
  siglas: "YUC",
  poblacion: "2.3 millones",
  municipios: 106,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Quintana Roo", slug: "quintana-roo" },
  { nombre: "Campeche", slug: "campeche" },
  { nombre: "Tabasco", slug: "tabasco" },
  { nombre: "Ciudad de México", slug: "ciudad-de-mexico" },
  { nombre: "Jalisco", slug: "jalisco" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? "Yucatán";

// Tarjetas EPP para la sección de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Diseñado para los bomberos de <strong>${ubicacion}</strong> que protegen la capital cultural del sureste. Certificación NFPA para emergencias en el Centro Histórico UNESCO, rescate en cenotes y zona arqueológica maya.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para operaciones en <strong>Yucatán</strong>. Compatible con rescate en cenotes, protección de Chichén Itzá y Uxmal UNESCO, y respuesta a huracanes en temporada.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia térmica certificada para emergencias en <strong>${ubicacion}</strong>. Prensión segura para rescate en cenotes, operaciones en el Puerto de Progreso y temporada de huracanes.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el entorno de <strong>Yucatán</strong>. Suela antiderrapante para cenotes, zonas arqueológicas, Centro Histórico de Mérida y clima tropical húmedo.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>

  <Fragment slot="seo-content">
    <h2>Bomberos en {estacion.municipio}, Yucatán</h2>
    <p>
      La <strong>{estacion.nombreCorto}</strong> es parte del <strong>H. Cuerpo de Bomberos de {estacion.municipio}</strong>,
      institución que protege a los más de <strong>2.3 millones de yucatecos</strong>. Esta estación, ubicada en
      <strong>{estacion.direccion}, {estacion.colonia}, {estacion.municipio}</strong>, brinda atención las 24 horas del día,
      los 365 días del año.
    </p>
    <p>
      En caso de <strong>emergencia en {estacion.municipio}</strong>, marca el <strong>911</strong> o comunícate directamente
      a esta estación al <strong>{estacion.telefono}</strong>. Los bomberos de Yucatán están capacitados para atender
      incendios estructurales, rescate en cenotes, respuesta a huracanes, protección de patrimonio arqueológico
      y todo tipo de emergencias.
    </p>
    <h3>Yucatán: Capital Cultural del Sureste</h3>
    <p>
      <strong>Yucatán</strong> es la capital cultural del sureste mexicano, hogar de la civilización <strong>maya</strong>.
      <strong>Chichén Itzá</strong> es una de las Nuevas 7 Maravillas del Mundo y Patrimonio UNESCO, junto con <strong>Uxmal</strong>.
      El Centro Histórico de <strong>Mérida</strong> es una joya colonial. El estado tiene más de <strong>6,000 cenotes</strong>
      que requieren equipos especializados de rescate acuático. El <strong>Puerto de Progreso</strong> es importante para cruceros.
      La temporada de <strong>huracanes</strong> afecta al estado anualmente. Los bomberos tienen capacidades de rescate en cenotes
      y protección del invaluable patrimonio maya.
    </p>
    <h3>¿Necesitas equipo certificado para bomberos?</h3>
    <p>
      En BOMBERO.MX distribuimos <strong>equipo para bomberos certificado NFPA</strong> en {estado.nombre}.
      Equipamos estaciones en todo Yucatán con <a href="/productos/trajes-para-bomberos/">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>, <a href="/productos/guantes-para-bomberos/">guantes</a>,
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> y más.
      <a href="/cotizar/">Solicita una cotización</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
