          <tr><td><strong>Incendios forestales y agrícolas</strong></td><td>Estiaje y cosecha</td><td>Cajeme, Navojoa, Álamos, sierra sonorense</td></tr>
          <tr><td><strong>Coordinación binacional</strong></td><td>Activa</td><td>Nogales, Agua Prieta, San Luis R.C.</td></tr>
        </tbody>
