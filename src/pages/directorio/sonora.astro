  heroImageAlt="Estación de Bomberos en Sonora"
  heroCaption="H. Cuerpo de Bomberos · Sonora"
  title={`Bomberos en ${estado} — Directorio`}
  description={`Bomberos en Sonora: ${estacionesSonora.length} estaciones — Nogales (1917, primer cuerpo del estado), Hermosillo (1946), minería de cobre Grupo México, desierto a 47 °C, Ford y frontera con Arizona. Emergencias: 911.`}
