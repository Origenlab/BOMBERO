// ─── FAQs específicas de Sonora (≥10) ────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Sonora?",
    a: `Marca el <strong>911</strong>, número único de emergencias disponible las 24 horas a través del C4 Sonora (Centro de Coordinación, Comando, Comunicaciones y Cómputo). En Hermosillo, el teléfono directo de la Estación Central es <strong>662 210 3600</strong>; en Nogales, <strong>631 312 1690</strong>; en Ciudad Obregón, <strong>644 415 7070</strong>. En cualquier emergencia activa, el 911 es la línea prioritaria.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Sonora?",
    a: `Este directorio registra <strong>${estacionesSonora.length} estaciones activas</strong> distribuidas en los principales municipios de Sonora: Hermosillo (4), Nogales (2), Ciudad Obregón (2), Guaymas y San Carlos, Puerto Peñasco, Cananea, Nacozari, San Luis Río Colorado, Caborca, Agua Prieta, Navojoa, Huatabampo, Magdalena de Kino, Álamos y otras localidades. Todos los datos de contacto están disponibles en el listado de esta página.`,
  },
  {
    q: "¿Cuándo se fundó el primer cuerpo de bomberos de Sonora?",
    a: `El <strong>primer cuerpo de bomberos del estado de Sonora fue el de Nogales</strong>, fundado el <strong>25 de noviembre de 1917</strong> por un grupo de ciudadanos encabezados por Gustavo L. Manríquez. El cuerpo lleva el nombre de su fundador: <strong>H. Cuerpo de Bomberos Voluntarios Gustavo L. Manríquez</strong>. En 2022 cumplió 105 años de servicio continuado. El Cuerpo de Bomberos de Hermosillo fue fundado posteriormente, el <strong>13 de agosto de 1946</strong>, por Jahudiel Zamorano Ledesma y siete voluntarios en la Sociedad de Artesanos.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Hermosillo?",
    a: `El <strong>13 de agosto de 1946</strong>, cuando Jahudiel Zamorano Ledesma y siete voluntarios firmaron el acta constitutiva del Club de Bomberos de Hermosillo A.C. en la Sociedad de Artesanos. En 2025 conmemoró su <strong>79 aniversario</strong>. El 15 de julio de 1950 se constituyó formalmente el <strong>Patronato de Bomberos de Hermosillo</strong>. La fecha nacional del Día del Bombero, el 22 de agosto, conmemora la fundación del primer cuerpo de México en Veracruz en 1873.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Ciudad Obregón?",
    a: `El <strong>4 de julio de 1949</strong>, cuando un grupo de ciudadanos de Cajeme encabezados por Ramón M. Ochoa constituyeron el Club de Bomberos Voluntarios de Ciudad Obregón, A.C., con Guillermo Vélez Calderón como primer comandante. El H. Cuerpo de Bomberos de Cajeme celebró su <strong>76 aniversario en julio de 2025</strong>.`,
  },
  {
    q: "¿Qué fue el derrame del río Sonora en 2014?",
    a: `El <strong>6 de agosto de 2014</strong>, una falla en las instalaciones de lixiviación del complejo Buenavista del Cobre de Grupo México en Cananea liberó aproximadamente <strong>40 millones de litros</strong> (40,000 m³) de solución de sulfato de cobre con ácido sulfúrico al Arroyo Tinajas, afluente del Río Bacanuchi y del Río Sonora. El frente contaminante recorrió más de 180 km del corredor fluvial, afectando el agua potable de más de 22,000 personas en 7 municipios. Es considerado el mayor desastre ambiental minero en la historia de México. Los bomberos de Cananea activaron coordinación con CONAGUA, COFEPRIS y la Brigada HAZMAT estatal.`,
  },
  {
    q: "¿Por qué el calor es un riesgo crítico para los bomberos en Sonora?",
    a: `Hermosillo ha sido registrada como la ciudad más caliente del mundo en picos estivales, alcanzando <strong>47.5 °C</strong> en agosto de 2024. A esas temperaturas, una persona sin agua puede desarrollar golpe de calor (temperatura corporal superior a 40°C, cese de sudoración, confusión) en 90 minutos a 3 horas. Los bomberos deben llevar tanques adicionales de agua al campo para protocolos de enfriamiento de emergencia, y los rescates en zonas desérticas alejadas pueden tardar entre 45 y 90 minutos de llegada, tiempo durante el cual el daño neurológico puede ser irreversible.`,
  },
  {
    q: "¿Qué es el acuerdo binacional de bomberos Sonora-Arizona?",
    a: `Sonora y Arizona mantienen un <strong>Convenio de Cooperación para la Prevención y Respuesta a Emergencias Binacionales</strong> firmado el 19 de junio de 2004 con vigencia indefinida. En la práctica, los cuerpos de bomberos de Nogales-Sonora y Nogales-Arizona coordinan activaciones de apoyo mutuo, con un plan binacional que se actualizó más recientemente tras la pausa pandémica. Acuerdos similares operan en Douglas/Agua Prieta y San Luis Río Colorado/San Luis Arizona.`,
  },
  {
    q: "¿Cuáles son los principales riesgos HAZMAT que enfrentan los bomberos de Sonora?",
    a: `Sonora concentra varios perfiles HAZMAT únicos en México: (1) <strong>minería de cobre</strong> en Cananea y Nacozari con ácido sulfúrico, cianuro y reactivos metalúrgicos; (2) <strong>industria automotriz</strong> en Hermosillo (Ford, Kia, maquiladoras Tier 1) con isocianatos, solventes orgánicos y baterías de litio; (3) <strong>frontera</strong> en Nogales, Agua Prieta y San Luis R.C. con carga internacional que puede incluir cualquier categoría de materiales peligrosos; (4) <strong>puertos</strong> de Guaymas con combustibles marinos e hidrocarburos; y (5) agroquímicos y fertilizantes en el Valle del Yaqui y Valle del Mayo.`,
  },
  {
    q: "¿Cómo atienden los bomberos las emergencias en el Golfo de California?",
    a: `Las estaciones de Guaymas, San Carlos y Puerto Peñasco cuentan con lanchas de rescate y coordinan con la Capitanía de Puerto y la Secretaría de Marina para emergencias marítimas en el Golfo de California. Atienden rescates de buzos, turistas en embarcaciones, incendios en instalaciones portuarias y control de derrames de hidrocarburo marino. Puerto Peñasco, conocido como Rocky Point en Arizona, recibe millones de turistas estadounidenses al año, por lo que sus bomberos mantienen capacidades de atención en inglés.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Sonora?",
    a: `Combate de <strong>incendios</strong> (estructurales, forestales, agrícolas e industriales), <strong>rescate vehicular</strong>, <strong>atención prehospitalaria</strong>, <strong>materiales peligrosos (HAZMAT)</strong> industrial/minero/fronterizo, <strong>rescate acuático</strong> en el Golfo de California, <strong>rescate aeronáutico (ARFF)</strong> en el aeropuerto de Hermosillo, control de <strong>fugas de gas</strong>, <strong>rescate en zonas desérticas</strong> con protocolo de golpe de calor, coordinación binacional con Arizona y <strong>prevención</strong> mediante inspecciones y simulacros.`,
  },
  {
    q: "¿Cómo puedo prevenir un incendio en zonas de calor extremo como Sonora?",
    a: `En el contexto sonorense: revisa <strong>sistemas de aire acondicionado</strong> antes de temporada (sobrecalentamiento eléctrico es causa frecuente de incendio en verano); no dejes vehículos con materiales inflamables al sol directo; en zonas rurales, evita quemas no controladas en época de calor; mantén <strong>detectores de humo</strong> y un extintor vigente. Ante cualquier emergencia, marca siempre el <strong>911</strong>. En el desierto, lleva siempre agua suficiente y un teléfono cargado en viajes fuera de localidades.`,
  },
];

// ─── Schema.org JSON-LD ───────────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio oficial de las ${estacionesSonora.length} estaciones de bomberos en Sonora. Hermosillo (fundación 1946), Nogales (1917, primer cuerpo del estado), Ciudad Obregón (1949). Minería de cobre Grupo México, corredor automotriz Ford-Kia, 588 km de frontera con Arizona, Golfo de California. Emergencias: 911.`,
  numberOfItems: estacionesSonora.length,
  itemListElement: estacionesSonora.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipio,
        addressRegion: estado,
        addressCountry: "MX",
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}/`,
    },
  })),
};

