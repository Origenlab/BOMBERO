    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipiosCubiertos?.[0] || estado,
