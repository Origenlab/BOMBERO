// ── Schemas estructurados ──────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Oaxaca",
  "description": `Directorio de las ${totalEstaciones} estaciones del Heroico Cuerpo de Bomberos del Estado de Oaxaca. Fundado en diciembre de 1954. Cobertura de 2 sitios UNESCO (Centro Histórico y Monte Albán), Costa Oaxaqueña, Istmo industrial y 570 municipios en sierra y mixteca. Emergencias: 911.`,
  "numberOfItems": totalEstaciones,
  "itemListElement": estacionesOaxaca.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.municipio ?? e.ciudad ?? "Oaxaca",
        "addressRegion": "Oaxaca",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/oaxaca/${e.slug}/`,
    },
  })),
};

