const totalEstaciones = estacionesOaxaca.length;
const totalMunicipios = getMunicipios().length;
const totalPersonal   = estacionesOaxaca.reduce((s, e) => s + (e.personal ?? 0), 0);

const canonical = "https://bombero.mx/directorio/oaxaca/";

// ── Zonas con perfil de cobertura ─────────────────────────────────────────
const zonas = [
  {
    nombre:    "Valles Centrales",
    municipios: ["Oaxaca de Juárez", "Santa Cruz Xoxocotlán", "Tlacolula"],
    nEst:       3,
    cobertura: "Total",
    chip:      "total",
    perfil:    "Centro Histórico UNESCO (1987), Monte Albán (1987), Aeropuerto OAX, Guelaguetza y Día de Muertos.",
