---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesChihuahua,
  ESTADISTICAS_CHIHUAHUA,
} from "@data/estaciones-chihuahua";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { breadcrumbJsonLd } from "@lib/seo";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("chihuahua");

// ── Derivar municipios y estadísticas desde el array de estaciones ──────────
const municipios        = [...new Set(estacionesChihuahua.map((e) => e.ciudad))].sort();
const totalEstaciones   = ESTADISTICAS_CHIHUAHUA.total_estaciones;
const totalMunicipios   = ESTADISTICAS_CHIHUAHUA.municipios_cubiertos;
const totalBomberos     = ESTADISTICAS_CHIHUAHUA.total_bomberos;
const totalUnidades     = ESTADISTICAS_CHIHUAHUA.total_unidades;

const canonical = "https://bombero.mx/directorio/chihuahua/";

// ── Comparativa regional ────────────────────────────────────────────────────
const zonasDef = [
  { nombre: "Zona Metropolitana Chihuahua", municipiosZona: ["Chihuahua"], cobertura: "Total", chip: "total", perfil: "Capital del estado · Parques industriales · Grutas de Nombre de Dios · Coordinación estatal." },
  { nombre: "Zona Fronteriza Ciudad Juárez",  municipiosZona: ["Juárez"],     cobertura: "Total", chip: "total", perfil: "400+ maquiladoras · ARFF Abraham González · Coordinación El Paso Fire Dept. · HAZMAT industrial." },
  { nombre: "Sierra Tarahumara",              municipiosZona: ["Creel", "Bocoyna", "Guachochi", "Madera", "Batopilas"], cobertura: "Media", chip: "media", perfil: "Barrancas del Cobre · rescate montaña · incendios forestales · –20°C en invierno." },
  { nombre: "Zona Agrícola Centro-Sur",       municipiosZona: ["Delicias", "Cuauhtémoc", "Camargo", "Jiménez"],         cobertura: "Alta",  chip: "alta",  perfil: "Agricultura tecnificada · comunidades menonitas · carreteras federales 45 y 45D." },
  { nombre: "Noroeste y Sur Histórico",       municipiosZona: ["Casas Grandes", "Nuevo Casas Grandes", "Hidalgo del Parral", "Santa Bárbara"], cobertura: "Media", chip: "media", perfil: "Paquimé UNESCO · rescate minero Parral · pastizales Janos." },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesChihuahua.filter((e) => z.municipiosZona.includes(e.ciudad));
  return {
    ...z,
    nEst:  est.length || "—",
    nPers: est.reduce((s, e) => s + (e.personal ?? 0), 0) || "—",
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0) || "—",
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio",                 url: "/" },
  { name: "Directorio de Bomberos", url: "/directorio/" },
  { name: "Chihuahua",              url: "/directorio/chihuahua/" },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Chihuahua, México",
  "description": `Directorio oficial de las ${totalEstaciones} estaciones de bomberos en Chihuahua. Teléfonos directos en Chihuahua capital, Ciudad Juárez, Creel, Hidalgo del Parral y más. Estado más grande de México, frontera 560 km con EE.UU. Emergencias: llama al 911.`,
  "numberOfItems": estacionesChihuahua.length,
  "itemListElement": estacionesChihuahua.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Chihuahua",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/chihuahua/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Chihuahua: estaciones, historia y servicios de emergencia",
  "description": "Guía del Heroico Cuerpo de Bomberos de Chihuahua: historia (1923–hoy), Ciudad Juárez (1918), infraestructura, HAZMAT maquiladoras, rescate Sierra Tarahumara, incendios forestales y directorio con teléfonos directos.",
  "about": [
    "Heroico Cuerpo de Bomberos de Chihuahua",
    "Heroico Cuerpo de Bomberos de Ciudad Juárez",
    "Protección Civil Chihuahua",
    "Incendios forestales Sierra Tarahumara",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/chihuahua.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Chihuahua",
  "description": `Directorio verificado de las ${totalEstaciones} estaciones de bomberos en Chihuahua en ${totalMunicipios} ciudades, con teléfonos, cobertura, funciones e historia del Heroico Cuerpo de Bomberos.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de Chihuahua" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/chihuahua.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Chihuahua (≥10) — alimentan el FAQPage schema ─────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Chihuahua?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas en todo el estado, con o sin saldo, en español e inglés. Los teléfonos directos por ciudad son: Chihuahua capital (614 429-3300), Ciudad Juárez (656 616-1000), Creel / Sierra Tarahumara (635 456-0066), Hidalgo del Parral (627 522-0077), Cuauhtémoc (625 581-0088). En zonas rurales y serranas, el tiempo de respuesta puede extenderse; el 911 activa también helicópteros estatales en emergencias de alto riesgo.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de Chihuahua capital?",
    a: `El <strong>Heroico Cuerpo de Bomberos de Chihuahua</strong> fue fundado en <strong>1923</strong> con una plantilla inicial de cuatro elementos. El <strong>28 de noviembre de 1948</strong>, sesenta bomberos respondieron a un incendio en la ferretería "La Sirena" (Las Palmas y 16 de Septiembre); la barda del inmueble colapsó y sepultó a <strong>12 bomberos bajo los escombros</strong>. A partir de ese episodio se les llamó héroes y la institución adoptó el nombre de <strong>Heroico Cuerpo de Bomberos</strong>. En 2023 se conmemoró su primer centenario.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de Ciudad Juárez?",
    a: `El <strong>Cuerpo de Bomberos de Ciudad Juárez</strong> fue fundado en <strong>1918</strong> bajo el mando del jefe <strong>Arturo Duglas</strong>, durante la administración municipal de Alberto B. Almeida. Nació como cuerpo voluntario ante la urgencia de atender los incendios frecuentes de la ciudad. En <strong>1926</strong> se adquirió la primera máquina extintora, lo que marcó el inicio de la profesionalización. En mayo de 2025 el cuerpo celebró su <strong>107 aniversario</strong>.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque conmemora la fundación del <strong>primer cuerpo de bomberos de México</strong> el 22 de agosto de <strong>1873 en Veracruz</strong>. Desde 1956 se celebra en esa fecha el <strong>Día del Bombero</strong> en toda la República. Tanto el Heroico Cuerpo de Bomberos de Chihuahua como el de Ciudad Juárez son reconocidos cada año en esa fecha.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Chihuahua?",
    a: `El directorio de Chihuahua reúne <strong>${totalEstaciones} estaciones</strong> activas en <strong>${totalMunicipios} ciudades</strong> del estado. La distribución principal es: Chihuahua capital (5 estaciones), Ciudad Juárez (7 estaciones), Sierra Tarahumara (Creel, Bocoyna, Guachochi, Madera, Batopilas), Zona Agrícola Centro-Sur (Delicias, Cuauhtémoc, Camargo, Jiménez) y Sur Histórico (Hidalgo del Parral, Nuevo Casas Grandes). Encuentra el directorio completo con teléfonos directos en esta página.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en Chihuahua?",
    a: `Combate de <strong>incendios</strong> (estructurales, forestales e industriales), <strong>rescate vehicular</strong> en carreteras, <strong>materiales peligrosos (HAZMAT)</strong> en la zona maquiladora de Ciudad Juárez, <strong>rescate de montaña y barranca</strong> en las Barrancas del Cobre, <strong>búsqueda en desierto</strong>, atención prehospitalaria, control de <strong>fugas de gas</strong>, rescate en espacios confinados (minas de Parral), servicio ARFF en el Aeropuerto Internacional Abraham González y coordinación binacional con el <strong>El Paso Fire Department</strong> de Texas.`,
  },
  {
    q: "¿Cuál es el riesgo de incendios forestales en la Sierra Tarahumara?",
    a: `Chihuahua es el estado con mayor afectación forestal del país. En la temporada <strong>2025</strong> se registraron <strong>598 incendios</strong> que consumieron más de <strong>222,000 hectáreas</strong> —un aumento de 827.6% respecto a 2024—, con los focos más intensos en Bocoyna, Guadalupe y Calvo y otros municipios serranos. Las brigadas de bomberos de Creel, Madera, Guachochi y Bocoyna, junto con más de 400 combatientes del Estado y la Federación, operan con vehículos 4×4 y equipo de combate forestal en la <strong>Sierra Madre Occidental</strong> durante la temporada seca (nov–may).`,
  },
  {
    q: "¿Cómo responden los bomberos de Ciudad Juárez a emergencias en maquiladoras?",
    a: `Las estaciones de Ciudad Juárez —incluyendo la unidad de <strong>Zona Industrial</strong>— cuentan con unidades HAZMAT especializadas, laboratorio móvil de identificación química y sistemas de descontaminación masiva para atender las más de <strong>400 plantas maquiladoras</strong> de las industrias automotriz (Delphi, Bosch), aeroespacial, electrónica (Foxconn, Lexmark) y médica. Los protocolos de respuesta están coordinados con el <strong>El Paso Fire Department</strong> de Texas y contemplan despliegue cruzado de unidades para incidentes transfronterizos.`,
  },
  {
    q: "¿Qué debo hacer en una emergencia en la Sierra Tarahumara o las Barrancas del Cobre?",
    a: `Marca el <strong>911</strong> de inmediato; el sistema puede activar helicópteros de rescate para emergencias en zonas de difícil acceso. La estación de <strong>Creel</strong> (Pueblo Mágico, 2,338 msnm) es la sede de rescate de montaña más especializada del norte: personal certificado en rappel, tirolesa y búsqueda en barranca, con equipos de atención de hipotermia para los <strong>–20°C de la sierra en invierno</strong>. La estación de Bocoyna cubre el recorrido del tren Chepe (Chihuahua al Pacífico). Da tu ubicación exacta o el kilómetro de carretera más cercano.`,
  },
  {
    q: "¿Qué debo hacer si detecto un incendio o una fuga de gas en Chihuahua?",
    a: `Llama de inmediato al <strong>911</strong>. Ante una <strong>fuga de gas</strong>: no acciones interruptores, cierra la llave de paso, ventila el espacio y evacúa; en invierno las intoxicaciones por calefacción de propano son frecuentes en la Sierra Tarahumara. Ante un <strong>incendio</strong>: sal de inmediato, cierra puertas a tu paso para frenar el avance del fuego y nunca regreses por objetos. En zonas rurales del desierto con tiempos de respuesta de 45–90 minutos, señala tu ubicación con claridad y mantén encendido el teléfono.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios forestales en la Sierra Tarahumara?",
    a: `No enciendas fogatas en temporada de estiaje (noviembre–mayo) fuera de los sitios habilitados; nunca dejes brasas sin apagar; no arrojes colillas desde el automóvil en carreteras serranas. Reporta humo o columnas de fuego de inmediato al <strong>911</strong> o a la Comisión Nacional Forestal (CONAFOR). El acceso oportuno de las brigadas depende de alertas tempranas: un reporte a tiempo puede salvar miles de hectáreas de bosque de pino-encino de la <strong>Sierra Madre Occidental</strong>.`,
  },
  {
    q: "¿Cuánto personal tiene el Heroico Cuerpo de Bomberos de Chihuahua capital?",
    a: `El Heroico Cuerpo de Bomberos del Municipio de Chihuahua cuenta con <strong>212 elementos</strong>, incluyendo 39 mujeres bombero, distribuidos en ocho estaciones de la capital, según datos oficiales de 2023. A nivel estatal, el directorio de Chihuahua suma <strong>${totalBomberos.toLocaleString()} bomberos</strong> en las ${totalEstaciones} estaciones publicadas en esta página.`,
  },
];



