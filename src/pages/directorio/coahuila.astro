---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesCoahuila,
  ESTADISTICAS_COAHUILA,
} from "@data/estaciones-coahuila";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("coahuila");

// ── Derivar municipios desde el array de estaciones ────────────────────────
const municipios      = [...new Set(estacionesCoahuila.map((e) => e.ciudad))].sort();
const totalEstaciones = ESTADISTICAS_COAHUILA.total_estaciones;
const totalMunicipios = ESTADISTICAS_COAHUILA.municipios_cubiertos;
const totalBomberos   = ESTADISTICAS_COAHUILA.total_bomberos;
const totalUnidades   = ESTADISTICAS_COAHUILA.total_unidades;

const canonical = "https://bombero.mx/directorio/coahuila/";

// ── Comparativa regional ───────────────────────────────────────────────────
const zonas = [
  {
    nombre:    "Sureste / Saltillo (Capital)",
    nEst:      ESTADISTICAS_COAHUILA.estaciones_saltillo,
    cobertura: "Total",
    chip:      "total",
    perfil:    "Capital del estado; clúster automotriz GM/Chrysler/Daimler en Ramos Arizpe; Sierra de Arteaga (incendios forestales).",
