  {
    nombre:    "Región Carbonífera (Sabinas-Múzquiz)",
    nEst:      ESTADISTICAS_COAHUILA.estaciones_carboniferas,
    cobertura: "Media",
    chip:      "media",
    perfil:    "95 % de la producción nacional de carbón; minas subterráneas activas; rescate minero especializado.",
  },
  {
    nombre:    "Norte / Frontera con Texas",
    nEst:      ESTADISTICAS_COAHUILA.estaciones_frontera,
    cobertura: "Media",
    chip:      "media",
    perfil:    "512 km de frontera; protocolos binacionales Eagle Pass / Del Rio; Presa de la Amistad (cuenca compartida).",
  },
