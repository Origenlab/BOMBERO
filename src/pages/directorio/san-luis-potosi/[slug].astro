---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesSanLuisPotosi, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-san-luis-potosi";

// Generar rutas estaticas
export function getStaticPaths() {
  return estacionesSanLuisPotosi.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "San Luis Potosi",
  slug: "san-luis-potosi",
  siglas: "SLP",
  poblacion: "2.8 millones",
  municipios: 58,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Zacatecas", slug: "zacatecas" },
  { nombre: "Nuevo Leon", slug: "nuevo-leon" },
  { nombre: "Tamaulipas", slug: "tamaulipas" },
  { nombre: "Guanajuato", slug: "guanajuato" },
  { nombre: "Queretaro", slug: "queretaro" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? estacion.municipiosCubiertos?.[0] ?? "San Luis Potosi";

// Tarjetas EPP para la seccion de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Disenado para los bomberos de <strong>${ubicacion}</strong> que protegen el corazon industrial de Mexico. Certificacion HAZMAT para emergencias en plantas automotrices BMW y GM, y proteccion contra incendios estructurales.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificacion NFPA 1971 para operaciones en <strong>San Luis Potosi</strong>. Compatible con rescate espeleologico en la Huasteca Potosina y emergencias industriales en la zona automotriz mas importante del Bajio.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia termica y quimica certificada para emergencias HAZMAT en <strong>${ubicacion}</strong>. Prension segura para rescate en cuevas, cenotes y operaciones en el corredor industrial San Luis-Villa de Reyes.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el exigente entorno de <strong>San Luis Potosi</strong>. Suela antiderrapante para pisos industriales, terreno espeleologico en la Huasteca y Centro Historico colonial.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>

  <Fragment slot="seo-content">
    <h2>Bomberos en {ubicacion}, San Luis Potosi</h2>
    <p>
      La <strong>{estacion.nombreCorto ?? estacion.nombre}</strong> es parte del <strong>H. Cuerpo de Bomberos de {ubicacion}</strong>,
      institucion que protege a los mas de <strong>2.8 millones de potosinos</strong>. Esta estacion, ubicada en
      <strong>{estacion.direccion}</strong>, brinda atencion las 24 horas del dia,
      los 365 dias del ano.
    </p>
    <p>
      En caso de <strong>emergencia en {ubicacion}</strong>, marca el <strong>911</strong> o comunicate directamente
      a esta estacion al <strong>{estacion.telefono}</strong>. Los bomberos de San Luis Potosi estan capacitados para atender
      incendios estructurales e industriales, emergencias HAZMAT, rescate espeleologico, swift water rescue,
      incendios forestales y todo tipo de emergencias.
    </p>
    <h3>San Luis Potosi: El Corazon de Mexico</h3>
    <p>
      <strong>San Luis Potosi</strong> es el corazon industrial de Mexico, sede de plantas automotrices de
      <strong>BMW</strong> y <strong>General Motors</strong>, asi como cientos de proveedores Tier 1 y Tier 2.
      La <strong>Huasteca Potosina</strong> es uno de los destinos ecoturisticos mas importantes del pais,
      con cascadas, sotanos, cuevas y cenotes que requieren equipos especializados de rescate espeleologico.
      El estado cuenta con <strong>7 Pueblos Magicos</strong> y un Centro Historico colonial patrimonio nacional.
      Los bomberos enfrentan emergencias industriales de alta complejidad, incendios forestales y rescates en zonas de dificil acceso.
    </p>
    <h3>Necesitas equipo certificado para bomberos?</h3>
    <p>
      En <strong><a href="/">BOMBERO.MX</a></strong> somos distribuidores autorizados de <strong>equipo para bomberos certificado NFPA</strong>.
      Equipamos estaciones en todo San Luis Potosi con <a href="/productos/trajes-para-bomberos/">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>, <a href="/productos/guantes-para-bomberos/">guantes</a>,
      <a href="/productos/trajes-para-bomberos/traje-hazmat/">trajes HAZMAT</a> y mas.
      <a href="/cotizar/">Solicita una cotizacion</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
