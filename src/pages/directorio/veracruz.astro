    "Rescate marítimo Puerto de Veracruz",
    "HAZMAT industria petroquímica Coatzacoalcos",
    "Rescate de altura Pico de Orizaba",
  ],
  inLanguage: "es-MX",
  image: "https://bombero.mx/api/og/estado/veracruz.svg",
  author:    { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  publisher: { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
