---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";
import {
  estacionesZacatecas,
  getMunicipios,
} from "@data/estaciones-zacatecas";

const estado = "Zacatecas";
const sigla = "ZAC";
const slug = "zacatecas";

const canonical = "https://bombero.mx/directorio/zacatecas/";

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const totalEstaciones = estacionesZacatecas.length;
const municipios      = getMunicipios();
const totalMunicipios = municipios.length;
const totalBomberos   = estacionesZacatecas.reduce((s, e) => s + (e.personalActivo ?? 0), 0);
const totalUnidades   = 58; // ESTADISTICAS_ZACATECAS.total_unidades

// ── Comparativa regional ───────────────────────────────────────────────────
const zonasDef = [
  {
    nombre:    "ZM Zacatecas-Guadalupe",
    municipios: ["Zacatecas", "Guadalupe"],
    cobertura: "Total",
    chip:      "total",
    perfil:    "Centro Histórico UNESCO (1993), Catedral barroca, Mina El Edén, 2 440 msnm.",
  },
  {
    nombre:    "Corredor Minero Fresnillo",
    municipios: ["Fresnillo"],
    cobertura: "Alta",
    chip:      "alta",
    perfil:    "Peñasquito (Newmont, ~33 Moz Ag/año), Fresnillo plc, HAZMAT explosivos/cianuro.",
  },
  {
    nombre:    "Corredor Minero Noreste",
    municipios: ["Concepción del Oro"],
    cobertura: "Alta",
    chip:      "alta",
    perfil:    "Minas de plata y zinc activas; Real de Providencia; ácidos mineros.",
  },
  {
    nombre:    "Pueblos Mágicos y Sierra",
    municipios: ["Jerez", "Sombrerete", "Valparaíso"],
    cobertura: "Media",
    chip:      "media",
    perfil:    "Jerez (Pueblo Mágico), Sombrerete (450 años minería), Sierra de Órganos PN.",
  },
  {
    nombre:    "Corredor Norte y Sur",
    municipios: ["Río Grande", "Juan Aldama", "Juchipila", "Nochistlán de Mejia", "Loreto", "Tlaltenango", "Pinos", "Villanueva"],
    cobertura: "Baja",
    chip:      "baja",
    perfil:    "Ganadería extensiva, carreteras 45 y 54D, Sierra Madre Occidental, Cañón de Juchipila.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesZacatecas.filter((e) => z.municipios.includes(e.municipio ?? ""));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio verificado de las ${totalEstaciones} estaciones de bomberos en Zacatecas. Centro Histórico UNESCO (1993), Peñasquito mayor productora de plata en México (~33 Moz/año), HAZMAT especializado en cianuro y explosivos mineros, Sierra de Órganos Parque Nacional. Emergencias: 911.`,
  numberOfItems: totalEstaciones,
  itemListElement: estacionesZacatecas.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipio,
        addressRegion: estado,
        addressCountry: "MX",
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}/`,
    },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Bomberos en Zacatecas: estaciones, historia y servicios de emergencia",
  description: "Guía del H. Cuerpo de Bomberos de Zacatecas: historia, infraestructura en 15 municipios, HAZMAT minero, protección del Centro Histórico UNESCO y directorio de estaciones con teléfonos directos.",
  about: [
    "H. Cuerpo de Bomberos de Zacatecas",
    "Protección Civil",
    "HAZMAT minero",
    "Rescate en espacios confinados",
  ],
  inLanguage: "es-MX",
  image: `https://bombero.mx/api/og/estado/${slug}.svg`,
  author:    { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  publisher: { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  dateModified: DIRECTORIO_VERIFICADO_ISO,
  mainEntityOfPage: canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  url: canonical,
  name: "Estaciones de Bomberos en Zacatecas",
  description: `Directorio verificado de ${totalEstaciones} estaciones de bomberos en Zacatecas, con teléfonos, cobertura, funciones e historia del H. Cuerpo de Bomberos del estado minero de México.`,
  inLanguage: "es-MX",
  isPartOf: { "@type": "WebSite", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  about: { "@type": "GovernmentOrganization", name: "H. Cuerpo de Bomberos de Zacatecas" },
  primaryImageOfPage: `https://bombero.mx/api/og/estado/${slug}.svg`,
  dateModified: DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Zacatecas (≥10) ─────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Zacatecas?",
    a: `Marca el <strong>911</strong> desde cualquier teléfono en el estado; el sistema opera las 24 horas y despacha a la estación más cercana. Para emergencias directas en la capital puedes llamar al <strong>492 922 0020</strong> (Cuartel Central Zacatecas) y en el corredor minero de Fresnillo al <strong>493 932 0101</strong>. En cualquier emergencia, el 911 es la línea recomendada.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Zacatecas?",
    a: `Este directorio reúne <strong>${totalEstaciones} estaciones verificadas</strong> del H. Cuerpo de Bomberos de Zacatecas, distribuidas en <strong>${totalMunicipios} municipios</strong> que abarcan las principales zonas urbanas, el corredor minero y las regiones serranas del estado.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque el <strong>22 de agosto de 1873</strong> se fundó en el puerto de <strong>Veracruz</strong> el primer cuerpo de bomberos de México. La fecha se conmemora anualmente en todo el país, incluidos los bomberos de Zacatecas, como reconocimiento a su labor de proteger vidas y bienes.`,
  },
  {
    q: "¿Qué hace especial la labor de los bomberos de Zacatecas frente a otros estados?",
    a: `Zacatecas es el estado con mayor producción de plata de México —alrededor del <strong>40 % del total nacional</strong>— lo que exige a sus bomberos certificaciones HAZMAT de clase mundial: manejo de cianuro de sodio (proceso de cianuración), explosivos tipo ANFO, xantatos de flotación y ácidos mineros. A esto se suma la protección del <strong>Centro Histórico Patrimonio de la Humanidad UNESCO (1993)</strong> y el rescate en terreno serrano a más de 2 400 msnm.`,
  },
  {
    q: "¿Qué es el HAZMAT minero y por qué es crítico en Zacatecas?",
    a: `HAZMAT (materiales peligrosos) en contexto minero incluye <strong>cianuro de sodio</strong> usado en el proceso de cianuración para disolver oro y plata, explosivos industriales como <strong>ANFO y emulsiones</strong>, xantatos inflamables usados en flotación de zinc, y ácidos de lixiviación. En Zacatecas estos químicos están presentes en operaciones a gran escala —Peñasquito en Mazapil, Fresnillo plc en Fresnillo— y un incidente mal atendido puede ser letal en segundos si el bombero no porta SCBA y detector de gases.`,
  },
  {
    q: "¿Por qué la Mina El Edén es un riesgo especial para los bomberos de Zacatecas capital?",
    a: `La <strong>Mina El Edén</strong> es un museo subterráneo en el Cerro del Grillo, a minutos del Centro Histórico, con túneles a más de 320 metros de profundidad. En una emergencia con visitantes en su interior, los bomberos enfrentan evacuación en espacios confinados, comunicaciones limitadas por radio a partir de los 50 m de profundidad, aire sin oxígeno suficiente en galerías sin ventilación activa y temperatura creciente con la profundidad. Los protocolos de respuesta en minería subterránea son obligatorios, no opcionales, en este escenario.`,
  },
  {
    q: "¿Cómo afectan las heladas y el clima del altiplano a las operaciones de bomberos en Zacatecas?",
    a: `La ciudad de Zacatecas se ubica a <strong>2 440 msnm</strong> en el altiplano semiárido; las temperaturas invernales caen regularmente por debajo de 0 °C y pueden alcanzar <strong>-10 °C</strong> en zonas serranas. El frío extremo aumenta el riesgo de incendios por calefactores y estufas de leña mal instalados, reduce la autonomía de los SCBA (mayor frecuencia respiratoria), congela mangueras y válvulas, y dificulta el rescate vial en carreteras heladas. En verano, la humedad relativa puede caer por debajo del 20 %, elevando el riesgo de incendio forestal.`,
  },
  {
    q: "¿Cuántas hectáreas afectaron los incendios forestales en Zacatecas recientemente?",
    a: `En los primeros meses de <strong>2026</strong>, antes de que iniciara oficialmente la temporada de incendios forestales, el fuego ya había consumido más de <strong>4 500 hectáreas</strong> en Zacatecas. La temporada de estiaje (noviembre–mayo) combinada con el clima semiárido del altiplano genera condiciones de alto riesgo que activan la coordinación entre bomberos municipales y brigadas de <strong>CONAFOR</strong>.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Zacatecas?",
    a: `Combate de <strong>incendios estructurales, forestales e industriales</strong>; <strong>rescate vehicular</strong> y extricación; <strong>atención prehospitalaria</strong>; <strong>HAZMAT minero</strong> (cianuro, explosivos, ácidos); rescate en <strong>espacios confinados y minas</strong>; control de <strong>fugas de gas</strong>; <strong>rescate en montaña</strong> (Sierra de Órganos, Sierra Madre Occidental); protección del <strong>patrimonio histórico UNESCO</strong> y prevención e inspecciones de Protección Civil.`,
  },
  {
    q: "¿Los bomberos de Zacatecas cobran por sus servicios de emergencia?",
    a: `Las emergencias que ponen en riesgo la vida —incendios, rescates, fugas de gas, accidentes— se atienden de forma <strong>gratuita</strong>. Algunos servicios secundarios como dictámenes técnicos, capacitación a empresas o simulacros pueden tener cuota de recuperación según el municipio. La atención de emergencia nunca se condiciona a un pago.`,
  },
  {
    q: "¿Cómo coordina el Cuerpo de Bomberos de Zacatecas con las brigadas mineras privadas?",
    a: `Las grandes operaciones mineras —Peñasquito (Newmont), Fresnillo plc— mantienen brigadas de emergencia internas certificadas en rescate minero. En un incidente de magnitud, los bomberos municipales activan el <strong>Sistema de Comando de Incidentes (ICS)</strong> para coordinar la respuesta integrada, donde las brigadas internas conocen la planta y los gases presentes, y los bomberos municipales aportan la capacidad de extinción y el mando unificado. Esta coordinación se practica en simulacros periódicos.`,
  },
  {
    q: "¿Cómo puedo prevenir emergencias en mi hogar en Zacatecas?",
    a: `Revisa periódicamente la instalación de <strong>gas LP</strong> (mangueras, reguladores) y la <strong>instalación eléctrica</strong>; evita sobrecargar contactos. En temporada de frío, utiliza calefactores certificados y con ventilación adecuada; nunca uses braseros en interiores cerrados. Instala un <strong>detector de humo</strong> y ten un extintor accesible. Comparte el número <strong>911</strong> con toda tu familia y practica un <strong>plan de evacuación</strong> con punto de reunión definido.`,
  },
];

