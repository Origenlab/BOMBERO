          <tr><td><strong>HAZMAT minero (cianuro, explosivos)</strong></td><td>24/7</td><td>Fresnillo, Concepción del Oro, Zacatecas capital</td></tr>
          <tr><td><strong>Rescate en espacios confinados</strong></td><td>24/7</td><td>Brigadas especializadas corredor minero</td></tr>
