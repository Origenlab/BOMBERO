---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesCDMX,
  getAlcaldias,
} from "@data/estaciones-cdmx";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { breadcrumbJsonLd } from "@lib/seo";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("ciudad-de-mexico");

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const alcaldias       = getAlcaldias();
const totalEstaciones = estacionesCDMX.length;
const totalAlcaldias  = alcaldias.length;
const totalBomberos   = estacionesCDMX.reduce((sum, e) => sum + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesCDMX.reduce((sum, e) => sum + (e.unidades ?? 0), 0);

const canonical = "https://bombero.mx/directorio/ciudad-de-mexico/";

// ── Comparativa regional (calculada desde los datos reales del directorio) ──
const limpiaAlcaldia = (a: string) =>
  a.replace(" de Morelos", "").replace("La Magdalena Contreras", "Magdalena Contreras");

const zonasDef = [
  { nombre: "Centro y Oriente",     alcaldias: ["Cuauhtémoc", "Venustiano Carranza", "Iztacalco", "Iztapalapa"],                       cobertura: "Total", chip: "total", perfil: "Centro Histórico (UNESCO), Metro, AICM y la mayor densidad de población de la capital." },
  { nombre: "Norte",                alcaldias: ["Gustavo A. Madero", "Azcapotzalco"],                                                   cobertura: "Alta",  chip: "alta",  perfil: "Basílica de Guadalupe y corredor industrial de Vallejo-Azcapotzalco." },
  { nombre: "Poniente y Barrancas", alcaldias: ["Miguel Hidalgo", "Álvaro Obregón", "Cuajimalpa de Morelos", "La Magdalena Contreras"], cobertura: "Alta",  chip: "alta",  perfil: "Corporativos, barrancas profundas y el bosque del Desierto de los Leones." },
  { nombre: "Sur y Zona Lacustre",  alcaldias: ["Tlalpan", "Coyoacán", "Benito Juárez", "Xochimilco", "Tláhuac", "Milpa Alta"],         cobertura: "Media", chip: "media", perfil: "Ajusco, Suelo de Conservación y las chinampas de Xochimilco (UNESCO)." },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesCDMX.filter((e) => z.alcaldias.includes(e.alcaldia ?? ''));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio",                 url: "/" },
  { name: "Directorio de Bomberos", url: "/directorio/" },
  { name: "Ciudad de México",       url: "/directorio/ciudad-de-mexico/" },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Ciudad de México",
  "description": `Directorio de las ${totalEstaciones} estaciones del Heroico Cuerpo de Bomberos de la Ciudad de México en las 16 alcaldías. Primera estación instalada en 1887; carácter "Heroico" desde 1951. Búsqueda y rescate urbano (USAR) en suelo lacustre, ARFF del AICM y rescate acuático en Xochimilco. Emergencias: 911.`,
  "numberOfItems": estacionesCDMX.length,
  "itemListElement": estacionesCDMX.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Ciudad de México",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/ciudad-de-mexico/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en la Ciudad de México: estaciones, historia y servicios de emergencia",
  "description": "Guía del Heroico Cuerpo de Bomberos de la Ciudad de México: historia (1873–hoy), infraestructura en las 16 alcaldías, funciones, retos y directorio de estaciones con teléfonos directos.",
  "about": [
    "Heroico Cuerpo de Bomberos de la Ciudad de México",
    "Protección Civil",
    "Búsqueda y rescate urbano",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/ciudad-de-mexico.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en la Ciudad de México",
  "description": `Directorio verificado de estaciones de bomberos en las 16 alcaldías de la Ciudad de México, con teléfonos, cobertura, funciones e historia del Heroico Cuerpo de Bomberos.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de la Ciudad de México" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/ciudad-de-mexico.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de la Ciudad de México (≥10) — alimentan el FAQPage schema ───
const faqsCDMX = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en la Ciudad de México?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas a través del Centro de Comando, Control, Cómputo, Comunicaciones y Contacto Ciudadano (C5). La llamada se enruta a la estación con menor tiempo de respuesta desde tu ubicación. En zonas urbanas densas el tiempo promedio de llegada es de <strong>4 a 8 minutos</strong>. Algunas comandancias conservan el histórico <strong>068</strong>, pero el 911 es la línea recomendada.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en la Ciudad de México?",
    a: `El Heroico Cuerpo de Bomberos de la Ciudad de México opera <strong>23 instalaciones oficiales</strong> (estaciones y subestaciones) distribuidas en las <strong>16 alcaldías</strong>, según el directorio oficial del Gobierno de la Ciudad de México. Este directorio reúne <strong>${totalEstaciones} estaciones</strong> con teléfono directo, dirección y servicios; la sede es la Estación Central, en el Centro de la ciudad.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de la Ciudad de México?",
    a: `El <strong>primer cuerpo de bomberos de México</strong> se fundó el <strong>22 de agosto de 1873 en Veracruz</strong>. En la capital, la <strong>primera estación de bomberos se instaló en 1887</strong>, en el Centro Histórico. El primer Reglamento del Cuerpo de Bomberos se expidió en <strong>1922</strong> y en <strong>1951</strong>, por decreto presidencial, se le otorgó el carácter de <strong>"Heroico"</strong>.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque conmemora la fundación del <strong>primer cuerpo de bomberos del país</strong>, el 22 de agosto de 1873 en el puerto de Veracruz. Cada año, en esa fecha, se reconoce la labor de los bomberos de toda la República, incluidos los del Heroico Cuerpo de Bomberos de la Ciudad de México.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de la Ciudad de México?",
    a: `Combate de <strong>incendios</strong> (estructurales, forestales y de pasto), <strong>rescate vehicular</strong> y extricación, <strong>atención prehospitalaria</strong>, <strong>búsqueda y rescate urbano (USAR)</strong> en derrumbes y sismos, <strong>materiales peligrosos (HAZMAT)</strong>, control de <strong>fugas de gas</strong>, atención de <strong>inundaciones</strong> y encharcamientos, rescate acuático en Xochimilco y Tláhuac, retiro de enjambres y manejo de fauna. La prevención (inspecciones y capacitación) también es parte central de su labor.`,
  },
  {
    q: "¿Los servicios de los bomberos de la CDMX tienen costo?",
    a: `Las emergencias que comprometen la <strong>vida o la integridad</strong> de las personas —incendios, rescates, fugas de gas— se atienden de forma <strong>gratuita</strong>. Algunos servicios secundarios (retiro de enjambres, dictámenes, capacitación a empresas) pueden tener una cuota de recuperación. La atención de emergencia nunca se condiciona a un pago.`,
  },
  {
    q: "¿Cómo responden los bomberos a un sismo en la Ciudad de México?",
    a: `El <strong>suelo lacustre</strong> del antiguo Lago de Texcoco amplifica las ondas sísmicas varias veces, lo que multiplica el riesgo de colapso. Por eso el cuerpo mantiene brigadas de <strong>búsqueda y rescate urbano (USAR)</strong> con equipo de corte, detección de vida y apuntalamiento. El <strong>Sistema de Alerta Sísmica (SASMEX)</strong> da segundos de aviso y la respuesta se coordina con la Secretaría de Gestión Integral de Riesgos y Protección Civil y el C5. El sismo de 1985 fue el punto de inflexión que dio origen al Sistema Nacional de Protección Civil.`,
  },
  {
    q: "¿Quién atiende las emergencias en el Aeropuerto Internacional (AICM)?",
    a: `El AICM cuenta con un servicio de <strong>rescate y extinción de incendios de aeronaves (ARFF)</strong> con vehículos especializados y tiempos de respuesta de pocos minutos a cualquier punto de las pistas, conforme a los estándares de aviación. Trabaja en coordinación con el Heroico Cuerpo de Bomberos para incidentes en el entorno aeroportuario.`,
  },
  {
    q: "¿Cómo se atiende un incendio dentro del Metro de la Ciudad de México?",
    a: `El Sistema de Transporte Colectivo Metro —12 líneas y 195 estaciones— exige protocolos específicos para espacios subterráneos confinados: uso de <strong>equipo de respiración autónoma (SCBA)</strong>, ventilación, evacuación masiva y coordinación con el personal del STC. Las estaciones de bomberos de la zona central entrenan de forma específica para este escenario.`,
  },
  {
    q: "¿Qué debo hacer si detecto un incendio o una fuga de gas en casa?",
    a: `Llama de inmediato al <strong>911</strong>. Ante una <strong>fuga de gas</strong>: no enciendas ni apagues interruptores, no uses el teléfono dentro del inmueble, cierra la llave de paso, abre puertas y ventanas y evacúa. Ante un <strong>incendio</strong>: sal de inmediato, cierra puertas a tu paso para frenar el avance del fuego y nunca regreses por objetos. No intentes combatir un fuego que ya no puedes controlar.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en mi hogar en la Ciudad de México?",
    a: `Revisa periódicamente la instalación de <strong>gas</strong> (mangueras, reguladores y conexiones) y la <strong>instalación eléctrica</strong>; evita sobrecargar contactos y "diablitos". Instala <strong>detectores de humo</strong>, mantén un extintor vigente y accesible, no dejes velas o estufas sin vigilancia y acuerda con tu familia un <strong>plan de evacuación</strong> con punto de reunión. Conserva el 911 visible para todos en casa.`,
  },
  {
    q: "¿Cómo puedo apoyar o convertirme en bombero en la Ciudad de México?",
    a: `Puedes apoyar mediante donativos al patronato del cuerpo de bomberos o difundiendo este directorio. Para ingresar como bombero, el Heroico Cuerpo de Bomberos forma a su personal en su <strong>Academia de Bomberos</strong> y publica convocatorias de reclutamiento con requisitos de edad, escolaridad y condición física. Consulta los canales oficiales del Gobierno de la Ciudad de México para fechas vigentes.`,
  },
];
const faqsEstado = faqsCDMX.map((f) => ({ q: f.q, a: f.a }));

