<DirectorioEstadoLayout
  estado={estado}
  sigla={sigla}
  slug={slug}
  description={`Bomberos en Tlaxcala: ${totalEstaciones} estaciones, historia desde 1982, HAZMAT Audi y Ferromex en Apizaco, rescate alta montaña La Malinche (4,461 msnm) e incendios textiles Chiautempan. Emergencias: 911.`}
