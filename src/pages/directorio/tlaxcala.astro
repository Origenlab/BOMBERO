---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesTlaxcala,
  getMunicipios,
  getEstacionBySlug,
  getEstacionesCercanas,
} from "@data/estaciones-tlaxcala";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { breadcrumbJsonLd } from "@utils/seo";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estado = "Tlaxcala";
const sigla = "TLA";
const slug = "tlaxcala";

const canonical = "https://bombero.mx/directorio/tlaxcala/";

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const municipios      = getMunicipios();
const totalEstaciones = estacionesTlaxcala.length;
const totalMunicipios = municipios.length;
const totalBomberos   = estacionesTlaxcala.reduce((sum, e) => sum + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesTlaxcala.reduce((sum, e) => sum + (e.unidades ?? 0), 0);

// ── Comparativa regional ───────────────────────────────────────────────────
const zonas = [
  {
    nombre: "Capital e histórica",
    municipiosZona: ["Tlaxcala", "Ixtacuixtla", "Papalotla", "Tlaltelulco"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital del estado, Centro Histórico colonial (s. XVI), Xochitécatl-Cacaxtla y corredor Apizaco.",
  },
  {
    nombre: "Corredor industrial norte",
    municipiosZona: ["Apizaco", "Tetla"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Nodo ferroviario Ferromex, parque industrial con química/farmacéutica y sector textil.",
  },
  {
    nombre: "Audi / automotriz",
    municipiosZona: ["San José Chiapa"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Única planta Audi en América. HAZMAT automotriz, baterías HV y VOCs de pintura.",
  },
