    cobertura: "Media",
    chip: "media",
    perfil: "Capital textilera nacional, fibras sintéticas, colorantes azo y zona metropolitana Puebla-Tlaxcala.",
  },
  {
    nombre: "Oriente / La Malinche",
    municipiosZona: ["Huamantla", "Tetlatlahuca"],
    cobertura: "Media",
    chip: "media",
    perfil: "Volcán La Malinche 4,461 msnm, rescate alta montaña, incendios forestales y heladas.",
  },
  {
    nombre: "Noroeste / corredor 150D",
    municipiosZona: ["Calpulalpan", "Tlaxco"],
    cobertura: "Baja",
    chip: "baja",
    perfil: "Planta Grupo Modelo, HAZMAT NH₃/CO₂, autopista 150D y bosques pino-encino norte.",
  },
];

const estadosVecinos = getEstadosVecinos("tlaxcala");

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio oficial de las ${totalEstaciones} estaciones de bomberos en Tlaxcala. Única planta Audi en las Américas (San José Chiapa), capital textilera de México (Chiautempan), Volcán La Malinche (4,461 msnm), Grupo Modelo Calpulalpan. Heroico Cuerpo de Bomberos fundado en febrero de 1982. Emergencias 911.`,
  numberOfItems: estacionesTlaxcala.length,
  itemListElement: estacionesTlaxcala.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipio,
        addressRegion: estado,
        addressCountry: "MX",
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}`,
    },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Tlaxcala: estaciones, historia y servicios de emergencia",
  "description": "Guía del Heroico Cuerpo de Bomberos de Tlaxcala: historia (1982–hoy), infraestructura en sus municipios, funciones, retos y directorio de estaciones con teléfonos directos. La Malinche, corredor Audi, Ferromex y zona textilera.",
  "about": [
    "Heroico Cuerpo de Bomberos de Tlaxcala",
    "Protección Civil Tlaxcala",
    "Rescate en alta montaña La Malinche",
    "HAZMAT industrial Tlaxcala",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/tlaxcala.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": `Estaciones de Bomberos en Tlaxcala`,
  "description": `Directorio verificado de las ${totalEstaciones} estaciones de bomberos en Tlaxcala, con teléfonos, cobertura, funciones e historia del Heroico Cuerpo de Bomberos fundado en 1982.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de Tlaxcala" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/tlaxcala.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

