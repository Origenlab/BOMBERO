// ── FAQ únicas de Tlaxcala (≥10) ──────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Tlaxcala?",
    a: `Marca el <strong>911</strong> desde cualquier teléfono en Tlaxcala para emergencias de bomberos, rescate o ambulancia. El número opera las 24 horas y despacha a la estación más cercana según tu ubicación. Las principales estaciones con guardia permanente son Tlaxcala capital (<strong>246 462 0100</strong>), Apizaco (<strong>241 418 0300</strong>), Huamantla (<strong>247 472 0500</strong>), Calpulalpan (<strong>591 922 0300</strong>) y Chiautempan (<strong>241 416 0200</strong>).`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de Tlaxcala?",
    a: `El <strong>Heroico Cuerpo de Bomberos de Tlaxcala</strong>, adscrito a la Secretaría de Seguridad Ciudadana (SSC) del estado, fue fundado en <strong>febrero de 1982</strong>. Inició con una motobomba y una combi Volkswagen instalados en el Palacio de Gobierno; en octubre de 1982 recibió su primer camión de bomberos, bautizado <em>"Camaxtli"</em> (dios tlaxcalteca del fuego). En junio de 1985 se instaló oficialmente en el edificio diseñado para ello. En agosto de 2025 cumplió <strong>43 años de servicio ininterrumpido</strong>.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Conmemora la fundación del <strong>primer cuerpo de bomberos de México</strong> el 22 de agosto de 1873 en el puerto de Veracruz. Cada año, el Heroico Cuerpo de Bomberos de Tlaxcala celebra su aniversario institucional y se premia a los elementos con actos de valor y perseverancia en esa fecha.`,
  },
  {
    q: "¿Qué riesgos industriales atienden los bomberos en Tlaxcala?",
    a: `Tlaxcala concentra múltiples perfiles HAZMAT: <strong>automotriz premium</strong> en la planta Audi de San José Chiapa (disolventes, isocianatos, baterías de ión de litio de alta tensión); <strong>HAZMAT ferroviario</strong> en el nodo Ferromex de Apizaco (clorosulfúrico, ácidos, combustibles en tránsito); <strong>incendios textiles</strong> en Chiautempan (fibras sintéticas de alta propagación y colorantes azo que generan HCN y HCl al arder); y <strong>HAZMAT amoniaco/CO₂</strong> en la planta cervecera Grupo Modelo de Calpulalpan.`,
  },
  {
    q: "¿Cómo atienden los bomberos emergencias en el Volcán La Malinche?",
    a: `El Volcán La Malinche (Matlalcuéytl), con 4,461 msnm, exige rescate en alta montaña con equipo especializado para altitud, hipotermia y terreno volcánico. Los bomberos de <strong>Huamantla</strong> son la primera respuesta; Tetlatlahuca apoya en la ladera norte y San Pablo del Monte en la ladera sur. Por encima de 3,000 msnm, las autobombas pierden hasta un 30% de caudal, los SCBA duran 20–25% menos y la espuma mecánica sobreexpande, lo que exige recalibración operativa constante. El Parque Nacional La Malinche concentra más del 72% de los incendios forestales anuales del estado.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Tlaxcala?",
    a: `Este directorio documenta <strong>${totalEstaciones} estaciones</strong> del Heroico Cuerpo de Bomberos de Tlaxcala, distribuidas en <strong>${totalMunicipios} municipios</strong> de los 60 que tiene el estado. La red está coordinada desde la Estación Central de Tlaxcala de Xicohténcatl con subestaciones estratégicas en Apizaco, Huamantla, Calpulalpan, Chiautempan, Tlaxco y otras localidades clave.`,
  },
  {
    q: "¿Qué es el corredor industrial Puebla-Tlaxcala y cómo lo cubren los bomberos?",
    a: `La <strong>Zona Metropolitana Puebla-Tlaxcala</strong> es la cuarta más poblada de México; 20 de sus municipios pertenecen a Tlaxcala. En el lado tlaxcalteca se concentra la planta Audi, parques industriales con automotriz, química, farmacéutica y textil, así como el corredor de carga de la autopista 150D. Las estaciones de Zacatelco, San Pablo del Monte, Teolocholco y Chiautempan coordinan de forma habitual con el Cuerpo de Bomberos de Puebla para emergencias en la franja conurbada.`,
  },
  {
    q: "¿Cuáles son los servicios que prestan los bomberos en Tlaxcala?",
    a: `Combate de <strong>incendios estructurales, forestales e industriales</strong>; <strong>rescate vehicular</strong> en autopistas y carreteras federales; <strong>rescate en alta montaña</strong> (La Malinche); <strong>materiales peligrosos (HAZMAT)</strong> automotriz, ferroviario, químico y cervecero; <strong>atención prehospitalaria</strong> y traslados; <strong>control de fugas de gas</strong>; <strong>rescate en espacios confinados</strong>; y <strong>prevención</strong> (inspecciones, simulacros y capacitación).`,
  },
  {
    q: "¿Los bomberos de Tlaxcala tienen costo?",
    a: `Las emergencias que comprometen la <strong>vida o la integridad</strong> de las personas se atienden de forma <strong>gratuita</strong>. Algunos servicios secundarios pueden tener cuota de recuperación según el municipio. La atención de emergencia nunca se condiciona a un pago. Llama al <strong>911</strong> en cualquier caso.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en fábricas textiles o industriales en Tlaxcala?",
    a: `Mantén <strong>vías de escape libres</strong> y señalizadas; revisa periódicamente los <strong>sistemas eléctricos</strong> y de gas; instala <strong>detectores de humo y de gases tóxicos</strong> en talleres con colorantes azo; almacena fibras sintéticas separadas de fuentes de calor; capacita a tu brigada contraincendios conforme a las <strong>NOM de Protección Civil</strong>; y coordina con Protección Civil municipal tu plan de emergencia. Ante cualquier siniestro, llama al <strong>911</strong>.`,
  },
  {
    q: "¿Qué ropa de protección usan los bomberos de Tlaxcala?",
    a: `Según el tipo de emergencia, el personal del Heroico Cuerpo de Bomberos de Tlaxcala usa: <strong>traje estructural NFPA 1971</strong> para incendios en edificios, fábricas textiles y bodegas; <strong>traje HAZMAT</strong> de nivel A/B para el corredor automotriz Audi o las emergencias ferroviarias de Apizaco; y equipo de rescate en altura con casco técnico y arnés para operaciones en La Malinche. La altitud del volcán obliga a cilindros SCBA de mayor capacidad para compensar la mayor frecuencia respiratoria de los elementos.`,
  },
  {
    q: "¿Cuándo son los incendios forestales en Tlaxcala?",
    a: `La temporada crítica es de <strong>enero a mayo</strong>, con el pico en marzo y abril cuando coinciden las heladas nocturnas, los vientos del norte y la vegetación seca. El Parque Nacional La Malinche concentra el 72% de todos los siniestros forestales del estado. En 1998, el año más severo registrado, Tlaxcala documentó <strong>439 incendios que afectaron 8,855 hectáreas</strong>. Los bomberos de Huamantla, Tetlatlahuca y San Pablo del Monte coordinan con la CONANP y la CONAFOR para la respuesta en el parque.`,
  },
];

