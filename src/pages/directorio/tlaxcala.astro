    "bomberos tlaxcala",
    "estaciones bomberos tlaxcala",
    "emergencias tlaxcala 911",
    "heroico cuerpo bomberos tlaxcala",
    "telefono bomberos tlaxcala capital",
    "bomberos apizaco hazmat ferroviario",
    "rescate alta montana la malinche",
    "bomberos chiautempan incendio textil",
    "bomberos calpulalpan grupo modelo",
    "hazmat audi mexico san jose chiapa",
    "directorio bomberos tlaxcala municipios",
    "incendios forestales parque nacional malinche",
  ]}
  canonical={canonical}
  jsonLd={jsonLd}

  totalEstaciones={totalEstaciones}
