  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio oficial de ${estacionesOaxaca.length} estaciones de bomberos en Oaxaca. Protección de 2 sitios UNESCO (Monte Albán, Centro Histórico). Cobertura Costa turística, Istmo industrial y Sierra Norte.`,
  numberOfItems: estacionesOaxaca.length,
  itemListElement: estacionesOaxaca.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipiosCubiertos?.[0] || estado,
        addressRegion: estado,
        addressCountry: "MX"
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}`
