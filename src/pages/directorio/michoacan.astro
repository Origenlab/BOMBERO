---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesMichoacan, getMunicipios } from "@data/estaciones-michoacan";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("michoacan");
const municipios = getMunicipios();

const canonical = "https://bombero.mx/directorio/michoacan/";

// ── Comparativa regional (calculada desde los datos reales del directorio) ──
const zonasDef = [
  {
    nombre: "Zona Metropolitana Morelia",
    municipios: ["Morelia", "Tarímbaro"],
    nivel: "Total",
    chip: "total",
    perfil: "Capital del estado, Centro Histórico UNESCO (1991), zona industrial sur.",
  },
  {
    nombre: "Meseta Purépecha y Lacustre",
    municipios: ["Uruapan", "Paracho de Verduzco", "Tancítaro", "Pátzcuaro", "Quiroga"],
    nivel: "Alta",
    chip: "alta",
    perfil: "Capital mundial del aguacate, bosques pino-encino, Lago de Pátzcuaro y Janitzio.",
  },
  {
    nombre: "Costa del Pacífico",
    municipios: ["Lázaro Cárdenas", "Playa Azul", "Caleta de Campos"],
    nivel: "Alta",
    chip: "alta",
    perfil: "Puerto industrial, ArcelorMittal (ex-SICARTSA), HAZMAT nivel III, rescate marítimo.",
  },
  {
    nombre: "Tierra Caliente y Ciénega",
    municipios: ["Apatzingán", "Huetamo", "Zamora de Hidalgo", "Jiquilpan de Juárez", "Sahuayo de Morelos"],
    nivel: "Media",
    chip: "media",
    perfil: "Producción de limón, fresa y berries; clima extremo hasta 45 °C.",
  },
  {
    nombre: "Oriente — Mariposa Monarca",
    municipios: ["Zitácuaro", "Angangueo", "Ciudad Hidalgo", "La Piedad de Cabadas"],
    nivel: "Media",
    chip: "media",
    perfil: "Reserva Biosfera Mariposa Monarca UNESCO (2008), bosques de oyamel a 3,400 msnm.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesMichoacan.filter((e) => z.municipios.includes(e.ciudad));
  return {
    ...z,
    nEst: est.length,
    nMunicipios: z.municipios.length,
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Michoacán de Ocampo, México",
  "description": `Directorio completo de las ${estacionesMichoacan.length} estaciones de bomberos en Michoacán. Protección para Morelia (Patrimonio UNESCO), Lázaro Cárdenas, Uruapan, Pátzcuaro, Reserva Mariposa Monarca y 4.7 millones de habitantes. Emergencias 911.`,
  "numberOfItems": estacionesMichoacan.length,
  "itemListElement": estacionesMichoacan.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Michoacán",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/michoacan/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Michoacán: estaciones, historia y servicios de emergencia",
  "description": "Guía del Heroico Cuerpo de Bomberos de Michoacán: historia (1873–hoy), infraestructura en las principales ciudades, incendios forestales, volcán Paricutín, puerto industrial de Lázaro Cárdenas y directorio de estaciones con teléfonos directos.",
  "about": [
    "H. Cuerpo de Bomberos de Michoacán",
    "Protección Civil",
    "Incendios forestales",
    "HAZMAT portuario",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/michoacan.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Michoacán de Ocampo",
  "description": `Directorio verificado de las ${estacionesMichoacan.length} estaciones de bomberos en Michoacán, con teléfonos, cobertura regional, funciones e historia del cuerpo de bomberos.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "H. Cuerpo de Bomberos de Michoacán de Ocampo" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/michoacan.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Michoacán (≥10) — alimentan el FAQPage schema ─────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Michoacán?",
    a: `Marca el <strong>911</strong>, el número único de emergencias que opera las 24 horas a través del Centro de Coordinación, Control, Cómputo y Comunicaciones (C4) del estado. La llamada se enruta a la estación más cercana. Los teléfonos directos principales son: Morelia (443) 312-3232, Lázaro Cárdenas (753) 532-1234, Uruapan (452) 524-5252 y Zamora (351) 512-1212.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Michoacán?",
    a: `Este directorio reúne <strong>${estacionesMichoacan.length} estaciones de bomberos</strong> en Michoacán, distribuidas entre la Zona Metropolitana de Morelia, la Meseta Purépecha, la Costa del Pacífico, Tierra Caliente, la Ciénega de Chapala y la Región Oriente (Mariposa Monarca). El estado tiene <strong>113 municipios</strong>.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Morelia?",
    a: `El <strong>Cuerpo de Bomberos de Morelia</strong> fue fundado en <strong>1954</strong>. Protege el Centro Histórico de Morelia, declarado Patrimonio de la Humanidad por la UNESCO en 1991 y cuenta con especialización en incendios en edificios coloniales de cantera rosa. El primer cuerpo de bomberos de México fue fundado el <strong>22 de agosto de 1873</strong> en Veracruz, fecha que se conmemora como el Día del Bombero.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque conmemora la fundación del <strong>primer cuerpo de bomberos del país</strong>, el 22 de agosto de 1873 en el puerto de Veracruz. Cada año, en esa fecha, se reconoce la labor de los bomberos en toda la República, incluidos los de Michoacán.`,
  },
  {
    q: "¿Qué riesgo representa el volcán Paricutín para los bomberos de Michoacán?",
    a: `El Paricutín, que nació el <strong>20 de febrero de 1943</strong> en una parcela del municipio de Parangaricutiro y estuvo activo hasta 1952, está hoy inactivo. Sin embargo, su existencia evidencia que la región forma parte del <strong>Campo Volcánico Michoacán-Guanajuato</strong>, uno de los más activos del país. Los bomberos de Uruapan y Tancítaro incluyen el riesgo volcánico en sus protocolos de planificación de emergencias. El volcán Jorullo, también en Michoacán, nació en <strong>1759</strong> en Tierra Caliente.`,
  },
  {
    q: "¿Qué hace especial la respuesta de bomberos en el Puerto de Lázaro Cárdenas?",
    a: `El Puerto de Lázaro Cárdenas alberga la planta <strong>ArcelorMittal</strong> (fundada en 1976 como SICARTSA), el mayor complejo siderúrgico del Pacífico mexicano. Sus hornos de arco eléctrico funden chatarra a 1,600 °C. Los bomberos de Lázaro Cárdenas están certificados en <strong>HAZMAT Nivel III</strong> y en el protocolo crítico de emergencias siderúrgicas: en zonas con metal fundido se usan arena seca o polvo de cal, nunca agua, ya que su contacto con acero líquido genera vapor explosivo.`,
  },
  {
    q: "¿Cómo responden los bomberos a un incendio forestal vinculado al aguacate en Michoacán?",
    a: `Michoacán aporta el <strong>86 % de la producción nacional de aguacate</strong>. La expansión de huertas sobre bosques de pino-encino, especialmente en la Meseta Purépecha, ha generado incendios forestales, algunos vinculados a cambios de uso de suelo. Los bomberos de Uruapan, Tancítaro y Paracho trabajan en coordinación con la <strong>Comisión Nacional Forestal (CONAFOR)</strong> en la temporada de estiaje (marzo-mayo). La lucha en pendientes boscosas se hace con herramienta manual y mochilas extintoras.`,
  },
  {
    q: "¿Qué plan operativo activan los bomberos durante el Día de Muertos en Janitzio?",
    a: `La Isla de Janitzio, con aproximadamente 3,000 residentes permanentes, recibe entre 120,000 y 150,000 visitantes durante las noches del 1 y 2 de noviembre. El único acceso es por lancha desde Pátzcuaro. Los bomberos de Pátzcuaro activan un <strong>plan de contingencia anual</strong> con pre-posicionamiento de lanchas de rescate, una unidad de tierra en el embarcadero y coordinación con Cruz Roja y Protección Civil Estatal en canal de radio exclusivo.`,
  },
  {
    q: "¿Por qué los bomberos no pueden usar autobombas en los santuarios de la Mariposa Monarca?",
    a: `Los santuarios El Rosario, Sierra Chincua y Cerro Pelón de la Reserva de la Biosfera Mariposa Monarca (UNESCO, 2008; 56,259 ha) están a altitudes de 3,000–3,400 msnm, con caminos que terminan 1–2 km antes de las colonias. Los vehículos pesados no pueden acceder. Ante un incendio forestal, los bomberos de Zitácuaro y Angangueo responden <strong>a pie con herramientas manuales y mochilas extintoras de 20 litros</strong>, apoyados por guardabosques ejidales que conocen el terreno.`,
  },
  {
    q: "¿Michoacán tiene riesgo sísmico?",
    a: `Sí. Michoacán forma parte de la <strong>zona de subducción de la Placa de Cocos</strong> bajo la Placa Norteamericana. El segmento michoacano tiene una magnitud máxima estimada de Mw 8.3. El <strong>sismo de 1985 (Mw 8.1)</strong> fue el más destructivo del siglo XX en México y tuvo su epicentro frente a las costas de Michoacán. Los cuerpos de bomberos costeros incluyen protocolos sísmicos y de tsunamis en su capacitación.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Michoacán?",
    a: `Los cuerpos de bomberos michoacanos atienden <strong>incendios estructurales, forestales e industriales</strong>; <strong>rescate vehicular</strong> en carreteras serranas y autopistas; <strong>atención prehospitalaria</strong>; <strong>materiales peligrosos (HAZMAT)</strong> en el puerto y zonas agroindustriales; <strong>rescate acuático</strong> en el Lago de Pátzcuaro, la costa y el Río Balsas; y <strong>protección civil</strong> con simulacros y capacitación comunitaria.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en casa en Michoacán?",
    a: `Revisa periódicamente la instalación de <strong>gas</strong> (mangueras y reguladores) y la <strong>instalación eléctrica</strong>. Instala <strong>detectores de humo</strong> y mantén un extintor vigente. En temporada seca no quemes basura ni pastizales cerca de zonas forestales. Define un <strong>plan de evacuación familiar</strong> con punto de reunión y ten el <strong>911</strong> visible para todos.`,
  },
];

