---

import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import SectionHeader from "@components/SectionHeader.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CTABanner from "@components/CTABanner.astro";
import FAQDirectorio from "@components/directorio/FAQDirectorio.astro";
import DirectorioSearch from "@components/directorio/DirectorioSearch.astro";
import HeroSection from "@components/HeroSection.astro";
import { cdnW } from "@lib/cdn";
import QuickNav from "@components/QuickNav.astro";
import {
  ESTACIONES_POR_ESTADO,
  TOTAL_ESTACIONES_NACIONAL,
  TOTAL_ESTADOS,
  DIRECTORIO_VERIFICADO_LEGIBLE,
  DIRECTORIO_VERIFICADO_ISO,
} from "@data/directorio-stats";

// Datos de los 32 estados con información relevante (sin contadores hardcodeados)
interface Estado {
  name: string;
  slug: string;
  abbr: string;
  capital: string;
  stations: number;
  featured?: boolean;
}

// Tabla maestra de estados — los conteos vienen de directorio-stats.ts (siempre reales)
const estadosBase: Omit<Estado, "stations">[] = [
  { name: "Aguascalientes", slug: "aguascalientes", abbr: "AGS", capital: "Aguascalientes" },
  { name: "Baja California", slug: "baja-california", abbr: "BC", capital: "Mexicali", featured: true },
  { name: "Baja California Sur", slug: "baja-california-sur", abbr: "BCS", capital: "La Paz" },
  { name: "Campeche", slug: "campeche", abbr: "CAM", capital: "Campeche" },
  { name: "Chiapas", slug: "chiapas", abbr: "CHIS", capital: "Tuxtla Gutiérrez" },
  { name: "Chihuahua", slug: "chihuahua", abbr: "CHIH", capital: "Chihuahua", featured: true },
  { name: "Ciudad de México", slug: "ciudad-de-mexico", abbr: "CDMX", capital: "Ciudad de México", featured: true },
  { name: "Coahuila", slug: "coahuila", abbr: "COAH", capital: "Saltillo" },
  { name: "Colima", slug: "colima", abbr: "COL", capital: "Colima" },
  { name: "Durango", slug: "durango", abbr: "DGO", capital: "Durango" },
  { name: "Estado de México", slug: "estado-de-mexico", abbr: "EDOMEX", capital: "Toluca", featured: true },
  { name: "Guanajuato", slug: "guanajuato", abbr: "GTO", capital: "Guanajuato", featured: true },
  { name: "Guerrero", slug: "guerrero", abbr: "GRO", capital: "Chilpancingo" },
  { name: "Hidalgo", slug: "hidalgo", abbr: "HGO", capital: "Pachuca" },
  { name: "Jalisco", slug: "jalisco", abbr: "JAL", capital: "Guadalajara", featured: true },
  { name: "Michoacán", slug: "michoacan", abbr: "MICH", capital: "Morelia" },
  { name: "Morelos", slug: "morelos", abbr: "MOR", capital: "Cuernavaca" },
  { name: "Nayarit", slug: "nayarit", abbr: "NAY", capital: "Tepic" },
  { name: "Nuevo León", slug: "nuevo-leon", abbr: "NL", capital: "Monterrey", featured: true },
  { name: "Oaxaca", slug: "oaxaca", abbr: "OAX", capital: "Oaxaca", featured: true },
  { name: "Puebla", slug: "puebla", abbr: "PUE", capital: "Puebla", featured: true },
  { name: "Querétaro", slug: "queretaro", abbr: "QRO", capital: "Querétaro", featured: true },
  { name: "Quintana Roo", slug: "quintana-roo", abbr: "QROO", capital: "Chetumal", featured: true },
  { name: "San Luis Potosí", slug: "san-luis-potosi", abbr: "SLP", capital: "San Luis Potosí", featured: true },
  { name: "Sinaloa", slug: "sinaloa", abbr: "SIN", capital: "Culiacán" },
  { name: "Sonora", slug: "sonora", abbr: "SON", capital: "Hermosillo" },
  { name: "Tabasco", slug: "tabasco", abbr: "TAB", capital: "Villahermosa" },
  { name: "Tamaulipas", slug: "tamaulipas", abbr: "TAMPS", capital: "Ciudad Victoria" },
  { name: "Tlaxcala", slug: "tlaxcala", abbr: "TLAX", capital: "Tlaxcala" },
  { name: "Veracruz", slug: "veracruz", abbr: "VER", capital: "Xalapa", featured: true },
  { name: "Yucatán", slug: "yucatan", abbr: "YUC", capital: "Mérida" },
  { name: "Zacatecas", slug: "zacatecas", abbr: "ZAC", capital: "Zacatecas" },
];

// Inyectar conteos reales desde el módulo central
const estados: Estado[] = estadosBase.map((e) => ({
  ...e,
  stations: ESTACIONES_POR_ESTADO[e.slug] ?? 0,
}));

const totalEstaciones = TOTAL_ESTACIONES_NACIONAL;
const totalEstados = TOTAL_ESTADOS;
const estadosDestacados = estados.filter((e) => e.featured);

// JSON-LD CollectionPage con dateModified + speakable + mainEntity → GEO/AI
const directorioJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Directorio de Estaciones de Bomberos en México",
  description: `${totalEstaciones}+ estaciones de bomberos verificadas en los 32 estados de México. Directorio con teléfono directo de comandancia, dirección, servicios y horarios por municipio.`,
  url: "https://bombero.mx/directorio/",
  dateModified: DIRECTORIO_VERIFICADO_ISO,
  inLanguage: "es-MX",
  isPartOf: { "@type": "WebSite", url: "https://bombero.mx/" },
  about: {
    "@type": "Thing",
    name: "Estaciones de Bomberos en México",
    sameAs: [
      "https://es.wikipedia.org/wiki/Bombero",
      "https://www.wikidata.org/wiki/Q33829",
    ],
  },
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".dir-hero__title", ".dir-hero__desc"],
  },
  publisher: {
    "@type": "Organization",
    name: "Distribuidores EPP",
    url: "https://bombero.mx",
    logo: "https://bombero.mx/images/logo-equipo-para-bomberos.avif",
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: totalEstados,
    itemListElement: estados.map((e, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://bombero.mx/directorio/${e.slug}/`,
      name: `Bomberos en ${e.name}`,
    })),
  },
};

// Service schema — para que aparezcamos en búsquedas tipo "servicios de bomberos en México"
const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Directorio de Bomberos en México",
  serviceType: "Información de emergencias y directorio público",
  areaServed: {
    "@type": "Country",
    name: "México",
    sameAs: "https://es.wikipedia.org/wiki/M%C3%A9xico",
  },
  provider: {
    "@type": "Organization",
    name: "Distribuidores EPP",
    url: "https://bombero.mx",
  },
  category: [
    "Emergency Services",
    "Fire Stations",
    "Public Safety Directory",
  ],
  audience: {
    "@type": "Audience",
    audienceType: "Ciudadanía general y procurement municipal",
  },
};

// Regiones para interlinking
const regiones = [
  { name: "Norte", states: ["Baja California", "Sonora", "Chihuahua", "Coahuila", "Nuevo León", "Tamaulipas"] },
  { name: "Centro", states: ["Ciudad de México", "Estado de México", "Puebla", "Querétaro", "Guanajuato", "Hidalgo", "Morelos"] },
  { name: "Sur", states: ["Oaxaca", "Chiapas", "Guerrero", "Veracruz", "Tabasco"] },
  { name: "Occidente", states: ["Jalisco", "Michoacán", "Colima", "Nayarit", "Sinaloa"] },
];
---

<PageLayout
  quickNav={false}
  title={`Directorio de Estaciones de Bomberos en México — ${totalEstaciones}+ verificadas`}
  description={`${totalEstaciones}+ estaciones de bomberos en México — directorio verificado con teléfono directo de comandancia, dirección y servicios en los 32 estados. Actualizado ${DIRECTORIO_VERIFICADO_LEGIBLE}.`}
  canonical="https://bombero.mx/directorio/"
  modifiedTime={DIRECTORIO_VERIFICADO_ISO}
  jsonLd={[directorioJsonLd, serviceJsonLd]}
>
  <Breadcrumb items={[
    { label: "Directorio" },
  ]} />


  <HeroSection
    badge={`Directorio Nacional — Verificado ${DIRECTORIO_VERIFICADO_LEGIBLE}`}
    title={`Directorio de Estaciones de Bomberos en <span class="hero__title-highlight">México</span>`}
    subtitle={`${totalEstaciones}+ fichas verificadas con teléfono directo de comandancia, dirección y especialidades. Datos recabados de los propios H. Cuerpos de Bomberos en los ${totalEstados} estados — no de agregadores.`}
  >
    <div slot="left-extra">
      <DirectorioSearch />
      <div class="dir-hero__stats">
        <div class="dir-hero__stat">
          <span class="dir-hero__stat-number">{totalEstados}</span>
          <span class="dir-hero__stat-label">Estados</span>
        </div>
        <div class="dir-hero__stat">
          <span class="dir-hero__stat-number">{totalEstaciones}+</span>
          <span class="dir-hero__stat-label">Estaciones</span>
        </div>
        <div class="dir-hero__stat">
          <span class="dir-hero__stat-number">24/7</span>
          <span class="dir-hero__stat-label">Emergencias</span>
        </div>
      </div>
    </div>

    <div slot="right" class="dir-hero__right">

      <div class="dir-hero__info-card">
        <span class="dir-hero__info-label">Sobre este directorio</span>
        <p>En 15 años de distribución de equipo contra incendios tuvimos contacto directo con comandancias en los 32 estados. Ese acceso es el origen de este directorio: la información no se copia de otros portales — se verifica con cada cuerpo. Cada ficha incluye teléfono directo de la comandancia, dirección, horarios y especialidades.</p>
        <p>Para emergencias activas, marca el <strong>911</strong> — enruta automáticamente a la unidad más cercana. Este directorio cubre lo que el 911 no cubre: coordinación administrativa, licitaciones, donaciones de equipo y capacitación.</p>
      </div>

      <div class="dir-hero__emergency">
        <div class="dir-hero__emergency-item">
          <span class="dir-hero__emergency-number">911</span>
          <span class="dir-hero__emergency-desc">Emergencias — nacional 24/7</span>
        </div>
        <div class="dir-hero__emergency-divider"></div>
        <div class="dir-hero__emergency-item">
          <span class="dir-hero__emergency-number">068</span>
          <span class="dir-hero__emergency-desc">Bomberos en algunas ciudades</span>
        </div>
      </div>

    </div>
  </HeroSection>

  <QuickNav pool="directorio" count={7} />



  <section class="dir-main">
    <div class="container">
      <div class="dir-main__grid">

        <div class="dir-main__content">
          <SectionHeader
            label="Cobertura Nacional"
            title="Estaciones de Bomberos por Estado"
            description={`${totalEstaciones}+ estaciones de bomberos documentadas en los 32 estados de la República. Cada ficha incluye teléfono directo de la comandancia, dirección, municipio y servicios de emergencia disponibles.`}
          />

          <div class="dir-states">
            {estados.map((estado) => (
              <a href={`/directorio/${estado.slug}/`} class={`dir-state ${estado.featured ? 'dir-state--featured' : ''}`}>
                <div class="dir-state__abbr">{estado.abbr}</div>
                <div class="dir-state__info">
                  <h3 class="dir-state__name">{estado.name}</h3>
                  <p class="dir-state__meta">
                    <span class="dir-state__capital">{estado.capital}</span>
                    <span class="dir-state__stations">{estado.stations} estaciones</span>
                  </p>
                </div>
                <div class="dir-state__arrow">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </a>
            ))}
          </div>


          <div class="dir-seo">
            <h2>Cómo navegar este directorio de bomberos</h2>
            <p>
              Selecciona tu estado en la lista. Cada página estatal muestra todas las estaciones del
              <strong>H. Cuerpo de Bomberos</strong> con dirección, teléfono directo de comandancia
              y los servicios que cubre cada unidad. Las fichas individuales incluyen mapa, horario y enlace
              directo a Google Maps para llegar desde tu teléfono.
            </p>
            <p>
              La información se verifica con cada comandancia antes de publicarse. Si detectas un dato
              desactualizado — número equivocado, estación cerrada o nueva — escríbenos a
              <strong>{SITE.contact.email}</strong> y lo corregimos sin costo. La precisión del directorio
              depende de esa retroalimentación colectiva.
            </p>
            <h3>¿Por qué no existe un directorio oficial nacional de bomberos en México?</h3>
            <p>
              En México los cuerpos de bomberos son municipales: cada municipio opera y financia el suyo, sin
              una base de datos federal centralizada. Eso explica por qué el número de la estación de
              Monterrey es distinto al de Guadalajara, y por qué el <strong>068</strong> — línea directa de
              bomberos — solo funciona en algunas ciudades. El <strong>911</strong> es la única línea nacional
              que enruta automáticamente a la unidad más cercana, pero no tiene la información de contacto
              directo por comandancia. Este directorio cubre exactamente ese vacío: los datos de cada cuerpo
              municipal, verificados y actualizados, en un solo lugar.
            </p>
            <h3>¿Qué estados y regiones cubre el directorio?</h3>
            <p>
              El directorio tiene cobertura nacional dividida en cuatro regiones. La <strong>Zona Norte</strong>
              incluye Nuevo León, Chihuahua, Coahuila, Tamaulipas, Baja California y Sonora — estados con
              cuerpos municipales de alto volumen operativo por densidad industrial y fronteriza. La
              <strong>Zona Centro</strong> abarca Ciudad de México, Estado de México, Puebla, Querétaro,
              Guanajuato e Hidalgo — la región de mayor concentración de estaciones por km² del país.
              La <strong>Zona Occidente</strong> cubre Jalisco, Michoacán, Colima, Nayarit y Sinaloa, y la
              <strong>Zona Sur y Sureste</strong> incluye Veracruz, Oaxaca, Chiapas, Guerrero, Yucatán y
              Tabasco, donde coexisten cuerpos municipales profesionales con brigadas comunitarias y de
              protección civil estatal. Cada ficha estatal tiene su propio desglose por municipio.
            </p>
          </div>
        </div>


        <aside class="dir-sidebar">

          <div class="dir-sidebar__card">
            <h4>Estados Más Buscados</h4>
            <ul class="dir-sidebar__list">
              {estadosDestacados.map((estado) => (
                <li>
                  <a href={`/directorio/${estado.slug}/`}>
                    <span class="dir-sidebar__bullet"></span>
                    <span class="dir-sidebar__state-name">{estado.name}</span>
                    <span class="dir-sidebar__state-count">{estado.stations}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>


          <div class="dir-sidebar__card">
            <h4>Buscar por Región</h4>
            <div class="dir-sidebar__regions">
              {regiones.map((region) => (
                <div class="dir-sidebar__region">
                  <h5>{region.name}</h5>
                  <div class="dir-sidebar__region-states">
                    {region.states.map((stateName) => {
                      const estado = estados.find(e => e.name === stateName);
                      return estado ? (
                        <a href={`/directorio/${estado.slug}/`}>{estado.abbr}</a>
                      ) : null;
                    })}
                  </div>
                </div>
              ))}
            </div>
          </div>


          <div class="dir-sidebar__card dir-sidebar__card--emergency">
            <h4>Números de Emergencia</h4>
            <div class="dir-sidebar__emergency">
              <div class="dir-sidebar__emergency-item">
                <span class="dir-sidebar__emergency-number">911</span>
                <span class="dir-sidebar__emergency-label">Emergencias Nacional</span>
              </div>
              <div class="dir-sidebar__emergency-item">
                <span class="dir-sidebar__emergency-number">068</span>
                <span class="dir-sidebar__emergency-label">Bomberos (algunas ciudades)</span>
              </div>
            </div>
            <p class="dir-sidebar__emergency-note">
              En caso de emergencia, llama inmediatamente al <strong>911</strong>.
              Es el número único de emergencias en toda la República Mexicana.
            </p>
          </div>


          <div class="dir-sidebar__card dir-sidebar__card--cta">
            <h4>Equipa tu Estación</h4>
            <p>Distribuidor autorizado NFPA para H. Cuerpos de Bomberos. Cotización en 24 hrs con ficha técnica y certificado de laboratorio incluidos. Atendemos compras directas, licitaciones municipales y donativos al patronato.</p>
            <a href="/cotizar/" class="dir-sidebar__cta-btn">Solicitar Cotización</a>
          </div>


          <div class="dir-sidebar__card">
            <h4>Explora Nuestro Sitio</h4>
            <ul class="dir-sidebar__links">
              <li><a href="/productos/trajes-para-bomberos/">Trajes de Bombero</a></li>
              <li><a href="/productos/cascos-para-bomberos/">Cascos Certificados</a></li>
              <li><a href="/productos/capuchas-para-bomberos/">Capuchas para Bombero</a></li>
              <li><a href="/productos/botas-para-bomberos/">Botas de Bombero</a></li>
              <li><a href="/productos/guantes-para-bomberos/">Guantes de Protección</a></li>
              <li><a href="/#preguntas-frecuentes">Preguntas Frecuentes</a></li>
            </ul>
          </div>


          <div class="dir-sidebar__card">
            <h4>Contacto Directo</h4>
            <ul class="dir-sidebar__contact">
              <li>
                <a href={`tel:${SITE.contact.phoneRaw}`}>{SITE.contact.phone}</a>
              </li>
              <li>
                <a href={`https://wa.me/${SITE.contact.whatsapp}`}>WhatsApp</a>
              </li>
              <li>
                <a href={`mailto:${SITE.contact.email}`}>{SITE.contact.email}</a>
              </li>
            </ul>
            <address class="dir-sidebar__address">
              Av. Tamaulipas 150, Piso 13<br>
              Col. Condesa, Cuauhtémoc<br>
              06140 CDMX
            </address>
          </div>
        </aside>
      </div>
    </div>
  </section>


  <section class="dir-gallery">
    <div class="container">
      <div class="dir-gallery__header">
        <h2 class="dir-gallery__title">Bomberos de México en Acción</h2>
        <p class="dir-gallery__desc">Estaciones equipadas, vehículos de emergencia y personal especializado al servicio de la ciudadanía</p>
      </div>
      <div class="dir-gallery__grid">
        <div class="dir-gallery__item dir-gallery__item--large">
          <img
            src={cdnW("/images/accion/estacion-bomberos-mexico-moderna.avif", 800)}
            alt="Estación de bomberos México fachada - instalaciones profesionales"
            width="800" height="450"
            loading="lazy"
            decoding="async"
          />
          <div class="dir-gallery__caption">
            <span>Estaciones Modernas</span>
            <p>Instalaciones equipadas en los 32 estados</p>
          </div>
        </div>
        <div class="dir-gallery__item">
          <img
            src={cdnW("/images/why-choose/experiencia-comprobada-bombero-mx.avif", 400)}
            alt="Flota vehicular de bomberos - autobombas y vehículos especializados"
            width="400" height="280"
            loading="lazy"
            decoding="async"
          />
          <div class="dir-gallery__caption">
            <span>Flota Vehicular</span>
            <p>Autobombas y vehículos especializados</p>
          </div>
        </div>
        <div class="dir-gallery__item">
          <img
            src={cdnW("/images/directorio/descontaminacion-hazmat-01.avif", 400)}
            alt="Equipo HAZMAT materiales peligrosos bomberos - protección especializada"
            width="400" height="280"
            loading="lazy"
            decoding="async"
          />
          <div class="dir-gallery__caption">
            <span>Unidades HAZMAT</span>
            <p>Protocolos para materiales peligrosos</p>
          </div>
        </div>
        <div class="dir-gallery__item">
          <img
            src={cdnW("/images/directorio/traje-inmersion-rescate-01.avif", 400)}
            alt="Rescate acuático bomberos - operaciones de rescate en agua"
            width="400" height="280"
            loading="lazy"
            decoding="async"
          />
          <div class="dir-gallery__caption">
            <span>Rescate Acuático</span>
            <p>Especialistas en operaciones acuáticas</p>
          </div>
        </div>
        <div class="dir-gallery__item">
          <img
            src={cdnW("/images/accion/bomberos-accion-incendio-estructural.avif", 400)}
            alt="Bomberos en emergencia incendio estructural - combate activo"
            width="400" height="280"
            loading="lazy"
            decoding="async"
          />
          <div class="dir-gallery__caption">
            <span>Combate de Incendios</span>
            <p>Respuesta inmediata 24/7</p>
          </div>
        </div>
        <div class="dir-gallery__item">
          <img
            src={cdnW("/images/directorio/capacitacion-bomberos-profesional-01.avif", 400)}
            alt="Capacitación de bomberos profesional - formación especializada"
            width="400" height="280"
            loading="lazy"
            decoding="async"
          />
          <div class="dir-gallery__caption">
            <span>Capacitación Continua</span>
            <p>Formación y certificación NFPA</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQDirectorio scope="nacional" totalEstaciones={totalEstaciones} totalEstados={totalEstados} />

  <CTABanner
    title="¿Necesitas equipar tu estación de bomberos?"
    desc="Asesoramos y surtimos equipo certificado NFPA para cuerpos de bomberos en todo México."
    btnText="Solicitar Cotización"
    btnHref="/cotizar/"
    whatsapp={true}
  />
</PageLayout>

<style>

  .dir-hero__stats {
    display: flex;
    gap: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* ── Col derecha del hero ── */
  .dir-hero__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
  }

  .dir-hero__info-card {
    flex: 1;
    padding: var(--space-6);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .dir-hero__info-label {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-fire-400);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .dir-hero__info-card p {
    font-size: var(--text-sm);
    color: var(--color-smoke-400);
    line-height: 1.75;
    margin: 0;
  }

  .dir-hero__info-card strong {
    color: var(--color-smoke-200);
  }

  .dir-hero__emergency {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background: rgba(220, 38, 38, 0.08);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: var(--radius-xl);
  }

  .dir-hero__emergency-item {
    flex: 1;
