---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesTabasco, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-tabasco";

// Generar rutas estaticas
export function getStaticPaths() {
  return estacionesTabasco.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "Tabasco",
  slug: "tabasco",
  siglas: "TAB",
  poblacion: "2.5 millones",
  municipios: 17,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Veracruz", slug: "veracruz" },
  { nombre: "Chiapas", slug: "chiapas" },
  { nombre: "Campeche", slug: "campeche" },
  { nombre: "Quintana Roo", slug: "quintana-roo" },
  { nombre: "Ciudad de Mexico", slug: "ciudad-de-mexico" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? "Tabasco";

// Tarjetas EPP para la seccion de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Disenado para los bomberos de <strong>${ubicacion}</strong> que protegen la cuna del petroleo mexicano. Certificacion NFPA para emergencias HAZMAT en PEMEX, refineria Dos Bocas y la industria petroquimica.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificacion NFPA 1971 para operaciones en <strong>Tabasco</strong>. Compatible con emergencias petroleras, rescate en inundaciones y operaciones en condiciones de humedad extrema.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia termica y quimica certificada para emergencias petroleras en <strong>${ubicacion}</strong>. Prension segura para operaciones HAZMAT en refineria Dos Bocas y rescate en inundaciones.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el entorno de <strong>Tabasco</strong>. Suela antiderrapante para operaciones en instalaciones petroleras, zonas inundables y clima tropical humedo.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>

  <Fragment slot="seo-content">
    <h2>Bomberos en {estacion.municipio}, Tabasco</h2>
    <p>
      La <strong>{estacion.nombreCorto}</strong> es parte del <strong>H. Cuerpo de Bomberos de {estacion.municipio}</strong>,
      institución que protege a los más de <strong>2.5 millones de tabasqueños</strong>. Esta estación, ubicada en
      <strong>{estacion.direccion}, {estacion.colonia}, {estacion.municipio}</strong>, brinda atención las 24 horas del día,
      los 365 días del año.
    </p>
    <p>
      En caso de <strong>emergencia en {estacion.municipio}</strong>, marca el <strong>911</strong> o comunícate directamente
      a esta estación al <strong>{estacion.telefono}</strong>. Los bomberos de Tabasco están capacitados para atender
      incendios estructurales y petroleros, emergencias HAZMAT, rescate en inundaciones, emergencias industriales
      y todo tipo de emergencias.
    </p>
    <h3>Tabasco: La Cuna del Petróleo Mexicano</h3>
    <p>
      <strong>Tabasco</strong> es la cuna de la industria petrolera mexicana y sede de la nueva <strong>Refinería Dos Bocas</strong>,
      uno de los proyectos de infraestructura más grandes de Latinoamérica. <strong>Villahermosa</strong> es un importante
      centro de negocios petroleros. El estado enfrenta retos únicos por su geografía de ríos, lagunas y pantanos,
      que provocan <strong>inundaciones recurrentes</strong>. El patrimonio arqueológico <strong>olmeca</strong> en La Venta
      es Patrimonio Cultural. Los bomberos tienen capacidades especializadas en HAZMAT petrolero y rescate acuático.
    </p>
    <h3>¿Necesitas equipo certificado para bomberos?</h3>
    <p>
      En <strong><a href="/">BOMBERO.MX</a></strong> somos distribuidores autorizados de <strong>equipo para bomberos certificado NFPA</strong>.
      Equipamos estaciones en todo Tabasco con <a href="/productos/trajes-para-bomberos/">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>, <a href="/productos/guantes-para-bomberos/">guantes</a>,
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> y más.
      <a href="/cotizar/">Solicita una cotización</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
