---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesSinaloa, getMunicipios } from "@data/estaciones-sinaloa";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

// Configuración del estado
const estado = "Sinaloa";
const sigla = "SIN";
const slug = "sinaloa";

const canonical = "https://bombero.mx/directorio/sinaloa/";

// ── Estadísticas derivadas ──────────────────────────────────────────────────
const totalEstaciones = estacionesSinaloa.length;
const totalMunicipios = getMunicipios().length;
const totalBomberos   = estacionesSinaloa.reduce((sum, e) => sum + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesSinaloa.reduce((sum, e) => sum + (e.unidades ?? 0), 0);

// ── Comparativa regional ────────────────────────────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Norte",
    municipios: ["Ahome", "El Fuerte", "Choix", "Guasave", "Sinaloa"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Los Mochis (agroindustria y Tren Chepe), Puerto Topolobampo, zona cañera norte.",
  },
  {
    nombre: "Zona Centro",
    municipios: ["Culiacán", "Navolato", "Angostura", "Mocorito", "Salvador Alvarado", "Badiraguato"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital Culiacán, Aeropuerto Bachigualato, Ingenio El Dorado (Navolato), valle hortícola.",
  },
  {
    nombre: "Zona Sur — Mazatlán",
    municipios: ["Mazatlán", "Concordia", "Rosario", "Escuinapa", "Cosalá"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Puerto de Mazatlán, Zona Dorada turística, costa sur, Marismas Nacionales, Pueblos Mágicos.",
  },
  {
    nombre: "Sierra Madre Occidental",
    municipios: ["Badiraguato", "Choix", "Cosalá"],
    cobertura: "Media",
    chip: "media",
    perfil: "Incendios forestales, rescate en alta montaña, comunidades de difícil acceso.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesSinaloa.filter((e) => z.municipios.includes(e.municipio ?? ""));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// Miniaturas hero
const heroThumbs = [
  {
    src: "/images/directorio/estacion-bomberos-playa-01.avif",
    alt: "Malecón de Mazatlán y Zona Dorada - Sinaloa",
    label: "Mazatlán"
  },
  { src: "/images/directorio/central-despacho-bomberos-alerta-estacion-01.avif", alt: "Sistema de alerta en estación de bomberos de Sinaloa", label: "Sistema de Alertas" },
  {
    src: "/images/directorio/estacion-bomberos-equipada-01.avif",
    alt: "Campos agrícolas de tomate y hortalizas Sinaloa",
    label: "Agroexportación"
  }
];

// Galería de imágenes
const galleryImages = [
  {
    src: "/images/directorio/estacion-bomberos-puerto-01.avif",
    alt: "Bomberos de Sinaloa en operaciones portuarias Mazatlán",
    label: "Puerto Mazatlán"
  },
  {
    src: "/images/directorio/camion-bomberos-equipado-01.avif",
    alt: "Tren Chepe Express ruta El Fuerte a Barrancas del Cobre",
    label: "Tren Chepe"
  },
  { src: "/images/directorio/central-despacho-bomberos-operador-nocturno-01.avif", alt: "Operador nocturno en central de bomberos de Sinaloa", label: "Operación Nocturna" },
  {
    src: "/images/directorio/estacion-bomberos-norte-mexico-01.avif",
    alt: "Ciudad de Los Mochis zona agroindustrial norte",
    label: "Los Mochis"
  },
];

// Números de emergencia SIN
const emergencyNumbers = [
  { number: "911", label: "Emergencias" },
  { number: "(667) 715-8311", label: "Bomberos Culiacán" },
  { number: "(669) 982-0800", label: "Bomberos Mazatlán" },
  { number: "(668) 815-7050", label: "Bomberos Los Mochis" }
];

// Regiones de Sinaloa
const regiones = [
  {
    nombre: "Zona Centro",
    desc: "Culiacán capital, Navolato (Ingenio El Dorado), zona cañera, aeropuerto internacional"
  },
  {
    nombre: "Zona Sur - Mazatlán",
    desc: "Puerto de Mazatlán, Zona Dorada, cruceros, Rosario y Concordia (Pueblos Mágicos)"
  },
  {
    nombre: "Zona Norte",
    desc: "Los Mochis, Guasave, El Fuerte (Pueblo Mágico), inicio Tren Chepe a Barrancas del Cobre"
  },
  {
    nombre: "Sierra Madre Occidental",
    desc: "Badiraguato, Choix, Cosalá (Pueblo Mágico) - incendios forestales y rescate en montaña"
  }
];

// Tarjetas de equipamiento EPP
const eppCards = [
  {
    image:     "/images/directorio/traje-inmersion-rescate-01.avif",
    imageAlt:  "Equipo de rescate acuático para costas de Sinaloa",
    badge:     "Costa",
    title:     "Rescate Acuático Pacífico",
    text:      "Equipamiento para rescate en <strong>playas de Mazatlán y zona costera</strong> del Pacífico. Lanchas, tablas de rescate y equipo de neopreno para oleaje fuerte.",
    href:      "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Equipo Acuático",
  },
  {
    image:     "/images/directorio/traje-hazmat-nivel-a-01.avif",
    imageAlt:  "Equipo HAZMAT para agroindustria en Sinaloa",
    badge:     "HAZMAT",
    title:     "HAZMAT Agroindustrial",
    text:      "Trajes y detectores para emergencias con <strong>agroquímicos y fertilizantes</strong> en los valles agrícolas de Sinaloa. Protección contra organofosforados y síndrome colinérgico.",
    href:      "/productos/trajes-para-bomberos/traje-hazmat/",
    linkLabel: "Ver Equipos HAZMAT",
  },
  {
    image:     "/images/accion/bomberos-accion-incendio-estructural.avif",
    imageAlt:  "Equipo forestal para incendios en Sierra Madre de Sinaloa",
    badge:     "Forestal",
    title:     "Incendios Sierra Madre",
    text:      "Equipo forestal NFPA 1950 para combate de incendios en la <strong>Sierra Madre Occidental</strong>. Trajes ligeros y herramientas manuales para terreno escarpado.",
    href:      "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/",
    linkLabel: "Ver Equipo Forestal",
  },
  {
    image:     "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt:  "Botas estructurales para bomberos de Sinaloa",
    badge:     "NFPA 1970",
    title:     "Botas Estructurales",
    text:      "Calzado certificado para los bomberos de <strong>Culiacán, Mazatlán y Los Mochis</strong>. Puntera de acero y suela antiderrapante para todo tipo de terreno y emergencias.",
    href:      "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];

// ── Schemas estructurados ───────────────────────────────────────────────────
