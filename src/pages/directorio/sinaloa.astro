  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio de ${estacionesSinaloa.length} estaciones de bomberos en Sinaloa. Culiacán (fundación 1949), Mazatlán (fundación 1942), Los Mochis (fundación 1954). HAZMAT agroindustrial, rescate acuático Pacífico y cobertura huracanes. Emergencias: 911.`,
  numberOfItems: estacionesSinaloa.length,
  itemListElement: estacionesSinaloa.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipio,
        addressRegion: estado,
        addressCountry: "MX"
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}/`
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Sinaloa: estaciones, historia y servicios de emergencia",
  "description": "Guía del Heroico Cuerpo de Bomberos de Sinaloa: historia (Culiacán 1949, Mazatlán 1942, Los Mochis 1954), infraestructura en 18 municipios, HAZMAT agroindustrial, rescate acuático Pacífico, protección ante huracanes y directorio de estaciones con teléfonos directos.",
  "about": [
    "Heroico Cuerpo de Bomberos de Sinaloa",
    "Protección Civil Sinaloa",
    "HAZMAT agroquímicos",
    "Rescate acuático Pacífico",
    "Huracanes del Pacífico",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/sinaloa.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Sinaloa",
  "description": `Directorio verificado de ${estacionesSinaloa.length} estaciones de bomberos en Sinaloa, con teléfonos, cobertura, funciones e historia. Culiacán (1949), Mazatlán (1942), Los Mochis (1954).`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de Sinaloa" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/sinaloa.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// Estados vecinos
const estadosVecinos = getEstadosVecinos("sinaloa");

// ── FAQ únicas de Sinaloa (≥10) ─────────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Sinaloa?",
    a: `El número único de emergencias en todo Sinaloa es el <strong>911</strong>, disponible las 24 horas. Para emergencias en campo agrícola con posible intoxicación por agroquímico, el protocolo activa simultáneamente a bomberos y IMSS — el antídoto (atropina para síndrome colinérgico) puede requerirse antes de confirmación diagnóstica. Los números directos de las principales estaciones son: Culiacán (667 715 8311), Mazatlán (669 982 0800) y Los Mochis (668 815 7050).`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Culiacán?",
    a: `El <strong>H. Cuerpo de Bomberos de Culiacán</strong> tiene sus orígenes en <strong>1948</strong>, cuando Gilberto González, Manuel Rodríguez, Jorge Sataraín y Nicolás Tamayo formaron el primer grupo organizado para combatir incendios en la capital sinaloense. La primera junta directiva se constituyó formalmente el <strong>5 de junio de 1949</strong>, con el periodista Gustavo Daniel Cañedo de "La Voz de Sinaloa" como primer presidente. El edificio actual de la estación principal fue construido a partir de <strong>1966</strong> con donación del Club Rotario Culiacán.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Mazatlán?",
    a: `El <strong>H. Cuerpo Voluntario de Bomberos de Mazatlán</strong> fue fundado el <strong>13 de enero de 1942</strong> por el doctor Olavo Corona, quien tras presenciar un incendio en el Puerto Viejo apagado a cubetazos organizó al primer grupo de voluntarios. Lo que comenzó con una ambulancia improvisada y herramientas rudimentarias cuenta hoy con cuatro estaciones en el puerto y proyecta una quinta en la zona de Cerritos. En enero de 2026 el cuerpo conmemoró <strong>84 años de historia</strong>.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Los Mochis?",
    a: `El <strong>H. Cuerpo Voluntario de Bomberos de Los Mochis</strong> fue fundado el <strong>16 de febrero de 1954</strong> por un grupo de jóvenes comprometidos con su comunidad. En febrero de 2026 el cuerpo conmemoró <strong>72 años</strong> de servicio continuo. Desde su fundación protege el principal centro urbano del norte de Sinaloa, el puerto industrial de Topolobampo y las zonas agroindustriales del municipio de Ahome.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en Sinaloa?",
    a: `Los cuerpos de bomberos de Sinaloa prestan: combate de <strong>incendios estructurales, forestales y agrícolas</strong> (cañaverales, campos de tomate y rastrojos), <strong>rescate acuático</strong> en costas del Pacífico, esteros y lagunas, <strong>HAZMAT agroindustrial</strong> (organofosforados, amoniaco portuario, fertilizantes), <strong>rescate vehicular y extricación</strong>, atención <strong>prehospitalaria</strong>, <strong>rescate en sierra</strong> (Sierra Madre Occidental), <strong>ARFF aeroportuario</strong> en el Aeropuerto de Culiacán, y protección civil ante <strong>huracanes del Pacífico</strong>. La prevención e inspecciones también forman parte de su labor.`,
  },
  {
    q: "¿Qué riesgos específicos enfrenta Sinaloa por los agroquímicos?",
    a: `Sinaloa aplica el mayor volumen de pesticidas agrícolas de México en sus aproximadamente 640,000 hectáreas de riego tecnificado. Los <strong>organofosforados</strong> —la familia de plaguicidas más usada— producen un síndrome colinérgico reconocible: pupilas puntiformes, broncospasmo, bradicardia e hipersalivación. El problema operacional es que los bomberos llegan a campos donde los jornaleros afectados no pueden identificar el compuesto porque el envase fue reutilizado. El protocolo es tratar el síndrome clínico, no esperar confirmación del producto; activar antídoto (atropina IV) y notificar al IMSS.`,
  },
  {
    q: "¿Cómo afectan los huracanes del Pacífico a Sinaloa?",
    a: `Sinaloa tiene <strong>640 km de litoral</strong> expuesto al Pacífico oriental, que registra algunas de las intensificaciones de huracán más rápidas del mundo. El <strong>Huracán Manuel (septiembre 2013)</strong> dejó 412 mm de lluvia en Culiacán en pocas horas —casi la precipitación anual normal— con el desbordamiento del Río Culiacán (confluencia del Humaya y Tamazula) que inundó colonias y dejó <strong>146,270 damnificados</strong> en 95 comunidades. El <strong>Huracán Willa (octubre 2018)</strong> alcanzó categoría 5 en el Pacífico y afectó el sur de Sinaloa. El protocolo de evacuación activa la alerta con 72 horas de anticipación.`,
  },
  {
    q: "¿Qué riesgos HAZMAT existen en los puertos de Mazatlán y Topolobampo?",
    a: `El <strong>Puerto de Mazatlán</strong> opera una flota camaronera industrial con refrigerantes de <strong>amoniaco</strong> en los barcos de pesca congeladora; una fuga activa zona de exclusión de 500 metros y requiere traje nivel B mínimo. El puerto recibe más de 300,000 cruceristas al año. <strong>Topolobampo</strong> (municipio de Ahome, norte de Sinaloa) es terminal del ferrocarril y maneja granel sólido, fertilizantes y contenedores intermodales; un incendio en silo de grano puede generar polvo combustible en suspensión con riesgo de deflagración. Ambos puertos tienen convenio con la Armada de México para operaciones marítimas.`,
  },
  {
    q: "¿Qué es el incendio de cañaveral y por qué es peligroso en Sinaloa?",
    a: `La <strong>quema de caña</strong> previa a cosecha —práctica autorizada bajo condiciones controladas— genera un frente de fuego que puede avanzar entre 4 y 15 km/h según el viento. Lo que distingue al cañaveral es la <strong>trayectoria de las brasas</strong>: fragmentos de hoja encendida que viajan 150 a 250 metros por delante del frente con el viento, creando focos secundarios que pueden cortar la ruta de retirada del bombero si el viento rota. La estación de Navolato tiene convenio con el <strong>Ingenio Azucarero El Dorado</strong> para activación conjunta; el criterio de abandono del perímetro se activa con viento superior a 25 km/h.`,
  },
  {
    q: "¿Qué municipios cubre la Sierra Madre Occidental en Sinaloa?",
    a: `Los municipios serranos de Sinaloa con mayor riesgo de incendio forestal y rescate en montaña son <strong>Badiraguato</strong>, <strong>Choix</strong> y <strong>Cosalá</strong> (Pueblo Mágico con minas históricas de plata). Sus estaciones operan con vehículos 4x4 preparados para terrenos de alta pendiente, con tiempos de respuesta de 15 a 40 minutos en las comunidades más alejadas. También se incluye la presierra de <strong>Concordia</strong> y <strong>Mocorito</strong> (Pueblo Mágico). El municipio de El Fuerte, en el norte serrano, es punto de partida del <strong>Tren Chepe</strong> hacia las Barrancas del Cobre.`,
  },
  {
    q: "¿Cómo prevenir incendios en campos agrícolas de Sinaloa?",
    a: `Los cuerpos de bomberos de Sinaloa recomiendan para zonas agrícolas: avisar a la estación más cercana antes de realizar <strong>quemas autorizadas</strong> de rastrojo o caña; verificar la dirección y velocidad del viento antes de iniciar (no quemar con viento superior a 20 km/h); mantener cortafuegos de al menos 3 metros; tener agua disponible en tanques de emergencia; y llamar al <strong>911</strong> ante cualquier fuga o intoxicación por agroquímico. En caso de intoxicación, retirar a los afectados del campo, no inducir el vómito y comunicar al operador el nombre del cultivo y los productos empleados ese día.`,
  },
  {
    q: "¿Qué hacer en temporada de huracanes si vivo en la costa de Sinaloa?",
    a: `Ante un aviso de huracán en la costa de Sinaloa: sigue las instrucciones de <strong>Protección Civil Sinaloa</strong> y el <strong>Servicio Meteorológico Nacional (SMN)</strong>; evacúa las zonas de manglar, playa y riberas de ríos ante alerta naranja o roja; no esperes a que los caminos de terracería se vuelvan intransitables con las primeras bandas de lluvia. Ten preparada una <strong>mochila de emergencia</strong> con documentos, agua, medicamentos y linterna. Llama al <strong>911</strong> solo para emergencias reales; para información de refugios contacta al ayuntamiento de tu municipio.`,
  },
];

