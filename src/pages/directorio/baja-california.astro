---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesBajaCalifornia, getMunicipios, getEstadisticas } from "@data/estaciones-baja-california";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("baja-california");

const municipios   = getMunicipios();
const estadisticas = getEstadisticas();

const canonical = "https://bombero.mx/directorio/baja-california/";

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const totalEstaciones = estacionesBajaCalifornia.length;
const totalPersonal   = estacionesBajaCalifornia.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesBajaCalifornia.reduce((s, e) => s + (e.unidades ?? 0), 0);

// ── Comparativa regional ────────────────────────────────────────────────────
const zonasDef = [
  {
    nombre: "Tijuana Metropolitana",
    municipios: ["Tijuana"],
    chip: "total",
    cobertura: "Total",
    perfil: "Ciudad más poblada de BC (2.1M+), frontera San Diego, maquiladora Otay, cañones y deslaves.",
  },
  {
    nombre: "Mexicali y Desierto",
    municipios: ["Mexicali"],
    chip: "total",
    cobertura: "Total",
    perfil: "Capital del estado, calor extremo 52 °C, industria aeroespacial/electrónica, Valle agrícola y frontera Arizona.",
  },
  {
    nombre: "Ensenada y Costa",
    municipios: ["Ensenada"],
    chip: "alta",
    cobertura: "Alta",
    perfil: "Puerto de altura Pacífico, Valle de Guadalupe (vitivinícola), San Quintín (agroindustrial).",
  },
  {
    nombre: "Tecate y Sierra",
    municipios: ["Tecate"],
    chip: "alta",
    cobertura: "Alta",
    perfil: "Sierra de Juárez, La Rumorosa (1 275 msnm), industria cervecera Heineken, paso fronterizo.",
  },
  {
    nombre: "Playas de Rosarito",
    municipios: ["Playas de Rosarito"],
    chip: "media",
    cobertura: "Media",
    perfil: "Corredor turístico costero, rescate acuático Pacífico, eventos masivos Spring Break.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesBajaCalifornia.filter((e) => z.municipios.includes(e.municipio ?? ''));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nMun:  z.municipios.length,
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Baja California, México",
  "description": `Directorio de las ${totalEstaciones} estaciones de bomberos en los 5 municipios de Baja California: Tijuana (fundada 1925), Mexicali (1918), Ensenada, Tecate y Playas de Rosarito. HAZMAT maquiladora, incendios forestales Sierra de Juárez, rescate sísmico y respuesta binacional San Diego/Imperial County. Emergencias: 911.`,
  "numberOfItems": totalEstaciones,
  "itemListElement": estacionesBajaCalifornia.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.municipio || e.ciudad,
        "addressRegion": "Baja California",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/baja-california/${e.slug}/`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Baja California: estaciones, historia y servicios de emergencia",
  "description": "Guía del H. Cuerpo de Bomberos de Baja California: historia (Mexicali 1918, Tijuana 1925), infraestructura en los 5 municipios, HAZMAT maquiladoras, riesgo sísmico, vientos Santa Ana y directorio con teléfonos directos.",
  "about": [
    "Heroico Cuerpo de Bomberos de Baja California",
    "Protección Civil",
    "Materiales peligrosos HAZMAT",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/baja-california.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Baja California",
  "description": `Directorio verificado de las ${totalEstaciones} estaciones de bomberos en los 5 municipios de Baja California: Tijuana, Mexicali, Ensenada, Tecate y Playas de Rosarito. Teléfonos, cobertura, funciones e historia.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "H. Cuerpo de Bomberos de Baja California" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/baja-california.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Baja California (≥10) ────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Baja California?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas en los 5 municipios de Baja California. La llamada se enruta al C4 municipal más cercano (Tijuana, Mexicali, Ensenada, Tecate o Rosarito), que coordina respuesta simultánea de bomberos, policía y servicios médicos. Los teléfonos directos de las estaciones principales son: Tijuana <strong>664 684 0580</strong>, Mexicali <strong>686 558 1616</strong>, Ensenada <strong>646 178 2388</strong>, Tecate <strong>665 654 1313</strong>, Rosarito <strong>661 612 0808</strong>.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Tijuana?",
    a: `El <strong>20 de noviembre de 1925</strong>, un grupo de ciudadanos voluntarios fundó el Cuerpo de Bomberos de Tijuana para proteger la entonces pequeña ciudad fronteriza. La fecha y la historia están documentadas en la exposición centenaria <em>«100 años en la línea de fuego»</em> del Centro Cultural Tijuana (CECUT), que conmemoró el primer siglo de servicio del cuerpo. A nivel nacional, el primer cuerpo de bomberos de México fue fundado el <strong>22 de agosto de 1873</strong> en Veracruz.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Mexicali?",
    a: `El Cuerpo de Bomberos de Mexicali fue fundado en <strong>1918</strong>, cuatro años después de que el municipio fuera creado formalmente (1914). La institución celebró su centenario en 2018, con cobertura de La Voz de la Frontera. En el transcurso de más de un siglo ha desarrollado protocolos únicos para operar en el desierto de Sonora, donde las temperaturas pueden superar los 52 °C.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque conmemora la fundación del <strong>primer cuerpo de bomberos de México</strong>, el 22 de agosto de 1873 en el puerto de Veracruz. Cada año, en esa fecha, se reconoce la labor de todos los bomberos del país, incluidos los de los cinco municipios de Baja California.`,
  },
  {
    q: "¿Qué es el riesgo HAZMAT en las maquiladoras de Tijuana y Mexicali?",
    a: `Baja California concentra más de 700 plantas maquiladoras de exportación en sectores de electrónica, aeroespacial, dispositivos médicos y automotriz. Estas instalaciones almacenan solventes, metales, resinas y gases industriales que generan emergencias de <strong>materiales peligrosos (HAZMAT)</strong> de alta complejidad: incendios con llama invisible (solventes), derrames de químicos regulados y fugas de gases industriales. Las estaciones de Otay (Tijuana) e Industrial (Mexicali) tienen personal certificado en HAZMAT con trajes encapsulados Nivel A y laboratorio móvil.`,
  },
  {
    q: "¿Qué tan activa es la actividad sísmica en Baja California?",
    a: `Baja California está en el límite entre las placas tectónicas del Pacífico y Norteamérica, con alrededor de <strong>15 fallas activas</strong> identificadas, entre ellas Cerro Prieto (80 km, responsable de sismos de 7.1 en 1940 y 6.6 en 1979), San Andrés, Rose Canyon (entre San Diego y Tijuana), Elsinore y Coronado Banks. El sismo más reciente de gran magnitud fue el <strong>El Mayor-Cucapah del 4 de abril de 2010 (Mw 7.2)</strong>, el mayor instrumentalmente registrado en la región. Los municipios con mayor actividad sísmica son Tijuana, Mexicali, Tecate y Ensenada.`,
  },
  {
    q: "¿Qué son los vientos de Santa Ana y cómo afectan a los bomberos de BC?",
    a: `Los <strong>vientos de Santa Ana</strong> son corrientes de aire caliente y muy seco que descienden desde el interior del suroeste de Estados Unidos hacia la costa del sur de California y el norte de Baja California. Ocurren principalmente entre <strong>octubre y febrero</strong>, con rachas que pueden superar los 100 km/h. En Tijuana, Tecate y Rosarito, estos vientos propagan incendios de matorral y chaparral a velocidades extremas, obligan a evacuaciones y ponen en alerta permanente a los cuerpos de bomberos durante toda la temporada seca. Coordinan con San Diego Fire-Rescue por la continuidad transfronteriza del riesgo.`,
  },
  {
    q: "¿Cómo funciona la cooperación binacional de los bomberos de Baja California con Estados Unidos?",
    a: `Baja California es el único estado de México con protocolos formales de respuesta conjunta con agencias de bomberos de Estados Unidos. La estación central de Tijuana coordina con <strong>San Diego Fire-Rescue Department</strong>; Mexicali mantiene acuerdos con el <strong>Imperial County Fire Department</strong> de California; y San Luis Río Colorado opera en coordinación con agencias de <strong>Yuma, Arizona</strong>. Estos convenios permiten cruce de unidades cuando el incendio o emergencia afecta ambos lados de la frontera, y generan capacitación continua bilateral.`,
  },
  {
    q: "¿Por qué el calor de Mexicali es tan peligroso para los bomberos?",
    a: `Mexicali registra temperaturas que superan los <strong>52 °C en julio y agosto</strong>, convirtiéndola en una de las ciudades habitadas más calurosas del hemisferio occidental. Un bombero en traje estructural completo puede sufrir golpe de calor —temperatura corporal superior a 40 °C con cese de sudoración y pérdida de conciencia— en menos de 15 minutos de exposición sin hidratación. Las estaciones de Mexicali mantienen <strong>puestos de hidratación y enfriamiento rápido</strong> permanentes durante los meses de verano y aplican rotaciones de personal de 8 a 10 minutos en el perímetro de trabajo.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Baja California?",
    a: `Combate de incendios estructurales, forestales y de matorral; <strong>materiales peligrosos (HAZMAT)</strong> en la industria maquiladora; rescate vehicular (incluyendo la peligrosa carretera de La Rumorosa con más de 80 curvas); <strong>rescate acuático</strong> en el Pacífico (Ensenada, Playas de Tijuana, Rosarito); atención prehospitalaria; búsqueda y rescate en zonas sísmicas; emergencias por golpe de calor (Mexicali); <strong>emergencias portuarias</strong> en el Puerto de Ensenada, y capacitación y prevención.`,
  },
  {
    q: "¿Qué riesgo representan los incendios forestales en la Sierra de Juárez y La Rumorosa?",
    a: `La <strong>Sierra de Juárez</strong> y la zona de <strong>La Rumorosa</strong> (1 275 msnm) albergan bosques de pino-encino dentro del Parque Nacional Constitución de 1857. Durante la temporada seca (mayo-septiembre), y especialmente cuando confluyen con los <strong>vientos de Santa Ana</strong>, los incendios de matorral y bosque pueden avanzar varios kilómetros por hora. La Estación La Rumorosa fue establecida específicamente para cubrir este punto crítico, donde además se registran numerosos accidentes vehiculares por niebla densa, nieve invernal y viento.`,
  },
  {
    q: "¿Cómo debo actuar ante una emergencia en la zona maquiladora de Tijuana o Mexicali?",
    a: `En cualquier emergencia industrial, llama inmediatamente al <strong>911</strong> e indica el nombre del parque industrial y el tipo de sustancia involucrada si la conoces. <strong>No entres al área</strong> hasta que el personal HAZMAT haya evaluado el riesgo y establecido el perímetro de seguridad. Evacúa siguiendo las rutas del plan de emergencias de la planta y activa la brigada interna mientras aguardas la llegada de los bomberos. Las estaciones Otay (Tijuana) e Industrial (Mexicali) tienen tiempos de respuesta de 5 a 10 minutos en zonas industriales.`,
  },
];

