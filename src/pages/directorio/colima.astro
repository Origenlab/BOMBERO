---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesColima,
  ESTADISTICAS_COLIMA,
} from "@data/estaciones-colima";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("colima");

// ── Derivar municipios desde el array de estaciones ────────────────────────
const municipios      = [...new Set(estacionesColima.map((e) => e.ciudad))].sort();
const totalEstaciones = ESTADISTICAS_COLIMA.total_estaciones;
const totalMunicipios = ESTADISTICAS_COLIMA.municipios_cubiertos;
const totalBomberos   = ESTADISTICAS_COLIMA.total_bomberos;
const totalUnidades   = ESTADISTICAS_COLIMA.total_unidades;

const canonical = "https://bombero.mx/directorio/colima/";

// ── Comparativa regional (desde datos reales del directorio) ───────────────
const zonasDef = [
  {
    nombre: "Zona Metropolitana Colima–Villa de Álvarez",
    municipios: ["Colima", "Villa de Álvarez"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital estatal, coordinación volcánica (CENAPRED), zona universitaria y corredor comercial.",
  },
  {
    nombre: "Zona Portuaria Manzanillo",
    municipios: ["Manzanillo"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Puerto #1 del Pacífico mexicano (~3.7 M TEU/año), HAZMAT marítimo, playas turísticas.",
  },
  {
    nombre: "Zona Agrícola Tecomán",
    municipios: ["Tecomán"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Principal productor de limón mexicano (35 % nacional), industria citrícola, Laguna Cuyutlán.",
  },
  {
    nombre: "Zona Volcánica Comala",
    municipios: ["Comala"],
    cobertura: "Media",
    chip: "media",
    perfil: "Pueblo Mágico a ~8 km del cráter; respuesta volcánica, lahares y turismo cultural.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesColima.filter((e) => z.municipios.includes(e.ciudad));
  return {
    ...z,
    nMun: z.municipios.length,
    nEst: est.length,
    nPers: est.reduce((s, e) => s + (e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades  ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Colima",
  "description": `Directorio de las ${totalEstaciones} estaciones de bomberos en Colima: Volcán de Fuego (~3,860 msnm, uno de los más activos de Norteamérica), Puerto de Manzanillo (#1 Pacífico mexicano, ~3.7 M TEU), tsunamis y huracanes del Pacífico. Emergencias: 911.`,
  "numberOfItems": estacionesColima.length,
  "itemListElement": estacionesColima.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Colima",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/colima/${e.slug}/`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Colima: estaciones, historia y servicios de emergencia",
  "description": "Guía de los cuerpos de bomberos de Colima: historia (1942–hoy), infraestructura en 5 municipios, respuesta volcánica, HAZMAT portuario, tsunamis y directorio de estaciones con teléfonos directos.",
  "about": [
    "Cuerpo de Bomberos de Colima",
    "Volcán de Fuego de Colima",
    "Puerto de Manzanillo",
    "Protección Civil Colima",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/colima.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Colima",
  "description": `Directorio verificado de las ${totalEstaciones} estaciones de bomberos en Colima, con teléfonos, cobertura por municipio, historia de los cuerpos y perfil de riesgo volcánico, portuario y costero.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Cuerpo de Bomberos de Colima" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/colima.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Colima (≥10) — alimentan el FAQPage schema ──────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Colima?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas en todo el estado de Colima. La llamada se enruta al Centro Estatal de Emergencias, que despacha la unidad más cercana. Para alertas volcánicas, el <strong>Semáforo Volcánico del CENAPRED</strong> activa protocolos de evacuación automáticos; ante erupción inminente, sigue las instrucciones de Protección Civil sin esperar confirmación. Ante tsunami, el Sistema Nacional activa sirenas automáticas en la costa cuando se detecta un sismo mayor a 7.0 en el Pacífico.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Colima?",
    a: `El directorio de BOMBERO.MX registra <strong>${totalEstaciones} estaciones</strong> de bomberos en Colima, distribuidas en <strong>${totalMunicipios} municipios</strong>: Estación Central de Colima (1942), Estación de Villa de Álvarez (1985), Estación de Manzanillo (Bomberos Voluntarios de Manzanillo, A.C., fundada el 23 de noviembre de 2001), Estación de Tecomán (1972) y Estación de Comala (1990). El total es de <strong>${totalBomberos} bomberos</strong> y <strong>${totalUnidades} unidades</strong> en el directorio.`,
  },
  {
    q: "¿Cuándo se fundó el primer cuerpo de bomberos en Colima?",
    a: `La <strong>Estación Central de Bomberos de Colima</strong>, en la capital del estado, fue fundada en <strong>1942</strong>. A nivel nacional, el primer cuerpo de bomberos de México se fundó el <strong>22 de agosto de 1873 en el puerto de Veracruz</strong>, fecha que se conmemora cada año como el <strong>Día del Bombero en México</strong>. En Manzanillo, los <strong>Bomberos Voluntarios de Manzanillo, A.C.</strong> se constituyeron el <strong>23 de noviembre de 2001</strong> como asociación civil sin fines de lucro especializada en emergencias portuarias.`,
  },
  {
    q: "¿Qué es el Semáforo Volcánico del Volcán de Fuego de Colima?",
    a: `El <strong>Semáforo Volcánico</strong> es el sistema del <strong>CENAPRED</strong> (Centro Nacional de Prevención de Desastres) para comunicar el nivel de actividad del Volcán de Fuego de Colima (~3,860 msnm). Sus fases van de Verde (actividad normal) a Amarillo Fase 1, 2 y 3 (actividad creciente) y Rojo (evacuación obligatoria inmediata). Cuando el semáforo escala a <strong>Amarillo Fase 2</strong>, los bomberos de Comala y Colima activan la evacuación preventiva de las comunidades dentro del radio de 8 km del cráter —Pueblo Juárez, La Yerbabuena, Zacualpan— sin esperar confirmación de flujo piroclástico.`,
  },
  {
    q: "¿Qué tan peligroso es el Volcán de Fuego de Colima?",
    a: `El Volcán de Fuego de Colima es <strong>uno de los volcanes más activos de Norteamérica</strong> y el más activo de México, con erupciones documentadas desde el siglo XVI. La última erupción mayor, en <strong>julio de 2015</strong>, fue la más intensa desde 1913 según el CENAPRED: generó flujos piroclásticos en las barrancas de Montegrande y San Antonio que descendieron a más de 100 km/h, con columnas de ceniza de hasta 10 km de altura. Hasta <strong>350,000 personas</strong> viven en el área de influencia del volcán, y el municipio de Comala colinda a solo 8 km del cráter.`,
  },
  {
    q: "¿Hay riesgo de tsunami en Colima?",
    a: `Sí. Los <strong>157 km de costa de Colima</strong> son de los más vulnerables de México a tsunamis generados por sismos en la Placa de Cocos. El evento histórico más destructivo fue el <strong>tsunami del 22 de junio de 1932 en Cuyutlán</strong>: un sismo de Mw 6.9 generó olas que superaron los 10 metros de altura, causaron más de 75 muertos y dejaron una franja de 20 km de costa sin una sola casa en pie. El evento se conoce como la <strong>"Ola Verde"</strong>. El <strong>Sistema Nacional de Alerta de Tsunamis</strong> activa sirenas automáticas en Manzanillo, Santiago y Cuyutlán cuando detecta sismos mayores a 7.0 en el Pacífico.`,
  },
  {
    q: "¿Cómo debo actuar ante una alerta de tsunami en Manzanillo o en las playas de Colima?",
    a: `Ante una alerta de tsunami: <strong>evacúa de inmediato</strong> hacia tierra adentro o a zonas elevadas, siguiendo las rutas de evacuación señalizadas. No esperes ver el agua retroceder —esa señal indica que la primera ola ya está en camino. La ventana de evacuación desde las costas de Colima puede ser de apenas <strong>10 a 30 minutos</strong> desde el sismo. Llama al <strong>911</strong> solo si hay lesionados; en caso contrario, usa la línea para reportar situaciones críticas y mantén libre la red para emergencias. Sigue las instrucciones de Protección Civil y Bomberos de Manzanillo en sitio.`,
  },
  {
    q: "¿Qué hace el cuerpo de bomberos de Manzanillo en el puerto?",
    a: `Los <strong>Bomberos Voluntarios de Manzanillo</strong> y el cuerpo municipal atienden emergencias específicas del <strong>Puerto de Manzanillo</strong> (#1 del Pacífico mexicano, ~3.7 millones de TEU en 2023): incendios en contenedores y buques, derrames de materiales peligrosos (HAZMAT), rescate acuático en bahía y zonas portuarias, y emergencias en las terminales CONTECON y SSA México. Trabajan en coordinación con la <strong>Capitanía de Puerto</strong> y la <strong>Armada de México</strong>. El mayor riesgo son los contenedores con carga no declarada correctamente, que pueden contener sustancias reactivas o inflamables.`,
  },
  {
    q: "¿Qué es el sismo de 2003 y cómo afectó a los bomberos de Colima?",
    a: `El <strong>21 de enero de 2003</strong> un sismo de <strong>Mw 7.6</strong> con epicentro frente a las costas de Cuyutlán sacudió Colima durante aproximadamente 55 segundos. El terremoto causó <strong>23 muertos</strong>, alrededor de 300 heridos y más de 10,000 viviendas afectadas, principalmente en Colima capital, Villa de Álvarez, Pueblo Juárez, Coquimatlán y Zacualpan. Los cuerpos de bomberos de la capital y Villa de Álvarez coordinaron búsqueda y rescate urbano, atención prehospitalaria y control de incendios secundarios en las horas posteriores al sismo.`,
  },
  {
    q: "¿Cómo prevenir incendios en zonas de cultivo y empacadoras de limón en Tecomán?",
    a: `Tecomán concentra el <strong>35 % de la producción nacional de limón mexicano</strong>. En empacadoras y almacenes citrícolas, el principal riesgo es el aceite esencial de limón (limoneno), que es inflamable con punto de ignición de 48 °C y puede crear atmósferas explosivas en espacios cerrados. Las recomendaciones básicas son: mantener ventilación en zonas de proceso, no acumular residuos de cáscara húmeda en espacios cerrados, tener extintores de polvo químico seco o espuma AFFF a la mano, prohibir fumar o encender fuego cerca de zonas de proceso, y capacitar a los trabajadores en el plan de evacuación. Ante cualquier incendio, llama al <strong>911</strong> de inmediato.`,
  },
  {
    q: "¿Los bomberos de Colima atienden incendios forestales en la Sierra de Manantlán?",
    a: `Sí. La <strong>Reserva de la Biosfera Sierra de Manantlán</strong> (139,577 ha, compartida con Jalisco) es uno de los ecosistemas más biodiversos de México, con bosques de pino-encino, maíz primitivo (teosinte) y poblaciones de jaguar. Los cuerpos de bomberos de Colima apoyan combate de incendios forestales en coordinación con la <strong>CONAFOR</strong> (Comisión Nacional Forestal) y la Secretaría de Protección Civil. La temporada de mayor riesgo es la de estiaje (noviembre–mayo). Los incendios forestales en esta zona también pueden ser detonados por actividad volcánica que genera ceniza incandescente.`,
  },
  {
    q: "¿Qué servicios de emergencia cubre la estación de Comala, el Pueblo Mágico?",
    a: `La <strong>Estación de Bomberos de Comala</strong> (fundada en 1990) es la más cercana al cráter del Volcán de Fuego, a aproximadamente 8 km. Sus funciones principales son: monitoreo de actividad volcánica y enlace con CENAPRED, coordinación de evacuaciones de las comunidades más cercanas al volcán, combate de incendios forestales en la zona volcánica, rescate en barrancas (La Lumbre, Montegrande), atención a turistas del Pueblo Mágico y protección del patrimonio histórico. También es el punto de avanzada para respuesta a lahares —flujos de lodo volcánico que pueden descender las barrancas a más de 60 km/h.`,
  },
];

