  },
  {
    src: "/images/directorio/estacion-bomberos-petroquimica-01.avif",
    alt: "Corredor industrial Apodaca — Pesquería, Nuevo León",
    label: "Corredor Industrial"
  },
];

// Números de emergencia NL
const emergencyNumbers = [
  { number: "911",              label: "Emergencias (C5 NL)"   },
  { number: "(81) 8345-2424",  label: "Bomberos Monterrey"    },
  { number: "(81) 8378-8080",  label: "Bomberos San Pedro"    },
  { number: "(81) 8350-6060",  label: "HAZMAT Industrial"     },
  { number: "(81) 8367-9090",  label: "Bomberos Guadalupe"    },
  { number: "(81) 8285-1414",  label: "Bomberos Santiago"     },
];

// Estados vecinos
const estadosVecinos = getEstadosVecinos("nuevo-leon");

// Regiones de Nuevo León
const regiones = [
  {
    nombre: "Zona Metropolitana de Monterrey",
    desc: "Monterrey, San Pedro Garza García, Guadalupe, Apodaca, Santa Catarina, General Escobedo, García, Juárez"
  },
  {
    nombre: "Corredores Industriales",
    desc: "TERNIUM (Pesquería), CEMEX, Vitro (Santa Catarina), KIA Motors, Navistar (Apodaca) — 4 estaciones HAZMAT certificadas"
  },
  {
    nombre: "Sierra Madre Oriental",
    desc: "Santiago (Pueblo Mágico), Allende, Chipinque, La Huasteca, Cascada Cola de Caballo"
  },
  {
    nombre: "Zona Citrícola Sur",
    desc: "Montemorelos (capital citrícola), Linares, agroindustria naranja"
  }
];

// Tarjetas EPP
const eppCards = [
  {
    image:     "/images/directorio/traje-hazmat-nivel-a-01.avif",
    imageAlt:  "Traje HAZMAT para emergencias industriales en Nuevo León",
    badge:     "HAZMAT Industrial",
    title:     "Trajes Industriales NL",
    text:      "Equipo de protección HAZMAT para emergencias en los corredores industriales de <strong>Monterrey, Apodaca, Pesquería y Santa Catarina</strong>. Trajes certificados para el sector siderúrgico, cementero y petroquímico del estado.",
    href:      "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image:     "/images/directorio/mascara-scba-bombero-01.avif",
    imageAlt:  "Equipo SCBA para espacios confinados en Nuevo León",
    badge:     "NFPA 1970",
    title:     "SCBA Espacios Confinados",
    text:      "Equipos de respiración autónoma para operaciones en <strong>plantas TERNIUM, CEMEX y Vitro</strong>. Máxima autonomía en atmósferas IDLH con certificación NFPA 1970, indispensables en el Metrorrey (40 estaciones, 3 líneas).",
    href:      "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Equipo Respiratorio",
  },
  {
    image:     "/images/directorio/equipo-bomberos-rescate-vehicular-01.avif",
    imageAlt:  "Equipo de rescate vehicular para autopistas de Nuevo León",
    badge:     "Rescate",
    title:     "Rescate Vehicular Pesado",
    text:      "Herramientas hidráulicas de extricación para accidentes en la <strong>autopista Monterrey-Laredo</strong> y el corredor Colombia, con más de 15,000 tractocamiones diarios. Spreaders y cutters de última generación.",
    href:      "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Equipo de Rescate",
  },
  {
    image:     "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt:  "Casco estructural NFPA para bomberos de Nuevo León",
    badge:     "NFPA 1970",
    title:     "Cascos Certificados NFPA",
    text:      "Cascos estructurales con protección térmica avanzada para los bomberos de <strong>Monterrey y su zona metropolitana</strong>. Visores integrados y sistemas de comunicación compatibles con los protocolos del Centro de Operaciones de Emergencia (COE).",
    href:      "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
];

// Schemas estructurados
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio de ${totalEstaciones} estaciones de bomberos en Nuevo León. Bomberos de Nuevo León A.B.P., fundados en 1908 en Monterrey. Corredores industriales HAZMAT, Sierra Madre Oriental y corredor Monterrey-Laredo. Emergencias: 911.`,
  numberOfItems: totalEstaciones,
  itemListElement: estacionesNuevoLeon.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.ciudad,
        addressRegion: estado,
        addressCountry: "MX"
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}`
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Nuevo León: estaciones, historia y servicios de emergencia",
  "description": "Guía del Cuerpo de Bomberos de Nuevo León: historia (1908–hoy), infraestructura en la ZMM, HAZMAT industrial, rescate en Sierra Madre Oriental, Huracán Alex 2010 y directorio de estaciones con teléfonos directos.",
  "about": [
    "Bomberos de Nuevo León A.B.P.",
    "H. Cuerpo de Bomberos de Monterrey",
    "Protección Civil Nuevo León",
    "Materiales peligrosos HAZMAT industrial",
    "Servicios de emergencia noreste de México",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/nuevo-leon.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": `Estaciones de Bomberos en Nuevo León`,
  "description": `Directorio verificado de ${totalEstaciones} estaciones de bomberos en Nuevo León, con teléfonos directos, cobertura, funciones e historia del Cuerpo de Bomberos de Nuevo León desde 1908.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Bomberos de Nuevo León A.B.P." },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/nuevo-leon.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// FAQs únicas Nuevo León (≥10) — alimentan el FAQPage schema
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Nuevo León?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas a través del C5 de Nuevo León. El sistema enruta la llamada a la estación más cercana. Los teléfonos directos principales son: Monterrey (81) 8345-2424, San Pedro Garza García (81) 8378-8080, Guadalupe (81) 8367-9090, HAZMAT Industrial (81) 8350-6060 y Santiago Sierra Madre (81) 8285-1414.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Nuevo León?",
    a: `Los <strong>Bomberos de Nuevo León</strong> fueron fundados el <strong>28 de septiembre de 1908</strong> en la ciudad de Monterrey. La organización se constituyó como Asociación Civil en 1954 y como Asociación de Beneficencia Privada (A.B.P.) en 2011. El primer cuerpo de bomberos del país se fundó el <strong>22 de agosto de 1873</strong> en el puerto de Veracruz, fecha que se conmemora cada año como el <strong>Día del Bombero</strong> en México.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Nuevo León?",
    a: `Este directorio reúne <strong>${totalEstaciones} estaciones de bomberos</strong> en Nuevo León, distribuidas en la Zona Metropolitana de Monterrey, los corredores industriales, el corredor carretero norte y la zona citrícola sur. La ZMM concentra la mayor parte de las estaciones, incluyendo las cuatro unidades HAZMAT especializadas.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque conmemora la fundación del primer cuerpo de bomberos del país, el <strong>22 de agosto de 1873</strong> en el puerto de Veracruz. En esa fecha se reconoce cada año la labor de todos los bomberos de la República, incluidos los cuerpos de la Zona Metropolitana de Monterrey y el resto de Nuevo León.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Nuevo León?",
    a: `Combate de <strong>incendios estructurales, industriales y forestales</strong>; <strong>materiales peligrosos (HAZMAT)</strong> en los corredores industriales; <strong>rescate vehicular</strong> en autopistas de alto tráfico; <strong>rescate de montaña</strong> y cascadas en la Sierra Madre Oriental; <strong>rescate en agua rápida</strong> en el Canal del Río Santa Catarina; atención de emergencias en el <strong>Metrorrey</strong> (3 líneas, 40 estaciones); y prevención mediante inspecciones y simulacros.`,
  },
  {
    q: "¿Qué daños causó el Huracán Alex en Nuevo León?",
    a: `El <strong>Huracán Alex</strong> tocó tierra en Tamaulipas el <strong>1 de julio de 2010</strong> como categoría 2 y descargó entre 500 y 800 milímetros de lluvia en 60 horas sobre Nuevo León. El Canal del Río Santa Catarina se desbordó, afectando al menos 60 colonias en Monterrey. El saldo fue de <strong>15 personas fallecidas</strong>, más de 15,000 familias damnificadas y daños estimados en <strong>16,896 millones de pesos</strong>. Los bomberos y Protección Civil ejecutaron rescates en el canal en condiciones extremas de flujo rápido.`,
  },
  {
    q: "¿Por qué Nuevo León tiene la mayor concentración de estaciones HAZMAT de México?",
    a: `Nuevo León alberga la mayor concentración de industria pesada del norte del país: siderúrgicas como <strong>TERNIUM</strong> (Pesquería), cementeras como <strong>CEMEX</strong> (corporativo global, sede Monterrey), vidriera como <strong>Vitro</strong>, automotrices como <strong>KIA Motors</strong> y <strong>Navistar</strong> (Apodaca), y miles de empresas con materiales peligrosos en sus corredores industriales. Esta densidad industrial justifica las <strong>4 estaciones HAZMAT certificadas</strong> del estado.`,
  },
  {
    q: "¿Cómo responden los bomberos a una emergencia en el Metrorrey?",
    a: `El <strong>Metrorrey</strong> opera 3 líneas y 40 estaciones en Monterrey, San Pedro y Guadalupe, con una afluencia de aproximadamente 369,000 pasajeros diarios. Los protocolos de emergencia en el sistema requieren equipo de <strong>respiración autónoma (SCBA)</strong> para espacios confinados, ventilación táctica y evacuación coordinada con el personal del Sistema de Transporte Colectivo. La Estación Central de Monterrey es la primera respuesta para incidentes en las líneas que pasan por el centro.`,
  },
  {
    q: "¿Cómo trabajan los bomberos en los incendios forestales de Chipinque?",
    a: `El <strong>Parque Ecológico Chipinque</strong> tiene 1,624 hectáreas en la Sierra Madre Oriental dentro del municipio de San Pedro Garza García. La temporada crítica de incendios va de enero a junio. En condiciones de viento norte y baja humedad, un incendio en las laderas puede alcanzar zonas residenciales en menos de una hora. Los bomberos de San Pedro y Santa Catarina pre-posicionan unidades durante los días de alto riesgo y coordinan con los guardabosques del parque para detección temprana de columnas de humo.`,
  },
  {
    q: "¿Qué debo hacer si veo humo en la Sierra Madre Oriental o en Chipinque?",
    a: `Llama de inmediato al <strong>911</strong> o directamente a los Bomberos de Santiago al (81) 8285-1414. No intentes combatir el fuego por tu cuenta. Si estás en una zona de senderismo, sigue las rutas de evacuación señalizadas y aléjate en dirección contraria al humo. Durante la temporada de alto riesgo respeta las restricciones de acceso a las áreas naturales protegidas.`,
  },
  {
    q: "¿Cómo prevenir incendios en mi hogar en Nuevo León?",
    a: `Revisa periódicamente la instalación de <strong>gas</strong> y la <strong>instalación eléctrica</strong>; evita sobrecargar contactos. Instala <strong>detectores de humo</strong> y ten un extintor vigente. En temporada de calor extremo (mayo–septiembre con temperaturas de más de 40°C frecuentes en la ZMM), no abandones velas o aparatos eléctricos sin vigilancia. Establece un <strong>plan de evacuación</strong> con tu familia y ten el <strong>911</strong> a la mano.`,
  },
  {
    q: "¿Los servicios de los bomberos de Nuevo León tienen costo?",
    a: `Las emergencias que comprometen la <strong>vida o la integridad</strong> de las personas —incendios, rescates, fugas de gas— se atienden de forma <strong>gratuita</strong>. Los <strong>Bomberos de Nuevo León A.B.P.</strong> se sostienen también con donativos de particulares y empresas. Algunos servicios secundarios (capacitación, dictámenes a empresas) pueden tener cuota de recuperación. La atención de emergencia nunca se condiciona a un pago.`,
  },
];
---

<DirectorioEstadoLayout
  estado={estado}
  sigla={sigla}
  slug={slug}
  description={`Bomberos en Nuevo León: ${totalEstaciones} estaciones en la ZMM 5.8M, corredores industriales HAZMAT, Sierra Madre Oriental y corredor Monterrey-Laredo. Cuerpo fundado en 1908. Emergencias: 911.`}
  keywords={[
    "bomberos nuevo leon",
    "bomberos monterrey",
    "estaciones bomberos nuevo leon",
    "cuerpo bomberos monterrey 1908",
    "hazmat monterrey industrial",
    "bomberos san pedro garza garcia",
    "bomberos sierra madre nuevo leon",
    "incendios forestales chipinque",
    "rescate montana nuevo leon",
    "emergencias nuevo leon 911",
    "bomberos zona metropolitana monterrey",
    "rio santa catarina rescate inundaciones",
    "directorio bomberos nuevo leon",
  ]}
  canonical={canonical}
  jsonLd={jsonLd}

  totalEstaciones={totalEstaciones}
  totalMunicipios={totalMunicipios}
  habitantes="5.8M+"

  heroDesc={`Los <strong>Bomberos de Nuevo León</strong> —fundados el <strong>28 de septiembre de 1908</strong> en Monterrey— protegen a los <strong>5.8 millones de habitantes</strong> de la Zona Metropolitana de Monterrey y el resto del estado con <strong>${totalEstaciones} estaciones</strong> en este directorio. La corporación opera frente a la mayor concentración de industria pesada del norte de México: siderúrgicas, cementeras y automotrices con <strong>4 unidades HAZMAT certificadas</strong>; el <strong>Canal del Río Santa Catarina</strong>, escenario de rescate en agua rápida durante el Huracán Alex (2010); y la interfaz forestal-urbana de la <strong>Sierra Madre Oriental</strong> dentro del perímetro metropolitano.`}
  heroImage="/images/directorio/estacion-bomberos-monterrey-01.avif"
  heroImageAlt="Estación de Bomberos en Nuevo León — Zona Metropolitana de Monterrey"
  heroCaption="Bomberos de Nuevo León · Fundados en 1908 · ZMM y Sierra Madre"
  heroThumbs={heroThumbs}

  galleryImages={galleryImages}

  emergencyNumbers={emergencyNumbers}

  municipios={getMunicipios()}

