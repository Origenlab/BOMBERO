---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesNuevoLeon, getMunicipios } from "@data/estaciones-nuevo-leon";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { breadcrumbJsonLd } from "@lib/seo";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

// Configuración del estado
const estado = "Nuevo León";
const sigla = "NL";
const slug = "nuevo-leon";

const canonical = "https://bombero.mx/directorio/nuevo-leon/";

// Estadísticas derivadas del directorio
const totalEstaciones = estacionesNuevoLeon.length;
const totalMunicipios = getMunicipios().length;
const totalPersonal = estacionesNuevoLeon.reduce((sum, e) => sum + (e.personal ?? 0), 0);
const totalUnidades = estacionesNuevoLeon.reduce((sum, e) => sum + (e.unidades ?? 0), 0);

// Comparativa regional — zonas definidas explícitamente
const zonasDef = [
  {
    nombre: "Zona Metropolitana de Monterrey",
