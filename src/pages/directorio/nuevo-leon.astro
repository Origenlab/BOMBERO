    cobertura: "Total",
    chip: "total",
    perfil: "Centro histórico, corredores corporativos, Torre KOI (279.5 m), Metrorrey 3 líneas y 40 estaciones."
  },
  {
    nombre: "Corredores Industriales (Norte y Sur)",
    municipios: ["Apodaca (HAZMAT Norte)", "Santa Catarina (HAZMAT Sur)", "Pesquería"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "TERNIUM, CEMEX, Vitro, KIA Motors, Navistar — 4 estaciones HAZMAT certificadas."
  },
  {
    nombre: "Corredor Carretero Norte",
    municipios: ["General Zuazua", "Salinas Victoria", "Ciénega de Flores"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Autopista Monterrey-Colombia-Laredo: corredor comercial terrestre más importante de México hacia EE.UU."
  },
  {
    nombre: "Sierra Madre Oriental",
    municipios: ["Santiago", "Allende"],
    cobertura: "Media",
    chip: "media",
    perfil: "Rescate de montaña, incendios forestales Chipinque y La Huasteca, Pueblo Mágico Santiago."
  },
  {
    nombre: "Zona Citrícola Sur",
    municipios: ["Montemorelos", "Linares"],
    cobertura: "Media",
    chip: "media",
    perfil: "Capital citrícola de México, agroindustria de naranja, carretera nacional sur."
  },
];

// zonas con conteo de estaciones del directorio
const zonas = zonasDef.map((z) => {
  const estaciones = estacionesNuevoLeon.filter((e) =>
    z.municipios.some((m) => e.municipio?.includes(m.split(" ")[0]) || e.ciudad?.includes(m.split(" ")[0]))
  );
  return {
    ...z,
    nEst:  estaciones.length,
    nPers: estaciones.reduce((s, e) => s + (e.personal ?? 0), 0),
    nUni:  estaciones.reduce((s, e) => s + (e.unidades ?? 0), 0),
    nMunicipios: z.municipios.length,
  };
});

// Imágenes para tarjetas de estaciones
const stationImages = [
