---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-bomberos-tijuana-playas";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para bomberos de Playas de Tijuana",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 35 elementos de la estación costera de Tijuana: incendios en restaurantes de mariscos frente al mar, hoteles boutique y residencias en zona de acantilados, donde la brisa salina del Pacífico acelera la corrosión del equipamiento no certificado.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para rescate en acantilados de Playas de Tijuana",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia a impacto certificada para rescate en acantilados de roca volcánica en la zona costera de Playas. Los desprendimientos de roca en operaciones de rapel y las caídas de altura en el litoral hacen del casco NFPA 1971 el estándar mínimo exigible.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate acuático en el Pacífico",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia térmica certificada para rescate en embarcaciones y operaciones con equipos de rapel en acantilados costeros. Compatibles con guantes de neopreno en rescate acuático de corriente fría del Pacífico.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para operaciones costeras en Playas de Tijuana",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para roca húmeda de litoral marino, arena de playa y estructuras costeras con algas. Certificadas NFPA 1971 para operaciones en el terreno más mixto de Tijuana: del asfalto urbano al acantilado de basalto en metros.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Rescate Acuático donde el Muro Fronterizo Entra al Pacífico: 35 Elementos para Turismo Internacional, Acantilados y el Faro Icónico de Playas de Tijuana</h2>
    <p>
      La <strong>Estación de Bomberos Tijuana Playas</strong>, ubicada en Paseo Playas de Tijuana 1200,
      protege uno de los litorales más simbólicos del continente americano: el punto exacto donde el muro
      fronterizo México-Estados Unidos se adentra en las aguas del océano Pacífico. Con 35 elementos activos,
      4 unidades —incluyendo unidad de rescate acuático con motos acuáticas, tablas de rescate y equipo
      de rapel para acantilados— y tiempo de respuesta de 5 a 10 minutos, esta estación opera en un entorno
      que ninguna otra en México comparte: turismo binacional de playa, acantilados de basalto y la
      presencia internacional del Border Field State Park al otro lado de la frontera.
    </p>

    <h3>¿Cómo Llamar a la Estación Playas de Tijuana?</h3>
    <p>
      Para emergencias en Playas de Tijuana, Monumental, San Antonio del Mar o Playas Coronado, marca
      el <strong>911</strong>. El despacho centralizado coordina esta estación con la Central según el
      tipo de incidente y, en rescates acuáticos de gran magnitud, con la Guardia Costera. Contacto
      directo: 664 680 2121. El tiempo de respuesta de 5 a 10 minutos cubre todo el litoral bajo
      jurisdicción de esta estación.
    </p>

    <h3>Rescate Acuático en el Océano Pacífico: Bañistas, Surfistas y Turismo Binacional</h3>
    <p>
      Las playas de Tijuana reciben anualmente a miles de bañistas locales y turistas estadounidenses
      que cruzaron desde San Diego para pasar el día en la playa mexicana. El Pacífico en esta zona tiene
      corrientes de resaca —rip currents— que arrastran a bañistas lejos de la orilla. El personal
      certificado en rescate acuático de esta estación opera con motos acuáticas para alcanzar a víctimas
      en minutos antes de que el agotamiento sea un factor de riesgo adicional a la corriente.
    </p>

    <h3>El Faro de Playas y la Zona Turística más Singular de la Frontera</h3>
    <p>
      El Faro de Playas de Tijuana es el punto de referencia visual de esta zona, rodeado de restaurantes
      de mariscos, hoteles boutique y el emblemático anfiteatro al aire libre de Playas. Los incendios en
      establecimientos gastronómicos de mariscos —con frituras y cocinas industriales frente al mar—
      son el tipo de emergencia estructural más frecuente en esta zona, exigiendo acceso rápido en calles
      con doble fila de estacionamiento y alta afluencia peatonal.
    </p>

    <h3>Rescate en Acantilados de Basalto: Rapel y Acceso a Zonas sin Camino</h3>
    <p>
      Al sur de Playas de Tijuana, los acantilados de roca volcánica de 15 a 30 metros son frecuentados
      por personas que buscan vistas panorámicas y bajan a playas de difícil acceso. Las caídas desde
      estos acantilados generan llamados de rescate técnico que requieren equipos de rapel y personal
      certificado en rescate en altura. En <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
