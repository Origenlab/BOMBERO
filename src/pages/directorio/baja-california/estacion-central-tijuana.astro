---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-central-tijuana";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para incendios en Tijuana",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 110 elementos activos que operan en la metrópolis más grande del noroeste de México: incendios estructurales en cañones, plantas maquiladoras de Zona Río y emergencias en edificios de hasta 12 pisos, todo en condiciones de humedad costera del Pacífico.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para bomberos de Tijuana",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia a impactos certificada para operaciones USAR en estructuras colapsadas por sismos —Tijuana está en zona sísmica activa— y para rescate en edificios de la Zona Río y Blvd. Agua Caliente con riesgo de derrumbe parcial.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate vehicular en Tijuana",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Prensión certificada para rescate vehicular en la autopista Tijuana-Mexicali y vialidades de alta velocidad. Resistencia térmica para operaciones en maquiladoras de Zona Río y Otay, coordinadas desde esta estación central.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para la Estación Central de Tijuana",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para operaciones en terreno de cañones, escombros de estructuras colapsadas y pavimentos húmedos en temporada de lluvias. Certificadas NFPA 1971 para los 9 tipos de servicio de la Estación Central.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Núcleo Operativo de una Metrópolis Fronteriza de 2 Millones: 110 Elementos, Escalera de 35 Metros, Equipo USAR y Coordinación Binacional con San Diego Fire-Rescue</h2>
    <p>
      La <strong>Estación Central de Bomberos de Tijuana</strong>, ubicada en Blvd. Agua Caliente 4500,
      Aviación, es el corazón operativo del Heroico Cuerpo de Bomberos de la ciudad más poblada de Baja
      California y una de las 10 más grandes de México. Con 110 elementos activos, 11 unidades —incluyendo
      escalera telescópica de 35 metros, unidad HAZMAT con capacidad de descontaminación masiva, equipo
      USAR completo y sistema de drones con cámaras térmicas—, esta estación coordina la respuesta a
      emergencias en una metrópolis con topografía de cañones, industria maquiladora y la frontera más
      transitada del mundo.
    </p>

    <h3>¿Cómo Llamar a la Estación Central de Bomberos de Tijuana?</h3>
    <p>
      En cualquier emergencia en Tijuana, marca el <strong>911</strong>: el centro de despacho de la
      Estación Central coordina la respuesta metropolitana de las 8 estaciones de la ciudad y activa
      protocolos binacionales con San Diego cuando el incidente lo requiere. Contacto directo: 664 684 0580.
      Las zonas de cobertura primaria —Zona Río, Aviación, Cacho, Chapultepec, Hipódromo— tienen tiempo
      de respuesta de 4 a 8 minutos.
    </p>

    <h3>Centro de Mando Metropolitano: 8 Estaciones, Cañones y Zona Industrial</h3>
    <p>
      Tijuana es una ciudad que crece en vertical y en vertical al mismo tiempo: edificios de departamentos
      en zonas planas y asentamientos en cañones con laderas de 30 a 60 grados de pendiente. La Estación
      Central coordina los recursos de las 8 estaciones de la ciudad para garantizar que ninguna zona —desde
      los cañones del este hasta el corredor industrial de Otay o las playas del Pacífico— quede sin
      cobertura simultánea. En temporada de lluvias (diciembre a marzo), los deslaves en cañones generan
      el pico de llamados más alto del año.
    </p>

    <h3>Escalera Telescópica de 35 Metros para la Zona Río y Agua Caliente</h3>
    <p>
      El corredor de Blvd. Agua Caliente y la Zona Río Tijuana concentran hoteles, edificios residenciales
      y comerciales de 8 a 12 pisos. La escalera telescópica de 35 metros —la más grande de Baja California—
      permite rescate en piso 11 y apertura de ventilación en incendios contenidos en altura. Su uso en
      el Centro Histórico y la Zona Urbana Río es también herramienta de acceso en estructuras con
      escaleras de emergencia bloqueadas.
    </p>

    <h3>Equipo USAR: Búsqueda y Rescate en Estructuras Colapsadas por Sismo</h3>
    <p>
      Tijuana está ubicada en la zona sísmica activa del sistema de fallas del Pacífico. El equipo USAR
      —Urban Search and Rescue— incluye cámaras de detección de vida, herramientas de corte especializado,
      equipos de apuntalamiento y personal certificado para extraer víctimas de escombros en edificios
      colapsados. La Estación Central es la única en el estado con esta capacidad desplegable, disponible
      para apoyar a cualquier municipio en un evento sísmico mayor.
    </p>

    <h3>Coordinación Binacional con San Diego Fire-Rescue Department</h3>
    <p>
      Desde 1925, el Cuerpo de Bomberos de Tijuana ha mantenido una relación operativa con sus pares de
      San Diego. El acuerdo vigente de respuesta mutua permite el cruce de unidades en incendios de gran
      magnitud, especialmente en la zona de los cañones que cruzan la línea fronteriza. El personal
      recibe capacitación continua de San Diego Fire-Rescue en técnicas USAR, HAZMAT y rescate en
      estructuras colapsadas. Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica y certificado de laboratorio incluidos.
    </p>
  </Fragment>
</EstacionLayout>
