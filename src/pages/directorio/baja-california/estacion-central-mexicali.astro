---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-central-mexicali";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para operaciones a 50°C en Mexicali",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación obligatoria para los 95 elementos activos de la Estación Central ante incendios en temperaturas ambiente de 50°C: el traje debe disipar calor externo mientras aísla al bombero del fuego estructural en el Centro Histórico y el corredor industrial de Mexicali.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para bomberos de Mexicali",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia térmica certificada para operaciones HAZMAT y rescate en plantas maquiladoras del corredor industrial. Compatible con los sistemas de comunicación de la unidad de comando móvil satelital de la Estación Central.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate vehicular en Mexicali",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Prensión certificada para rescate vehicular en la Autopista Mexicali-Tijuana y resistencia química para operaciones HAZMAT en el corredor de parques industriales del Centro Cívico al Vigía.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para la Estación Central de Mexicali",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Puntera de acero y suela antiderrapante para pisos de fábricas maquiladoras, pavimentos del Centro Cívico a más de 45°C y acceso a instalaciones industriales. Certificadas NFPA 1971 para los 8 servicios operativos de esta sede.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Centro de Mando Estatal en el Desierto más Caluroso de México: 95 Elementos, Escalera de 32 Metros y Coordinación Binacional con California a 50°C</h2>
    <p>
      La <strong>Estación Central de Bomberos de Mexicali</strong>, ubicada en Calzada Independencia 998,
      Centro Cívico, es el eje operativo del Heroico Cuerpo de Bomberos de la capital de Baja California.
      Con 95 elementos activos, 10 unidades operativas —incluyendo escalera telescópica de 32 metros, unidad
      HAZMAT con trajes Nivel A y drones térmicos— y tiempo de respuesta de 4 a 7 minutos, esta estación
      enfrenta el reto operativo más extremo del noroeste de México: proteger a más de 1.1 millones de
      habitantes bajo temperaturas que superan regularmente los 50°C en verano.
    </p>

    <h3>¿Cómo Llamar a la Estación Central de Bomberos de Mexicali?</h3>
    <p>
      En cualquier emergencia en Mexicali, marca el <strong>911</strong>: el sistema de despacho de la
      Estación Central, el único en el estado con comunicaciones satelitales, dirige la unidad más cercana
      y adecuada según el tipo de incidente. Para coordinación no urgente: 686 558 1616. Las zonas de
      cobertura primaria —Centro Cívico, Centro Histórico, Zona Río Nuevo, Industrial y Pueblo Nuevo—
      tienen tiempo de respuesta de 4 a 7 minutos.
    </p>

    <h3>Centro de Mando Estatal: Coordinación en Condiciones de Calor Extremo</h3>
    <p>
      Esta es la única estación del estado con la especialidad de base de operaciones para desastres naturales
      y coordinación de emergencias metropolitanas. El desafío operativo que la distingue a nivel nacional
      es climático: Mexicali registra temperaturas de 50°C en julio y agosto, lo que significa que los
      bomberos trabajan en condiciones de estrés térmico sin precedente en el interior del país. La estación
      ha desarrollado protocolos de rotación de personal, hidratación forzada y refrigeración de equipos
      que la posicionan como referencia para otras ciudades desérticas del norte de México.
    </p>

    <h3>Escalera Telescópica de 32 Metros para el Centro Histórico y Blvd. López Mateos</h3>
    <p>
      El Centro Histórico de Mexicali concentra edificios de 4 a 8 pisos de arquitectura Art Déco y
      estilo misión, muchos con calles estrechas que limitan el acceso de autobombas convencionales.
      La escalera telescópica de 32 metros —equivalente a un décimo piso— es la única en el estado con
      capacidad para rescate en altura en esta zona patrimonial. Cubre también el corredor de edificios
      residenciales y comerciales del Blvd. López Mateos, donde la estación tiene sede.
    </p>

    <h3>Coordinación Binacional con el California Fire Department</h3>
    <p>
      Como ciudad fronteriza con Calexico, California, la Estación Central mantiene protocolos formales
      de cooperación con agencias de emergencia del condado Imperial. Este acuerdo binacional permite la
      entrada mutua de unidades en incidentes de gran magnitud, incendios forestales que cruzan la frontera
      o emergencias industriales que afecten a ambos lados. Es la única estación de Baja California con
      esta capacidad operativa activa documentada.
    </p>

    <h3>Drones Térmicos y HAZMAT para los Parques Industriales del Estado</h3>
    <p>
      Los corredores industriales de Mexicali —El Vigía, Cachanilla, Industrial 2000— concentran plantas
      de electrónica, maquiladoras automotrices y bodegas con materiales peligrosos. La unidad HAZMAT con
      trajes encapsulados Nivel A y los drones térmicos permiten detección remota de puntos calientes en
      incendios industriales antes de comprometer al personal. En
      Se distribuye <a href="/productos/trajes-para-bomberos/">trajes
      estructurales NFPA 1971</a>, <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> a estaciones de Baja California.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica y certificado de laboratorio incluidos.
    </p>
  </Fragment>
</EstacionLayout>
