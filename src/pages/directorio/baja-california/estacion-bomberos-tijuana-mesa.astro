---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-bomberos-tijuana-mesa";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para bomberos de La Mesa en Tijuana",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 35 elementos de la estación de La Mesa que operan en incendios en hospitales privados con gases medicinales a presión, clínicas de especialidades y laboratorios, donde los riesgos añadidos a un incendio convencional incluyen cilindros de oxígeno y nitrógeno líquido.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para emergencias en hospitales privados de Tijuana",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia certificada para operaciones en pisos de instalaciones hospitalarias con infraestructura técnica compleja: ductos de gases medicinales, bancos de baterías UPS y equipos de diagnóstico con materiales de riesgo en incendio.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate vehicular en el Blvd. Díaz Ordaz",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Prensión certificada para rescate vehicular en el Blvd. Díaz Ordaz, una de las vías rápidas más transitadas de Tijuana con volumen vehicular de alta velocidad en ambas direcciones durante todo el día y la noche.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para la Estación La Mesa de Tijuana",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para pisos clínicos de hospitales privados, estacionamientos de plazas comerciales y pavimento del Blvd. Díaz Ordaz. Certificadas NFPA 1971 para los tipos de emergencia más frecuentes en la zona residencial-comercial de La Mesa.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>35 Elementos para la Zona Residencial de Mayor Concentración Hospitalaria: Clínicas Privadas, Universidades y el Blvd. Díaz Ordaz, Corredor más Transitado del Este de Tijuana</h2>
    <p>
      La <strong>Estación La Mesa de Tijuana</strong>, ubicada en Blvd. Díaz Ordaz 12500, La Mesa, atiende
      una zona de Tijuana que combina las características de una ciudad desarrollada: hospitales privados
      de especialidades, universidades, plazas comerciales modernas y fraccionamientos residenciales de
      clase media-alta. Con 35 elementos activos, 4 unidades y tiempo de respuesta de 5 a 10 minutos,
      esta estación cubre el corredor residencial-comercial de mayor consolidación urbana del este de la
      ciudad.
    </p>

    <h3>¿Cómo Llamar a la Estación La Mesa de Tijuana?</h3>
    <p>
      Para emergencias en La Mesa, Otay Universidad, Las Palmas, Santa Fe o Vista Hermosa, marca el
      <strong>911</strong>. El despacho coordina esta estación con la Central según el tipo de incidente.
      Para contacto directo: 664 681 5656. El tiempo de respuesta de 5 a 10 minutos cubre todo el
      corredor del Blvd. Díaz Ordaz y los fraccionamientos aledaños.
    </p>

    <h3>Hospitales Privados y Clínicas de Especialidades: Incendios con Gases Medicinales</h3>
    <p>
      La zona de La Mesa concentra algunos de los hospitales privados más importantes de Tijuana, con
      servicios de especialidades que incluyen unidades de cuidados intensivos, quirófanos y laboratorios
      de análisis. Los incendios en instalaciones hospitalarias tienen un perfil de riesgo elevado por
      la presencia de oxígeno medicinal a presión —acelerador de combustión— y la dificultad de evacuar
      pacientes en condición crítica. El personal de esta estación conoce los protocolos de evacuación
      hospitalaria y coordina con los equipos de seguridad internos de las instalaciones.
    </p>

    <h3>Universidades y Centros Educativos: Miles de Estudiantes en Horario Pico</h3>
    <p>
      El corredor universitario de La Mesa —con planteles de nivel superior y bachillerato— concentra
      a decenas de miles de estudiantes en horario matutino y vespertino. Los laboratorios de ciencias,
      talleres de electrónica y auditorios con alta capacidad son los espacios de mayor riesgo en estos
      campus. El personal de esta estación realiza simulacros periódicos y conoce la distribución de
      las principales instalaciones educativas de su zona.
    </p>

    <h3>Blvd. Díaz Ordaz: Rescate Vehicular en el Corredor de Mayor Tráfico</h3>
    <p>
      El Blvd. Díaz Ordaz es una arteria de alta velocidad y volumen vehicular que conecta el este de
      Tijuana con la zona central. Los accidentes vehiculares de mayor complejidad —con atrapados en
      el vehículo— requieren el equipo hidráulico de rescate y el personal certificado de esta estación.
      En <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
