---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-bomberos-mexicali-zona-rio";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1970 para incendios en restaurantes y hoteles de la Zona Río",
    badge: "NFPA 1970",
    title: "Traje Estructural NFPA 1970",
    text: `Certificación NFPA 1970 para los 38 elementos de la Estación Zona Río que operan en incendios de cocinas comerciales, instalaciones con freidoras industriales y fugas de gas LP en los restaurantes de la gastronomía chino-mexicana más concentrada del país.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1970 para rescate en edificios comerciales de la Zona Río Mexicali",
    badge: "NFPA 1970",
    title: "Casco Estructural NFPA 1970",
    text: `Protección a impacto para rescate en hoteles y edificios de altura media del Blvd. López Mateos. Los incendios en instalaciones hoteleras con decenas de ocupantes exigen cascos que soporten derrumbes parciales de cielos rasos y particiones internas.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1970 para rescate vehicular en el Blvd. López Mateos",
    badge: "NFPA 1970",
    title: "Guantes Estructurales NFPA 1970",
    text: `Prensión certificada para rescate vehicular en el Blvd. Adolfo López Mateos, una de las vías más transitadas de Mexicali, y resistencia térmica para control de fugas de gas LP en cocinas industriales con riesgo de ignición.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1970 para la Estación Zona Río de Mexicali",
    badge: "NFPA 1970",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para pisos de cocinas comerciales con aceites y grasas, estacionamientos de centros comerciales y lobbies de hoteles. Puntera de acero certificada para rescate vehicular en vialidades de alta velocidad.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>38 Elementos en el Corazón Gastronómico y Turístico de la Capital: Primera Respuesta para la Zona Río, Restaurantes Chino-Mexicanos y Miles de Visitantes de California</h2>
    <p>
      La <strong>Estación Zona Río de Mexicali</strong>, ubicada en Blvd. Adolfo López Mateos 800, Nueva
      Mexicali, protege el distrito de mayor densidad comercial y turística de la capital bajacaliforniana.
      La Zona Río de Mexicali alberga la mayor concentración de restaurantes de cocina chino-mexicana —una
      fusión gastronómica única en el mundo— junto con hoteles internacionales, centros comerciales y
      espacios de entretenimiento que reciben miles de visitantes diarios de California. Con 38 elementos
      activos y tiempo de respuesta de 4 a 8 minutos, esta estación es la primera línea de atención para
      emergencias en el área de mayor afluencia de la ciudad.
    </p>

    <h3>¿Cómo Llamar a la Estación Zona Río de Mexicali?</h3>
    <p>
      Para emergencias en la Zona Río, Zona Dorada y Blvd. López Mateos, marca el <strong>911</strong>.
      El despacho centralizado de la Estación Central coordina la respuesta y activa esta sede como primera
      o segunda unidad según la disponibilidad. Contacto de coordinación: 686 552 4545. El tiempo de
      respuesta de 4 a 8 minutos cubre las zonas de mayor concentración hotelera y restaurantera de la ciudad.
    </p>

    <h3>Gastronomía Chino-Mexicana: Incendios en Cocinas Industriales de Alta Temperatura</h3>
    <p>
      La cocina china-mexicana que hace famosa a Mexicali en el mundo opera con woks a 350°C, aceites de
      alta temperatura y freidoras industriales en restaurantes que en muchos casos tienen decenas de años
      sin renovar instalaciones de gas. Los incendios de cocina con grasa —Clase K— representan la
      emergencia más frecuente en esta zona, requiriendo equipos de supresión específicos distintos al
      agua para evitar explosiones de vapor. El personal de esta estación está capacitado en el protocolo
      de incendios de grasa en cocinas comerciales.
    </p>

    <h3>Eventos Masivos y Turismo Fronterizo de San Diego y California</h3>
    <p>
      La Zona Río de Mexicali recibe anualmente festivales, conciertos y eventos culturales que concentran
      miles de asistentes en espacios cerrados. La cercanía con la frontera de Calexico significa que una
      parte significativa de los visitantes son residentes del Condado Imperial y San Diego en busca de
      gastronomía auténtica. Los protocolos de emergencia masiva de esta estación están diseñados para
      evacuaciones de recintos de 500 a 5,000 personas.
    </p>

    <h3>Hoteles y Edificios de Altura Media en el Corredor López Mateos</h3>
    <p>
      El Blvd. Adolfo López Mateos concentra hoteles de 5 a 12 pisos, edificios de oficinas y plazas
      comerciales que requieren atención en altura. Los incendios en pisos superiores con escaleras de
      emergencia bloqueadas son el escenario más complejo para esta estación, que coordina con la escalera
      telescópica de la Estación Central cuando el incidente lo requiere. En
      Se distribuye <a href="/productos/trajes-para-bomberos/">trajes NFPA 1970</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
