---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-bomberos-mexicali-sur";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para incendios residenciales en el Sur de Mexicali",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Protección certificada para los 32 elementos de la Estación Sur en incendios de viviendas unifamiliares y edificios de departamentos de los fraccionamientos Valle Dorado, Calafia y Residencial del Bosque, donde la alta densidad habitacional exige tiempos de contención cortos.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para emergencias en campus universitarios de Mexicali",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia a impactos certificada para operaciones en laboratorios universitarios de la UABC y CETYS, donde los productos químicos de investigación representan un riesgo añadido a los incendios estructurales convencionales.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate en fraccionamientos del Sur de Mexicali",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Prensión certificada para rescate vehicular en Av. Calafia y los corredores residenciales del sur. Resistencia térmica para control de fugas de gas residencial LP en fraccionamientos con alta densidad de instalaciones domésticas.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para la Estación Sur de Mexicali",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para operaciones en cocinas domésticas con grasa, jardines residenciales y pasillos de edificios multifamiliares. Certificadas NFPA 1971 para los 5 tipos de emergencia más frecuentes en zona residencial.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>32 Elementos para la Zona Residencial de Mayor Densidad Universitaria: UABC, CETYS y Fraccionamientos de Clase Media en el Crecimiento Habitacional del Sur de Mexicali</h2>
    <p>
      La <strong>Estación Sur de Mexicali</strong>, ubicada en Av. Calafia 2500, Residencial del Bosque,
      protege la zona de mayor expansión habitacional reciente de la capital de Baja California. Con 32
      elementos activos, 4 unidades y tiempo de respuesta de 6 a 10 minutos, esta estación cubre
      fraccionamientos residenciales de clase media y alta, los dos campus universitarios más grandes de
      la ciudad —UABC y CETYS Universidad— y un corredor de centros educativos que concentra a miles de
      estudiantes en horario diurno.
    </p>

    <h3>¿Cómo Llamar a la Estación Sur de Mexicali?</h3>
    <p>
      Para emergencias en Residencial del Bosque, Valle Dorado, Calafia y los campus universitarios del
      sur, marca el <strong>911</strong>. El sistema de despacho coordina esta estación con la Central
      en incidentes que requieren más recursos. Contacto directo: 686 566 7878. El tiempo de respuesta
      de 6 a 10 minutos cubre los fraccionamientos más alejados del sur de la ciudad.
    </p>

    <h3>UABC y CETYS Universidad: Emergencias en Campus con Laboratorios y Miles de Estudiantes</h3>
    <p>
      La Universidad Autónoma de Baja California y CETYS Universidad juntas suman más de 30,000 estudiantes
      en Mexicali. Los campus universitarios presentan riesgos específicos: laboratorios de química con
      reactivos, almacenes de productos biológicos, auditorios con alta capacidad de ocupación y talleres
      con maquinaria. El personal de esta estación realiza inspecciones preventivas periódicas y conoce
      la distribución de los campus para reducir los tiempos de localización dentro de las instalaciones.
    </p>

    <h3>Fraccionamientos Valle Dorado y Calafia: Incendios en Viviendas con Gas LP</h3>
    <p>
      Los fraccionamientos residenciales del sur de Mexicali usan principalmente gas LP en cilindros
      domésticos —a diferencia de la red de gas natural del centro— lo que eleva el riesgo de incendio
      por fuga y explosión en espacios cerrados durante el verano. Los 32 elementos de esta estación
      están especializados en control de fugas de gas LP doméstico, el tipo de emergencia más frecuente
      en esta zona junto con los incendios de cocina.
    </p>

    <h3>Zona Residencial de Alto Crecimiento: Rescate Vehicular en Av. Calafia</h3>
    <p>
      La Av. Calafia es uno de los ejes viales de mayor crecimiento en el sur de Mexicali, con tráfico
      en aumento sostenido por el desarrollo de nuevos fraccionamientos. Los accidentes vehiculares de
      mayor complejidad requieren coordinación con la Estación Central para el uso de la unidad de rescate
      pesado. En <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> sin costo, con ficha técnica y certificado incluidos.
    </p>
  </Fragment>
</EstacionLayout>
