---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-bomberos-tijuana-zona-norte";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1970 para incendios en el centro histórico de Tijuana",
    badge: "NFPA 1970",
    title: "Traje Estructural NFPA 1970",
    text: `Certificación NFPA 1970 para los 42 elementos de la zona más densa de Tijuana: incendios en hoteles, bares y restaurantes de construcción histórica de 2 a 4 pisos en la Av. Revolución, donde el patrimonio arquitectónico y la alta ocupación nocturna definen la complejidad del incidente.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1970 para rescate en edificios históricos de Tijuana",
    badge: "NFPA 1970",
    title: "Casco Estructural NFPA 1970",
    text: `Resistencia certificada para operaciones en edificios históricos de la Zona Norte y Centro, donde las losas de concreto de los años 40-60 tienen mayor riesgo de colapso por deterioro estructural combinado con estrés térmico de incendio.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1970 para emergencias nocturnas en Tijuana Norte",
    badge: "NFPA 1970",
    title: "Guantes Estructurales NFPA 1970",
    text: `Prensión y resistencia térmica certificada para incendios en cocinas de restaurantes y bares de alta rotación en la Av. Revolución. La cocina industrial a pleno rendimiento en horario nocturno de mayor afluencia es el escenario de riesgo más frecuente en esta zona.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1970 para la Estación Zona Norte de Tijuana",
    badge: "NFPA 1970",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para calles de la Zona Norte con fragmentos de vidrio, derrames de bebidas y pavimento deteriorado. Puntera de acero para rescate en recintos de alta ocupación con riesgo de estampida o colapso de menaje.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Guardián de la Avenida Revolución y el Centro Histórico: 42 Elementos para Turismo de San Diego, Zona de Tolerancia y la Mayor Concentración Nocturna de Tijuana</h2>
    <p>
      La <strong>Estación de Bomberos Tijuana Zona Norte</strong>, ubicada en Calle Segunda 8050, Zona Norte,
      protege el corazón histórico y turístico de Tijuana: la Avenida Revolución y el Centro, que han
      recibido a millones de visitantes estadounidenses durante más de un siglo. Con 42 elementos activos,
      4 unidades y tiempo de respuesta de 4 a 7 minutos, esta estación es la primera respuesta en la zona
      de mayor densidad nocturna de la ciudad, donde la combinación de construcciones históricas, alta
      ocupación de bares y restaurantes, y visitantes internacionales crea un perfil de riesgo único.
    </p>

    <h3>¿Cómo Llamar a la Estación Zona Norte de Tijuana?</h3>
    <p>
      En emergencias en la Zona Norte, Centro, Av. Revolución o Colonia Libertad, marca el <strong>911</strong>.
      El despacho coordina esta estación con la Central según el tipo y magnitud del incidente. Para
      contacto directo: 664 685 9090. El tiempo de respuesta de 4 a 7 minutos es posible gracias a la
      ubicación estratégica en el corazón del tejido histórico de la ciudad.
    </p>

    <h3>Avenida Revolución: Millones de Turistas Estadounidenses y Emergencias en Alta Densidad</h3>
    <p>
      La Avenida Revolución fue, durante décadas, el destino de fin de semana de los jóvenes de San Diego
      y el condado de Orange. Los bares y discotecas de alta capacidad de esta zona presentan el riesgo
      más exigente en incendios de recintos: salidas bloqueadas, alta densidad de personas, humo en
      espacio cerrado y pánico colectivo. Los 42 elementos de esta estación están capacitados en
      evacuación de recintos de alta ocupación y atención a intoxicaciones masivas por inhalación de humo.
    </p>

    <h3>Centro Histórico: Construcciones de 50-80 Años con Mayor Riesgo Estructural</h3>
    <p>
      El Centro Histórico de Tijuana tiene un tejido de edificios de 2 a 5 pisos construidos entre los
      años 1940 y 1970, muchos con losas de concreto armado que nunca han recibido mantenimiento estructural.
      Un incendio en uno de estos edificios —combinado con el estrés térmico que debilita el acero de
      refuerzo— tiene mayor probabilidad de colapso que un edificio moderno, lo que exige tácticas
      defensivas de combate externo cuando la estructura está comprometida.
    </p>

    <h3>Emergencias Médicas Masivas y Evacuaciones de Recintos</h3>
    <p>
      La Zona Norte concentra la mayor densidad de bares y establecimientos de vida nocturna de Tijuana,
      con eventos de alta concurrencia que generan emergencias médicas masivas: intoxicaciones, peleas
      con heridos múltiples y episodios de pánico. La coordinación entre esta estación, las ambulancias
      del sector y las autoridades sanitarias es rutinaria en fines de semana. En
      Se distribuye <a href="/productos/trajes-para-bomberos/">trajes NFPA 1970</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
