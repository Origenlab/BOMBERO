---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-central-rosarito";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1970 para emergencias en hoteles y eventos de Rosarito",
    badge: "NFPA 1970",
    title: "Traje Estructural NFPA 1970",
    text: `Certificación NFPA 1970 para los 42 elementos que operan en el destino turístico de playa más frecuentado por estadounidenses en México: incendios en hoteles frente al mar con ocupación máxima durante Spring Break, emergencias en restaurantes de langosta con cocinas industriales y rescate acuático en el Pacífico.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1970 para emergencias en Fox Baja Studios de Rosarito",
    badge: "NFPA 1970",
    title: "Casco Estructural NFPA 1970",
    text: `Resistencia certificada para operaciones en los enormes foros de grabación de Fox Baja Studios, donde las estructuras de acero y madera de gran escala usadas en producciones de Hollywood tienen perfiles de colapso en incendio que requieren tácticas defensivas específicas.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1970 para rescate acuático en Playas de Rosarito",
    badge: "NFPA 1970",
    title: "Guantes Estructurales NFPA 1970",
    text: `Resistencia térmica certificada y compatibilidad con equipos de buceo para operaciones en la playa del Pacífico de Rosarito. Los rescates acuáticos durante Spring Break —con cientos de bañistas simultáneos en condición de riesgo— son los incidentes de mayor complejidad de esta estación.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1970 para operaciones en playa y hoteles de Rosarito",
    badge: "NFPA 1970",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para arena húmeda de playa, pisos de hotel con cerámica mojada y pavimento del Blvd. Benito Juárez durante eventos masivos con alta concentración de personas. Certificadas NFPA 1970 para el rango de emergencias de un destino turístico internacional.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Spring Break, Fox Baja Studios y Puerto Nuevo: 42 Elementos para Eventos Masivos, Rescate Acuático y el Principal Destino Turístico Fronterizo a 30 Minutos de San Diego</h2>
    <p>
      La <strong>Estación Central de Bomberos de Playas de Rosarito</strong>, ubicada en Blvd. Benito
      Juárez 900, Centro, protege el quinto municipio de Baja California desde su independencia de
      Tijuana en 1995. Rosarito es el destino de playa más cercano y más visitado desde San Diego:
      a solo 29 km de la frontera, recibe anualmente a miles de turistas estadounidenses que vienen
      por la langosta de Puerto Nuevo, los hoteles frente al mar y el Spring Break. Con 42 elementos
      activos, 6 unidades —incluyendo unidad de rescate acuático con motos acuáticas y equipo de buceo—
      y tiempo de respuesta de 5 a 10 minutos, esta estación opera en uno de los destinos turísticos
      de mayor dinamismo de la frontera del Pacífico.
    </p>

    <h3>¿Cómo Llamar a la Estación Central de Bomberos de Rosarito?</h3>
    <p>
      En emergencias en el Centro de Rosarito, Zona Hotelera, Puerto Nuevo o Calafia, marca el <strong>911</strong>.
      El despacho coordina esta estación con la de Tijuana Central para incidentes que superan su capacidad.
      Contacto directo: 661 612 0808. El tiempo de respuesta de 5 a 10 minutos cubre el corredor hotelero
      del Blvd. Benito Juárez y las playas principales.
    </p>

    <h3>Spring Break: Emergencias con Miles de Turistas Estadounidenses Simultáneos</h3>
    <p>
      Durante el Spring Break de universidades de California —generalmente en marzo— Rosarito puede
      recibir entre 10,000 y 30,000 visitantes adicionales en un fin de semana, concentrados en hoteles,
      bares y la playa. Los incidentes en esta temporada tienen una característica que los hace únicos:
      alta densidad de personas con consumo de alcohol, comportamiento impredecible y mezcla de turistas
      internacionales con escasa familiaridad de las instalaciones. La estación mantiene planes de
      contingencia específicos para este período.
    </p>

    <h3>Fox Baja Studios: Estructuras de Hollywood con Perfiles Especiales de Riesgo</h3>
    <p>
      Los estudios cinematográficos Fox Baja Studios, donde se filmaron Titanic, Piratas del Caribe y
      otras producciones de Hollywood, tienen la mayor piscina de filmación del mundo con capacidad para
      millones de litros de agua. Las estructuras de los foros —escenografías de gran escala en acero,
      madera y fibra de vidrio— presentan perfiles de colapso en incendio muy distintos a la construcción
      convencional, y el personal de esta estación ha recibido instrucción específica sobre las
      instalaciones del estudio.
    </p>

    <h3>Puerto Nuevo y la Langosta: Protección del Corredor Gastronómico más Famoso</h3>
    <p>
      Puerto Nuevo, a 10 km al sur de Rosarito, es el pueblo de la langosta estilo Puerto Nuevo: unas
      30 familias que desde hace más de 60 años han convertido un pequeño caserío en el restaurante
      más famoso del corredor fronterizo del Pacífico. Los incendios en cocinas de leña de langosta
      —con mantequilla y aceites a alta temperatura— son la emergencia gastronómica más frecuente de
      este corredor. Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1970</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
