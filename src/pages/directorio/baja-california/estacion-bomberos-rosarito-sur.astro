---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california";

const slug = "estacion-bomberos-rosarito-sur";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California",
  slug: "baja-california",
  siglas: "BC",
  poblacion: "3.8 millones",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Sonora", slug: "sonora" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para incendios forestales costeros en el sur de Rosarito",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 22 elementos de la estación sur que operan en la interfaz entre desarrollos de lujo y vegetación costera inflamable. Los incendios de chaparral en este corredor se alimentan del viento marino y la pendiente del acantilado para propagarse hacia residencias de alto valor en minutos.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para rescate en acantilados del corredor Rosarito-Ensenada",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Protección certificada para rescate en acantilados de arenisca del corredor costero sur, donde los desmoronamientos de roca blanda son frecuentes durante operaciones de rapel y los golpes de ola en la base del acantilado representan un riesgo adicional.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate en K-38 y playas remotas de Rosarito Sur",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia mecánica para operaciones de rescate en K-38 y puntos de surf remotos, donde los accidentes con tablas de surf, roca submarina y corrientes de resaca generan lesiones que requieren extracción de la zona de rompiente con equipo de rescate especializado.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para terreno costero en Rosarito Sur",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela de máximo agarre para roca de litoral con algas, arena de playa y terreno de chaparral costero con pendiente. Las botas con certificación NFPA 1971 son el mínimo estándar para el terreno más variado de la zona de cobertura sur de Playas de Rosarito.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>22 Elementos en el Corredor Costero de Acantilados, Surf y Desarrollos de Lujo: K-38, La Fonda, Las Gaviotas y Playas de Difícil Acceso entre Rosarito y Ensenada</h2>
    <p>
      La <strong>Estación Sur de Rosarito</strong>, ubicada en Blvd. Popotla km 35, Primo Tapia, atiende
      el corredor costero que se extiende desde Rosarito hacia Ensenada: un mosaico de acantilados del
      Pacífico, puntos de surf de fama internacional, desarrollos residenciales de lujo y playas semiprivadas
      de difícil acceso. Con 22 elementos activos, 4 unidades —incluyendo unidad forestal y autobombas—
      y tiempo de respuesta de 10 a 18 minutos en los puntos más alejados, esta estación cubre uno de los
      territorios de mayor atractivo turístico y mayor complejidad operativa de Baja California.
    </p>

    <h3>¿Cómo Llamar a la Estación Sur de Rosarito?</h3>
    <p>
      Para emergencias en Primo Tapia, La Fonda, Las Gaviotas, K-38, Campo López o La Misión, marca
      el <strong>911</strong>. El despacho coordina esta estación con la Estación Central de Rosarito
      para incidentes que requieren más recursos. Contacto directo: 661 614 3232. Los tiempos de 10 a
      18 minutos reflejan las distancias reales en el corredor costero con tráfico de fin de semana.
    </p>

    <h3>K-38: El Punto de Surf más Famoso del Norte de México</h3>
    <p>
      K-38 —llamado así por el kilómetro 38 de la vieja carretera libre— es uno de los puntos de surf
      más conocidos de Baja California y frecuentado por surfistas de todo el Pacífico norte. Los rescates
      acuáticos aquí son de alta complejidad: corrientes de rompiente de dos metros o más en temporada
      de swell norte, roca submarina irregular y rompiente sobre bajíos de arena que cambia con cada
      temporada de tormentas. La estación coordina con guardavidas voluntarios de la zona en los meses
      de mayor afluencia.
    </p>

    <h3>La Fonda y Las Gaviotas: Incendios en Desarrollos de Lujo con Acceso Restringido</h3>
    <p>
      Los fraccionamientos de lujo del corredor sur —La Fonda, Las Gaviotas, el complejo residencial
      de Km 38— tienen accesos privados con casetas de vigilancia que pueden retrasar la entrada de
      unidades de emergencia. Los incendios en residencias de madera y vidrio frente al acantilado tienen
      acceso perimetral limitado por la posición del terreno. El personal conoce los accesos y protocolos
      de entrada de cada desarrollo privado de su zona de cobertura.
    </p>

    <h3>Incendios Forestales en Vegetación Costera: Chaparral con Viento del Pacífico</h3>
    <p>
      La vegetación costera del corredor sur —chaparral mediterráneo, jara, cactus pitahaya y matorral
      costero— es de las más combustibles de la región por su alto contenido de aceites esenciales. Los
      incendios en este corredor en condiciones de viento marino pueden propagarse a 100-200 metros por
      minuto hacia los desarrollos residenciales en pendiente. La estación mantiene cuadrillas de
      cortafuegos manual como primera respuesta antes de que las autobombas lleguen al punto exacto del
      frente de fuego. Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
