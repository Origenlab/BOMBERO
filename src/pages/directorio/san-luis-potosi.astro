const estadosVecinos = getEstadosVecinos("san-luis-potosi");
---

<DirectorioEstadoLayout
  estado={estado}
  sigla={sigla}
  slug={slug}
  heroDesc="Directorio completo del <strong>H. Cuerpo de Bomberos de San Luis Potosí</strong>. Encuentra teléfonos de emergencia, direcciones y servicios de todas las estaciones del estado."
  heroImage="/images/directorio/estacion-bomberos-centro-historico-01.avif"
  heroImageAlt="Estación de Bomberos en San Luis Potosí"
  heroCaption="H. Cuerpo de Bomberos · San Luis Potosí"
  totalEstaciones={estacionesSanLuisPotosi.length}
  totalMunicipios={getMunicipios().length}
  habitantes="2.8M+"
  canonical="https://bombero.mx/directorio/san-luis-potosi/"
  keywords={["bomberos san-luis-potosi", "estaciones bomberos san-luis-potosi", "emergencias san-luis-potosi 911", "cuerpo bomberos san-luis-potosi"]}
  estaciones={estacionesSanLuisPotosi}
  stationImages={stationImages}
  municipios={getMunicipios()}
  estadosVecinos={estadosVecinos}
  heroThumbs={heroThumbs}
  galleryImages={galleryImages}
  emergencyNumbers={emergencyNumbers}
  regiones={regiones}
  eppCards={eppCards}
  jsonLd={[itemListSchema, breadcrumbSchema]}
  title={`Bomberos en ${estado} | Directorio Oficial ${estacionesSanLuisPotosi.length} Estaciones | BOMBERO.MX`}
  description={`Directorio completo de ${estacionesSanLuisPotosi.length} estaciones de bomberos en San Luis Potosí 2024. HAZMAT especializado para BMW Group Plant y GM Complejo. Rescate espeleológico Sótano de las Golondrinas (512m). Cobertura Huasteca Potosina y 4 Pueblos Mágicos. Tel: (444) 812-2583. Emergencias 911.`}
>
  <Fragment slot="seo">

      <h2>Bomberos de San Luis Potosí: El Corazón de México</h2>
      <p>
        El <strong>Heroico Cuerpo de Bomberos de San Luis Potosí</strong> protege a más de <strong>2.8 millones
        de habitantes</strong> en uno de los estados más diversos de México. Con <strong>16 estaciones
        estratégicamente distribuidas</strong>, los bomberos potosinos atienden desde <strong>emergencias HAZMAT
        en el clúster automotriz más importante del Bajío</strong> (BMW, GM, 300+ proveedores) hasta
        <strong>rescates espeleológicos en el Sótano de las Golondrinas</strong>, el sótano natural más profundo
        de México con <strong>512 metros de caída libre</strong>.
      </p>

      <h3>Clúster Automotriz: BMW y General Motors</h3>
      <p>
        San Luis Potosí es el <strong>cuarto estado automotriz de México</strong>, con <strong>45,000 empleos
        directos</strong> y <strong>$8,000 millones de dólares en exportaciones anuales</strong>. La
        <strong>BMW Group Plant San Luis Potosí</strong> (Villa de Reyes) produce la <strong>Serie 3 y
        Serie 2 Coupé</strong> con inversión de <strong>$1,000 millones USD</strong>, mientras que el
        <strong>Complejo General Motors</strong> opera la planta de motores y transmisiones más grande de
        Latinoamérica. Las <strong>3 estaciones HAZMAT</strong> del corredor industrial están certificadas
        para emergencias con <strong>pinturas automotrices, solventes, baterías de litio, aceites especiales
        y gases industriales</strong>, con personal bilingüe 24/7 para coordinación con ejecutivos internacionales.
      </p>

      <h3>Huasteca Potosina: Paraíso del Turismo de Aventura</h3>
      <p>
        La <strong>Huasteca Potosina</strong> recibe más de <strong>2 millones de visitantes anuales</strong>
        para actividades de aventura extrema. La <strong>Cascada de Tamul</strong> (105 metros de altura) es
        la más alta del estado, accesible únicamente por el <strong>río Tampaón</strong> en kayak o lancha.
        Los bomberos de <strong>Ciudad Valles</strong> y <strong>Aquismón</strong> mantienen equipos de
        <strong>swift water rescue</strong> certificados para rescate en ríos con corrientes clase II-IV,
        incluyendo temporada de lluvias (junio-octubre) cuando el riesgo de inundaciones es crítico.
      </p>

      <h3>Sótano de las Golondrinas: Rescate Espeleológico Extremo</h3>
      <p>
        El <strong>Sótano de las Golondrinas</strong> en Aquismón es una de las <strong>cavidades verticales
        más profundas del mundo</strong> con <strong>512 metros de caída libre</strong>. Atrae a más de
        <strong>50,000 visitantes anuales</strong> para observación de vencejos y base jumping extremo.
        La estación de bomberos de Aquismón mantiene <strong>equipo certificado de espeleología</strong>
        incluyendo <strong>cuerdas estáticas de 600m</strong>, sistemas de anclaje para sótanos, camillas
        técnicas verticales (Sked/Paraguard) y coordinación con grupos voluntarios de espeleología para
        rescates que pueden durar <strong>12-24 horas</strong>.
      </p>

      <h3>Cuatro Pueblos Mágicos con Cobertura Especializada</h3>
      <p>
        San Luis Potosí cuenta con <strong>4 Pueblos Mágicos</strong> con necesidades de emergencia únicas:
        <strong>Real de Catorce</strong> (pueblo fantasma minero a 2,750 msnm con minas abandonadas y clima
        extremo del desierto), <strong>Xilitla</strong> (Jardín Surrealista Edward James en selva húmeda),
        <strong>Aquismón</strong> (puerta de entrada a sótanos y cascadas extremas), y
        <strong>Santa María del Río</strong> (capital del rebozo con arquitectura histórica). Cada estación
        tiene protocolos adaptados a sus riesgos específicos.
      </p>

      <h3>Real de Catorce: Rescate en el Desierto</h3>
      <p>
        <strong>Real de Catorce</strong> es uno de los destinos de turismo místico más importantes de México,
        accesible únicamente a través del <strong>Túnel Ogarrio</strong> (2.3 km). Recibe <strong>350,000+
        visitantes anuales</strong> incluyendo peregrinos al desierto sagrado de <strong>Wirikuta</strong>
        (territorio Wixárika/Huichol). Los bomberos de Matehuala mantienen capacidad de
        <strong>búsqueda y rescate en desierto (SAR)</strong>, atención de emergencias por altitud,
        rescate en minas abandonadas del pueblo fantasma y coordinación con la comunidad Wixárika para
        emergencias en zona sagrada.
      </p>

      <h3>Zona Metropolitana: Centro Histórico Candidato UNESCO</h3>
      <p>
        El <strong>Centro Histórico de San Luis Potosí</strong> está en la <strong>Lista Tentativa de
        UNESCO</strong> con su arquitectura barroca y neoclásica del siglo XVII-XIX. La
        <strong>Estación Central</strong> cuenta con <strong>escalera telescópica de 42 metros</strong>
        para emergencias en edificios históricos, protocolos de protección patrimonial y cobertura del
        <strong>Parque Tangamanga</strong> (450 hectáreas, uno de los más grandes de Latinoamérica) para
        eventos masivos. También cubre la zona universitaria con <strong>UASLP, IPICYT y Tec de Monterrey</strong>.
      </p>

      <h3>Carretera 57D: Corredor Comercial Nacional</h3>
      <p>
        La <strong>Autopista 57D México-Piedras Negras</strong> atraviesa San Luis Potosí transportando
        <strong>25,000+ vehículos diarios</strong> incluyendo tractocamiones con materiales peligrosos.
        Las estaciones del corredor mantienen <strong>equipos de rescate vehicular pesado</strong>,
        capacidad <strong>HAZMAT para derrames en tránsito</strong> y coordinación con
        <strong>Capufe y la Guardia Nacional</strong> para accidentes carreteros de alto impacto.
      </p>

      <h3>Clima Extremo: Del Desierto a la Selva</h3>
      <p>
        San Luis Potosí presenta <strong>cuatro climas distintos</strong>: desierto extremo en el Altiplano
        (Real de Catorce con temperaturas de <strong>-5°C a 40°C</strong>), selva húmeda en la Huasteca
        (precipitaciones de <strong>2,000+ mm anuales</strong>), clima templado en la capital, y
        semiárido en la Zona Media. Los bomberos están capacitados para emergencias en todos estos
        escenarios, incluyendo <strong>incendios de matorrales, inundaciones súbitas y rescates en
        condiciones de hipotermia o golpe de calor</strong>.
      </p>

      <h3>Servicios Especializados de los Bomberos Potosinos</h3>
      <p>
        Los bomberos de San Luis Potosí ofrecen: <strong>combate de incendios estructurales, industriales
        y forestales</strong>; <strong>respuesta HAZMAT Nivel A para industria automotriz</strong>;
        <strong>rescate espeleológico certificado</strong>; <strong>swift water rescue en ríos de la
        Huasteca</strong>; <strong>búsqueda y rescate en desierto (SAR)</strong>; <strong>rescate en
        minas abandonadas</strong>; <strong>emergencias en edificios históricos</strong>;
        <strong>atención de eventos masivos</strong>; y <strong>coordinación bilingüe 24/7</strong>
        para industria internacional. El tiempo de respuesta varía de <strong>6 minutos</strong> en zona
        metropolitana a <strong>60+ minutos</strong> en zonas remotas de la Huasteca y el Altiplano.
      </p>
    </Fragment>
</DirectorioEstadoLayout>

