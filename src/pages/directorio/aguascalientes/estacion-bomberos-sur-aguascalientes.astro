---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-aguascalientes";

const slug = "estacion-bomberos-sur-aguascalientes";
const estacion = getEstacionBySlug(slug);
if (!estacion) return Astro.redirect("/404");
const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Aguascalientes",
  slug: "aguascalientes",
  siglas: "AGS",
  poblacion: "1.5 millones",
  municipios: 11,
};

const estadosVecinos = [
  { nombre: "Zacatecas", slug: "zacatecas" },
  { nombre: "San Luis Potosí", slug: "san-luis-potosi" },
  { nombre: "Jalisco", slug: "jalisco" },
  { nombre: "Guanajuato", slug: "guanajuato" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para bomberos Zona Sur Aguascalientes",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: "Requerido para incendios en el <strong>barrio de San Marcos</strong> y para las operaciones de la Feria Nacional, donde las instalaciones de gas LP temporal elevan el riesgo térmico en toda la zona sur.",
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 bomberos Feria San Marcos Aguascalientes",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: "Protección certificada para operaciones en espacios confinados de la <strong>Feria Nacional de San Marcos</strong> y en emergencias dentro de instalaciones temporales de alta concentración de personas.",
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 bomberos sur AGS",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: "Resistencia térmica y de corte para rescate en zonas históricas del sur de <strong>Aguascalientes</strong> y para la atención de incidentes en la zona comercial-ferial de San Marcos.",
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 bomberos Aguascalientes sur",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: "Suela antiderrapante para operaciones en explanadas y pasillos de la <strong>Feria de San Marcos</strong> y para atención de inundaciones en zonas bajas del sur, donde el suelo anegado es el entorno habitual.",
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Estación Zona Sur de Aguascalientes — Única Estación del Estado con Unidad de Eventos Masivos: Primera Respuesta para los 8 Millones de Visitantes de la Feria Nacional de San Marcos</h2>
    <p>
      La <strong>Estación de Bomberos Zona Sur de Aguascalientes</strong>, ubicada en Av. Convención de
      1914 Sur 701, colonia San Marcos, es la única en el estado con especialidad certificada en eventos
      masivos. Con 45 elementos activos, 5 unidades —incluyendo una unidad exclusiva para eventos
      masivos— y tiempo de respuesta de 5 a 9 minutos, esta estación opera en el entorno más complejo
      del estado durante los 45 días que dura la Feria Nacional de San Marcos: más de 500 instalaciones
      de gas LP temporal, aforos de hasta 100,000 personas por día y calles cerradas al tránsito que
      modifican completamente los tiempos y accesos de respuesta.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos Zona Sur de Aguascalientes?</h3>
    <p>
      En cualquier emergencia al sur de Aguascalientes, marca el <strong>911</strong>: el sistema de
      despacho asigna la unidad más cercana y apropiada para el tipo de incidente. Para contacto directo:
      449 915 3456. Durante la Feria Nacional de San Marcos —de finales de abril a mediados de mayo—
      esta estación opera en protocolo de emergencias en eventos masivos con tiempo de respuesta
      reforzado para el recinto ferial y el barrio histórico de San Marcos.
    </p>

    <h3>Feria Nacional de San Marcos: 500 Instalaciones de Gas LP sin Registro Centralizado</h3>
    <p>
      La Feria Nacional de San Marcos es el mayor evento al aire libre de México, con más de 8 millones
      de visitantes en 45 días. Cada edición instala aproximadamente 500 puestos de comida y servicios
      que operan con gas LP en cilindros individuales sin un sistema de corte centralizado: si hay una
      fuga o un incendio en un extremo del recinto, no es posible interrumpir el suministro de todo el
      ferial desde un solo punto. Esta característica —idéntica al riesgo que describimos para los
      parques industriales— convierte a la Feria en el evento de mayor densidad de riesgo por LP
      concentrado del estado. La unidad de eventos masivos de esta estación está dimensionada para
      primera respuesta simultánea en múltiples puntos del recinto.
    </p>

    <h3>Atención de Inundaciones en Zonas Bajas del Sur</h3>
    <p>
      El sur de Aguascalientes concentra varias colonias en cotas topográficas más bajas que el centro
      de la ciudad, lo que las convierte en receptoras de escurrimientos durante lluvias intensas del
      verano. La especialidad en atención de inundaciones de esta estación incluye operaciones de
      rescate de personas en vehículos varados, desalojo de inmuebles con nivel de agua crítico y
      coordinación con el sistema de drenaje pluvial municipal para monitorear los puntos de desborde
      históricos en las colonias San Marcos, La Cantera y Ojocaliente.
    </p>

    <h3>Barrio de San Marcos: Zona Histórica con Calles del Siglo XIX</h3>
    <p>
      El barrio de San Marcos, declarado zona de monumentos históricos, conserva trazas urbanas del
      siglo XIX con calles de entre 6 y 8 metros de ancho donde las autobombas convencionales operan
      al límite de su radio de maniobra. Los incendios en edificaciones de adobe y cantera rosa —con
      vigas de madera en entrepisos— tienen dinámicas de propagación distintas a la construcción
      moderna: el fuego viaja entre cavidades constructivas sin que sea visible desde el exterior.
      La familiaridad de esta estación con la geometría del barrio es un factor operativo que reduce
      el tiempo de contención efectiva en esta zona histórica.
    </p>

    <h3>Equipo NFPA para la Estación de Mayor Concentración Masiva de Aguascalientes</h3>
    <p>
      Eventos con millones de asistentes, incendios en zonas históricas y atención de inundaciones
      exigen equipo certificado con especificaciones distintas por tipo de operación. En
      Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes estructurales NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> directamente a estaciones
      de bomberos en Aguascalientes. <a href="/cotizar/">Solicita cotización</a> con ficha técnica
      y certificado de laboratorio.
    </p>
  </Fragment>
</EstacionLayout>
