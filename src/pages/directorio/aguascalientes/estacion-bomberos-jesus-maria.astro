---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-aguascalientes";

const slug = "estacion-bomberos-jesus-maria";
const estacion = getEstacionBySlug(slug);
if (!estacion) return Astro.redirect("/404");
const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Aguascalientes",
  slug: "aguascalientes",
  siglas: "AGS",
  poblacion: "1.5 millones",
  municipios: 11,
};

const estadosVecinos = [
  { nombre: "Zacatecas", slug: "zacatecas" },
  { nombre: "San Luis Potosí", slug: "san-luis-potosi" },
  { nombre: "Jalisco", slug: "jalisco" },
  { nombre: "Guanajuato", slug: "guanajuato" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 bomberos Jesús María Aguascalientes",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: "Certificación para incendios en la zona urbanizada de <strong>Jesús María</strong> y para operaciones en la interfaz urbano-forestal donde el fuego puede transitar de pastizal a tejado en minutos.",
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 bomberos segundo municipio ZMA",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: "Protección certificada para operaciones en entornos urbanos y forestales de <strong>Jesús María</strong>. La alternancia entre incendios estructurales y forestales exige un casco con certificación dual.",
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 rescate rural Jesús María",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: "Resistencia térmica y de corte para operaciones de rescate vehicular en la autopista Aguascalientes–Zacatecas y para rescate en zonas rurales de <strong>Cañada Honda</strong> y La Labor.",
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1977 forestal Jesús María",
    badge: "NFPA 1971 / 1977",
    title: "Botas para Operaciones Mixtas",
    text: "Calzado con puntera de acero para zona urbana y resistencia para terreno irregular en las laderas forestales de <strong>Jesús María</strong>, donde la unidad forestal accede a zonas sin camino pavimentado.",
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Estación de Bomberos Jesús María — Doble Frente Operativo: 200,000 Habitantes en la Zona Metropolitana y Combate Forestal en la Sierra Norte del Estado</h2>
    <p>
      La <strong>Estación de Bomberos de Jesús María</strong>, ubicada en Av. Independencia 210, Centro,
      protege el segundo municipio más poblado del estado y parte esencial de la Zona Metropolitana de
      Aguascalientes. Con 32 elementos activos, 4 unidades —incluyendo una unidad forestal— y tiempo de
      respuesta de 8 a 15 minutos, esta estación opera en dos frentes simultáneos: la zona urbana
      conurbada con la capital y el frente rural-forestal donde pastizales, laderas y comunidades
      dispersas como La Labor y Cañada Honda concentran los incendios de temporada seca.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Jesús María?</h3>
    <p>
      En cualquier emergencia en Jesús María o sus comunidades, marca el <strong>911</strong>: el sistema
      de despacho coordina la respuesta desde esta estación o desde la Estación Central si el incidente
      requiere refuerzos metropolitanos. Para contacto directo: 449 965 0123. El tiempo de respuesta
      varía entre 8 minutos en la zona conurbada con Aguascalientes capital y hasta 15 minutos en
      comunidades rurales alejadas como Gracias a Dios o Tapias Viejas.
    </p>

    <h3>Zona Metropolitana de Aguascalientes: Segundo Municipio de la Conurbación</h3>
    <p>
      Jesús María forma parte de la Zona Metropolitana de Aguascalientes junto con la capital y San
      Francisco de los Romo, una conurbación de más de un millón de habitantes. La parte urbanizada
      del municipio —Tapias Viejas, Villas de Nuestra Señora de la Asunción, colonias nuevas al norte—
      tiene densidad residencial comparable a la capital pero con menor cobertura de infraestructura
      de emergencias. Esta estación coordina con la Estación Central para incidentes en zonas limítrofes
      donde los tiempos de respuesta de ambas unidades son equivalentes.
    </p>

    <h3>Frente Forestal: Cañada Honda, La Labor y la Sierra Norte</h3>
    <p>
      Al norte y oriente de la cabecera municipal, el territorio de Jesús María cambia abruptamente
      de zona urbana a zona rural con pastizales y manchones forestales que en temporada seca —abril
      a junio— registran los incendios más frecuentes del municipio. La unidad forestal de esta
      estación está equipada para acceder a terrenos sin vialidad pavimentada y realizar trabajos
      de contención en la interfaz urbano-forestal, donde un incendio de pastizal puede alcanzar
      una vivienda en menos de 10 minutos con viento a favor.
    </p>

    <h3>Rescate Rural y Control de Fauna Silvestre</h3>
    <p>
      Las comunidades rurales del municipio —La Labor, Cañada Honda, Gracias a Dios— tienen acceso
      por caminos de terracería que en temporada de lluvias pueden ser intransitables. El tiempo de
      respuesta en estas zonas supera los 15 minutos incluso saliendo de inmediato. Además del rescate
      en zonas de difícil acceso, esta estación responde a incidentes con fauna silvestre —principalmente
      coyotes, víboras de cascabel y enjambres de abejas africanizadas— que son frecuentes en la
      periferia rural del municipio y en los límites con la zona serrana del norte del estado.
    </p>

    <h3>Equipo NFPA para Emergencias Urbanas y Forestales en Jesús María</h3>
    <p>
      La dualidad urbano-forestal de Jesús María requiere equipo certificado para dos entornos
      distintos: NFPA 1971 para incendios estructurales y NFPA 1977 para combate en vegetación.
      Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes estructurales NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> a estaciones de bomberos
      en Aguascalientes y toda la ZMA. <a href="/cotizar/">Solicita cotización</a> con especificaciones
      técnicas por tipo de operación.
    </p>
  </Fragment>
</EstacionLayout>
