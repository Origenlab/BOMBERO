---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-aguascalientes";

const slug = "estacion-bomberos-san-jose-gracia";
const estacion = getEstacionBySlug(slug);
if (!estacion) return Astro.redirect("/404");
const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Aguascalientes",
  slug: "aguascalientes",
  siglas: "AGS",
  poblacion: "1.5 millones",
  municipios: 11,
};

const estadosVecinos = [
  { nombre: "Zacatecas", slug: "zacatecas" },
  { nombre: "San Luis Potosí", slug: "san-luis-potosi" },
  { nombre: "Jalisco", slug: "jalisco" },
  { nombre: "Guanajuato", slug: "guanajuato" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje NFPA 1971 bomberos San José de Gracia Presa Calles",
    badge: "NFPA 1971 / 1977",
    title: "Traje Estructural y Forestal",
    text: "Doble certificación para operaciones en <strong>San José de Gracia</strong>: NFPA 1971 para incendios estructurales en la cabecera y zonas turísticas, y NFPA 1977 para combate forestal en la Sierra Fría.",
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco bomberos rescate acuático turístico San José de Gracia",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: "Protección certificada para operaciones en la <strong>Presa Plutarco Elías Calles</strong> y en emergencias turísticas en zonas boscosas. Compatible con visera para protección en entornos acuáticos.",
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes bomberos rescate acuático forestal AGS sur",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: "Resistencia térmica y a la abrasión para operaciones de rescate en las orillas rocosas de la <strong>Presa Calles</strong> y en terrenos irregulares de la Sierra Fría durante el combate de incendios forestales.",
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas bomberos zona turística forestal San José de Gracia",
    badge: "NFPA 1971 / 1977",
    title: "Botas para Operaciones Mixtas",
    text: "Suela de agarre para orillas resbaladizas de la <strong>Presa Plutarco Elías Calles</strong> y para trabajo en laderas forestales de la Sierra Fría. Impermeabilidad para operaciones en entornos acuáticos y de alta humedad.",
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Estación de Bomberos San José de Gracia — Rescate Acuático en la Presa más Grande del Estado, Combate Forestal en Sierra Fría y Lancha Especializada para el Principal Destino Ecoturístico de Aguascalientes</h2>
    <p>
      La <strong>Estación de Bomberos de San José de Gracia</strong>, ubicada en Plaza Principal 12,
      Centro, es la única en el estado con capacidad de rescate acuático equipada con lancha especializada.
      Con 20 elementos activos, 4 unidades —incluyendo una autobomba, una unidad forestal, una lancha
      de rescate y una ambulancia— y tiempo de respuesta de 10 a 20 minutos, esta estación opera en
      el destino ecoturístico más importante de Aguascalientes: la Presa Plutarco Elías Calles
      —la más grande del estado, con una capacidad de 350 millones de m³— y la Sierra Fría,
      el macizo boscoso que genera los incendios forestales de mayor extensión del sur del estado.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de San José de Gracia?</h3>
    <p>
      En cualquier emergencia en San José de Gracia o la Presa Calles, marca el <strong>911</strong>:
      el sistema de despacho activa esta estación y, para rescates acuáticos de larga duración,
      coordina con la Comisión Nacional del Agua para acceso a zonas restringidas de la presa.
      Para contacto directo: 495 957 0123. Para emergencias en zonas de la Sierra Fría sin
      cobertura celular, la notificación debe hacerse desde el punto más cercano con señal
      o a través de los guardabosques del área natural protegida.
    </p>

    <h3>Presa Plutarco Elías Calles: Rescate Acuático con Lancha Especializada</h3>
    <p>
      La Presa Plutarco Elías Calles —conocida popularmente como Presa Calles o Presa de San José—
      tiene una superficie espejo de agua de entre 50 y 80 km² según el nivel de almacenamiento,
      lo que la convierte en el cuerpo de agua artificial más extenso del estado. Los fines de
      semana y en temporadas vacacionales, más de 2,000 personas visitan el embalse para pesca
      deportiva, paseos en lancha y camping en las orillas. Los rescates acuáticos —personas
      caídas al agua desde embarcaciones, bañistas en corrientes ocultas, turistas atrapados
      en islas de tierra durante vaciado de presa— son el incidente más frecuente y de mayor
      riesgo de esta estación. La lancha de rescate permite acceder a puntos del embalse donde
      ninguna unidad terrestre puede llegar.
    </p>

    <h3>Sierra Fría: Incendios Forestales en la Zona Boscosa del Sur del Estado</h3>
    <p>
      La Sierra Fría que cruza el municipio de San José de Gracia tiene bosques de pino-encino
      con densidades de combustible de 8 a 12 toneladas por hectárea en los rodales más densos.
      Un incendio en estas condiciones puede generar columnas de humo visibles a más de 30 km
      y calores de irradiación que impiden el acceso a menos de 500 metros del frente activo
      sin equipo de protección personal certificado NFPA 1977. La unidad forestal todoterreno
      de esta estación está diseñada para apertura de brechas cortafuego en pendientes de hasta
      40 % y transporte de herramienta manual para trabajo en zonas sin acceso vehicular.
    </p>

    <h3>Emergencias Turísticas: Cobertura para el Principal Destino Ecoturístico de AGS</h3>
    <p>
      San José de Gracia concentra el turismo de naturaleza más importante del estado: la Presa
      Calles para pesca y lancha, la Sierra Fría para senderismo y ciclismo de montaña, y el
      centro histórico para turismo cultural ligado a la cuna del expresidente Plutarco Elías
      Calles. El flujo de visitantes —hasta 5,000 personas en puentes vacacionales— aumenta
      la frecuencia de rescates en zonas sin señalización, personas desorientadas en senderos
      y accidentes en vías de acceso a miradores que no están diseñadas para el volumen de
      tráfico que reciben en temporada alta.
    </p>

    <h3>Equipo NFPA para Rescate Acuático, Forestal y Emergencias Turísticas</h3>
    <p>
      Tres tipos de emergencia radicalmente distintos —rescate acuático, combate forestal y
      atención turística en zonas remotas— exigen equipo con certificaciones específicas para
      cada entorno. En <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971 y NFPA 1977</a> para
      operaciones mixtas, <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> para entornos húmedos
      y de montaña. <a href="/cotizar/">Solicita cotización</a> especificando el tipo de
      operación predominante de tu estación.
    </p>
  </Fragment>
</EstacionLayout>
