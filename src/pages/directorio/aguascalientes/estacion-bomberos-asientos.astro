---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-aguascalientes";

const slug = "estacion-bomberos-asientos";
const estacion = getEstacionBySlug(slug);
if (!estacion) return Astro.redirect("/404");
const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Aguascalientes",
  slug: "aguascalientes",
  siglas: "AGS",
  poblacion: "1.5 millones",
  municipios: 11,
};

const estadosVecinos = [
  { nombre: "Zacatecas", slug: "zacatecas" },
  { nombre: "San Luis Potosí", slug: "san-luis-potosi" },
  { nombre: "Jalisco", slug: "jalisco" },
  { nombre: "Guanajuato", slug: "guanajuato" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje NFPA 1970 bomberos Asientos minas históricas",
    badge: "NFPA 1970",
    title: "Traje Estructural NFPA 1970",
    text: "Certificación para incendios estructurales en <strong>Asientos</strong> y para operaciones en espacios confinados de las antiguas minas coloniales, donde las altas temperaturas se acumulan por la falta de ventilación.",
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco bomberos rescate en espacios confinados Asientos",
    badge: "NFPA 1970",
    title: "Casco Estructural NFPA 1970",
    text: "Protección para trabajo en <strong>espacios confinados</strong> y techos bajos de las galerías mineras históricas de Asientos. Sistema de iluminación frontal integrado para visibilidad en zonas subterráneas.",
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes bomberos rescate subterráneo minas AGS",
    badge: "NFPA 1970",
    title: "Guantes Estructurales NFPA 1970",
    text: "Resistencia a la abrasión para rescate en superficies rocosas de las <strong>antiguas minas coloniales</strong> de Asientos. Prensión en condiciones de humedad y polvo mineral presente en galerías subterráneas.",
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas bomberos zona minera serrana Asientos AGS",
    badge: "NFPA 1970",
    title: "Botas Estructurales de Cuero",
    text: "Suela antiderrapante para terreno húmedo en galerías y superficie con roca suelta en las zonas serranas de <strong>Asientos</strong>. Puntera de acero para protección en escombros de estructuras mineras históricas.",
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Estación de Bomberos Asientos — El Único Cuerpo del Estado Capacitado para Emergencias en las Minas Coloniales: Rescate en Espacios Confinados Históricos y Zona Serrana con 18 Elementos</h2>
    <p>
      La <strong>Estación de Bomberos de Asientos</strong>, ubicada en Calle Hidalgo 56, Centro, protege
      un municipio con un perfil de riesgo único en Aguascalientes: las antiguas minas de plata coloniales
      —algunas con más de 300 años de antigüedad— representan un escenario de rescate que no existe en
      ningún otro municipio del estado. Con 18 elementos activos, 3 unidades y tiempo de respuesta de
      12 a 20 minutos, esta estación opera en un entorno donde la capacitación en rescate en espacios
      confinados históricos, la zona serrana con comunidades de difícil acceso y los incendios forestales
      de temporada seca definen un perfil operativo sin paralelo en el H. Cuerpo de Bomberos de Aguascalientes.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Asientos?</h3>
    <p>
      En cualquier emergencia en Asientos o sus comunidades, marca el <strong>911</strong>: el sistema
      de despacho activa esta estación y, para rescates en minas o incidentes de larga duración,
      coordina con Protección Civil estatal y municipal. Para contacto directo: 496 963 0123.
      Las comunidades de Villa Juárez, Pilotos, El Llavero y Ciénega Grande tienen tiempo de
      respuesta de 15 a 20 minutos por la calidad de las vías de acceso serrano.
    </p>

    <h3>Minas Coloniales: La Geometría Subterránea que Cambia Todo en Rescate</h3>
    <p>
      Las antiguas minas de Asientos, explotadas desde el siglo XVII hasta principios del XX,
      conservan galerías subterráneas de entre 1.5 y 2 metros de altura, con anchos de 80 a
      120 centímetros en las vías principales. En estos espacios, el rescate de una persona
      lesionada no puede hacerse con camilla estándar: requiere sistemas de extricación lateral
      y procedimientos de avance en posición de cuclillas que reducen la velocidad del rescate
      a menos de 20 metros por minuto. La capacitación específica de esta estación en espacios
      confinados históricos es un activo operativo que no puede improvisarse al momento de
      un incidente.
    </p>

    <h3>Atmósferas Deficientes en Galerías: El Riesgo Invisible del Rescate Subterráneo</h3>
    <p>
      Las galerías mineras cerradas acumulan dióxido de carbono y, en algunos casos, ácido
      sulfhídrico proveniente de filtraciones de agua con azufre. Una atmósfera con menos del
      19.5 % de oxígeno —umbral de la NFPA 1— es deficiente y puede causar pérdida de
      consciencia en segundos sin advertencia olfativa previa. El rescate en estas condiciones
      exige SCBA de presión positiva para cada elemento que ingrese a la galería, monitoreo
      continuo de la atmósfera con detector multigas y un protocolo de retirada inmediata
      ante cualquier lectura anormal.
    </p>

    <h3>Zona Serrana: Incendios Forestales y Comunidades de Difícil Acceso</h3>
    <p>
      El municipio de Asientos ocupa la vertiente más oriental de la sierra de Aguascalientes,
      con comunidades en cotas de hasta 2,200 metros conectadas por brechas que en temporada
      de lluvias pueden quedar inaccesibles por deslaves. Los incendios forestales de temporada
      seca en esta zona afectan principalmente manchones de encino y matorral semiárido, con
      propagación más lenta que en la Sierra Fría pero con mayor dificultad de acceso para
      las unidades de extinción. El conocimiento de los caminos de acceso alternativo es,
      en este municipio, una ventaja operativa tan importante como el equipo.
    </p>

    <h3>Equipo NFPA para Rescates en Espacios Confinados y Zona Serrana</h3>
    <p>
      Rescate en minas históricas, espacios confinados con atmósferas deficientes y operaciones
      en zona serrana exigen equipo certificado con énfasis en protección respiratoria y
      resistencia en terreno irregular. Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes estructurales NFPA 1970</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a>,
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> y
      <a href="/productos/scba/">equipos SCBA NFPA 1970</a> para rescate en atmósferas peligrosas.
      <a href="/cotizar/">Solicita cotización</a> con especificaciones por tipo de operación.
    </p>
  </Fragment>
</EstacionLayout>
