---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-aguascalientes";

const slug = "estacion-bomberos-calvillo";
const estacion = getEstacionBySlug(slug);
if (!estacion) return Astro.redirect("/404");
const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Aguascalientes",
  slug: "aguascalientes",
  siglas: "AGS",
  poblacion: "1.5 millones",
  municipios: 11,
};

const estadosVecinos = [
  { nombre: "Zacatecas", slug: "zacatecas" },
  { nombre: "San Luis Potosí", slug: "san-luis-potosi" },
  { nombre: "Jalisco", slug: "jalisco" },
  { nombre: "Guanajuato", slug: "guanajuato" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje NFPA 1971/1977 bomberos Calvillo Sierra Fría",
    badge: "NFPA 1971 / 1977",
    title: "Traje Estructural y Forestal",
    text: "Doble certificación para los bomberos de <strong>Calvillo</strong>: NFPA 1971 para incendios en la cabecera municipal y NFPA 1977 para combate forestal en la Sierra Fría a 2,800 metros de altitud.",
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco bomberos rescate montaña Sierra Fría Calvillo",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: "Resistencia certificada para operaciones de rescate en altura en la <strong>Sierra Fría</strong>. Compatible con sistemas de comunicación de largo alcance requeridos cuando las unidades operan fuera del radio de la red celular.",
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes bomberos rescate en montaña Calvillo AGS",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: "Resistencia térmica y de abrasión para rescate en <strong>terrenos rocosos de la Sierra Fría</strong>. La superficie irregular de la montaña genera abrasión constante sobre guantes no certificados.",
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1977 bomberos forestal montaña Calvillo",
    badge: "NFPA 1971 / 1977",
    title: "Botas para Montaña y Forestal",
    text: "Suela de agarre profundo para terrenos irregulares de la <strong>Sierra Fría</strong> a 2,800 m de altitud. Puntera de acero para protección en zonas de escombros y laderas con roca suelta.",
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Estación de Bomberos Calvillo — Triple Reto Operativo: Rescate en la Sierra Fría a 2,800 Metros, Capital Mundial de la Guayaba y la Presa de los Serna con Lancha Todoterreno</h2>
    <p>
      La <strong>Estación de Bomberos de Calvillo</strong>, ubicada en Calle Victoria 120, Centro, opera
      en el municipio más occidental y uno de los más complejos del estado. Con 28 elementos activos,
      5 unidades —incluyendo 2 unidades de rescate en montaña, una unidad forestal y una ambulancia—
      y tiempo de respuesta de 12 a 25 minutos en las zonas más remotas, esta estación enfrenta tres
      escenarios operativos que no tiene ninguna otra del estado: rescate en montaña a altitudes
      superiores a 2,800 metros en la Sierra Fría, incendios forestales en el macizo boscoso más
      importante de Aguascalientes y emergencias turísticas durante la temporada de guayaba, que
      concentra más de 200,000 visitantes en pocas semanas.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Calvillo?</h3>
    <p>
      En cualquier emergencia en Calvillo o la Sierra Fría, marca el <strong>911</strong>: el sistema
      de despacho activa esta estación y, para rescates en montaña de larga duración, coordina con
      Protección Civil estatal. Para contacto directo: 495 956 0567. En zonas de la Sierra Fría
      sin cobertura celular —El Sauz, Malpaso, cimas sobre los 2,500 m— la notificación debe hacerse
      desde el punto más cercano con señal o a través de radioaficionados locales.
    </p>

    <h3>Sierra Fría: Rescate en Montaña a 2,800 Metros con Unidades Todoterreno</h3>
    <p>
      La Sierra Fría, área natural protegida con bosques de encino y pino, alcanza cotas de 2,800
      metros en sus puntos más altos. El rescate en este entorno presenta condicionantes que no
      existen en emergencias urbanas: la altitud reduce la capacidad física de los elementos en
      aproximadamente un 15 %, los caminos de acceso son brechas de montaña donde solo operan
      vehículos de doble tracción, y la comunicación por radio tiene zonas muertas por la topografía.
      Las 2 unidades de rescate en montaña de esta estación —vehículos con tracción integral y
      camillas de evacuación para terreno inclinado— son el único recurso especializado para
      estos rescates en todo el estado.
    </p>

    <h3>Capital Mundial de la Guayaba: Turismo Masivo y Temporadas de Alto Riesgo</h3>
    <p>
      Calvillo produce más del 60 % de la guayaba nacional y su temporada de cosecha —octubre a
      diciembre— atrae a más de 200,000 turistas que visitan huertas, miradores y la presa de
      los Serna. Este flujo masivo en un municipio con infraestructura vial limitada multiplica
      la frecuencia de accidentes carreteros, emergencias en zonas turísticas sin señalización
      de emergencia y rescates de personas desorientadas en los senderos serranos. La estación
      refuerza sus guardias durante esta temporada para absorber la demanda adicional.
    </p>

    <h3>Incendios Forestales: Tiempo de Respuesta de 12 a 25 Minutos en Terrenos Sin Acceso</h3>
    <p>
      La Sierra Fría es el macizo forestal más importante de Aguascalientes, con 12,000 hectáreas
      de bosque de encino y pino. En temporada seca —marzo a junio— los incendios forestales son
      la emergencia más frecuente del municipio, y los más peligrosos son los que se inician en
      laderas con pendiente superior al 30 % donde el fuego asciende a una velocidad hasta 4 veces
      mayor que en terreno plano. La unidad forestal de esta estación opera con herramientas de
      apertura de brechas cortafuego y cuenta con equipos de comunicación satelital para zonas
      fuera del alcance de la red celular.
    </p>

    <h3>Equipo NFPA para Operaciones en Altitud y Entornos Forestales</h3>
    <p>
      Rescate en montaña, combate forestal y emergencias turísticas en entornos rurales exigen
      equipo ligero, resistente y certificado. En <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971 y NFPA 1977</a> para operaciones
      mixtas urbanas y forestales, <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> para terreno irregular.
      <a href="/cotizar/">Solicita cotización</a> especificando el tipo de operación predominante.
    </p>
  </Fragment>
</EstacionLayout>
