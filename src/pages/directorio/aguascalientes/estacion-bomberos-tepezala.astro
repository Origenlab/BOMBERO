---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-aguascalientes";

const slug = "estacion-bomberos-tepezala";
const estacion = getEstacionBySlug(slug);
if (!estacion) return Astro.redirect("/404");
const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Aguascalientes",
  slug: "aguascalientes",
  siglas: "AGS",
  poblacion: "1.5 millones",
  municipios: 11,
};

const estadosVecinos = [
  { nombre: "Zacatecas", slug: "zacatecas" },
  { nombre: "San Luis Potosí", slug: "san-luis-potosi" },
  { nombre: "Jalisco", slug: "jalisco" },
  { nombre: "Guanajuato", slug: "guanajuato" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje NFPA 1971 bomberos Tepezalá zona agrícola ganadera",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: "Protección certificada para incendios en bodegas ganaderas y agrícolas de <strong>Tepezalá</strong>. La combustión de materia orgánica compactada —granos, forraje— genera calor prolongado que supera la tolerancia de EPP no certificado.",
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco bomberos primera respuesta rural Tepezalá",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: "Resistencia certificada para los 15 elementos de <strong>Tepezalá</strong> que operan como primera respuesta en el municipio más disperso de la región norte del estado.",
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes bomberos rescate rural caminos terracería Tepezalá",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: "Resistencia a la abrasión para rescate vehicular en caminos de terracería de <strong>Tepezalá</strong> y para operaciones en entornos ganaderos donde las superficies irregulares son la norma.",
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas bomberos zona rural agrícola Tepezalá",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: "Suela antiderrapante para operaciones en terrenos irregulares de <strong>Tepezalá</strong>: tierra suelta, corrales ganaderos, pastizales secos y caminos sin pavimentar de las comunidades dispersas del municipio.",
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Estación de Bomberos Tepezalá — 15 Bomberos para el Municipio más Agrícola-Ganadero del Estado: Incendios en Pastizales de Propagación Rápida y Cobertura de Comunidades Rurales Dispersas</h2>
    <p>
      La <strong>Estación de Bomberos de Tepezalá</strong>, ubicada en Plaza Principal s/n, Centro,
      opera en el municipio con mayor vocación agrícola y ganadera del norte de Aguascalientes. Con
      15 elementos activos, 3 unidades y tiempo de respuesta de 15 a 25 minutos en las localidades
      más alejadas, esta estación cubre un territorio donde la dispersión de las comunidades y la
      ausencia de vialidades pavimentadas definen los límites reales de la respuesta de emergencia.
      En temporada seca, los pastizales del municipio generan los incendios de mayor extensión
      superficial del estado, aunque de menor temperatura que los forestales.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Tepezalá?</h3>
    <p>
      En cualquier emergencia en Tepezalá o sus localidades, marca el <strong>911</strong>: el
      operador de despacho activa esta estación o coordina refuerzos desde Asientos o Rincón
      de Romos para incendios de gran extensión. Para contacto directo: 465 959 0234.
      En las localidades de El Tule, Puerto de la Concepción, San Antonio y Mesillas el tiempo
      de llegada varía entre 15 y 25 minutos dependiendo del estado de los caminos de acceso.
    </p>

    <h3>Incendios de Pastizal: Propagación Rápida en Zona Árida-Semiárida</h3>
    <p>
      El municipio de Tepezalá tiene una precipitación anual de 450 a 550 mm, la más baja del
      estado. Esta condición de semi-aridez genera pastizales y matorrales que en la temporada
      seca —marzo a junio— tienen humedad residual inferior al 8 %, el umbral por debajo del
      cual la ignición por chispa eléctrica, colilla de cigarro o vidrio actúa como lupa puede
      iniciarse con mínima energía. La velocidad de propagación en estas condiciones supera los
      6 km/h con viento moderado, lo que significa que 3 hectáreas pueden arder en 30 minutos
      antes de que la unidad de la estación llegue al punto de ignición. La estrategia de
      contención perimetral —no de ataque directo— es la técnica aplicada en estos casos.
    </p>

    <h3>Comunidades Rurales Dispersas: El Reto de la Cobertura con 15 Elementos</h3>
    <p>
      Tepezalá tiene 22 localidades distribuidas en 571 km² de superficie municipal. Con 15 elementos
      activos y 3 unidades, la cobertura simultánea de dos incidentes en localidades distintas
      supera la capacidad operativa de la estación. En estos casos, el sistema estatal de despacho
      activa automáticamente la solicitud de apoyo a las estaciones vecinas de Asientos o Rincón
      de Romos. El conocimiento del territorio —cuáles caminos son transitables en lluvias, dónde
      hay hidrantes o norias privadas de agua, qué fincas tienen acceso alternativo— es un recurso
      operativo tan valioso como el propio equipamiento de la estación.
    </p>

    <h3>Emergencias Ganaderas: Riesgos en Corrales, Establos y Bodegas de Forraje</h3>
    <p>
      La ganadería extensiva del municipio genera emergencias específicas que no ocurren en zonas
      urbanas: incendios en establos con pacas de heno y paja almacenadas en alturas de hasta
      6 metros, rescate de animales grandes atrapados en fosos y canales de riego, y fugas de
      amoniaco en instalaciones de refrigeración de productores de lácteos de mediana escala.
      El forraje seco tiene una densidad calórica de 3,500 kcal/kg y arde con flama interna
      difícil de extinguir con agua: requiere técnicas de inundación completa o extracción de
      material para exposición al aire y extinción por sofocación.
    </p>

    <h3>Equipo NFPA para Primera Respuesta Rural en el Estado</h3>
    <p>
      Pastizales de propagación rápida, comunidades dispersas sin hidratación y bodegas ganaderas
      exigen equipo ligero, resistente y certificado para operaciones rurales prolongadas. En
      <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes estructurales NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> a estaciones de primera
      respuesta rural en Aguascalientes. <a href="/cotizar/">Solicita cotización</a> con
      especificaciones por tipo de operación y zona de riesgo.
    </p>
  </Fragment>
</EstacionLayout>
