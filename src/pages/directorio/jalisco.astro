---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesJalisco, getMunicipios, ESTADISTICAS_JALISCO } from "@data/estaciones-jalisco";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { breadcrumbJsonLd } from "@lib/seo";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("jalisco");

const municipios = getMunicipios();

const canonical = "https://bombero.mx/directorio/jalisco/";

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const totalEstaciones = estacionesJalisco.length;
const totalMunicipios = municipios.length;

// ── Comparativa regional (zonas del estado) ─────────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Metropolitana de Guadalajara",
    municipiosZona: ["Guadalajara", "Zapopan", "San Pedro Tlaquepaque", "Tonalá", "Tlajomulco de Zúñiga"],
    cobertura: "Total",
    chip: "total",
    perfil: "Segunda metrópoli de México (5.2 M hab.), Bosque La Primavera, corredor tecnológico El Salto y Aeropuerto Internacional GDL.",
  },
  {
    nombre: "Costa — Puerto Vallarta",
    municipiosZona: ["Puerto Vallarta", "Nuevo Vallarta"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "7 millones de turistas/año, rescate acuático en Bahía de Banderas, temporada de huracanes jun–nov.",
  },
  {
    nombre: "Ruta del Tequila — Valles",
    municipiosZona: ["Tequila", "Amatitán"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Paisaje Agavero UNESCO (2006), +160 destilerías, etanol de destilación a 55–65 % ABV.",
  },
  {
    nombre: "Lago de Chapala — Ciénega",
    municipiosZona: ["Chapala", "Ajijic", "Jocotepec", "Ocotlán", "La Barca"],
    cobertura: "Media",
    chip: "media",
    perfil: "Lago dulce más grande de México (1,100 km²), comunidad de ~16,000 residentes extranjeros, industria mueblera en Ocotlán.",
  },
  {
    nombre: "Altos, Sur y Periferia",
    municipiosZona: ["Lagos de Moreno", "Tepatitlán de Morelos", "San Juan de los Lagos", "Ciudad Guzmán", "Tamazula de Gordiano", "Autlán de Navarro", "Cihuatlán", "Colotlán"],
    cobertura: "Media",
    chip: "media",
    perfil: "Agroindustria avícola/azucarera, Pueblos Mágicos, peregrinaciones masivas, Volcán de Colima y zona Huichola.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesJalisco.filter((e) =>
    z.municipiosZona.includes(e.municipio ?? e.ciudad ?? "")
  );
  return {
    ...z,
    nEst: est.length,
    nMun: z.municipiosZona.length,
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio",                 url: "/" },
  { name: "Directorio de Bomberos", url: "/directorio/" },
  { name: "Jalisco",                url: "/directorio/jalisco/" },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Jalisco, México",
  "description": `Directorio completo de las ${totalEstaciones} estaciones de bomberos en Jalisco. Cubre la Zona Metropolitana de Guadalajara (5.2 M hab.), Puerto Vallarta, la Ruta del Tequila UNESCO y el Lago de Chapala. Emergencias: 911.`,
  "numberOfItems": estacionesJalisco.length,
  "itemListElement": estacionesJalisco.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Jalisco",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/jalisco/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Jalisco: estaciones, historia y servicios de emergencia",
  "description": "Guía del cuerpo de bomberos de Jalisco: historia (1923–hoy), infraestructura en la ZMG, Puerto Vallarta, Ruta del Tequila y Lago de Chapala, funciones, retos y directorio de estaciones con teléfonos directos.",
  "about": [
    "Cuerpo de Bomberos de Guadalajara",
    "Protección Civil Jalisco",
    "Rescate acuático",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/jalisco.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Jalisco",
  "description": `Directorio verificado de ${totalEstaciones} estaciones de bomberos en Jalisco: ZMG, Puerto Vallarta, Ruta del Tequila y Lago de Chapala. Teléfonos directos, cobertura e historia del cuerpo de bomberos.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "H. Cuerpo de Bomberos de Jalisco" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/jalisco.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Jalisco (≥10) — alimentan el FAQPage schema ───────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Jalisco?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas a través del C5 Jalisco (Centro de Control, Comando, Comunicaciones, Cómputo y Contacto Ciudadano). El sistema despacha la unidad de bomberos con menor tiempo de respuesta a tu ubicación. Para llamadas directas a las principales estaciones: Guadalajara (33) 3619-1515, Zapopan (33) 3818-2267, Puerto Vallarta (322) 222-0109. En Chapala y Ajijic los despachadores atienden también en inglés.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Jalisco?",
    a: `Este directorio reúne <strong>${totalEstaciones} estaciones verificadas</strong> en Jalisco, distribuidas en cinco zonas: la Zona Metropolitana de Guadalajara (ZMG), la costa de Puerto Vallarta, la Ruta del Tequila, el Lago de Chapala y el resto del estado (Altos, Sur y periferia). Cada estación incluye teléfono directo, dirección y servicios.`,
  },
  {
    q: "¿Cuándo se fundó el cuerpo de bomberos de Guadalajara?",
    a: `El <strong>Cuerpo de Bomberos de Guadalajara fue formalmente constituido el 23 de mayo de 1923</strong>, con 12 bomberos, dos cabos, un sargento y un comandante. En 2023 celebró su centenario. Existen registros de brigadas municipales de supresión de incendios anteriores a esa fecha, pero 1923 es el año reconocido de la institución formal. El incendio del Mercado Corona el 15 de noviembre de 1910 fue el detonante que llevó a las autoridades a crear una corporación profesional permanente.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `El 22 de agosto de 1873 se fundó en el puerto de <strong>Veracruz el primer cuerpo de bomberos del país</strong>. Esa fecha se conmemora cada año en toda la República como el Día del Bombero Mexicano. Los cuerpos de bomberos de Jalisco —Guadalajara, Zapopan, Puerto Vallarta y los demás municipios— participan en los eventos conmemorativos de esa fecha.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en Jalisco?",
    a: `Combate de <strong>incendios estructurales, forestales y en destilerías</strong>; <strong>rescate vehicular</strong> en carreteras y vialidades urbanas; <strong>rescate acuático</strong> en el Lago de Chapala, Puerto Vallarta y la Marina; <strong>atención prehospitalaria</strong>; materiales peligrosos (<strong>HAZMAT</strong>) incluyendo etanol de destilación y gases industriales; <strong>rescate aeronáutico (ARFF)</strong> en el Aeropuerto Internacional de Guadalajara; control de fugas de gas; incendios en campos de agave; y emergencias en zonas indígenas del norte del estado.`,
  },
  {
    q: "¿Los servicios de bomberos en Jalisco tienen costo?",
    a: `Las emergencias que ponen en riesgo la <strong>vida o la integridad de las personas</strong> —incendios, rescates, fugas de gas— se atienden de forma <strong>gratuita</strong>. Algunos cuerpos municipales pueden tener cuotas de recuperación para servicios no urgentes como dictámenes o retiro de enjambres. La atención de emergencia nunca se condiciona a un pago previo. Ante cualquier emergencia llama al <strong>911</strong>.`,
  },
  {
    q: "¿Por qué los incendios en las destilerías de tequila son más peligrosos que un incendio común?",
    a: `El etanol a las concentraciones de destilación (55–65 % ABV) tiene un <strong>punto de inflamación de 13 °C</strong> —es inflamable a temperatura ambiente— y su llama a plena luz solar es casi invisible: de color azul pálido, difícil de distinguir. Además, la espuma AFFF convencional se destruye en segundos al contacto con solventes polares como el etanol. Los bomberos de Tequila y Amatitán emplean <strong>espuma AR-AFFF</strong> (resistente al alcohol) y tienen planes de contención de derrames para proteger el suelo agavero declarado Patrimonio UNESCO en 2006.`,
  },
  {
    q: "¿Qué ocurrió en las explosiones del 22 de abril de 1992 en Guadalajara?",
    a: `El <strong>22 de abril de 1992</strong> una serie de explosiones destruyó más de 14 kilómetros de calles en el barrio de Analco, en el sector Oriente de Guadalajara. La causa fue la acumulación de gasolina en el sistema de drenaje del Colector Intermedio de Oriente. El saldo oficial fue de <strong>209 muertos, cerca de 500 heridos y 15,000 personas sin hogar</strong>. La tragedia transformó los protocolos de detección de gases en la red de drenaje de toda la ciudad y se conmemora cada año en Jalisco como fecha para la cultura de prevención de desastres.`,
  },
  {
    q: "¿Cómo responden los bomberos a emergencias en el Bosque La Primavera?",
    a: `El <strong>Bosque La Primavera</strong> es una reserva forestal de 30,500 hectáreas con perímetro compartido entre Guadalajara, Zapopan y Tlajomulco —tres municipios con corporaciones independientes, diferentes frecuencias de radio y diferentes estándares de equipo. En temporada de incendios (abril–junio), los tres cuerpos implementan un protocolo de <strong>preposicionamiento</strong>: despliegan unidades dentro de los límites del bosque al inicio de cada día de alto riesgo, antes de que se reporte humo, porque la coordinación posterior al inicio del fuego puede costar los minutos que hacen la diferencia entre contención y evacuación de colonias.`,
  },
  {
    q: "¿Cómo atienden los bomberos a los turistas y residentes extranjeros en Jalisco?",
    a: `Puerto Vallarta recibe cerca de <strong>7 millones de visitantes al año</strong>, y las estaciones de la zona hotelera tienen personal con capacitación para atención a turistas internacionales. En el Lago de Chapala, donde viven aproximadamente <strong>16,000 expatriados</strong> (principalmente jubilados de Estados Unidos y Canadá), las estaciones de Chapala y Ajijic mantienen <strong>despacho bilingüe español-inglés en todos los turnos</strong>. El 911 también tiene atención en inglés.`,
  },
  {
    q: "¿Cómo puedo prevenir un incendio o emergencia en mi hogar en Jalisco?",
    a: `Revisa periódicamente la instalación de <strong>gas</strong> (mangueras, reguladores y conexiones) y la <strong>instalación eléctrica</strong>. Instala <strong>detectores de humo</strong> y ten un extintor vigente y accesible. Si hueles gas, no acciones interruptores, cierra la llave de paso, ventila y evacúa. En caso de incendio, sal de inmediato cerrando puertas a tu paso. Define un <strong>plan de evacuación</strong> familiar con punto de reunión. Ten el <strong>911</strong> visible para toda la familia.`,
  },
  {
    q: "¿Cómo puedo apoyar o ingresar al cuerpo de bomberos en Jalisco?",
    a: `Cada municipio convoca sus propios procesos de selección con requisitos de edad, escolaridad y condición física. Los cuerpos de bomberos de Guadalajara, Zapopan y Puerto Vallarta publican convocatorias en los canales oficiales de sus ayuntamientos. El apoyo ciudadano también puede ser a través de donativos al patronato o difundiendo el directorio de emergencias. Para ingresar como voluntario, consulta directamente con la estación de tu municipio.`,
  },
];

