---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesBajaCaliforniaSur, getMunicipios, getEstadisticas } from "@data/estaciones-baja-california-sur";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("baja-california-sur");

const municipios   = getMunicipios();
const estadisticas = getEstadisticas();

const canonical = "https://bombero.mx/directorio/baja-california-sur/";

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const totalEstaciones = estacionesBajaCaliforniaSur.length;
const totalPersonal   = estacionesBajaCaliforniaSur.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesBajaCaliforniaSur.reduce((s, e) => s + (e.unidades ?? 0), 0);

// ── Comparativa regional por municipio ─────────────────────────────────────
const zonasDef = [
  { nombre: "Los Cabos",    municipios: ["Los Cabos"],    cobertura: "Total", chip: "total", perfil: "Cabo San Lucas · San José del Cabo · Corredor Turístico · 3M+ turistas anuales." },
  { nombre: "La Paz",       municipios: ["La Paz"],       cobertura: "Alta",  chip: "alta",  perfil: "Capital del estado · Bahía de La Paz · rescate acuático Mar de Cortés." },
  { nombre: "Loreto",       municipios: ["Loreto"],       cobertura: "Media", chip: "media", perfil: "Pueblo Mágico · Parque Nacional Bahía de Loreto (UNESCO) · islas remotas." },
  { nombre: "Comondú",      municipios: ["Comondú"],      cobertura: "Media", chip: "media", perfil: "Ciudad Constitución · Valle de Santo Domingo · Puerto San Carlos (ballena gris)." },
  { nombre: "Mulegé",       municipios: ["Mulegé"],       cobertura: "Baja",  chip: "baja",  perfil: "Santa Rosalía · patrimonio Eiffel · ferry Guaymas · mayor stock de madera histórica." },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesBajaCaliforniaSur.filter((e) => z.municipios.includes(e.municipio ?? ""));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Baja California Sur, México",
  "description": `Directorio verificado de las ${totalEstaciones} estaciones de bomberos en Baja California Sur. Teléfonos directos en La Paz, Los Cabos, Cabo San Lucas, Loreto y Santa Rosalía. Cobertura 24/7. Emergencias: llama al 911.`,
  "numberOfItems": estacionesBajaCaliforniaSur.length,
  "itemListElement": estacionesBajaCaliforniaSur.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.municipio ?? e.ciudad,
        "addressRegion": "Baja California Sur",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/baja-california-sur/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Baja California Sur: estaciones, historia y servicios de emergencia",
  "description": "Guía del Heroico Cuerpo de Bomberos de Baja California Sur: historia (1959–hoy), infraestructura en los 5 municipios, rescate acuático, huracanes y directorio de estaciones con teléfonos directos.",
  "about": [
    "Heroico Cuerpo de Bomberos de La Paz",
    "Bomberos Baja California Sur",
    "Rescate acuático Mar de Cortés",
    "Emergencias turísticas Los Cabos",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/baja-california-sur.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Baja California Sur",
  "description": `Directorio verificado de las ${totalEstaciones} estaciones de bomberos en los 5 municipios de Baja California Sur, con teléfonos directos, cobertura, funciones e historia del Heroico Cuerpo de Bomberos.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de La Paz, Baja California Sur" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/baja-california-sur.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Baja California Sur (≥10) ────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Baja California Sur?",
    a: `Marca el <strong>911</strong>, número único disponible las 24 horas en todo el estado. El sistema enruta la llamada a la unidad más cercana. En La Paz el número directo es 612 122 0054; en Cabo San Lucas 624 143 3577; en San José del Cabo 624 142 2466; en Loreto 613 135 0059; en Ciudad Constitución 613 132 0303; y en Santa Rosalía 615 152 0050. En emergencias en mar abierto, el 911 coordina también con la Armada de México.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de La Paz?",
    a: `El Heroico Cuerpo de Bomberos de La Paz fue fundado en <strong>1959</strong> y celebra su aniversario en agosto. En 2025 conmemoró su 66° aniversario. El <strong>Día del Bombero en México</strong> se celebra el <strong>22 de agosto</strong>, fecha que conmemora la fundación del primer cuerpo de bomberos del país en Veracruz en 1873.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Baja California Sur?",
    a: `Este directorio reúne <strong>${totalEstaciones} estaciones</strong> activas en los <strong>${estadisticas.totalMunicipios} municipios</strong> de Baja California Sur, con un total de <strong>${totalPersonal} bomberos</strong> y <strong>${totalUnidades} unidades</strong>: La Paz (Estación Central), San José del Cabo, Cabo San Lucas, Loreto, Ciudad Constitución y Santa Rosalía.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en Baja California Sur?",
    a: `Combate de <strong>incendios estructurales y forestales</strong>, <strong>rescate acuático</strong> en el Mar de Cortés y playas de alto riesgo, <strong>rescate vehicular</strong> en la Carretera Transpeninsular, <strong>atención prehospitalaria</strong>, control de <strong>materiales peligrosos (HAZMAT)</strong>, emergencias en <strong>embarcaciones y puertos</strong>, evacuaciones por <strong>huracanes</strong> y operaciones de rescate en <strong>islas remotas</strong> del Parque Nacional Bahía de Loreto.`,
  },
  {
    q: "¿Cómo respondieron los bomberos de BCS al huracán Odile en 2014?",
    a: `El huracán Odile tocó tierra en Cabo San Lucas el 14 de septiembre de 2014 como categoría 3, causando daños por aproximadamente <strong>16.6 mil millones de pesos</strong>. Las estaciones de Los Cabos coordinaron la evacuación de <strong>38,000 turistas</strong>, incluyendo 26,000 extranjeros, mediante un puente aéreo organizado con la Fuerza Aérea Mexicana hacia Guadalajara, Tijuana y Ciudad de México. Los bomberos operaron con comunicaciones cortadas y la Transpeninsular bloqueada.`,
  },
  {
    q: "¿Por qué Baja California Sur tiene un riesgo especial de huracanes?",
    a: `De acuerdo con la Conagua, <strong>Baja California Sur es el estado con mayor incidencia ciclónica de México</strong> en los últimos 60 años, con más de 170 ciclones tropicales en el Pacífico y un promedio de tres por año, además de alrededor de 50 impactos directos desde 1964. La posición del extremo peninsular, entre el Pacífico y el Mar de Cortés, la convierte en el destino más frecuente de las trayectorias ciclónicas del Pacífico mexicano.`,
  },
  {
    q: "¿Qué hace especial el rescate acuático en La Paz y el Mar de Cortés?",
    a: `El Mar de Cortés, llamado «el acuario del mundo» por Jacques Cousteau, combina <strong>corrientes de marea intensas</strong> entre islas, temperaturas de 14 a 20 °C en invierno y <strong>cobertura celular prácticamente nula</strong> en la mayoría de sus islas. Los buceadores y kayakistas que visitan Espíritu Santo, Los Islotes (colonia de lobos marinos) y La Ballena pueden perderse sin señal GPS. La estación de La Paz mantiene <strong>equipos de buceo y embarcaciones de respuesta rápida</strong> todo el año para este tipo de emergencias.`,
  },
  {
    q: "¿Qué es la Iglesia de Santa Bárbara en Santa Rosalía y por qué representa un riesgo de incendio?",
    a: `La Iglesia de Santa Bárbara fue <strong>diseñada por Gustave Eiffel</strong> en 1884 como prototipo de iglesia para colonias tropicales. La compró la Compagnie du Boleo en 1894 en Bruselas y la instaló en Santa Rosalía en 1897, siendo la <strong>única estructura diseñada por Eiffel en México</strong>. Está construida en hierro galvanizado, pero el centro histórico de Santa Rosalía concentra el <strong>mayor stock de edificios de madera del país</strong> —traídos prefabricados de Francia por El Boleo desde 1885—, lo que genera un riesgo de propagación de incendio muy alto en el clima desértico.`,
  },
  {
    q: "¿Qué cubre la estación de bomberos de Loreto?",
    a: `La estación de Loreto cubre el <strong>Parque Nacional Bahía de Loreto</strong> (Patrimonio Natural de la Humanidad UNESCO), que incluye islas como Coronado, Carmen y Danzante accesibles exclusivamente por embarcación. También protege la <strong>Misión de Nuestra Señora de Loreto</strong> (1697), la más antigua de las Californias, y atiende emergencias en la Sierra de la Giganta. Los rescates en islas pueden tomar de 30 a 60 minutos en llegar.`,
  },
  {
    q: "¿Por qué la Carretera Transpeninsular representa un reto para los bomberos de BCS?",
    a: `La <strong>Carretera Federal 1 Transpeninsular</strong> es la única vía terrestre de la península, con 1,125 km sin vía alterna entre La Paz y Los Cabos. Un accidente en el tramo norte puede quedar a más de <strong>400 km del hospital más cercano</strong> con capacidad quirúrgica. Las estaciones de Ciudad Constitución, Loreto y Santa Rosalía operan como <strong>primer respondiente médico extendido</strong>, con capacidad de manejo de vía aérea avanzada, dado que el traslado supera la «hora de oro». En temporada de huracanes, derrumbes e inundaciones pueden seccionar la carretera, aislando cada tramo como un corredor autónomo.`,
  },
  {
    q: "¿Cómo atienen los bomberos de BCS las emergencias en playas de alto riesgo de Los Cabos?",
    a: `Las playas de Divorce Beach (Playa del Divorcio) y Playa del Amor en Cabo San Lucas son conocidas por las <strong>corrientes del Pacífico extremadamente peligrosas</strong> que señalan todos los mapas de riesgo. Las unidades de Cabo San Lucas disponen de <strong>lanchas de rescate de 30 pies y motos acuáticas</strong> para intervenir con rapidez. En temporada alta, cuando los cruceros aportan hasta 5,000 pasajeros diarios, la demanda de rescate acuático aumenta significativamente.`,
  },
  {
    q: "¿Cómo puedo prevenir emergencias si viajo como turista a Baja California Sur?",
    a: `Guarda el <strong>911</strong> en tu teléfono antes de salir. En playas: respeta las banderas de advertencia y no nades en Divorce Beach ni Playa del Amor sin supervisión. En buceo y kayak: registra tu ruta con el dive master o guía y lleva un localizador de emergencia (PLB o EPIRB). En ruta por la Transpeninsular: informa tu itinerario, lleva agua y combustible extra, y evita conducir de noche. Durante temporada de huracanes (junio–noviembre): sigue las instrucciones de Protección Civil y del hotel para evacuación.`,
  },
];

