---

<DirectorioEstadoLayout
  estado="Nayarit"
  sigla="NAY"
  slug="nayarit"
  description={`Bomberos en Nayarit: ${totalEstaciones} estaciones con teléfonos directos — Tepic, Riviera Nayarit, Bahía de Banderas, San Blas, Islas Marietas y volcán Ceboruco. Emergencias: 911.`}
  keywords={["bomberos nayarit","estaciones bomberos tepic","bomberos riviera nayarit","emergencias nayarit 911","bomberos bahía de banderas","bomberos sayulita","rescate acuático nayarit","bomberos nuevo vallarta","cuerpo bomberos nayarit","bomberos punta mita","volcán ceboruco evacuación","huracán nayarit protección civil"]}
  canonical={canonical}
  jsonLd={jsonLd}

  totalEstaciones={totalEstaciones}
  totalMunicipios={totalMunicipios}
