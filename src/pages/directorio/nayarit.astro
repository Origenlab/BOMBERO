---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesNayarit, getMunicipios, ESTADISTICAS_NAYARIT } from "@data/estaciones-nayarit";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("nayarit");
const municipios = getMunicipios();

const canonical = "https://bombero.mx/directorio/nayarit/";

// ── Estadísticas derivadas ──────────────────────────────────────────────────
const totalEstaciones = estacionesNayarit.length;
const totalMunicipios = municipios.length;

// ── Comparativa regional (zonas del directorio) ─────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Metropolitana Tepic",
    municipiosZona: ["Tepic", "Xalisco"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital estatal, coordinación estatal de emergencias, único equipo HAZMAT Nivel II del estado.",
  },
  {
    nombre: "Riviera Nayarit Sur",
    municipiosZona: ["Bahía de Banderas"],
    cobertura: "Total",
    chip: "total",
    perfil: "Nuevo Vallarta, Punta de Mita, resorts de ultra lujo, Aeropuerto PVR (ARFF Cat. 9).",
  },
  {
    nombre: "Riviera Nayarit Norte",
    municipiosZona: ["Compostela"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Sayulita (Pueblo Mágico 2015), Rincón de Guayabitos, rescate surf y costas.",
  },
  {
    nombre: "Zona Histórica San Blas",
    municipiosZona: ["San Blas"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Puerto colonial, manglares La Tovara, Reserva RAMSAR, rescate en cocodrilos.",
  },
  {
    nombre: "Llanura Costera Norte",
    municipiosZona: ["Santiago Ixcuintla", "Tuxpan"],
    cobertura: "Media",
    chip: "media",
    perfil: "Marismas Nacionales (RAMSAR 1995), Mexcaltitán, zona tabacalera y agrícola.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesNayarit.filter((e) =>
    z.municipiosZona.includes(e.ciudad ?? e.municipio ?? "")
  );
  return {
    ...z,
    nEst: est.length,
    nPers: est.reduce((s, e) => s + (e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Nayarit, México",
  "description": `Directorio completo de las ${totalEstaciones} estaciones de bomberos en Nayarit. Protección para Tepic, Riviera Nayarit, Bahía de Banderas, Sayulita, 289 km de litoral y 1.3 millones de habitantes más 10 millones de visitantes anuales. Emergencias 911.`,
  "numberOfItems": estacionesNayarit.length,
  "itemListElement": estacionesNayarit.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Nayarit",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/nayarit/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Nayarit: estaciones, historia y servicios de emergencia",
  "description": "Guía del cuerpo de bomberos de Nayarit: historia, infraestructura en la Riviera Nayarit, Tepic, San Blas y la Sierra Wixárika, funciones, riesgos (Ceboruco, huracanes, rescate acuático) y directorio de estaciones.",
  "about": [
    "Heroico Cuerpo de Bomberos de Tepic",
    "H. Cuerpo de Bomberos de Bahía de Banderas",
    "Protección Civil Nayarit",
    "Rescate acuático Riviera Nayarit",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/nayarit.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Nayarit",
  "description": `Directorio verificado de ${totalEstaciones} estaciones de bomberos en Nayarit, con teléfonos, cobertura, funciones e historia del cuerpo de bomberos.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Cuerpo de Bomberos de Nayarit" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/nayarit.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Nayarit (≥10) ─────────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencias para llamar a los bomberos en Nayarit?",
    a: `Marca el <strong>911</strong>, número único que opera las 24 horas a través del C4 de Nayarit. Los teléfonos directos de las estaciones principales son: Tepic <strong>(311) 213-2232</strong>, Bahía de Banderas <strong>(329) 291-6060</strong>, San Blas <strong>(323) 285-0505</strong>, Sayulita <strong>(329) 291-3636</strong> y Compostela <strong>(311) 215-4141</strong>.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Nayarit?",
    a: `Este directorio registra <strong>${totalEstaciones} estaciones de bomberos</strong> distribuidas en los principales municipios del estado, desde la zona metropolitana de Tepic hasta la Riviera Nayarit, San Blas, la llanura costera norte y la sierra.`,
  },
  {
    q: "¿Cuándo se fundó el cuerpo de bomberos de Tepic?",
    a: `El Heroico Cuerpo de Bomberos de Tepic tiene documentadas décadas de servicio continuo en la capital del estado. El primer cuerpo de bomberos de México se fundó el <strong>22 de agosto de 1873 en Veracruz</strong>, fecha que se conmemora como el Día del Bombero en toda la República.`,
  },
  {
    q: "¿El volcán Ceboruco representa un riesgo real para Tepic?",
    a: `Sí. El Ceboruco es un <strong>estratovolcán activo</strong> ubicado a unos 80 km de Tepic, con su última erupción registrada entre <strong>1870 y 1875</strong>. Emite fumarolas activas y el CENAPRED lo clasifica entre los volcanes mexicanos con mayor nivel de riesgo. Las comunidades más cercanas, como <strong>Jala</strong> (Pueblo Mágico), están en el radio de atención prioritaria del plan de emergencia volcánica estatal.`,
  },
  {
    q: "¿Cómo evacúan los turistas de la Riviera Nayarit ante un huracán?",
    a: `Los hoteles de la Riviera Nayarit tienen planes de evacuación coordinados con la Unidad Estatal de Protección Civil y los bomberos de Bahía de Banderas. En temporada de huracanes (junio-noviembre) el protocolo establece refugios temporales en escuelas y recintos de zona alta; los turistas deben seguir instrucciones del hotel y del <strong>911</strong>. El huracán <strong>Patricia (2015)</strong> —el más intenso del Pacífico hasta entonces— y <strong>Willa (2018)</strong> activaron evacuaciones masivas de la costa nayarita.`,
  },
  {
    q: "¿Qué hace especial el rescate acuático en las Islas Marietas?",
    a: `Las Islas Marietas son un Parque Nacional con la famosa Playa del Amor, accesible únicamente nadando por un pasaje subacuático de unos 30 metros o caminando en ventana de marea baja. Un rescate allí combina técnicas de espacio confinado subacuático con rescate oceánico, con la restricción adicional de que la CONANP limita equipos motorizados en la zona. Los bomberos de Bahía de Banderas y la SEMAR coordinan la respuesta con nadadores de rescate.`,
  },
  {
    q: "¿Qué es un incendio de turba en los manglares de Marismas Nacionales?",
    a: `En temporadas de sequía severa, el suelo de turba bajo la cobertura de manglar puede deshidratarse y arder de forma subterránea a temperaturas de 200–400 °C <strong>sin llama visible</strong>. El fuego puede desplazarse kilómetros y el suelo sobre su frente puede colapsar bajo el peso de una persona. Los bomberos de San Blas y Santiago Ixcuintla sondean el terreno con vara antes de cada paso y usan mochilas de agua de 20 litros en lugar de autobomba.`,
  },
  {
    q: "¿Por qué el rescate de surfistas en Sayulita tiene un protocolo especial?",
    a: `El extremo norte de la playa de Sayulita termina en un campo de rocas volcánicas que emergen y se ocultan con el oleaje. Un surfista arrastrado hacia esa zona no puede ser alcanzado directamente por el rompiente norte: la aproximación de rescate se hace desde el sur, nadando lateralmente fuera del rompiente hasta alcanzar al accidentado por el costado sin roca. Los bomberos de Bahía de Banderas entrenan este protocolo junto con guardavidas del municipio.`,
  },
  {
    q: "¿Qué servicios ARFF ofrece la estación del Aeropuerto Internacional de Puerto Vallarta?",
    a: `El Aeropuerto Internacional Licenciado Gustavo Díaz Ordaz (PVR), en territorio de Bahía de Banderas, Nayarit, cuenta con servicios de <strong>Rescate y Extinción de Incendios de Aeronaves (ARFF)</strong> conforme a normativa OACI Categoría 9, con tiempo de respuesta máximo de 3 minutos a cualquier punto de las pistas. El aeropuerto recibió más de 3.7 millones de llegadas en el primer semestre de 2024.`,
  },
  {
    q: "¿Cómo atienden los bomberos emergencias en comunidades Wixárikas de la sierra?",
    a: `Las comunidades Wixárikas (Huichol) de la Sierra del Nayar se ubican entre 1,500 y 2,500 msnm, con caminos que se cortan durante lluvias. El primer contacto para cualquier respuesta externa es la estructura de gobernanza comunitaria propia. Los bomberos de Compostela y Tepic coordinan rescates con el apoyo de guías locales y, cuando es necesario, con helicópteros de la Secretaría de la Defensa.`,
  },
  {
    q: "¿Cuáles son los principales riesgos por huracán en la costa de Nayarit?",
    a: `Los <strong>289 km de litoral</strong> de Nayarit están expuestos a la temporada de ciclones del Pacífico (junio-noviembre). El huracán Patricia (2015), el de mayor intensidad registrada en el Pacífico, pasó cercano a las costas nayaritas como categoría 5; Willa (2018) tocó tierra como categoría 3 y causó el desbordamiento de los ríos San Pedro y Acaponeta, con más de 180,000 damnificados en Nayarit. El protocolo de evacuación incluye resorts, playas, marinas y comunidades en zona de inundación.`,
  },
  {
    q: "¿Cómo prevenir emergencias en la playa en la Riviera Nayarit?",
    a: `Nada siempre en zonas con bandera verde y vigilancia de guardavidas. Respeta las banderas de advertencia de corrientes, medusas o fauna marina. No entres al agua solo ni de noche. En resorts, localiza las salidas de emergencia y el punto de reunión del hotel antes de que ocurra cualquier incidente. Ante cualquier emergencia, marca el <strong>911</strong>; en la zona turística hay personal bilingüe.`,
  },
];

