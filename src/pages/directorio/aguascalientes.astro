---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesAguascalientes, getMunicipios } from "@data/estaciones-aguascalientes";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { breadcrumbJsonLd } from "@lib/seo";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("aguascalientes");

const municipios = getMunicipios();

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const totalEstaciones = estacionesAguascalientes.length;
const totalMunicipios = municipios.length;
const totalBomberos   = estacionesAguascalientes.reduce((sum, e) => sum + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesAguascalientes.reduce((sum, e) => sum + (e.unidades ?? 0), 0);

const canonical = "https://bombero.mx/directorio/aguascalientes/";

// ── Comparativa regional ───────────────────────────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Metropolitana",
    municipios: ["Aguascalientes", "Jesús María", "San Francisco de los Romo"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital estatal, Feria Nacional de San Marcos (8.5 M visitantes), complejo Nissan A1/A2/Powertrain y Centro Histórico.",
  },
  {
    nombre: "Zona Norte",
    municipios: ["Rincón de Romos", "Cosío", "Tepezalá", "Asientos"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Zona agrícola y ganadera; patrimonio minero histórico en Asientos; carretera federal a Zacatecas.",
  },
  {
    nombre: "Zona Sur",
    municipios: ["Calvillo", "San José de Gracia"],
    cobertura: "Media",
    chip: "media",
    perfil: "Sierra Fría (112,000 ha de bosque encino-pino), Presa Plutarco Elías Calles y turismo de naturaleza.",
  },
  {
    nombre: "Zona Oriente",
    municipios: ["El Llano", "Pabellón de Arteaga"],
    cobertura: "Media",
    chip: "media",
    perfil: "Corredor agrícola y textil-maquilador; carretera a San Luis Potosí.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesAguascalientes.filter((e) => z.municipios.includes(e.municipio));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio",                 url: "/" },
  { name: "Directorio de Bomberos", url: "/directorio/" },
  { name: "Aguascalientes",         url: "/directorio/aguascalientes/" },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Aguascalientes, México",
  "description": `Directorio completo de las ${totalEstaciones} estaciones de bomberos en Aguascalientes. Teléfonos de emergencia, direcciones y servicios cubriendo los ${totalMunicipios} municipios. Cuerpo de bomberos activo desde 1972. Emergencias: 911.`,
  "numberOfItems": estacionesAguascalientes.length,
  "itemListElement": estacionesAguascalientes.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.municipio,
        "addressRegion": "Aguascalientes",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/aguascalientes/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Aguascalientes: estaciones, historia y servicios de emergencia",
  "description": `Guía del H. Cuerpo de Bomberos de Aguascalientes: historia (desde 1972), infraestructura en los ${totalMunicipios} municipios, riesgos industriales (Nissan), Feria de San Marcos, Sierra Fría y directorio de estaciones con teléfonos directos.`,
  "about": [
    "H. Cuerpo de Bomberos de Aguascalientes",
    "Protección Civil Aguascalientes",
    "Bomberos industriales automotriz",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/aguascalientes.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": `Estaciones de Bomberos en Aguascalientes — Directorio de ${totalEstaciones} estaciones`,
  "description": `Directorio verificado de estaciones de bomberos en los ${totalMunicipios} municipios de Aguascalientes, con teléfonos, cobertura, funciones e historia del H. Cuerpo de Bomberos (desde 1972).`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "H. Cuerpo de Bomberos de Aguascalientes" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/aguascalientes.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Aguascalientes (≥10) ─────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Aguascalientes?",
    a: `Marca el <strong>911</strong> desde cualquier teléfono en Aguascalientes. El Centro de Comando, Control, Comunicaciones y Cómputo (C4) del estado despacha la unidad más cercana según la naturaleza del incidente, las 24 horas del día. También puedes comunicarte directamente a la Estación Central al <strong>449 910 2030</strong> o a Protección Civil Estatal al <strong>449 910 3300</strong>.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Aguascalientes?",
    a: `El directorio de BOMBERO.MX registra <strong>${totalEstaciones} estaciones de bomberos</strong> distribuidas en los <strong>${totalMunicipios} municipios</strong> del estado. La sede principal es la Estación Central, ubicada en Av. Adolfo López Mateos Oriente 1801 (Lomas del Campestre, Aguascalientes capital), que coordina las operaciones de emergencia metropolitanas.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Aguascalientes?",
    a: `El <strong>Cuerpo de Bomberos de Aguascalientes</strong> inició operaciones en <strong>1972</strong>, cuando se formalizó el servicio con la creación de la Inspección de Policía Municipal que integraba funciones de bomberos. La primera estación independiente se instaló después en la salida a San Luis Potosí. El <strong>22 de agosto</strong> se celebra el <strong>Día del Bombero</strong> en México, en conmemoración de la fundación del primer cuerpo del país en Veracruz el 22 de agosto de 1873.`,
  },
  {
    q: "¿Por qué los bomberos de Aguascalientes tienen capacitación especial en industria automotriz?",
    a: `Porque Aguascalientes alberga el <strong>complejo industrial Nissan</strong>, uno de los más grandes de América Latina, con tres plantas en operación: Planta Powertrain (desde 1982), Planta A1 de vehículos (desde 1992) y Planta A2 (desde noviembre de 2013). Las operaciones de pintura automotriz utilizan bases de poliuretano con isocianatos —compuestos con riesgo de sensibilización respiratoria irreversible— y los modelos más recientes incorporan baterías de alta tensión que requieren protocolos de <strong>thermal runaway</strong>. Las brigadas de San Francisco de los Romo y la unidad HAZMAT de la Estación Central entrenan regularmente con brigadas industriales internas.`,
  },
  {
    q: "¿Cómo atienden los bomberos de Aguascalientes la Feria Nacional de San Marcos?",
    a: `La <strong>Feria Nacional de San Marcos</strong> es el evento masivo más grande de México, con <strong>8.5 millones de visitantes</strong> en aproximadamente 25 días (edición 2026, según el Gobierno de Aguascalientes). Durante la feria, más de 500 puestos de comida operan con cilindros de gas LP individuales sin un sistema de corte centralizado, lo que obliga al cuerpo de bomberos a <strong>pre-posicionar unidades adicionales dentro del recinto ferial</strong>. La Estación Zona Sur, ubicada en la zona de San Marcos, es la primera respuesta durante el evento.`,
  },
  {
    q: "¿Qué riesgo representan los incendios forestales en Aguascalientes?",
    a: `La <strong>Sierra Fría</strong>, con 112,000 hectáreas de bosque de encino, pino, cedro y madroño, es el macizo forestal más importante del estado. Abarca los municipios de Calvillo, San José de Gracia, Pabellón de Arteaga, Rincón de Romos y Jesús María. La temporada de incendios se concentra entre marzo y junio; en 2025 el estado registró <strong>más de 5,000 hectáreas afectadas</strong> (Newsweek, junio 2025). Los bomberos de Calvillo coordinan con <strong>CONAFOR</strong> en terrenos de difícil acceso, a altitudes de hasta 3,050 msnm.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en Aguascalientes?",
    a: `Combate de <strong>incendios estructurales, forestales y agrícolas</strong>; <strong>rescate vehicular</strong> y extricación; <strong>atención prehospitalaria</strong>; <strong>materiales peligrosos (HAZMAT)</strong> en parques industriales; control de <strong>fugas de gas</strong>; rescate en montaña y zonas de difícil acceso; <strong>rescate acuático</strong> en la Presa Calles; atención de eventos masivos; retiro de enjambres y manejo de fauna. También realizan inspecciones preventivas y capacitación a empresas y comunidades.`,
  },
  {
    q: "¿Tiene costo el servicio de bomberos en Aguascalientes?",
    a: `Las emergencias que comprometen la <strong>vida o integridad</strong> de las personas —incendios, rescates, fugas de gas— se atienden de forma <strong>gratuita</strong>. Algunos servicios secundarios como dictámenes o capacitación a empresas pueden tener cuota de recuperación. La atención de emergencia nunca se condiciona a un pago. Para emergencias, marca siempre el <strong>911</strong>.`,
  },
  {
    q: "¿Qué es la Presa Plutarco Elías Calles y por qué es un riesgo para los bomberos?",
    a: `La <strong>Presa Plutarco Elías Calles</strong>, ubicada en el municipio de San José de Gracia, es la presa más grande de Aguascalientes y un destino turístico activo con embarcaciones recreativas. La Estación de Bomberos de San José de Gracia opera con <strong>lanchas de rescate</strong> especializadas para emergencias acuáticas, búsqueda de personas y atención a embarcaciones en el embalse y en las zonas boscosas de la Sierra Fría adyacentes a la presa.`,
  },
  {
    q: "¿Cómo atienden los bomberos el Centro Histórico de Aguascalientes?",
    a: `El Centro Histórico de Aguascalientes concentra edificios en <strong>cantera rosa</strong> del siglo XVIII, incluyendo la Catedral Basílica, el Palacio de Gobierno y el Teatro Morelos. Los callejones históricos con anchos de 3 a 4 metros limitan el acceso de autobombas estándar, obligando a extender líneas de manguera a mano. El protocolo de intervención coordina con el <strong>INAH</strong> el uso de niebla de baja presión en fachadas históricas para evitar daños estructurales por presión directa.`,
  },
  {
    q: "¿Qué debo hacer si detecto un incendio o una fuga de gas en Aguascalientes?",
    a: `Llama de inmediato al <strong>911</strong>. Ante una <strong>fuga de gas</strong>: no enciendas ni apagues interruptores, no uses el teléfono dentro del inmueble, cierra la llave de paso, abre puertas y ventanas y evacúa el lugar. Ante un <strong>incendio</strong>: sal de inmediato, cierra puertas a tu paso para frenar el avance del fuego y nunca regreses por objetos. No intentes combatir un incendio que ya no puedes controlar con un extintor doméstico.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en mi hogar en Aguascalientes?",
    a: `Revisa periódicamente la instalación de <strong>gas</strong> (mangueras, reguladores y conexiones) y la <strong>instalación eléctrica</strong>; evita sobrecargar contactos. Instala <strong>detectores de humo</strong>, mantén un extintor vigente en cocina y zonas de riesgo, no dejes estufas o velas sin vigilancia, y acuerda con tu familia un <strong>plan de evacuación</strong> con punto de reunión. Conserva el 911 visible para todos en casa.`,
  },
];

