  "/images/directorio/bombero-profesional-retrato-casco-exterior-01.avif",
  "/images/directorio/bombero-profesional-retrato-closeup-goggle-01.avif",
  "/images/directorio/bombero-profesional-retrato-casco-camion-01.avif",
  "/images/directorio/vestidor-bomberos-equipo-epp-madera-01.avif",
  "/images/directorio/vestidor-bomberos-equipo-epp-completo-02.avif",
