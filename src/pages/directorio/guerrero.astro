---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesGuerrero,
  ESTADISTICAS_GUERRERO,
  GUERRERO_SEO
} from "@data/estaciones-guerrero";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

// ═══════════════════════════════════════════════════════════════════════════
// CALCULAR DATOS DERIVADOS
// ═══════════════════════════════════════════════════════════════════════════

const municipios = [...new Set(estacionesGuerrero.map((e) => e.ciudad))].sort();

const canonical = "https://bombero.mx/directorio/guerrero/";

// ── Comparativa regional ────────────────────────────────────────────────────
const zonasDef = [
  { nombre: "Acapulco (Costa Central)",     ciudades: ["Acapulco de Juárez"],                                       cobertura: "Total", chip: "total",  perfil: "Principal destino turístico del Pacífico mexicano; zona más afectada por el Huracán Otis (oct 2023)." },
  { nombre: "Costa Grande (Ixtapa-Zihu.)",  ciudades: ["Zihuatanejo de Azueta", "Ixtapa"],                          cobertura: "Alta",  chip: "alta",   perfil: "Complejo turístico Ixtapa y pueblo pesquero Zihuatanejo; marina y bahías del norte." },
  { nombre: "Centro (Capital Chilpancingo)", ciudades: ["Chilpancingo de los Bravo"],                                cobertura: "Alta",  chip: "alta",   perfil: "Capital del estado, coordinación USAR sísmico y despacho estatal de emergencias." },
  { nombre: "Norte (Taxco-Iguala)",         ciudades: ["Taxco de Alarcón", "Iguala de la Independencia", "Teloloapan"], cobertura: "Media", chip: "media", perfil: "Taxco (Capital Mundial de la Plata, Pueblo Mágico); Iguala (cuna de la Bandera de México)." },
  { nombre: "Costa Chica (Afromexicana)",   ciudades: ["Ometepec", "San Marcos"],                                   cobertura: "Media", chip: "media",  perfil: "Comunidades afromexicanas; riesgo por huracanes, inundaciones y carretera costera." },
  { nombre: "Montaña y Tierra Caliente",    ciudades: ["Tlapa de Comonfort", "Ciudad Altamirano"],                  cobertura: "Baja",  chip: "baja",   perfil: "Región Montaña indígena (Nahua, Mixteca, Tlapaneca); Tierra Caliente con calor extremo." },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesGuerrero.filter((e) => z.ciudades.includes(e.ciudad ?? ""));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ── Schemas ─────────────────────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Guerrero, México",
  "description": `Directorio de las ${ESTADISTICAS_GUERRERO.total_estaciones} estaciones de bomberos en Guerrero: Acapulco, Chilpancingo, Ixtapa-Zihuatanejo, Taxco, Iguala y más. Respuesta a huracanes (Otis 2023), sismos de la Brecha de Guerrero y turismo internacional. Emergencias: 911.`,
  "numberOfItems": estacionesGuerrero.length,
  "itemListElement": estacionesGuerrero.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Guerrero",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/guerrero/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Guerrero: estaciones, historia y servicios de emergencia",
  "description": "Guía del Heroico Cuerpo de Bomberos de Guerrero: historia (1948–hoy), infraestructura en Acapulco, Costa Grande, Chilpancingo y Taxco, funciones, retos tras el Huracán Otis y directorio de estaciones con teléfonos.",
  "about": [
    "Heroico Cuerpo de Bomberos de Guerrero",
    "Protección Civil Guerrero",
    "Búsqueda y rescate urbano",
    "Rescate acuático Pacífico",
    "Huracán Otis 2023",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/guerrero.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Guerrero",
  "description": `Directorio verificado de estaciones de bomberos en Guerrero: Acapulco, Ixtapa-Zihuatanejo, Chilpancingo, Taxco e Iguala. Teléfonos, cobertura, funciones e historia del cuerpo de bomberos.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de Guerrero" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/guerrero.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQs únicas Guerrero (≥10) ──────────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Guerrero?",
    a: `Marca el <strong>911</strong>, número único de emergencias disponible las 24 horas en todo el estado. Los teléfonos directos de las principales estaciones son: Acapulco <strong>(744) 485-0808</strong>, Chilpancingo <strong>(747) 472-0505</strong>, Ixtapa-Zihuatanejo <strong>(755) 554-2020</strong>, Taxco <strong>(762) 622-0707</strong> e Iguala <strong>(733) 332-1234</strong>. En zonas costeras o durante contingencias por huracán, la red celular puede saturarse; el 911 tiene prioridad de red.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Guerrero?",
    a: `Este directorio reúne <strong>${ESTADISTICAS_GUERRERO.total_estaciones} estaciones</strong> con teléfono directo, dirección y servicios, distribuidas en Acapulco (${ESTADISTICAS_GUERRERO.estaciones_acapulco}), Costa Grande (${ESTADISTICAS_GUERRERO.estaciones_costa_grande}), Chilpancingo (${ESTADISTICAS_GUERRERO.estaciones_centro}), zona norte —Taxco, Iguala, Teloloapan— (${ESTADISTICAS_GUERRERO.estaciones_norte}), Costa Chica (${ESTADISTICAS_GUERRERO.estaciones_costa_chica}) y Montaña/Tierra Caliente (${ESTADISTICAS_GUERRERO.estaciones_montana}). En total, más de <strong>${ESTADISTICAS_GUERRERO.total_bomberos} bomberos</strong> y <strong>${ESTADISTICAS_GUERRERO.total_unidades} unidades</strong>.`,
  },
  {
    q: "¿Cuándo se fundó el cuerpo de bomberos de Acapulco?",
    a: `El Heroico Cuerpo de Bomberos de Acapulco inició operaciones el <strong>15 de diciembre de 1948</strong>, con una motobomba Mack de 6,000 litros y 15 metros de manguera. El primer gran incendio documentado en el puerto fue el del Teatro Flores, ocurrido la noche del 14 de febrero de 1909, antes de que existiera el cuerpo formal. La corporación lleva el título de "Heroico" en reconocimiento a su actuación en emergencias de magnitud mayor.`,
  },
  {
    q: "¿Qué fue el Huracán Otis y cómo respondieron los bomberos?",
    a: `El <strong>Huracán Otis</strong> tocó tierra en Acapulco el <strong>25 de octubre de 2023</strong> como huracán de <strong>categoría 5</strong> —el más intenso en tocar tierra en el Pacífico oriental mexicano—, con vientos máximos sostenidos de <strong>270 km/h</strong> y rachas de hasta 330 km/h. Pasó de categoría 1 a categoría 5 en menos de doce horas, lo que impidió una evacuación masiva previa. Las estaciones de Acapulco operaron de forma completamente autónoma durante las primeras 72 horas, sin comunicación entre ellas ni apoyo externo, tomando decisiones de mando en tiempo real. Desde entonces, cada estación mantiene autonomía mínima de 72 horas en combustible, agua y alimentos.`,
  },
  {
    q: "¿Qué es la Brecha de Guerrero y qué riesgo representa?",
    a: `La <strong>Brecha de Guerrero</strong> es un segmento de aproximadamente 230 km de la zona de subducción frente a las costas del estado que no ha liberado un gran evento sísmico desde 1911. El CENAPRED y el Servicio Sismológico Nacional estiman que, si toda la brecha se rompe a la vez, el sismo podría alcanzar <strong>magnitud 8.2 a 8.4</strong>. El 7 de septiembre de 2021 un sismo de <strong>magnitud 7.1</strong> con epicentro a 14 km al sureste de Acapulco causó 14 fallecimientos a nivel nacional y miles de afectados. El riesgo de tsunami asociado obliga a los bomberos a protocolos de evacuación hacia zonas elevadas —no hacia la costa— en los primeros minutos tras un gran sismo.`,
  },
  {
    q: "¿Cuánto tarda en llegar un tsunami a Acapulco tras un sismo en la Brecha de Guerrero?",
    a: `Según los estudios del CENAPRED sobre peligro de tsunami en la costa del Pacífico, el tiempo de arribo de la primera ola a la bahía de Acapulco en un evento sísmico de la Brecha de Guerrero puede ser de <strong>8 a 15 minutos</strong> desde el epicentro. Ese margen de tiempo es inferior al necesario para evacuar por vehículo la franja costera con alta densidad turística, por lo que el protocolo de los bomberos y de protección civil prioriza la <strong>evacuación a pie hacia zonas elevadas</strong> (cota mínima de 15 metros sobre el nivel del mar) sobre cualquier otra respuesta.`,
  },
  {
    q: "¿Qué servicios especializados ofrecen los bomberos en la zona turística de Acapulco?",
    a: `Las estaciones de Acapulco están especializadas en <strong>rescate acuático</strong> en bahía y mar abierto, <strong>emergencias en hoteles</strong> de alta ocupación, coordinación con la Capitanía del Puerto para incidentes en embarcaciones de crucero, <strong>atención prehospitalaria bilingüe</strong> (español-inglés) para turistas internacionales, rescate vehicular en la Costera Miguel Alemán y <strong>HAZMAT básico</strong>. La estación del Aeropuerto Internacional General Juan N. Álvarez cuenta con servicio <strong>ARFF</strong> (Aircraft Rescue and Fire Fighting) para emergencias aeronáuticas.`,
  },
  {
    q: "¿Cómo trabajan los bomberos de Taxco en las calles estrechas del centro histórico?",
    a: `Taxco de Alarcón tiene calles empedradas con anchuras de 2.5 a 3.5 metros y pendientes de hasta 18%, imposibles para una autobomba estándar. La respuesta llega con <strong>autobombas compactas de menos de 2.2 m de ancho</strong> hasta la vialidad más cercana que lo permita, y de ahí a pie con mangueras de 1.5 pulgadas y extintores portátiles. La estación mantiene un inventario de los más de 1,200 talleres de platería activos en el centro histórico: ubicación de tanques de gas LP, puntos de cierre de válvula y contacto de emergencia, porque en un incendio nocturno en el laberinto de callejones, la información previa es la ventaja más importante.`,
  },
  {
    q: "¿Qué hacen los bomberos en Ixtapa-Zihuatanejo?",
    a: `Las dos estaciones de la Costa Grande —Zihuatanejo y la zona hotelera de Ixtapa— se especializan en <strong>rescate acuático en bahía</strong> (playas La Ropa, Las Gatas y El Palmar), emergencias en <strong>resorts todo incluido</strong> y en la <strong>Marina Ixtapa</strong>, atención prehospitalaria bilingüe para turismo internacional, control de fauna silvestre (cocodrilos en la zona lagunar) y emergencias en embarcaciones pesqueras. Ambas estaciones coordinan con los operadores turísticos y con la capitanía de puerto local.`,
  },
  {
    q: "¿Cómo prevenir incendios en hoteles y alojamientos en Acapulco y Guerrero?",
    a: `Los bomberos recomiendan: familiarizarse con las <strong>rutas de evacuación</strong> y la ubicación de los extintores al llegar al hotel; no bloquear puertas de emergencia ni cortocircuitar detectores de humo; ante una alarma, <strong>no usar el elevador</strong> y bajar por las escaleras cerrando puertas a tu paso. En zonas costeras, también localiza los <strong>puntos de reunión en zonas elevadas</strong> para el caso de alerta de tsunami. Si hay fuga de gas, no enciendas interruptores; abre ventanas, cierra la llave de paso y avisa al personal del hotel para que llamen al <strong>911</strong>.`,
  },
  {
    q: "¿Qué riesgos enfrentan los bomberos de la Montaña de Guerrero?",
    a: `La región Montaña —con Tlapa de Comonfort como centro— tiene comunidades indígenas Nahua, Mixteca y Tlapaneca dispersas en la Sierra Madre del Sur, a veces a más de una hora de la estación más cercana por carreteras de terracería. Los bomberos de Tlapa atienden <strong>incendios forestales</strong>, <strong>deslaves</strong> durante temporada de lluvias, emergencias prehospitalarias en zonas remotas y situaciones en comunidades con barreras de idioma. El equipamiento incluye vehículos 4x4 y ambulancias rurales; la coordinación con protección civil estatal y con las propias autoridades comunitarias es parte del protocolo habitual.`,
  },
  {
    q: "¿Cómo colaboran los bomberos de Guerrero con la industria hotelera en evacuaciones?",
    a: `Las estaciones de Acapulco coordinan de forma regular con los equipos de seguridad de más de 300 hoteles en la franja costera para actualizar <strong>planes de evacuación vertical</strong> por escaleras, mantener actualizado el registro de huéspedes con <strong>movilidad reducida</strong> que requieren asistencia prioritaria y definir puntos de reunión por encima de la cota de riesgo de tsunami. Esto es especialmente crítico en temporada alta, cuando la zona concentra decenas de miles de turistas simultáneos en una franja de 8 km de costa con pocas rutas de salida vehicular.`,
  },
];

