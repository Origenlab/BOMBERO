---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { estacionesSonora, getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-sonora";

// Generar rutas estaticas
export function getStaticPaths() {
  return estacionesSonora.map((estacion) => ({
    params: { slug: estacion.slug },
  }));
}

const { slug } = Astro.params;
const estacion = getEstacionBySlug(slug as string);

if (!estacion) {
  return Astro.redirect("/404");
}

// Obtener estaciones cercanas para el sidebar
const estacionesCercanas = getEstacionesCercanas(slug as string, 3);

// Datos del estado
const estado = {
  nombre: "Sonora",
  slug: "sonora",
  siglas: "SON",
  poblacion: "3.0 millones",
  municipios: 72,
};

// Estados vecinos para interlinking
const estadosVecinos = [
  { nombre: "Baja California", slug: "baja-california" },
  { nombre: "Chihuahua", slug: "chihuahua" },
  { nombre: "Sinaloa", slug: "sinaloa" },
  { nombre: "Baja California Sur", slug: "baja-california-sur" },
  { nombre: "Ciudad de Mexico", slug: "ciudad-de-mexico" },
];

// Variables para contenido personalizado
const ubicacion = estacion.municipio ?? estacion.ciudad ?? "Sonora";

// Tarjetas EPP para la seccion de equipo certificado
const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: `Traje Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Disenado para los bomberos de <strong>${ubicacion}</strong> que operan en condiciones extremas del desierto de Sonora. Certificacion NFPA para emergencias industriales en Ford, mineria y agricultura de exportacion.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: `Casco Estructural NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Certificacion NFPA 1971 para operaciones en <strong>Sonora</strong>. Resistencia a temperaturas extremas del desierto, compatible con emergencias en minas, plantas de Ford y la industria ganadera.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: `Guantes Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia termica certificada para emergencias mineras e industriales en <strong>${ubicacion}</strong>. Prension segura para operaciones en el Puerto de Guaymas y rescate en zonas deserticas.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: `Botas Estructurales NFPA 1971 para bomberos ${ubicacion}`,
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Calzado certificado NFPA 1971 para el exigente terreno de <strong>Sonora</strong>. Suela resistente para desierto, minas, plantas automotrices Ford y operaciones en el Puerto de Guaymas.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>

  <Fragment slot="seo-content">
    <h2>Bomberos en {ubicacion}, Sonora</h2>
    <p>
      La <strong>{estacion.nombreCorto ?? estacion.nombre}</strong> es parte del <strong>H. Cuerpo de Bomberos de {ubicacion}</strong>,
      institucion que protege a los mas de <strong>3 millones de sonorenses</strong>. Esta estacion, ubicada en
      <strong>{estacion.direccion}</strong>, brinda atencion las 24 horas del dia,
      los 365 dias del ano.
    </p>
    <p>
      En caso de <strong>emergencia en {ubicacion}</strong>, marca el <strong>911</strong> o comunicate directamente
      a esta estacion al <strong>{estacion.telefono}</strong>. Los bomberos de Sonora estan capacitados para atender
      incendios estructurales e industriales, emergencias mineras, rescates en desierto, incendios forestales
      y todo tipo de emergencias.
    </p>
    <h3>Sonora: Industria, Mineria y Desierto</h3>
    <p>
      <strong>Sonora</strong> es el estado mas grande del noroeste mexicano y uno de los mas industrializados.
      <strong>Hermosillo</strong> alberga la planta de <strong>Ford</strong> mas grande de Latinoamerica.
      El estado es lider nacional en <strong>mineria</strong> (cobre, oro, plata) y <strong>ganaderia</strong>.
      El <strong>Puerto de Guaymas</strong> es estrategico para la exportacion. El <strong>Desierto de Sonora</strong>
      presenta retos unicos de rescate en condiciones extremas de calor. Los bomberos enfrentan emergencias industriales,
      mineras y agricolas de alta complejidad.
    </p>
    <h3>Necesitas equipo certificado para bomberos?</h3>
    <p>
      En <strong><a href="/">BOMBERO.MX</a></strong> somos distribuidores autorizados de <strong>equipo para bomberos certificado NFPA</strong>.
      Equipamos estaciones en todo Sonora con <a href="/productos/trajes-para-bomberos/">trajes estructurales</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>, <a href="/productos/guantes-para-bomberos/">guantes</a>,
      <a href="/productos/botas-para-bomberos/">botas certificadas</a> y mas.
      <a href="/cotizar/">Solicita una cotizacion</a> sin compromiso.
    </p>
  </Fragment>
</EstacionLayout>
