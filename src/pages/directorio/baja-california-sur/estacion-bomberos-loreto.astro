---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california-sur";

const slug = "estacion-bomberos-loreto";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California Sur",
  slug: "baja-california-sur",
  siglas: "BCS",
  poblacion: "800 mil",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California", slug: "baja-california" },
  { nombre: "Sonora", slug: "sonora" },
  { nombre: "Sinaloa", slug: "sinaloa" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para incendios en misiones históricas y turismo ecológico en Loreto",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 32 elementos del Pueblo Mágico más antiguo de las Californias: incendios en estructuras coloniales del siglo XVII, rescate acuático en el Parque Nacional Bahía de Loreto —Patrimonio UNESCO— e intervención en islas remotas accesibles solo por mar.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para incendios en estructuras coloniales del siglo XVII en Loreto",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia certificada para operaciones en bóvedas de piedra y adobe de la Misión de Nuestra Señora de Loreto —fundada en 1697— y otras estructuras coloniales bajo protección INAH. El colapso de adobe húmedo en incendio tiene patrones distintos al concreto convencional.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate en islas del Mar de Cortés desde Loreto",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia mecánica para operaciones de rescate en roca volcánica de las islas Coronado, Carmen y Danzante, y compatibilidad con trajes de neopreno para buceo de rescate en aguas del Parque Nacional Bahía de Loreto con tiempos de respuesta de 30 a 60 minutos.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para terreno de isla volcánica en la Bahía de Loreto",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela de máximo agarre para roca basáltica y riolítica de las islas del Mar de Cortés, terreno de bajada de lanchas en litoral de canto rodado y pisos de piedra del Centro Histórico colonial de Loreto. Certificadas NFPA 1971 para el entorno más diverso geológicamente de BCS.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>Primera Capital de las Californias desde 1697 y Parque Nacional UNESCO: 32 Elementos para Rescate en 5 Islas Remotas, Protección de la Misión más Antigua del Pacífico y Turismo de Ballena Azul</h2>
    <p>
      La <strong>Estación de Bomberos de Loreto</strong>, ubicada en Calle Salvatierra s/n, Centro,
      protege el Pueblo Mágico más antiguo de todo el sistema de misiones de las Californias. Loreto
      fue fundada el 25 de octubre de 1697 con el establecimiento de la Misión de Nuestra Señora de
      Loreto por el padre jesuita Juan María de Salvatierra, y desde allí se organizó la exploración
      y evangelización de lo que hoy son los estados de California, Arizona y Nevada. Con 32 elementos
      activos, 5 unidades —incluyendo lancha de rescate para operaciones en islas y unidad forestal
      todoterreno— y tiempo de respuesta de 5 a 10 minutos en zona urbana, esta estación opera en el
      entorno natural protegido más valioso del estado.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Loreto?</h3>
    <p>
      Para emergencias en Loreto, Nopoló, Puerto Escondido, la Bahía o cualquier isla del Parque
      Nacional, marca el <strong>911</strong>. El despacho coordina esta estación con la Armada de
      México y CONANP para incidentes en las islas del parque. Contacto directo: 613 135 0059.
      Los tiempos de respuesta en islas son de 30 a 60 minutos según condiciones del mar.
    </p>

    <h3>Parque Nacional Bahía de Loreto: Patrimonio Natural UNESCO con 5 Islas</h3>
    <p>
      El Parque Nacional Bahía de Loreto protege más de 206,000 hectáreas de mar y 5 islas —Coronado,
      Carmen, Danzante, Monserrate y Santa Catalina— que son parte del Patrimonio Natural de la
      Humanidad. Miles de turistas visitan el parque cada año para kayak de travesía, buceo, snorkel
      y avistamiento de ballena azul —el animal más grande que ha existido en el planeta. Un accidente
      en una isla a 20 km de la costa exige que la lancha de rescate haga una travesía de 30 a 45
      minutos antes de llegar al punto del incidente.
    </p>

    <h3>Misión de Nuestra Señora de Loreto: La Estructura Colonial más Antigua de California</h3>
    <p>
      La Misión de Nuestra Señora de Loreto, construida a partir de 1697 en piedra y adobe, es la
      construcción más antigua que sigue en uso de todo el sistema de misiones de California. Un
      incendio en esta estructura —o en las viviendas coloniales del Centro Histórico adyacentes—
      significaría la pérdida irreparable de patrimonio de 325 años de antigüedad. El personal de
      esta estación conoce las características estructurales del adobe mojado y las técnicas de
      combate que minimizan el daño al patrimonio construido.
    </p>

    <h3>Sierra de la Giganta: Incendios Forestales en el Corazón de la Península</h3>
    <p>
      La Sierra de la Giganta, que se eleva abruptamente del Mar de Cortés a más de 1,500 metros
      de altitud en algunos puntos, forma el telón de fondo natural de Loreto. Los incendios forestales
      en esta sierra —con vegetación de palo blanco, torote y palmilla— pueden verse desde la ciudad
      y representan un riesgo de expansión hacia zonas habitadas en condiciones de viento seco.
      La unidad forestal todoterreno es la primera respuesta antes de que la CONAFOR pueda movilizar
      recursos adicionales. Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
