---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california-sur";

const slug = "estacion-bomberos-santa-rosalia";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California Sur",
  slug: "baja-california-sur",
  siglas: "BCS",
  poblacion: "800 mil",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California", slug: "baja-california" },
  { nombre: "Sonora", slug: "sonora" },
  { nombre: "Sinaloa", slug: "sinaloa" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para incendios en arquitectura de madera francesa de Santa Rosalía",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 24 elementos que protegen la arquitectura de madera prefabricada francesa más única de México: galerones del siglo XIX diseñados en Francia y ensamblados en el desierto de BCS. El fuego en madera centenaria con aceite de linaza y barnices históricos genera humos distintos a la madera de construcción moderna.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para incendios en edificios históricos de madera en Santa Rosalía",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia certificada para operaciones en estructuras de madera prefabricada del siglo XIX, cuyo comportamiento en incendio es distinto al de la madera contemporánea: mayor densidad, envejecimiento de uniones y resinas históricas que aceleran la propagación del fuego.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para emergencias en el ferry Santa Rosalía-Guaymas",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia mecánica y térmica para emergencias en las instalaciones del ferry Guaymas-Santa Rosalía: incendios en cubierta de vehículos, emergencias médicas masivas en travesía y rescate en muelle de acero durante maniobras de atraque.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para terreno de mina y puerto en Santa Rosalía",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para pisos de madera mojada en casas históricas, superficie de acero de muelle del ferry y terreno de escoria volcánica de la zona minera El Boleo. Certificadas NFPA 1971 para el entorno más heterogéneo de operación en el estado.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>La Ciudad de Madera Diseñada por Gustave Eiffel y el Ferry que Conecta la Península con el Continente: 24 Elementos para Patrimonio Arquitectónico del Siglo XIX y Emergencias Portuarias en el Mar de Cortés</h2>
    <p>
      La <strong>Estación de Bomberos de Santa Rosalía</strong>, ubicada en Calle Constitución s/n,
      Mesa México, protege la ciudad más singular de Baja California Sur: un pueblo minero fundado en
      1885 por la Compagnie du Boleo francesa, con arquitectura de madera prefabricada traída desde
      Europa y ensamblada en el desierto del Mar de Cortés. Con 24 elementos activos, 4 unidades y
      tiempo de respuesta de 5 a 10 minutos, esta es la estación con el patrimonio arquitectónico más
      vulnerable del estado: si arde un edificio histórico de Santa Rosalía, no hay forma de reponerlo.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Santa Rosalía?</h3>
    <p>
      Para emergencias en Santa Rosalía Centro, Mesa México, Mesa Francia, el Puerto de Ferry o la zona
      minera El Boleo, marca el <strong>911</strong>. El despacho coordina con la Capitanía de Puerto en
      incidentes en el ferry o embarcaciones en el muelle. Contacto directo: 615 152 0050. El tiempo de
      respuesta de 5 a 10 minutos cubre el núcleo urbano histórico.
    </p>

    <h3>Arquitectura de Madera Francesa del Siglo XIX: El Mayor Riesgo Patrimonial de BCS</h3>
    <p>
      Los edificios de Santa Rosalía fueron diseñados en Francia, prefabricados en talleres parisinos y
      ensamblados en Baja California entre 1885 y 1910. Las casas de Mesa Francia —con techos de lámina
      de zinc acanalada y paredes de madera de guayacán y pino blanco europeo— son únicas en todo México.
      La madera centenaria, con más de 130 años de resecamiento en el clima desértico del Mar de Cortés,
      tiene un contenido de humedad casi nulo que la hace extraordinariamente inflamable. Un incendio
      en este barrio puede propagarse de edificio en edificio en minutos por el callejeo estrecho del
      diseño urbanístico francés.
    </p>

    <h3>Iglesia de Santa Bárbara: Diseñada por Gustave Eiffel, Exhibida en París en 1889</h3>
    <p>
      La iglesia de Santa Bárbara de Santa Rosalía fue diseñada por el taller de Gustave Eiffel —el
      mismo ingeniero que construyó la Torre Eiffel— y fue exhibida en la Exposición Universal de París
      de 1889 como ejemplo de construcción prefabricada de metal y vidrio. Fue transportada por barco
      y ensamblada en Santa Rosalía en 1897. Esta estructura de hierro fundado y vidrio de colores es
      Monumento Histórico Nacional y la joya arquitectónica que la estación protege con mayor cuidado.
    </p>

    <h3>Ferry Guaymas-Santa Rosalía: Punto de Cruce Peninsular con Emergencias Marítimas</h3>
    <p>
      El ferry que conecta Santa Rosalía con Guaymas, Sonora, es el único cruce marítimo civil en el
      interior del Mar de Cortés. Una emergencia a bordo —incendio en cubierta de vehículos, fallo
      estructural o incidente médico masivo en travesía— activa la coordinación con la Armada de México
      y la Capitanía de Puerto para rescate en mar abierto. La lancha de rescate de la estación opera
      exclusivamente en la zona del muelle y bahía inmediata. En
      Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
