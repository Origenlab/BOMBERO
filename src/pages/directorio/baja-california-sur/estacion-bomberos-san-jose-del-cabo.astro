---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-baja-california-sur";

const slug = "estacion-bomberos-san-jose-del-cabo";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Baja California Sur",
  slug: "baja-california-sur",
  siglas: "BCS",
  poblacion: "800 mil",
  municipios: 5,
};

const estadosVecinos = [
  { nombre: "Baja California", slug: "baja-california" },
  { nombre: "Sonora", slug: "sonora" },
  { nombre: "Sinaloa", slug: "sinaloa" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para emergencias en hoteles de lujo de San José del Cabo",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 55 elementos que protegen la infraestructura hotelera más valiosa del Pacífico mexicano: incendios en resorts Four Seasons, One&Only, St. Regis y Ritz-Carlton, emergencias en 15+ campos de golf de clase mundial y rescate en el Estero de San José, reserva ecológica de manglar.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para incendios en hoteles de Los Cabos",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia certificada para operaciones en estructuras de hoteles de gran altura frente al mar, donde los colapsos de techos de palma y las estructuras de madera tropical en incendio de resort generan riesgos distintos a la construcción convencional urbana.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate en el Estero de San José",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia mecánica para rescate en el Estero de San José —manglar con raíces entrelazadas y fondo lodoso— y compatibilidad con motos de agua para rescate acuático en la playa de San José del Cabo con rompiente moderada.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para operaciones en resorts y campos de golf de Los Cabos",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para pisos húmedos de lobby de hotel, terrazas de resort frente al mar y terreno de campo de golf con riego permanente. Certificadas NFPA 1971 para el perfil de emergencias de la zona más exclusiva del turismo mexicano.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>55 Elementos en el Corazón Cultural de Los Cabos: Resorts Four Seasons y St. Regis, Estero UNESCO, 15+ Campos de Golf y Evacuación de 30,000 Turistas en Huracán Odile</h2>
    <p>
      La <strong>Estación de Bomberos de San José del Cabo</strong>, ubicada en Blvd. Antonio Mijares s/n,
      Centro, protege el polo cultural del destino turístico de mayor valor económico de Baja California Sur.
      San José del Cabo combina un centro histórico con misión jesuita de 1730, galerías de arte de clase
      internacional, restaurantes gourmet con ingredientes del Mar de Cortés y una zona hotelera con resorts
      de las cadenas más exclusivas del mundo. Con 55 elementos activos, 4 unidades y tiempo de respuesta
      de 5 a 10 minutos, esta estación tiene el perfil de emergencias más diversificado del municipio de
      Los Cabos.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de San José del Cabo?</h3>
    <p>
      Para emergencias en el Centro Histórico, Zona Hotelera Fonatur, Estero de San José, Puerto Los Cabos
      o cualquier campo de golf del corredor, marca el <strong>911</strong>. El despacho coordina esta
      estación con la de Cabo San Lucas para incidentes que requieren refuerzos en el corredor turístico.
      Contacto directo: 624 142 2466. El personal habla español e inglés para atención a turistas
      internacionales.
    </p>

    <h3>Resorts de Ultra Lujo: Protección de Infraestructura Valuada en Miles de Millones</h3>
    <p>
      La zona hotelera de San José del Cabo concentra propiedades de Four Seasons, One&Only, St. Regis,
      Ritz-Carlton y otras cadenas cuya inversión combinada supera los 3,000 millones de dólares. Un
      incendio en un resort de gran altura con 400-600 habitaciones en ocupación máxima —con huéspedes
      en diferentes idiomas, sin conocimiento de las rutas de evacuación— es el escenario de mayor
      complejidad para esta estación. Los planes de evacuación de cada hotel están integrados con los
      protocolos de respuesta del cuerpo de bomberos.
    </p>

    <h3>Estero de San José: Reserva Ecológica con Rescates de Alta Complejidad</h3>
    <p>
      El Estero de San José es una reserva ecológica con más de 200 especies de aves y un manglar que
      separa la playa del desarrollo hotelero. Los accidentes de kayak y los turistas que se adentran
      en el manglar en zonas no habilitadas generan rescates técnicamente complejos: el fondo lodoso,
      las raíces entrelazadas de mangle y la escasa visibilidad en el interior de la vegetación hacen
      de esta zona uno de los entornos de rescate más exigentes de la costa de Los Cabos.
    </p>

    <h3>Huracán Odile 2014: Coordinación de la Evacuación de 30,000 Turistas</h3>
    <p>
      Cuando el huracán Odile tocó tierra en Los Cabos el 14 de septiembre de 2014, más de 30,000
      turistas se encontraban en la zona hotelera. La estación coordinó junto con autoridades federales
      y hoteleros la evacuación de huéspedes, la habilitación de hoteles como refugios de emergencia
      y la atención prehospitalaria en condiciones de colapso de energía eléctrica y comunicaciones.
      Esa experiencia reforzó los planes de contingencia de huracán que se actualizan cada año. En
      <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
