const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ─── FAQs únicas de Tamaulipas (≥10) ─────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Tamaulipas?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas en todo el estado. Para contacto directo: Bomberos Reynosa (899 922 0500), Bomberos Tampico (833 212 1515) y Bomberos Nuevo Laredo (867 712 8600). En emergencias industriales en el Puerto de Altamira o la Cuenca de Burgos, la coordinación con las brigadas internas de PEMEX y las plantas es parte del protocolo desde el primer aviso al 911.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de Tampico?",
    a: `El Heroico Cuerpo de Bomberos de Tampico fue fundado el <strong>30 de marzo de 1903</strong>, cuando el presidente municipal Amado Nicasio Jáuregui se reunió con los primeros fundadores en el teatro "Apolo". Es el <strong>tercer cuerpo de bomberos fundado en México</strong>, después del de Veracruz (22 de agosto de 1873) y el de la Ciudad de México (1887). La primera estación lleva el nombre de Antonio Cervantes Guajardo, bombero fallecido en acto de servicio.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de Nuevo Laredo?",
    a: `El Heroico Cuerpo de Bomberos de Nuevo Laredo fue fundado en <strong>1926</strong> por un grupo de ciudadanos encabezados por Isaac Echeverría, Heriberto Deándar Amador, Pedro de León y otros vecinos, entre ellos taxistas y electricistas. La primera estación se instaló en la esquina de Belden y Matamoros. En 2026, la corporación celebra su <strong>centenario</strong>.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque conmemora la fundación del <strong>primer cuerpo de bomberos de México</strong>, el 22 de agosto de 1873 en el puerto de Veracruz. En Tamaulipas, el Heroico Cuerpo de Bomberos de Tampico (1903) es uno de los más antiguos del país, fundado apenas 30 años después de esa fecha histórica.`,
  },
  {
    q: "¿Qué riesgos HAZMAT existen en el Puerto Industrial de Altamira?",
    a: `El Puerto Industrial de Altamira alberga la <strong>mayor planta química privada de México</strong> (BASF), además de Celanese (ácido acético y acetato de vinilo), Vitro (sosa cáustica), Braskem y decenas de plantas petroquímicas. El ácido acético —miscible en agua— no puede contenerse con barreras flotantes y requiere dilución masiva o neutralización con carbonato de sodio. Las brigadas de Altamira operan en coordinación directa con las brigadas internas de cada planta.`,
  },
  {
    q: "¿Qué es la Cuenca de Burgos y por qué representa un riesgo especial para los bomberos?",
    a: `La Cuenca de Burgos, bajo el norte de Tamaulipas, es la <strong>mayor reserva de gas natural no asociado de México</strong>, con cientos de pozos, compresoras y gasoductos de PEMEX. A diferencia de una refinería, los riesgos en campo abierto incluyen fugas de H₂S (sulfuro de hidrógeno) sin perímetro fijo: a 500 ppm es inmediatamente peligroso para la vida. Las brigadas HAZMAT de Reynosa cuentan con detectores de H₂S de lectura continua y protocolos de posicionamiento dinámico según la dirección del viento.`,
  },
  {
    q: "¿Cómo funciona la coordinación binacional entre los bomberos de Nuevo Laredo y Texas?",
    a: `Nuevo Laredo mantiene protocolos de ayuda mutua con el <strong>Laredo Fire Department</strong> de Texas, que pueden activar refuerzo desde el lado estadounidense en 10 a 15 minutos. En los cinco puentes internacionales, ante un accidente con HAZMAT en tránsito, se activa zona de exclusión de 100 metros, coordinación simultánea con bomberos de ambos lados de la frontera, y acceso inmediato de aduana sin trámite consular durante la emergencia activa.`,
  },
  {
    q: "¿Qué porcentaje del comercio México-EE.UU. pasa por Nuevo Laredo?",
    a: `Por el <strong>Puente Mundial del Comercio</strong> (World Trade Bridge) de Nuevo Laredo cruza alrededor del <strong>40% del comercio terrestre entre México y Estados Unidos</strong>. El intercambio comercial registra operaciones por más de 200 mil millones de dólares anuales. Este flujo incluye miles de tractocamiones diarios con cargas bajo cientos de clasificaciones UN/DOT de materiales peligrosos, lo que convierte cada accidente de tránsito en un posible incidente HAZMAT de clasificación desconocida hasta que se lee la placa o el manifiesto.`,
  },
  {
    q: "¿Cuáles han sido los huracanes más destructivos en Tamaulipas?",
    a: `Tamaulipas es uno de los estados con mayor historial de impactos ciclónicos del Golfo de México. El <strong>huracán Beulah (septiembre de 1967)</strong>, categoría 5, tocó tierra en Matamoros con vientos de hasta 218 km/h y causó daños superiores a 500 millones de dólares. El <strong>huracán Gilberto (septiembre de 1988)</strong> impactó con vientos máximos de 215 km/h. En 1933, el huracán Cuba-Brownsville devastó Matamoros. La zona costera de Tampico y el delta del Pánuco son las áreas más expuestas a marejadas ciclónicas.`,
  },
  {
    q: "¿Qué industria maquiladora existe en Matamoros y cuáles son sus riesgos?",
    a: `Matamoros alberga <strong>más de 100 empresas maquiladoras</strong>, de las cuales entre 40 y 50 pertenecen a la industria automotriz y electrónica (Aptiv/Delphi, Continental, proveedores Tier-1). Los riesgos industriales incluyen isocianatos, solventes y materiales inflamables propios del sector. Ante un incidente que supere la capacidad local, los acuerdos de ayuda mutua con los bomberos del condado de Cameron y Brownsville, Texas, pueden activar refuerzo a escasos kilómetros del Río Bravo.`,
  },
  {
    q: "¿Qué debo hacer si detecto una fuga de gas industrial en Tamaulipas?",
    a: `Llama de inmediato al <strong>911</strong>. No acciones ningún interruptor eléctrico, no enciendas vehículos y evacúa en dirección perpendicular o contraria al viento. Si estás cerca de instalaciones de PEMEX o una planta del Puerto de Altamira, aleja a todas las personas al menos 300 metros y espera las instrucciones de los bomberos. En zonas rurales de la Cuenca de Burgos, aléjate del pozo o gasoducto en dirección contraria al viento y llama inmediatamente al 911.`,
  },
  {
    q: "¿Cómo se atienden las emergencias de rescate acuático en Tamaulipas?",
    a: `El Río Bravo (Río Grande) en la frontera con Texas es el principal escenario de rescate acuático en Reynosa y Nuevo Laredo; las brigadas cuentan con lanchas y equipo de aguas rápidas (swift water). En Tampico y Ciudad Madero, el rescate se realiza en el río Pánuco y la zona estuarina. Durante la temporada de huracanes (junio-noviembre), las inundaciones en municipios costeros como Soto la Marina y San Fernando activan protocolos de rescate coordinados con Protección Civil estatal.`,
  },
];
---

<DirectorioEstadoLayout
  heroDesc={`El <strong>Heroico Cuerpo de Bomberos de Tamaulipas</strong> —con el de Tampico entre los tres más antiguos del país, fundado el 30 de marzo de 1903, y el de Nuevo Laredo celebrando su <strong>centenario en 2026</strong>— opera en el estado con el mayor flujo de materiales peligrosos en tránsito de México. Con <strong>${estacionesTamaulipas.length} estaciones</strong> en este directorio, protege a más de <strong>3.5 millones de tamaulipecos</strong> a lo largo de ~500 km de frontera con Texas, la <strong>Cuenca de Burgos</strong> (mayor reserva de gas natural no asociado del país), el <strong>Puerto Industrial de Altamira</strong> con BASF y Celanese, y la <strong>Refinería Francisco I. Madero</strong> en Ciudad Madero.`}
  heroImage="/images/directorio/estacion-bomberos-norte-mexico-01.avif"
  heroImageAlt="Estación de Bomberos en Tamaulipas — frontera norte, HAZMAT industrial y rescate fluvial"
  heroCaption="H. Cuerpo de Bomberos · Tamaulipas · Centenario Nuevo Laredo 2026"
  title={`Bomberos en ${estado} — Directorio`}
  description={`Bomberos Tamaulipas: ${estacionesTamaulipas.length} estaciones en Reynosa, Tampico, Nuevo Laredo y Matamoros. HAZMAT Cuenca de Burgos, Refinería Madero y Puerto Altamira. Emergencias: 911.`}
  keywords={keywords}
  canonical={canonical}
  estado={estado}
  sigla={sigla}
  slug={slug}
  totalEstaciones={estacionesTamaulipas.length}
  totalMunicipios={getMunicipios().length}
  habitantes="3.5M+"
  heroThumbs={heroThumbs}
  galleryImages={galleryImages}
  emergencyNumbers={emergencyNumbers}
  regiones={regiones}
  eppCards={eppCards}
  estaciones={estacionesTamaulipas}
  stationImages={stationImages}
  municipios={municipios}
  estadosVecinos={estadosVecinos}
  jsonLd={jsonLd}
  faqsEstado={faqsEstado}
  ctaTitle="Equipamos a los Cuerpos de Bomberos de Tamaulipas"
  ctaDesc={`Cotiza equipo certificado NFPA para las estaciones de bomberos de Tamaulipas: HAZMAT para Cuenca de Burgos y Puerto Altamira, rescate fluvial para Río Bravo y Pánuco, y EPP estructural para los cinco puentes internacionales de Nuevo Laredo. Atención a licitaciones municipales y estatales.`}
  ctaBtnText="Solicitar Cotización — Tamaulipas"
>

  <Fragment slot="seo">

    <h2>Bomberos en Tamaulipas</h2>

    <div class="de-statband" role="list" aria-label="Indicadores del cuerpo de bomberos de Tamaulipas">
