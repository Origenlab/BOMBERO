  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Tamaulipas",
  "description": `Directorio verificado de estaciones de bomberos en Tamaulipas: Reynosa, Matamoros, Nuevo Laredo, Tampico, Ciudad Victoria. HAZMAT industrial en Puerto Altamira y Cuenca de Burgos. Emergencias 911.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de Tamaulipas" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/tamaulipas.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
