  description={`Directorio oficial de las ${estacionesTamaulipas.length} estaciones de bomberos en Tamaulipas. Reynosa, Matamoros, Nuevo Laredo, Tampico, Altamira. PEMEX Cuenca de Burgos, maquiladora automotriz, Puerto Industrial y el mayor puerto terrestre de las Américas. Emergencias 911.`}
  keywords={keywords}
  canonical={`https://bombero.mx/directorio/${slug}`}
  estado={estado}
  sigla={sigla}
  slug={slug}
  totalEstaciones={estacionesTamaulipas.length}
  totalMunicipios={getMunicipios().length}
