---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesQueretaro, getMunicipios } from "@data/estaciones-queretaro";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

// Configuración del estado
const estado = "Querétaro";
const sigla = "QRO";
const slug = "queretaro";
const canonical = "https://bombero.mx/directorio/queretaro/";

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const municipios      = getMunicipios();
const totalEstaciones = estacionesQueretaro.length;
const totalMunicipios = municipios.length;

// Miniaturas hero
const heroThumbs = [
  { src: "/images/directorio/central-despacho-bomberos-monitores-mapa-01.avif", alt: "Central de despacho de emergencias de bomberos de Querétaro con monitores", label: "Central de Despacho" },
  { src: "/images/directorio/estacion-bomberos-queretaro-01.avif",              alt: "Centro Histórico de Querétaro Acueducto UNESCO 1996",                     label: "UNESCO 1996"        },
  { src: "/images/directorio/rescate-montana-bomberos-01.avif",                 alt: "Peña de Bernal tercer monolito más grande del mundo",                     label: "Peña de Bernal"    },
];

// Galería de imágenes
const galleryImages = [
  { src: "/images/directorio/estacion-bomberos-bahia-ventanal-01.avif",    alt: "Bahía de bomberos de Querétaro con ventanal panorámico",                label: "Instalaciones Modernas" },
  { src: "/images/directorio/estacion-bomberos-selva-01.avif",             alt: "Misiones Franciscanas Sierra Gorda UNESCO 2003",                        label: "Misiones UNESCO"        },
  { src: "/images/directorio/estacion-bomberos-moderna-01.avif",           alt: "Campus UNAM Juriquilla parques tecnológicos Querétaro",                 label: "Silicon Valley MX"      },
  { src: "/images/directorio/bomberos-profesionales-accion-01.avif",       alt: "Festival Internacional del Globo Tequisquiapan Querétaro",              label: "Festival del Globo"     },
];

// Números de emergencia Querétaro
const emergencyNumbers = [
  { number: "911",            label: "Emergencias"         },
  { number: "(442) 212-3939", label: "Central Querétaro"   },
  { number: "(442) 221-7800", label: "HAZMAT Industrial"   },
  { number: "(427) 272-0066", label: "San Juan del Río"    },
];

// Regiones de Querétaro
const regiones = [
  { nombre: "Centro Histórico UNESCO",    desc: "Santiago de Querétaro, Acueducto 74 arcos, templos barrocos (UNESCO 1996)" },
  { nombre: "Zona Aeroespacial Norte",    desc: "Bombardier, Safran, ITP Aero, Airbus — 200+ empresas, HAZMAT 24/7"         },
  { nombre: "Ruta del Vino y Queso",      desc: "Tequisquiapan, Bernal (Peña 350 m), Ezequiel Montes — 35 viñedos"          },
  { nombre: "Sierra Gorda",               desc: "Jalpan Pueblo Mágico, Misiones UNESCO 2003, Reserva Biósfera 383,567 ha"   },
];

// Tarjetas de equipamiento EPP
const eppCards = [
  {
    image:     "/images/directorio/traje-hazmat-nivel-a-01.avif",
    imageAlt:  "Traje HAZMAT para industria aeroespacial en Querétaro",
    badge:     "Aeroespacial",
    title:     "HAZMAT Nivel A Aeroespacial",
    text:      "Trajes encapsulados para emergencias en <strong>Bombardier, Safran y parque aeroespacial</strong>. Protección contra fluidos hidráulicos, resinas epóxicas y combustibles de aviación.",
    href:      "/productos/trajes-para-bomberos/traje-hazmat/",
    linkLabel: "Ver Equipos HAZMAT",
  },
  {
    image:     "/images/directorio/equipo-rescate-vertical-01.avif",
    imageAlt:  "Equipo de rescate vertical para Peña de Bernal Querétaro",
    badge:     "Rescate",
    title:     "Rescate Peña de Bernal",
    text:      "Sistemas de rescate vertical y cuerdas técnicas para emergencias en la <strong>Peña de Bernal</strong> y Sierra Gorda. Arneses y dispositivos de descenso certificados NFPA.",
    href:      "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Equipo de Rescate",
  },
  {
    image:     "/images/directorio/equipo-bomberos-rescate-vehicular-01.avif",
    imageAlt:  "Equipo de rescate vehicular para autopista 57D Querétaro",
    badge:     "Carretero",
    title:     "Rescate Autopista 57D",
    text:      "Herramientas hidráulicas para extricación en la <strong>autopista 57D México-Querétaro</strong> y periférico. Spreaders y cutters para vehículos pesados.",
    href:      "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Herramientas de Rescate",
  },
  {
    image:     "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt:  "Casco estructural para bomberos de Querétaro",
    badge:     "NFPA 1970",
    title:     "Cascos NFPA Certificados",
    text:      "Cascos estructurales para emergencias en <strong>zona industrial El Marqués y Juriquilla</strong>. Protección térmica avanzada con visor y sistema de comunicación integrado.",
    href:      "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
];

// ── Comparativa regional (4 zonas clave del estado) ─────────────────────────
const zonas = [
  {
    nombre:    "Centro Histórico y Capital",
    municipios: ["Santiago de Querétaro", "Corregidora", "Juriquilla"],
    cobertura: "Total",
    chip:      "total",
    perfil:    "Centro Histórico (UNESCO 1996), acueducto de 74 arcos, crecimiento urbano acelerado.",
  },
  {
    nombre:    "Zona Industrial Norte",
    municipios: ["El Marqués", "Parque Aeroespacial", "Aeropuerto QRO"],
    cobertura: "Alta",
    chip:      "alta",
    perfil:    "Clúster aeroespacial (Bombardier, Safran, ITP Aero), HAZMAT Nivel A, SSEI Cat. 8.",
  },
  {
    nombre:    "Zona Industrial Sur",
    municipios: ["San Juan del Río", "Pedro Escobedo"],
    cobertura: "Alta",
    chip:      "alta",
    perfil:    "Mabe, Kellogg's, Tremec, Brembo — 22,000+ empleos, rescate carretero 57D.",
  },
  {
    nombre:    "Sierra Gorda y Ruta del Vino",
    municipios: ["Jalpan de Serra", "Tequisquiapan", "Bernal"],
    cobertura: "Media",
    chip:      "media",
    perfil:    "Misiones UNESCO 2003, incendios forestales, rescate vertical Peña de Bernal.",
  },
];

// ── Schemas estructurados ────────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio de ${totalEstaciones} estaciones de bomberos en Querétaro. Hub aeroespacial n.º 1 de México con HAZMAT especializado. 2 sitios UNESCO (Centro Histórico 1996, Misiones 2003). 4 Pueblos Mágicos. Cuerpo fundado en 1949. Emergencias: 911.`,
  numberOfItems: totalEstaciones,
  itemListElement: estacionesQueretaro.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipiosCubiertos?.[0] || estado,
        addressRegion: estado,
        addressCountry: "MX",
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}`,
    },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Bomberos en Querétaro: estaciones, historia y servicios de emergencia",
  description: "Guía del H. Cuerpo de Bomberos Voluntarios de Querétaro: historia (1949–hoy), infraestructura, HAZMAT aeroespacial, Sierra Gorda, Peña de Bernal y directorio de estaciones con teléfonos directos.",
  about: [
    "H. Cuerpo de Bomberos Voluntarios de Querétaro",
    "Protección Civil Querétaro",
    "HAZMAT aeroespacial",
    "Rescate en montaña Sierra Gorda",
  ],
  inLanguage: "es-MX",
  image: `https://bombero.mx/api/og/estado/${slug}.svg`,
  author:    { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  publisher: { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  dateModified: DIRECTORIO_VERIFICADO_ISO,
  mainEntityOfPage: canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  url: canonical,
  name: `Estaciones de Bomberos en ${estado}`,
  description: `Directorio verificado de ${totalEstaciones} estaciones de bomberos en Querétaro, con teléfonos, cobertura, funciones e historia del H. Cuerpo de Bomberos Voluntarios fundado en 1949.`,
  inLanguage: "es-MX",
  isPartOf: { "@type": "WebSite", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  about: { "@type": "GovernmentOrganization", name: "H. Cuerpo de Bomberos Voluntarios de Querétaro" },
  primaryImageOfPage: `https://bombero.mx/api/og/estado/${slug}.svg`,
  dateModified: DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Querétaro (≥10) ────────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Querétaro?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas en todo el estado. La Central del H. Cuerpo de Bomberos de Querétaro también atiende en <strong>(442) 212-3939</strong>. Para emergencias industriales en la zona aeroespacial de El Marqués: <strong>(442) 221-7800</strong>. En San Juan del Río: <strong>(427) 272-0066</strong>. En zonas con señal reducida de la Sierra Gorda, la coordinación pasa por radio y protección civil estatal.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de Querétaro?",
    a: `El <strong>30 de agosto de 1949</strong> se firmó el acta constitutiva de <em>Previsión y Protección, S.C.</em>, organización civil que impulsó la creación del cuerpo. El <strong>30 de noviembre de 1949</strong> el H. Cuerpo de Bomberos Voluntarios de Querétaro entró formalmente en acción. La primera estación se ubicó en la calle Guerrero, en un antiguo cuartel del ejército, con tres unidades: una jeep Willis 1947, un carro tanque Chevrolet 1942 y una American La France 1958. La estación actual de la calle Zaragoza esquina Ocampo fue inaugurada el <strong>17 de mayo de 1963</strong>.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque conmemora la fundación del <strong>primer cuerpo de bomberos del país</strong>, el 22 de agosto de 1873 en el puerto de Veracruz. Cada año, en esa fecha, se reconoce la labor de los bomberos de toda la República, incluidos los del H. Cuerpo de Bomberos Voluntarios de Querétaro, fundado 76 años después.`,
  },
  {
    q: "¿Los bomberos de Querétaro tienen capacidad HAZMAT para la industria aeroespacial?",
    a: `Sí. La estación HAZMAT de El Marqués y la del Parque Aeroespacial cuentan con capacidad <strong>Nivel A</strong> para atender emergencias en las plantas de <strong>Bombardier, Safran, ITP Aero y las 200+ empresas</strong> del clúster aeroespacial. El protocolo incluye trajes encapsulados, aspiradores HEPA para fibra de carbono conductora, detectores de gases especializados y zona de descontaminación activa de 60 a 90 minutos posteriores al cierre del siniestro.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Querétaro?",
    a: `Combate de <strong>incendios</strong> estructurales, forestales y de pastizal; <strong>rescate vehicular</strong> y extricación en autopistas; <strong>atención prehospitalaria</strong>; <strong>búsqueda y rescate en altura</strong> (Peña de Bernal y Sierra Gorda); <strong>materiales peligrosos (HAZMAT)</strong> industriales y en tránsito; <strong>incendios forestales</strong> en la Reserva de la Biósfera; control de <strong>fugas de gas</strong>; <strong>rescate y extinción aeronáutica (SSEI)</strong> en el Aeropuerto Internacional; y prevención (inspecciones, simulacros y capacitación ciudadana).`,
  },
  {
    q: "¿Hay bomberos especializados para rescate en la Peña de Bernal?",
    a: `Sí. La estación de Bernal–Ezequiel Montes cuenta con equipo y personal certificado en <strong>rescate vertical</strong> para la Peña de Bernal (350 m de altura sobre la planicie), el tercer monolito más grande del mundo. Durante el equinoccio de primavera (tercera semana de marzo), cuando pueden concentrarse hasta <strong>500,000 visitantes en dos días</strong>, se implementa un pre-posicionamiento de unidad de rescate en el acceso noreste del monolito y coordinación de helipuerto provisional.`,
  },
  {
    q: "¿Los bomberos cubren la Sierra Gorda y sus misiones UNESCO?",
    a: `Sí. La estación de Jalpan de Serra cubre la <strong>Reserva de la Biósfera Sierra Gorda</strong> (383,567 hectáreas) y las cinco <strong>Misiones Franciscanas</strong> declaradas Patrimonio UNESCO en 2003 (Jalpan, Tilaco, Tancoyol, Landa y Concá). Trabajan con vehículo 4x4 ligero, coordinación con las brigadas de Pronatura Sierra Gorda para incendio forestal y el criterio INAH de no usar agua directa a presión sobre relieves polícromos de cantera.`,
  },
  {
    q: "¿Los bomberos atienden emergencias en la autopista México-Querétaro 57D?",
    a: `Sí. Las estaciones de San Juan del Río y la estación carretera 57D cuentan con <strong>rescate vehicular pesado</strong> y unidades HAZMAT para tránsito. La autopista registra más de 100,000 vehículos diarios y es uno de los corredores de mayor riesgo del país por la combinación de volumen de tráfico, materiales peligrosos en tránsito y zonas de curvas pronunciadas en la bajada de Palmillas.`,
  },
  {
    q: "¿Qué cobertura tienen los bomberos en el Centro Histórico UNESCO de Querétaro?",
    a: `La Estación Central cubre todo el <strong>Centro Histórico de Santiago de Querétaro</strong>, declarado Patrimonio de la Humanidad UNESCO en 1996. El protocolo de intervención en patrimonio impide el uso de agua directa a alta presión sobre el <strong>Acueducto de 74 arcos</strong> y los relieves de cantera de los templos barrocos. El equipo estructural de la estación incluye una escalera telescópica de 42 m para alcanzar cúpulas y torres en caso de incendio.`,
  },
  {
    q: "¿Cómo opera el SSEI del Aeropuerto Internacional de Querétaro?",
    a: `El Aeropuerto Internacional de Querétaro (QRO) cuenta con un <strong>Servicio de Salvamento y Extinción de Incendios (SSEI) Categoría 8 OACI</strong>, con capacidad para atender aeronaves de fuselaje ancho (A320, B737) con tiempo máximo de respuesta de <strong>3 minutos</strong> a cualquier punto de pista. Los hangares MRO adyacentes presentan riesgo combinado de materiales compuestos (fibra de carbono) y combustible Jet-A.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en Querétaro?",
    a: `Revisa periódicamente instalaciones de <strong>gas y electricidad</strong>; evita sobrecargar contactos. Instala <strong>detectores de humo</strong> y mantén un extintor vigente. En zonas industriales o de la <strong>Ruta del Vino y Queso</strong>, respeta las restricciones de fogatas en temporada de estiaje (noviembre–mayo). En la Sierra Gorda, no inicies fuego en zonas de matorral en época seca. Define un <strong>plan de evacuación</strong> familiar y ten el <strong>911</strong> visible y accesible para todos.`,
  },
  {
    q: "¿Los servicios de los bomberos de Querétaro tienen costo?",
    a: `Las emergencias que comprometen la <strong>vida o la integridad</strong> de las personas —incendios, rescates, fugas de gas— se atienden de forma <strong>gratuita</strong>. El H. Cuerpo de Bomberos Voluntarios de Querétaro funciona con estructura mixta de financiamiento municipal y aportaciones voluntarias. La atención de emergencia nunca se condiciona a un pago. Algunos servicios secundarios (dictámenes, capacitación a empresas) pueden generar una cuota de recuperación.`,
  },
];

