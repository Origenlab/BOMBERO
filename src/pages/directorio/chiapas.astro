<DirectorioEstadoLayout
  estado="Chiapas"
  sigla="CHIS"
  slug="chiapas"
  description={`Bomberos en Chiapas: ${estadisticas.totalEstaciones} estaciones en ${estadisticas.totalMunicipios} municipios, teléfonos directos, rescate en Palenque UNESCO, Cañón del Sumidero, selva Lacandona y HAZMAT PEMEX. Emergencias: 911.`}
  keywords={[
    "bomberos chiapas",
    "bomberos tuxtla gutierrez",
    "emergencias chiapas 911",
    "bomberos san cristobal de las casas",
    "bomberos tapachula",
    "bomberos palenque selva lacandona",
    "bomberos comitan de dominguez",
    "rescate cañon del sumidero",
    "bomberos cascadas agua azul chiapas",
    "cuerpo bomberos chiapas",
    "bomberos incendios forestales chiapas",
    "hazmat reforma chiapas pemex",
    "rescate acuatico rio grijalva",
