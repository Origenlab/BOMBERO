---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesChiapas, getMunicipios, getEstadisticas } from "@data/estaciones-chiapas";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("chiapas");

const municipios   = getMunicipios();
const estadisticas = getEstadisticas();

const totalBomberos = estacionesChiapas.reduce((sum, e) => sum + (e.personalActivo ?? 0), 0);
const totalUnidades = estacionesChiapas.reduce((sum, e) => sum + (e.unidadesDisponibles?.length ?? 0), 0);

const canonical = "https://bombero.mx/directorio/chiapas/";

// ── Comparativa regional (calculada desde datos reales del directorio) ──────
const zonasDef = [
  {
    nombre: "Zona Metropolitana",
    munis: ["Tuxtla Gutiérrez", "Chiapa de Corzo", "Cintalapa"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital estatal (3 est.), Cañón del Sumidero, carretera Panamericana y Reserva El Ocote.",
  },
  {
    nombre: "Los Altos y Frontera Sur",
    munis: ["San Cristóbal de las Casas", "Comitán de Domínguez", "Las Margaritas"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "San Cristóbal (Pueblo Mágico, 2,200 msnm), Lagos de Montebello y selva fronteriza Tojolabal.",
  },
  {
    nombre: "Selva y Zona Norte",
    munis: ["Palenque", "Ocosingo", "Pichucalco", "Reforma"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Palenque UNESCO, Selva Lacandona, Montes Azules y Complejo Cactus PEMEX.",
  },
  {
    nombre: "Soconusco y Costa",
    munis: ["Tapachula", "Tonalá", "Huixtla", "Arriaga", "Villaflores"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Frontera Guatemala, río Suchiate, Puerto Chiapas, costa del Pacífico y zona cafetalera.",
  },
];

const zonas = zonasDef.map((z) => {
  const ests = estacionesChiapas.filter((e) => z.munis.includes(e.municipio ?? ""));
  return {
    ...z,
    nEst:  ests.length,
    nPers: ests.reduce((s, e) => s + (e.personalActivo ?? 0), 0),
    nUni:  ests.reduce((s, e) => s + (e.unidadesDisponibles?.length ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Chiapas, México",
  "description": `Directorio verificado de las ${estadisticas.totalEstaciones} estaciones de bomberos en Chiapas. Teléfonos directos en Tuxtla Gutiérrez, San Cristóbal de las Casas, Tapachula, Palenque y Comitán. Cobertura 24/7. Emergencias: 911.`,
  "numberOfItems": estacionesChiapas.length,
  "itemListElement": estacionesChiapas.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.municipio || e.ciudad,
        "addressRegion": "Chiapas",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/chiapas/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Chiapas: estaciones, historia y servicios de emergencia",
  "description": "Guía del H. Cuerpo de Bomberos de Chiapas: historia (1952–hoy), infraestructura en 15 municipios, sismo Mw 8.2 de 2017, volcanes Chichonal y Tacaná, selva Lacandona y directorio con teléfonos directos.",
  "about": [
    "H. Cuerpo de Bomberos de Chiapas",
    "Instituto de Bomberos del Estado de Chiapas",
    "Protección Civil Chiapas",
    "Búsqueda y rescate urbano",
    "Incendios forestales selva Lacandona",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/chiapas.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Chiapas",
  "description": `Directorio verificado de las ${estadisticas.totalEstaciones} estaciones de bomberos en Chiapas, con teléfonos, cobertura municipal, historia del cuerpo e información sobre riesgos sísmicos, volcánicos y forestales.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "H. Cuerpo de Bomberos de Chiapas" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/chiapas.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Chiapas (≥10) — alimentan el FAQPage schema ───────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Chiapas?",
    a: `Marca el <strong>911</strong>, número único nacional que opera las 24 horas. En zonas urbanas el despacho llega a la estación más cercana en segundos. En municipios como Tuxtla Gutiérrez el tiempo promedio de llegada es de <strong>6 a 10 minutos</strong>. En comunidades de la Selva Lacandona sin cobertura celular, la estación de Ocosingo opera con <strong>comunicación satelital Iridium</strong>. Teléfonos directos adicionales: Tuxtla Gutiérrez 961 612-4692, San Cristóbal 967 678-0770, Tapachula 962 626-1515.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Chiapas?",
    a: `El H. Cuerpo de Bomberos de Chiapas opera <strong>${estadisticas.totalEstaciones} estaciones activas</strong> distribuidas en <strong>${estadisticas.totalMunicipios} municipios</strong>, con <strong>${totalBomberos} bomberos profesionales</strong>. Las estaciones más grandes se ubican en Tuxtla Gutiérrez (3 estaciones), Tapachula (2) y las ciudades de San Cristóbal de las Casas, Palenque y Comitán.`,
  },
  {
    q: "¿Cuándo se fundó el cuerpo de bomberos en Chiapas?",
    a: `La <strong>primera estación profesional de bomberos del sureste mexicano</strong> se fundó en <strong>Tuxtla Gutiérrez en 1952</strong>. Desde 1998 opera como Centro de Comando C4 estatal, coordinando las ${estadisticas.totalEstaciones} estaciones activas. El <strong>22 de agosto</strong> se conmemora el Día del Bombero en México, en recuerdo de la fundación del primer cuerpo en Veracruz en <strong>1873</strong>.`,
  },
  {
    q: "¿Cómo respondieron los bomberos de Chiapas al sismo del 7 de septiembre de 2017?",
    a: `El <strong>sismo Mw 8.2 del 7 de septiembre de 2017</strong> —el más fuerte registrado en México desde 1932, con epicentro en el Golfo de Tehuantepec a 133 km al suroeste de Pijijiapan— causó <strong>18 muertes en Chiapas</strong> y daños severos en Tuxtla Gutiérrez, Tonalá y Arriaga. Las brigadas del H. Cuerpo activaron el protocolo de <strong>búsqueda y rescate urbano (USAR)</strong> en las primeras horas, con operaciones de apuntalamiento y evacuación en edificaciones dañadas. La Central de Tuxtla Gutiérrez coordinó las operaciones de los 15 municipios afectados.`,
  },
  {
    q: "¿Qué riesgo representa el volcán Chichonal para Chiapas?",
    a: `El <strong>Volcán Chichonal</strong> registró su última gran erupción el <strong>28 de marzo de 1982</strong>, generando columnas piroclásticas de hasta 32 km de altura, destruyendo 9 comunidades zoques y causando alrededor de <strong>2,000 fallecidos</strong>, el mayor desastre volcánico de la historia de México. Hoy el volcán sigue activo con actividad fumarólica monitoreada por el CENAPRED. Las estaciones de Pichucalco y la Central de Tuxtla coordinan con Protección Civil Chiapas para evacuaciones preventivas en escenario de alerta volcánica.`,
  },
  {
    q: "¿Qué riesgo representa el volcán Tacaná para los bomberos de Tapachula?",
    a: `El <strong>Volcán Tacaná</strong> (4,093 msnm, en la frontera México-Guatemala) es considerado uno de los volcanes de mayor riesgo relativo del país por el CENAPRED. Registra actividad fumarólica con una frecuencia histórica de 25 a 50 años y genera en promedio 5 eventos volcano-tectónicos mensuales. La estación de Tapachula forma parte del Plan Operativo de Protección Civil del Tacaná, con protocolos de evacuación para los municipios de Tapachula, Unión Juárez, Cacahoatán, Motozintla y Tuxtla Chico.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en la Selva Lacandona?",
    a: `La estación de Ocosingo —que cubre el municipio más extenso de Chiapas con <strong>8,887 km²</strong>— opera con equipos de incendio forestal, ambulancia todo terreno, comunicación satelital Iridium y transporte a lomo de mula para comunidades sin camino vehicular. Combate incendios forestales en la Selva Lacandona y la <strong>Reserva de la Biosfera Montes Azules</strong>, coordina búsquedas de personas extraviadas y atiende comunidades lacandonas y tzeltales. La temporada crítica de incendios abarca de febrero a mayo.`,
  },
  {
    q: "¿Cómo atienden los bomberos las emergencias en la Zona Arqueológica de Palenque?",
    a: `La estación de Palenque opera un <strong>protocolo específico de protección de patrimonio INAH</strong>: extinción perimetral con niebla de agua a presión reducida, espuma seca como barrera cortaluegos alrededor de estructuras mayas, y acceso de agua directa sobre piedra solo con autorización del custodio INAH. La zona arqueológica, <strong>Patrimonio de la Humanidad UNESCO desde 1987</strong>, recibe más de 1 millón de turistas anuales y está rodeada por selva activa en tres frentes.`,
  },
  {
    q: "¿Cómo funciona el rescate acuático en el Cañón del Sumidero?",
    a: `La estación de Chiapa de Corzo opera <strong>3 lanchas de rescate, motos acuáticas y equipo de buceo</strong> certificado para la corriente del río Grijalva. El Cañón tiene paredes de hasta 1,000 metros de altura: hay puntos donde la ruta por agua desde la estación toma 20 minutos, mientras que la misma ubicación por carretera requiere más de 3 horas. Más de <strong>500,000 turistas</strong> navegan anualmente el cañón en embarcaciones turísticas.`,
  },
  {
    q: "¿Cómo atienden los bomberos las emergencias migratorias en el río Suchiate?",
    a: `Los bomberos de <strong>Tapachula</strong> operan dos lanchas de rescate especializadas en el río Suchiate, frontera natural con Guatemala. En temporada de lluvias (junio-octubre) el río alcanza 2 metros de profundidad con corriente que supera 2 m/s. La estación coordina con Bomberos Voluntarios de Tecún Umán, Guatemala, bajo <strong>protocolos de rescate binacional</strong> formalizados —los únicos de ese tipo en la frontera sur de México.`,
  },
  {
    q: "¿Qué tipo de emergencias industriales atiende la estación de Reforma?",
    a: `La estación de Reforma custodia el <strong>Complejo Procesador de Gas Cactus</strong>, el mayor procesador de gas natural del sureste de México. Su personal está certificado en <strong>HAZMAT nivel técnico</strong>, rescate en espacios confinados y control de blowouts (reventones de pozo) por Wild Well Control. Cuenta con unidades de espuma AFFF, dos unidades HAZMAT de nivel técnico y equipo de nitrógeno para incendios de hidrocarburos.`,
  },
  {
    q: "¿Qué debo hacer si hay un incendio o una emergencia en Chiapas?",
    a: `Llama de inmediato al <strong>911</strong>. Indica tu municipio y referencia exacta de ubicación, ya que en zonas rurales el GPS puede no funcionar y el nombre de la comunidad es clave para el despacho correcto. En comunidades sin cobertura celular, recurre a la radio comunitaria o busca el punto de acceso más cercano con señal. Para incendios forestales en la temporada seca, la coordinación también va con <strong>CONANP</strong> y <strong>CONAFOR</strong>.`,
  },
];

