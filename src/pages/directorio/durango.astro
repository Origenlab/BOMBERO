import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("durango");

// ── Derivar municipios desde el array de estaciones ────────────────────────
const municipios      = [...new Set(estacionesDurango.map((e) => e.ciudad))].sort();
const totalEstaciones = ESTADISTICAS_DURANGO.total_estaciones;
const totalMunicipios = ESTADISTICAS_DURANGO.municipios_cubiertos;
const totalBomberos   = ESTADISTICAS_DURANGO.total_bomberos;
const totalUnidades   = ESTADISTICAS_DURANGO.total_unidades;

const canonical = "https://bombero.mx/directorio/durango/";

// ── Comparativa regional (calculada desde los datos reales del directorio) ──
