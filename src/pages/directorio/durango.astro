  "numberOfItems": estacionesDurango.length,
  "itemListElement": estacionesDurango.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Durango",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
