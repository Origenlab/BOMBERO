          <tr><td><strong>Emergencias invernales / hipotermia</strong></td><td>Dic–Feb</td><td>Santiago Papasquiaro, El Salto</td></tr>
          <tr><td><strong>Control de fugas de gas industrial</strong></td><td>24/7</td><td>Gómez Palacio, Estación Central Durango</td></tr>
        </tbody>
      </table>
