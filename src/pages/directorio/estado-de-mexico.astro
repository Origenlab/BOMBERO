    { number: "55 5390 4100", label: "Bomberos Tlalnepantla"             },
    { number: "800 019 0000", label: "Protección Civil Estado de México" },
  ]}

  municipios={municipios}

  regiones={[
    { nombre: "Valle de Toluca (Capital Estatal)",       desc: "Toluca (fund. 1939) · Metepec (plazas comerciales) · Lerma (90+ parques industriales HAZMAT) · Zinacantepec (rescate alta montaña Nevado 4,680 msnm) — 2.3M habitantes" },
    { nombre: "ZMVM Norte (Conurbación CDMX)",           desc: "Ecatepec (1.6M municipio más poblado México) · Tlalnepantla (industrial) · Naucalpan (fund. 1964, corporativos Satélite) · Cuautitlán Izcalli · Tultitlán · Coacalco · Tecámac — 4.5M habitantes" },
    { nombre: "ZMVM Oriente (Zona Chalco Inundaciones)", desc: "Nezahualcóyotl (1.2M, 19,000 hab/km²) · Chalco (inundaciones masivas) · Valle de Chalco (rescate acuático) · Ixtapaluca · Chimalhuacán · Texcoco (cenizas Popocatépetl) — 3.8M" },
    { nombre: "ZMVM Poniente (Zona Residencial-Bosque)", desc: "Huixquilucan (Interlomas, Bosque Real) · Atizapán (incendios forestales Sierra Cruces) · Nicolás Romero (rescate barrancas) — 1.2M habitantes" },
  ]}

  estadosVecinos={estadosVecinos}

  estaciones={estacionesEdoMex.map((e) => ({
    nombreCorto: e.nombreCorto,
    slug:        e.slug,
    direccion:   e.direccion,
    colonia:     e.colonia,
    ciudad:      e.ciudad,
    telefono:    e.telefono,
    servicios:   e.servicios,
    horario:     e.horario,
  }))}

  stationImages={stationImages}

  ctaTitle="¿Equipas una estación en Estado de México?"
  ctaDesc="Somos distribuidores oficiales de equipo certificado NFPA para cuerpos de bomberos en todo el país. Equipamiento completo para rescate urbano, alta montaña, HAZMAT y emergencias acuáticas."
  ctaBtnText="Solicitar Cotización"

  eppCards={[
    {
      image:     "/images/directorio/equipo-rescate-tecnico-01.avif",
      imageAlt:  "Equipo Rescate Técnico Urbano NFPA 1006 bomberos Ecatepec 1.6M habitantes edificios colapsados sismos búsqueda extracción",
