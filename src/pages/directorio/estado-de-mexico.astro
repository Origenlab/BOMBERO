---

<DirectorioEstadoLayout
  estado="Estado de México"
  sigla="EDOMEX"
  slug="estado-de-mexico"
  description={`${totalEstaciones} estaciones en el estado más poblado de México — 17.4M habitantes, Ecatepec (1.6M), rescate alta montaña Nevado de Toluca (4,680 msnm), HAZMAT 90+ parques industriales y Valle de Chalco inundaciones. Emergencias: 911.`}
  keywords={[
    "bomberos Estado de México",
    "bomberos Ecatepec municipio más poblado México",
    "bomberos Toluca rescate alta montaña",
    "bomberos Nezahualcóyotl ZMVM",
    "bomberos Naucalpan zona industrial",
    "bomberos rescate Nevado de Toluca 4680 msnm",
    "bomberos Tlalnepantla HAZMAT",
    "bomberos inundaciones Valle de Chalco",
    "bomberos Metepec corredor industrial",
    "bomberos Huixquilucan Interlomas",
    "bomberos Popocatépetl volcán activo",
    "bomberos Cuautitlán Izcalli parques industriales",
    "bomberos Atizapán incendios forestales",
    "bomberos emergencias ZMVM 17 millones habitantes",
    "directorio bomberos Estado de México teléfonos",
  ]}
  canonical={canonical}
  jsonLd={jsonLd}

  totalEstaciones={totalEstaciones}
  totalMunicipios={totalMunicipios}
  habitantes="17.4M"

  heroDesc={`<strong>Estado de México</strong>, el <strong>estado más poblado de México</strong> con <strong>17.4 millones de habitantes</strong> (13.5% de la población nacional) y hogar de <strong>Ecatepec</strong> — el <strong>municipio más poblado del país</strong> con <strong>1.6+ millones de habitantes</strong> — integra la <strong>Zona Metropolitana del Valle de México (ZMVM)</strong>, el <strong>área urbana más grande de América</strong> con 22+ millones de habitantes. Con <strong>${totalEstaciones} estaciones</strong> y <strong>${totalBomberos} bomberos profesionales</strong>, los cuerpos del estado cubren escenarios separados por 60 kilómetros pero distintos en magnitud: desde los <strong>4,680 metros del Nevado de Toluca</strong> (volcán con 2 lagunas en cráter, operaciones a -15°C), hasta los <strong>2,240 metros del antiguo lecho del Lago de Chalco</strong> (inundaciones masivas de 1-2 metros en 24h), el corredor industrial <strong>Lerma-Toluca con 90+ parques industriales</strong> HAZMAT y el volcán <strong>Popocatépetl activo</strong> a 70 km.`}
  heroImage="/images/directorio/estacion-bomberos-moderna-01.avif"
  heroImageAlt="Bomberos Estado de México — Ecatepec 1.6M habitantes rescate urbano Nevado Toluca 4680 msnm ZMVM área urbana más grande América"
  heroCaption="Bomberos Estado de México · EDOMEX · 20 Estaciones · Estado Más Poblado México · 17.4 Millones Habitantes"
  heroThumbs={[
    { src: "/images/directorio/rescate-urbano-bomberos-01.avif",                   alt: "Rescate urbano densidad Ecatepec 1.6M habitantes Nezahualcóyotl 1.2M ZMVM conurbación México edificios multifamiliares emergencias masivas",     label: "Rescate Urbano ZMVM"     },
    { src: "/images/directorio/rescate-montana-bomberos-01.avif",                  alt: "Rescate alta montaña Nevado Toluca 4,680 msnm volcán lagunas cráter hipotermia altitud Zinacantepec",                                              label: "Nevado Toluca 4,680 msnm" },
    { src: "/images/directorio/bombero-profesional-retrato-closeup-goggle-01.avif",alt: "Bombero del Estado de México con goggle protector en servicio activo",                                                                              label: "Protección Especializada" },
  ]}

  galleryImages={[
    { src: "/images/directorio/rescate-espeleologico-cuevas-01.avif",             alt: "Popocatépetl volcán activo cenizas caída CENAPRED evacuaciones Alerta Amarilla Texcoco Chalco Ixtapaluca",   label: "Popocatépetl Volcán Activo"  },
    { src: "/images/directorio/estacion-bomberos-bahia-camiones-frontal-01.avif", alt: "Bahía de camiones de bomberos del Estado de México vista frontal",                                              label: "Flota Vehicular EDOMEX"      },
    { src: "/images/directorio/puesto-comando-incidente-01.avif",                 alt: "C4 Estado México geolocalización emergencias coordinación Toluca Naucalpan Tlalnepantla Ecatepec",             label: "C4 Control de Emergencias"   },
    { src: "/images/directorio/lancha-rescate-bomberos-01.avif",                  alt: "Lancha rescate acuático inundaciones Valle de Chalco lecho lago arcilla impermeable cables sumergidos CFE",   label: "Rescate Acuático Chalco"     },
  ]}

  emergencyNumbers={[
    { number: "911",          label: "Emergencias Estado de México"      },
    { number: "722 215 7790", label: "Bomberos Toluca (Central Estatal)" },
    { number: "55 5787 4512", label: "Bomberos Ecatepec"                 },
