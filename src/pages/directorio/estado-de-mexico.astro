---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesEdoMex,
} from "@data/estaciones-edomex";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { breadcrumbJsonLd } from "@utils/seo";

const estadosVecinos = getEstadosVecinos("estado-de-mexico");

// ── Derivar estadísticas desde el array de estaciones ─────────────────────
const municipios      = [...new Set(estacionesEdoMex.map((e) => e.ciudad))].sort();
const totalEstaciones = estacionesEdoMex.length;
const totalMunicipios = municipios.length;
const totalBomberos   = estacionesEdoMex.reduce((sum, e) => sum + (e.personal || 0), 0);

const breadcrumbSchema = breadcrumbJsonLd([
  { name: "Inicio",                 url: "/" },
  { name: "Directorio de Bomberos", url: "/directorio/" },
  { name: "Estado de México",       url: "/directorio/estado-de-mexico/" },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Estado de México",
  "description": `Directorio oficial de las ${totalEstaciones} estaciones de bomberos en Estado de México. Estado más poblado de México (17.4M), Ecatepec municipio más poblado del país (1.6M), ZMVM área urbana más grande de América, Nevado Toluca 4,680 msnm rescate alta montaña, Popocatépetl activo, 90+ parques industriales. Emergencias: 911.`,
  "numberOfItems": estacionesEdoMex.length,
  "itemListElement": estacionesEdoMex.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Estado de México",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `/directorio/estado-de-mexico/${e.slug}`,
      "description": e.descripcion,
      "openingHours": "Mo-Su 00:00-23:59",
    },
  })),
};

const jsonLd = [itemListSchema];

const stationImages = [
  "/images/directorio/estacion-bomberos-moderna-01.avif",
  "/images/directorio/estacion-bomberos-equipada-01.avif",
  "/images/directorio/estacion-bomberos-central-edificio-01.avif",
  "/images/directorio/estacion-bomberos-profesional-01.avif",
  "/images/directorio/bomberos-guardia-nocturna-scba-equipo-02.avif",
  "/images/directorio/estacion-bomberos-bahia-interior-bandera-01.avif",
  "/images/directorio/estacion-bomberos-bahia-camiones-frontal-01.avif",
