---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesEdoMex,
} from "@data/estaciones-edomex";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("estado-de-mexico");

// ── Derivar estadísticas desde el array de estaciones ─────────────────────
const municipios      = [...new Set(estacionesEdoMex.map((e) => e.ciudad))].sort();
const totalEstaciones = estacionesEdoMex.length;
const totalMunicipios = municipios.length;
const totalBomberos   = estacionesEdoMex.reduce((sum, e) => sum + (e.personal || 0), 0);

const canonical = "https://bombero.mx/directorio/estado-de-mexico/";

// ── Comparativa regional (agrupando municipios por zona) ──────────────────
const zonasDef = [
  {
    nombre: "Valle de Toluca",
    municipios: ["Toluca de Lerdo", "Metepec", "San Miguel Zinacantepec", "Lerma de Villada"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital estatal (2,600 msnm), corredor industrial Lerma-Toluca, Nevado de Toluca 4,680 msnm, Aeropuerto Internacional Toluca.",
  },
  {
    nombre: "ZMVM Norte",
    municipios: ["Ecatepec", "Tlalnepantla", "Cuautitlán Izcalli", "Coacalco", "Tultitlán de Mariano Escobedo", "Tecámac de Felipe Villanueva"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Ecatepec (1.6M, municipio más poblado del país), zona industrial Vallejo, autopistas México-Pachuca y México-Querétaro.",
  },
  {
    nombre: "ZMVM Oriente",
    municipios: ["Ciudad Nezahualcóyotl", "Chalco de Díaz Covarrubias", "Valle de Chalco", "Ixtapaluca", "Chimalhuacán", "Texcoco de Mora"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Nezahualcóyotl (1.2M, 19,000 hab/km²), lecho del Lago de Chalco (inundaciones masivas), faldas Sierra Nevada y cenizas Popocatépetl.",
  },
  {
    nombre: "ZMVM Poniente",
    municipios: ["Huixquilucan", "Atizapán", "Ciudad Nicolás Romero"],
    cobertura: "Media",
    chip: "media",
    perfil: "Interlomas, Bosque Real, Sierra de las Cruces (incendios forestales), barrancas y zonas boscosas.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesEdoMex.filter((e) => z.municipios.includes(e.ciudad));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personal ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Estado de México",
  "description": `Directorio oficial de las ${totalEstaciones} estaciones de bomberos en Estado de México. Estado más poblado de México (17.4M), Ecatepec municipio más poblado del país (1.6M), ZMVM área urbana más grande de América, Nevado Toluca 4,680 msnm rescate alta montaña, Popocatépetl activo, 90+ parques industriales. Emergencias: 911.`,
  "numberOfItems": estacionesEdoMex.length,
  "itemListElement": estacionesEdoMex.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Estado de México",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/estado-de-mexico/${e.slug}/`,
      "description": e.descripcion,
      "openingHours": "Mo-Su 00:00-23:59",
    },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en el Estado de México: estaciones, historia y servicios de emergencia",
  "description": "Guía de los cuerpos de bomberos del Estado de México: historia (Toluca 1939, Naucalpan 1964), infraestructura por región, rescate alta montaña Nevado de Toluca, HAZMAT corredor Lerma-Toluca, inundaciones Valle de Chalco y Popocatépetl.",
  "about": [
    "H. Cuerpo de Bomberos del Estado de México",
    "Protección Civil Estado de México",
    "Rescate alta montaña Nevado de Toluca",
    "Materiales peligrosos HAZMAT corredor industrial",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/estado-de-mexico.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en el Estado de México",
  "description": `Directorio verificado de ${totalEstaciones} estaciones de bomberos en el Estado de México, con teléfonos, cobertura por región, historia y especialidades: alta montaña, HAZMAT industrial, rescate acuático y volcán Popocatépetl.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "H. Cuerpo de Bomberos del Estado de México" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/estado-de-mexico.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas Estado de México (≥10) ────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en el Estado de México?",
    a: `Marca el <strong>911</strong>, número único de emergencias que conecta con el C4 (Centro de Coordinación, Control, Cómputo y Comunicaciones) del Estado de México las 24 horas. El sistema enruta la llamada a la estación con menor tiempo de respuesta según tu ubicación. Para emergencias en el Nevado de Toluca, la estación de Zinacantepec coordina con el CENAPRED; para inundaciones en Valle de Chalco, la estación local tiene lanchas de rescate disponibles.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en el Estado de México?",
    a: `Este directorio reúne <strong>${totalEstaciones} estaciones de bomberos</strong> en <strong>${totalMunicipios} municipios</strong> del Estado de México. Las estaciones se distribuyen en cuatro grandes zonas: Valle de Toluca (capital estatal), ZMVM Norte (Ecatepec, Tlalnepantla, Cuautitlán Izcalli), ZMVM Oriente (Nezahualcóyotl, Chalco, Valle de Chalco) y ZMVM Poniente (Huixquilucan, Atizapán, Nicolás Romero).`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Toluca?",
    a: `El <strong>Heroico Cuerpo de Bomberos de Toluca</strong> fue fundado formalmente el <strong>7 de septiembre de 1939</strong>, bajo la gestión del gobernador Wenceslao Labra y el presidente municipal Antonio Mancilla Bauza, como respuesta directa a un incendio en el Mercado Riva Palacio ocurrido en 1935 que evidenció la necesidad de un cuerpo profesional. El equipo inicial fue donado por la Cervecería Toluca y el gobierno del Distrito Federal.`,
  },
  {
    q: "¿Cuándo se fundaron los bomberos de Naucalpan?",
    a: `El primer cuerpo de bomberos de Naucalpan fue organizado alrededor de <strong>1960 por taxistas</strong> del sitio El Prieto, que respondían a incendios por iniciativa propia adaptando herramientas. En <strong>1964</strong> se constituyó formalmente el <strong>Heroico Cuerpo de Bomberos de Naucalpan de Juárez</strong>, con aquellos taxistas en su primera generación. En sus primeros años cubría también emergencias en Atizapán, Huixquilucan, Tlalnepantla y partes de Ecatepec y Nezahualcóyotl.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque el <strong>22 de agosto de 1873</strong> se fundó en el <strong>puerto de Veracruz</strong> el primer cuerpo de bomberos organizado de México. Esa fecha se conmemora cada año en toda la República como el Día del Bombero, incluyendo a los cuerpos del Estado de México.`,
  },
  {
    q: "¿Qué hacen los bomberos del Estado de México ante una erupción del Popocatépetl?",
    a: `El volcán Popocatépetl se encuentra a unos <strong>70 km</strong> de los municipios orientales del Estado de México. En episodios de actividad alta, las estaciones de Texcoco, Chalco, Ixtapaluca y Nezahualcóyotl coordinan con el <strong>CENAPRED</strong> (Centro Nacional de Prevención de Desastres) y Protección Civil Estatal los protocolos de evacuación preventiva, distribución de cubrebocas y limpieza de techos con caída de ceniza. El 911 es la línea de reporte en esos eventos.`,
  },
  {
    q: "¿Qué equipamiento tienen los bomberos del Estado de México para rescate en el Nevado de Toluca?",
    a: `La <strong>Estación de Bomberos de Zinacantepec</strong> mantiene la brigada de rescate de alta montaña del estado, con vehículos 4x4 todoterreno, camillas especializadas tipo Stokes para pendientes, oxígeno suplementario portátil para casos de mal de altura agudo (AMS), comunicación satelital (sin cobertura celular en el cráter a 4,200 msnm) y ropa térmica para temperaturas de -15°C. Coordina directamente con el CENAPRED y el Parque Nacional Nevado de Toluca.`,
  },
  {
    q: "¿Qué pasa en las inundaciones de Valle de Chalco y cómo responden los bomberos?",
    a: `El Valle de Chalco Solidaridad y Chalco ocupan el lecho del antiguo <strong>Lago de Chalco</strong> (desecado en 1895–1904), con suelo arcilloso impermeable al nivel más bajo de la Cuenca de México. Tormentas de <strong>200+ mm en 24 horas</strong> —como la de septiembre de 2021— generan inundaciones de 1 a 2 metros que no drenan por días. Las estaciones de <strong>Valle de Chalco y Chalco</strong> responden con lanchas inflables de material dieléctrico, porque cables de CFE sumergidos electrifican el agua en zonas de autoconstrucción.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos del Estado de México?",
    a: `Combate de <strong>incendios</strong> estructurales, industriales y forestales; <strong>rescate vehicular</strong> y extricación; <strong>atención prehospitalaria</strong>; <strong>materiales peligrosos (HAZMAT)</strong> en los 90+ parques industriales del corredor Lerma-Toluca; <strong>rescate de alta montaña</strong> en el Nevado de Toluca (4,680 msnm); <strong>rescate acuático</strong> en temporadas de inundación; control de fugas de gas; retiro de enjambres; y coordinación con Protección Civil en emergencias masivas y volcánicas.`,
  },
  {
    q: "¿Los servicios de los bomberos del Estado de México tienen costo?",
    a: `Las emergencias que comprometen la <strong>vida o la integridad</strong> de las personas se atienden de forma <strong>gratuita</strong>. Algunos servicios secundarios (dictámenes, capacitación a empresas, retiro de enjambres no urgente) pueden tener cuota de recuperación según el municipio. La atención de emergencia nunca se condiciona al pago previo.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en el Estado de México?",
    a: `Revisa periódicamente la instalación de <strong>gas</strong> (mangueras, reguladores) y la <strong>instalación eléctrica</strong>; evita sobrecargar contactos. Instala <strong>detectores de humo</strong> y ten un extintor vigente en la cocina. Define un <strong>plan de evacuación</strong> con tu familia. En zonas boscosas de Atizapán, Nicolás Romero o Huixquilucan, no quemes basura durante estiaje (noviembre–mayo) y reporta cualquier conato de incendio forestal al <strong>911</strong> de inmediato.`,
  },
  {
    q: "¿Qué zona del Estado de México tiene mayor riesgo de incendio forestal?",
    a: `Las zonas con mayor riesgo de incendio forestal en el Estado de México son: la <strong>Sierra de las Cruces</strong> (municipios de Nicolás Romero, Huixquilucan y Atizapán de Zaragoza), las <strong>faldas del Nevado de Toluca</strong> en temporada de estiaje, y las áreas boscosas de la <strong>Sierra Nevada</strong> (Texcoco, Ixtapaluca). Las estaciones de Atizapán, Nicolás Romero, Zinacantepec y Texcoco mantienen unidades forestales especializadas para estos frentes.`,
  },
];

const stationImages = [
  "/images/directorio/estacion-bomberos-moderna-01.avif",
  "/images/directorio/estacion-bomberos-equipada-01.avif",
  "/images/directorio/estacion-bomberos-central-edificio-01.avif",
