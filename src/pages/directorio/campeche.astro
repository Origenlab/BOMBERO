---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesCampeche, getMunicipios, getEstadisticas } from "@data/estaciones-campeche";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("campeche");

const municipios   = getMunicipios();
const estadisticas = getEstadisticas();

const canonical = "https://bombero.mx/directorio/campeche/";

// ── Comparativa regional ────────────────────────────────────────────────────
const zonas = [
  {
    nombre: "Zona Capital UNESCO",
    municipios: ["Campeche"],
    cobertura: "Total",
    chip: "total",
    perfil: "San Francisco de Campeche · Ciudad amurallada siglo XVII · Malecón · 8 baluartes.",
  },
  {
    nombre: "Zona Petrolera",
    municipios: ["Carmen"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Ciudad del Carmen (isla) · Sonda de Campeche · +200 plataformas PEMEX · Laguna de Términos.",
  },
  {
    nombre: "Zona Maya-Biósfera",
    municipios: ["Calakmul"],
    cobertura: "Media",
    chip: "media",
    perfil: "Calakmul · Xpujil · Reserva Biósfera UNESCO 723 k ha · Frontera Petén Guatemala.",
  },
  {
    nombre: "Zona Sur Selvática",
    municipios: ["Candelaria", "Escárcega"],
    cobertura: "Media",
    chip: "media",
    perfil: "Candelaria · Escárcega · Tren Maya · carreteras 186/261 · Frontera Guatemala.",
  },
  {
    nombre: "Zona Norte Camino Real",
    municipios: ["Calkiní", "Champotón"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Calkiní · Champotón · Carretera 180 · Costa del Golfo · comunidades mayas.",
  },
];

const zonasConDatos = zonas.map((z) => {
  const est = estacionesCampeche.filter((e) => z.municipios.includes(e.municipio ?? ''));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

const totalBomberos = estacionesCampeche.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades = estacionesCampeche.reduce((s, e) => s + (e.unidades ?? 0), 0);

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Campeche, México",
  "description": `Directorio verificado de las ${estadisticas.totalEstaciones} estaciones de bomberos en Campeche: San Francisco de Campeche (capital UNESCO), Ciudad del Carmen (petrolera), Escárcega, Champotón, Calkiní, Candelaria y Calakmul (Reserva Biósfera). Emergencias: 911.`,
  "numberOfItems": estacionesCampeche.length,
  "itemListElement": estacionesCampeche.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.municipio || e.ciudad,
        "addressRegion": "Campeche",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/campeche/${e.slug}/`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Campeche: estaciones, historia y servicios de emergencia",
  "description": "Directorio del Heroico Cuerpo de Bomberos de Campeche: historia, infraestructura en los 13 municipios, riesgo petrolero offshore (Sonda de Campeche), triple Patrimonio UNESCO y servicios de emergencia con teléfonos directos.",
  "about": [
    "Heroico Cuerpo de Bomberos de Campeche",
    "Sonda de Campeche PEMEX",
    "Patrimonio UNESCO Campeche",
    "Reserva Biósfera Calakmul",
    "Servicios de emergencia sureste México",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/campeche.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": `Estaciones de Bomberos en Campeche — Directorio Verificado`,
  "description": `Directorio verificado de las ${estadisticas.totalEstaciones} estaciones de bomberos en Campeche, con teléfonos, cobertura por región, historia y servicios de emergencia.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de Campeche" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/campeche.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

// breadcrumbSchema NO se pasa: el componente <Breadcrumb> ya emite el BreadcrumbList.
const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQs únicas de Campeche (≥10) ─────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencias para llamar a los bomberos en Campeche?",
    a: `Marca el <strong>911</strong>, el número único de emergencias que opera las 24 horas en los 13 municipios del estado. Para teléfonos directos: Campeche capital <strong>981 811 3636</strong>, Ciudad del Carmen <strong>938 382 5050</strong>, Escárcega <strong>982 824 0066</strong>, Champotón <strong>982 828 0038</strong>, Calkiní <strong>996 963 0033</strong>, Candelaria <strong>982 826 0025</strong>, Calakmul (Xpujil) <strong>983 871 6036</strong>. En emergencias offshore en la Sonda de Campeche, el 911 coordina también con la Armada de México y brigadas industriales de PEMEX.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Campeche?",
    a: `El estado de Campeche cuenta con <strong>${estadisticas.totalEstaciones} estaciones de bomberos activas</strong> en este directorio, distribuidas en <strong>${estadisticas.totalMunicipios} municipios</strong>: San Francisco de Campeche (capital), Ciudad del Carmen, Escárcega, Champotón, Calkiní, Candelaria y Calakmul (Xpujil). El cuerpo opera con <strong>${totalBomberos} bomberos</strong> y <strong>${totalUnidades} unidades</strong>, con cobertura 24/7 en los 13 municipios del estado.`,
  },
  {
    q: "¿Por qué el 22 de agosto es el Día del Bombero en México?",
    a: `Porque el <strong>22 de agosto de 1873</strong> se fundó en el puerto de Veracruz el <strong>primer cuerpo de bomberos de México</strong> —y de América Latina—. Esa fecha se conmemora cada año como el Día del Bombero en toda la República, incluyendo los cuerpos de Campeche. Los bomberos de Campeche capital, Ciudad del Carmen, Escárcega y los demás municipios celebran este aniversario nacional cada año.`,
  },
  {
    q: "¿Cómo responden los bomberos a una emergencia en las plataformas petroleras de la Sonda de Campeche?",
    a: `Las emergencias offshore en la <strong>Sonda de Campeche</strong> —más de 200 plataformas marinas que producen una fracción importante del petróleo nacional— requieren un protocolo especializado. La <strong>Estación de Ciudad del Carmen</strong> (la más cercana, en isla) coordina con las brigadas de emergencia industriales de <strong>PEMEX</strong>, la <strong>Armada de México</strong> y contratistas como Halliburton, Schlumberger y Baker Hughes. El personal mantiene certificaciones HAZMAT nivel técnico para hidrocarburos y el tiempo de respuesta offshore puede ser de <strong>45 a 90 minutos</strong> dependiendo de la posición de la plataforma. Para incidentes de gran magnitud se activa el plan de emergencias regional del sector petrolero.`,
  },
  {
    q: "¿Qué riesgos especiales enfrentan los bomberos de la Ciudad del Carmen?",
    a: `Ciudad del Carmen es una <strong>isla</strong> conectada al continente únicamente por los puentes <strong>Zacatal (3.2 km)</strong> y <strong>La Unidad (3.8 km)</strong>. Cuando un huracán del Golfo impacta la zona o los puentes quedan bloqueados, la estación activa protocolos de isla: respuesta autónoma sin refuerzos externos durante horas o días. A ello se suma la alta concentración de industria petrolera con riesgo de incendios en tanques de hidrocarburos, derrames en Laguna de Términos y emergencias en helipuertos y muelles de servicio a plataformas.`,
  },
  {
    q: "¿Qué hace diferente la protección del Centro Histórico UNESCO de Campeche?",
    a: `La <strong>Ciudad Histórica Fortificada de Campeche</strong>, inscrita en el Patrimonio de la Humanidad el 4 de diciembre de 1999, tiene murallas del siglo XVII construidas originalmente para resistir ataques piratas. La cantera original de sus edificios coloniales, baluartes y fuertes requiere técnicas de extinción especializadas para no causar daños adicionales con agua a presión o productos químicos. Cualquier intervención en el perímetro del centro histórico se coordina con el <strong>INAH</strong>, y los bomberos de la estación capital tienen capacitación específica en protección del patrimonio construido.`,
  },
  {
    q: "¿Cómo combaten los bomberos los incendios forestales en la Reserva de la Biósfera de Calakmul?",
    a: `La <strong>Reserva de la Biósfera Calakmul</strong> (723,185 hectáreas, Patrimonio UNESCO desde 2014) exige combate forestal especializado. La <strong>Estación Calakmul</strong> en Xpujil opera con <strong>drones de cámara térmica</strong> para detección de frentes activos, unidades forestales 4x4, tanques nodriza de 15,000 litros, motopulverizadoras y líneas cortafuegos. El trabajo se coordina con <strong>CONANP</strong> (guardaparques) y <strong>CONAFOR</strong>. En zonas sin acceso vehicular, el combate se hace a pie con herramienta manual. La temporada crítica va de <strong>febrero a mayo</strong>; un incendio en la reserva puede cruzar hacia el Petén guatemalteco en horas.`,
  },
  {
    q: "¿Qué riesgo representa la temporada de huracanes para los bomberos de Campeche?",
    a: `Campeche es uno de los estados con mayor exposición a ciclones tropicales del Golfo de México. El <strong>huracán Isidore (2002)</strong> descargó hasta <strong>777 mm de lluvia en 96 horas</strong> sobre Campeche, uno de los máximos registrados en el estado. Las estaciones de la capital, Champotón y Ciudad del Carmen activan planes de contingencia ante avisos de huracán: preposicionamiento de equipos en lugares seguros, coordinación con Protección Civil estatal y refuerzo de brigadas de rescate acuático para inundaciones costeras. La temporada va de junio a noviembre.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Campeche además de apagar incendios?",
    a: `Los cuerpos de bomberos de Campeche atienden: <strong>rescate vehicular</strong> con herramienta hidráulica (especialmente en carreteras 186 y 261), <strong>rescate acuático</strong> en Laguna de Términos, río Champotón, ríos Candelaria y San Pedro; <strong>HAZMAT</strong> para hidrocarburos en Ciudad del Carmen; <strong>incendios forestales</strong> en Calakmul y zona selvática; atención <strong>prehospitalaria</strong>; control de <strong>fugas de gas</strong>; retiro de <strong>enjambres de abejas africanizadas</strong>; y apoyo en emergencias del <strong>Tren Maya</strong> (estación Escárcega).`,
  },
  {
    q: "¿Los servicios de bomberos en Campeche tienen costo?",
    a: `Las emergencias que comprometen la <strong>vida o la integridad</strong> de personas —incendios, rescates, fugas de gas— se atienden de forma <strong>gratuita</strong>. Algunos servicios secundarios como retiro de enjambres, dictámenes preventivos o capacitación a empresas pueden tener cuota de recuperación. La atención de emergencia nunca se condiciona a pago previo. Para emergencias, llama siempre al <strong>911</strong>.`,
  },
  {
    q: "¿Cómo puedo prevenir incendios en mi hogar en Campeche?",
    a: `Las principales recomendaciones para hogares en Campeche: revisa periódicamente la instalación de <strong>gas LP</strong> (mangueras, reguladores, conexiones), ya que el clima húmedo del trópico acelera el deterioro de los materiales. Instala <strong>detectores de humo</strong> y ten un extintor vigente en cocina. Ante una fuga de gas, <strong>no acciones interruptores</strong>, abre ventanas, cierra la llave de paso y evacúa. En temporada seca, evita quemas agrícolas no controladas cerca de zonas forestales. Si detectas un incendio, llama de inmediato al <strong>911</strong> o al teléfono directo de la estación más cercana.`,
  },
  {
    q: "¿Qué tan peligrosos son los incendios de manglar en la Laguna de Términos?",
    a: `Los incendios en los manglares de la <strong>Laguna de Términos</strong> —Área de Protección de Flora y Fauna con 891,000 hectáreas— son especialmente difíciles porque la combustión ocurre en la materia orgánica del suelo y en raíces aéreas, produciendo <strong>humo denso con escasa llama visible</strong>. El terreno fangoso impide el acceso terrestre y obliga a los bomberos a operar desde embarcaciones. Cualquier intervención requiere coordinación con <strong>CONANP</strong> y la <strong>Armada de México</strong>. La Laguna de Términos es además el sistema lagunar costero más importante del Golfo de México, sustento de la pesca artesanal de la isla del Carmen.`,
  },
];

