<DirectorioEstadoLayout
  estado="Yucatán"
  sigla="YUC"
  slug="yucatan"
  description={`Bomberos en Yucatán: ${totalEstaciones} estaciones en Mérida y el estado — rescate en cenotes, huracanes Gilberto e Isidoro, Chichén Itzá y Uxmal UNESCO, Puerto Progreso y reservas biósfera. Emergencias: 911.`}
  keywords={[
    "bomberos yucatan",
    "bomberos merida yucatan",
    "cuerpo bomberos merida 1948",
    "estaciones bomberos yucatan directorio",
    "telefono bomberos merida 911",
    "rescate cenotes yucatan espeleobuceo",
    "bomberos chichen itza patrimonio",
    "bomberos puerto progreso cruceros",
    "bomberos huracan yucatan gilberto isidoro",
    "bomberos celestun rio lagartos reserva biosfera",
    "rescate acuatico cenotes yucatan",
    "bomberos uxmal ruta puuc",
    "calor extremo merida emergencia yucatan",
    "arff aeropuerto merida yucatan",
    "directorio bomberos yucatan municipios",
  ]}
  canonical={canonical}
  jsonLd={jsonLd}

  totalEstaciones={totalEstaciones}
  totalMunicipios={totalMunicipios}
  habitantes="2.3M+"

  heroDesc={`El <strong>Cuerpo de Bomberos del Municipio de Mérida</strong> —creado el <strong>14 de agosto de 1948</strong> mediante Decreto 223 del Congreso del Estado de Yucatán— protege el único estado de México sin un solo río superficial permanente: aquí el agua dulce existe exclusivamente en el <strong>acuífero kárstico de más de 6,000 cenotes</strong>, y los bomberos operan sin hidrantes rurales. Con <strong>${totalEstaciones} estaciones</strong> en este directorio, cubren <strong>2.3 millones de habitantes</strong>, dos sitios <strong>Patrimonio de la Humanidad UNESCO</strong> (Chichén Itzá y Uxmal), el <strong>Puerto de Progreso</strong> con su muelle de 6.5 km —uno de los más largos del continente—, el <strong>Aeropuerto Internacional de Mérida</strong> (ICAO Cat. 7), las reservas biósfera de <strong>Celestún y Ría Lagartos</strong> (RAMSAR) y una costa histórica de paso de huracanes, desde el <strong>Gilberto de 1988</strong> hasta el <strong>Isidoro de 2002</strong>.`}
  heroImage="/images/directorio/estacion-bomberos-turistica-01.avif"
