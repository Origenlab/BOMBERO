    { src: "/images/directorio/estacion-bomberos-playa-01.avif",                       alt: "Bomberos Puerto Progreso Yucatán — muelle 6.5 km cruceros internacionales rescate marítimo",                          label: "Puerto Progreso"        },
    { src: "/images/directorio/entrenamiento-bomberos-fuego-01.avif",                  alt: "Protección Chichén Itzá y Uxmal UNESCO Yucatán — protocolo INAH niebla baja presión zonas arqueológicas",            label: "Patrimonio UNESCO"      },
  ]}

  galleryImages={[
    { src: "/images/directorio/equipo-buceo-rescate-01.avif",              alt: "Rescate acuático y espeleobuceo en cenotes de Yucatán — sistema kárstico subterráneo acuífero maya",         label: "Cenotes: rescate kárstico" },
