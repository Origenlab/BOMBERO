---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import {
  estacionesYucatan,
  getMunicipios,
} from "@data/estaciones-yucatan";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("yucatan");

// ── Estadísticas derivadas del directorio ──────────────────────────────────
const totalEstaciones = estacionesYucatan.length;
const totalMunicipios = getMunicipios().length;
const totalBomberos   = estacionesYucatan.reduce((sum, e) => sum + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesYucatan.reduce((sum, e) => sum + (e.unidades ?? 0), 0);

const canonical = "https://bombero.mx/directorio/yucatan/";

// ── Comparativa regional ───────────────────────────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Metropolitana de Mérida",
    municipios: ["Mérida", "Kanasín", "Umán"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital (1.2M hab.), Centro Histórico colonial, corredor industrial, aeropuerto internacional y zona hospitalaria del sureste.",
  },
  {
    nombre: "Costa Norte / Puerto Progreso",
    municipios: ["Progreso", "Río Lagartos"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Muelle de 6.5 km (uno de los más largos del continente), cruceros internacionales, Reserva Biósfera Ría Lagartos (RAMSAR) y Las Coloradas.",
  },
  {
    nombre: "Corredor Chichén Itzá / Oriente",
    municipios: ["Tinum", "Valladolid", "Tizimín"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Chichén Itzá (2.5M visitantes/año), Valladolid (Pueblo Mágico), cenotes del oriente, corredor Mérida-Cancún.",
  },
  {
    nombre: "Ruta Puuc / Sur",
    municipios: ["Ticul", "Oxkutzcab", "Tekax"],
    cobertura: "Media",
    chip: "media",
    perfil: "Uxmal UNESCO, Kabah, Sayil, Labná; selva baja caducifolia y municipio más extenso del estado (Tekax).",
  },
  {
    nombre: "Reservas Biósfera / Costa Oeste",
    municipios: ["Celestún", "Izamal", "Motul"],
    cobertura: "Media",
    chip: "media",
    perfil: "Reserva Biósfera Ría Celestún (UNESCO/RAMSAR), humedales de manglar, Izamal Pueblo Mágico y corredor norte Mérida-Tizimín.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesYucatan.filter((e) => z.municipios.includes(e.municipio ?? ""));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Yucatán",
  "description": `Directorio de las ${totalEstaciones} estaciones del Heroico Cuerpo de Bomberos de Yucatán. Fundado en Mérida el 14 de agosto de 1948 (Decreto 223). Rescate espeleoacuático en cenotes, protección de Chichén Itzá y Uxmal (UNESCO), huracanes, Puerto Progreso y reservas biósfera. Emergencias: 911.`,
  "numberOfItems": estacionesYucatan.length,
  "itemListElement": estacionesYucatan.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.municipio,
        "addressRegion": "Yucatán",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/yucatan/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Yucatán: estaciones, historia y servicios de emergencia",
  "description": "Guía del Cuerpo de Bomberos de Yucatán: historia (1948–hoy), infraestructura en Mérida y el estado, rescate en cenotes, huracanes Gilberto e Isidoro, Chichén Itzá UNESCO, Puerto Progreso y directorio de estaciones con teléfonos directos.",
  "about": [
    "Cuerpo de Bomberos del Municipio de Mérida",
    "Protección Civil Yucatán",
    "Rescate espeleoacuático en cenotes",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/yucatan.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Yucatán",
  "description": `Directorio verificado de estaciones de bomberos en Yucatán, con teléfonos, cobertura, funciones e historia del Cuerpo de Bomberos fundado en Mérida en 1948.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Cuerpo de Bomberos del Municipio de Mérida, Yucatán" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/yucatan.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQ únicas de Yucatán (≥10) ─────────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Yucatán?",
    a: `Marca el <strong>911</strong> desde cualquier teléfono en Yucatán, las 24 horas del día, para bomberos, rescate o ambulancia. El sistema enruta la llamada a la unidad más cercana según tu ubicación. El Cuartel Central de Mérida tiene también el teléfono directo <strong>999 924 9242</strong>; Progreso: <strong>969 935 0071</strong>; Valladolid: <strong>985 856 2023</strong>. En zonas rurales y comunidades mayas alejadas, el 911 sigue siendo el canal más confiable.`,
  },
  {
    q: "¿Cuándo se fundó el Cuerpo de Bomberos de Mérida, Yucatán?",
    a: `El Cuerpo de Bomberos del Municipio de Mérida fue creado formalmente mediante el <strong>Decreto Número 223</strong>, publicado en el Diario Oficial del Estado de Yucatán el <strong>14 de agosto de 1948</strong>, bajo el gobierno del profesor José González Beytia. La ley lo define como una institución de servicio público cuyo objetivo es prevenir y extinguir incendios, y proteger vidas ante cualquier desastre. Cada <strong>22 de agosto</strong> se conmemora el Día del Bombero en México, fecha en que se fundó en 1873 el primer cuerpo de bomberos del país, en Veracruz.`,
  },
  {
    q: "¿Por qué el rescate en cenotes es una especialidad única de los bomberos de Yucatán?",
    a: `Yucatán tiene más de <strong>6,000 cenotes catalogados</strong> —pozas naturales de acceso al acuífero kárstico subterráneo— con profundidades de entre 5 y más de 40 metros y extensas galerías inundadas. Cuando un buceador o turista queda atrapado en estos sistemas, el rescate requiere <strong>buceo espeleoacuático</strong> (buceo en cuevas inundadas) con equipamiento técnico y protocolos de seguridad distintos al rescate acuático convencional. En 2025, Yucatán graduó a los <strong>primeros buzos espeleosocorristas de México</strong>, un equipo integrado a la red de rescate de Protección Civil y los cuerpos de bomberos estatales. La estación de Valladolid opera el único servicio con certificación en rescate espeleoacuático del sureste de México.`,
  },
  {
    q: "¿Qué fue el huracán Gilberto y cómo afectó a Yucatán?",
    a: `El huracán Gilberto tocó tierra en la Península de Yucatán el <strong>14 de septiembre de 1988</strong> como categoría 5, con vientos sostenidos de hasta <strong>287 km/h</strong>. Aunque el ojo no atravesó directamente Mérida, la capital experimentó vientos de hasta 152 km/h. El saldo en Yucatán incluyó decenas de miles de damnificados, 35,000 personas sin hogar en la península, 83 barcos hundidos y semanas sin electricidad ni agua potable. Gilberto representa hasta hoy el punto de referencia de la planificación de emergencias ante huracanes en el estado.`,
  },
  {
    q: "¿Qué fue el huracán Isidoro y qué lecciones dejó para los bomberos de Yucatán?",
    a: `El huracán Isidoro impactó la costa norte de Yucatán el <strong>22 de septiembre de 2002</strong>, tocando tierra en Telchac Puerto (a 45 km al este de Progreso) como categoría 3, con vientos de <strong>205 km/h</strong> y rachas de 250 km/h. El ciclón permaneció sobre la península durante más de 30 horas, dejando <strong>500,000 damnificados, 15,000 viviendas dañadas y 85 municipios en estado de desastre</strong>. Los servicios básicos tardaron hasta un mes en restablecerse en algunas comunidades. Isidoro fue el catalizador que modernizó los protocolos de coordinación entre bomberos, Protección Civil y SEMAR para la respuesta a huracanes en el sureste de México.`,
  },
  {
    q: "¿Por qué el calor extremo es un riesgo de emergencia en Yucatán?",
    a: `Mérida es una de las ciudades más cálidas de México: las temperaturas entre abril y mayo superan frecuentemente los <strong>40°C</strong>, con sensación térmica que puede alcanzar los <strong>45°C</strong> por el efecto de "isla de calor" urbana, que eleva la temperatura entre 3 y 5 grados más que el campo circundante. Estudios internacionales de 2026 han colocado a Mérida dentro del mapa mundial de ciudades con mayor exposición a riesgo por calor extremo. Para los bomberos, esto significa atención frecuente a golpes de calor en turistas, trabajadores y adultos mayores, además de mayores riesgos de incendio en época seca. Llamar al <strong>911</strong> ante síntomas de insolación grave.`,
  },
  {
    q: "¿Cómo protegen los bomberos yucatecos a Chichén Itzá y Uxmal durante eventos masivos?",
    a: `Chichén Itzá recibe más de <strong>2.5 millones de visitantes al año</strong> y concentra hasta <strong>40,000 personas en un solo día</strong> durante los equinoccios de primavera y otoño. La unidad de bomberos de Tinum mantiene protocolos de evacuación masiva coordinados con el INAH para esos eventos. Un factor crítico es que el sitio tiene una sola vía principal de acceso, lo que exige planificación específica de flujo ante emergencias. Los bomberos aplican técnica de <strong>niebla de baja presión</strong> para cualquier incendio en zona arqueológica, a fin de no dañar la caliza original de las estructuras. La estación de Ticul cubre la <strong>Zona Arqueológica de Uxmal</strong> (UNESCO), en la Ruta Puuc.`,
  },
  {
    q: "¿Qué hace especial al Puerto de Progreso en materia de emergencias?",
    a: `El muelle de Progreso tiene <strong>6.5 kilómetros de longitud</strong>, lo que lo convierte en uno de los más extensos del continente. Cuando un crucero atraca en el extremo del muelle, los pasajeros están a 6.5 km del punto de emergencia terrestre. Los bomberos de Progreso mantienen una unidad posicionada en el extremo del muelle durante la temporada de cruceros (aproximadamente <strong>150 cruceros internacionales al año</strong>), coordinan con la Capitanía de Puerto de la SEMAR y mantienen enlace de radio VHF con los oficiales de seguridad de cada navío. Los protocolos siguen los estándares IMO/OMI para emergencias a bordo.`,
  },
  {
    q: "¿Por qué Yucatán no tiene ríos superficiales y qué implica eso para los bomberos?",
    a: `La Península de Yucatán es una plataforma de <strong>roca caliza porosa (karst)</strong> que ha absorbido toda el agua superficial a lo largo de millones de años de erosión, sin dejar un solo río permanente en los 39,612 km² del estado. El agua dulce existe únicamente en el <strong>acuífero subterráneo</strong>, accesible a través de los cenotes. Para los bomberos que responden a incendios en zonas rurales, esto significa que el suministro de agua equivale estrictamente al contenido de los tanques de la autobomba. Cuando se vacían, la recarga requiere regresar a un punto de abastecimiento pre-identificado, un ciclo que puede durar de 20 a 40 minutos en municipios alejados. Esta logística de <em>tanque lanzadera</em> es el modo de operación estándar en cada incendio rural de Yucatán.`,
  },
  {
    q: "¿Qué servicios de emergencia prestan los bomberos de Yucatán?",
    a: `Los cuerpos de bomberos de Yucatán atienden: <strong>incendios estructurales, forestales y de manglar</strong>; <strong>rescate vehicular y extricación</strong>; <strong>atención prehospitalaria</strong>; <strong>rescate acuático y espeleoacuático en cenotes</strong>; <strong>materiales peligrosos (HAZMAT)</strong> en industria y transporte; control de <strong>fugas de gas</strong>; <strong>emergencias portuarias y marítimas</strong> en Progreso; <strong>ARFF aeronáutico</strong> en el aeropuerto de Mérida (ICAO Cat. 7); y <strong>protección civil ante huracanes</strong>. En las reservas biósfera (Celestún y Ría Lagartos), disponen de unidades de rescate acuático para emergencias en humedales y manglares.`,
  },
  {
    q: "¿Los bomberos de Yucatán atienden emergencias en las reservas biósfera?",
    a: `Sí. Las estaciones de <strong>Celestún</strong> y <strong>Río Lagartos</strong> cubren, respectivamente, la Reserva de la Biósfera Ría Celestún y la Reserva de la Biósfera Ría Lagartos, ambas sitios <strong>RAMSAR</strong> y de gran importancia para la conservación de los flamencos rosados. Los incendios en manglar y vegetación hídrica producen humo denso con llama poco visible, lo que complica la localización del frente activo. Las unidades de estas estaciones cuentan con lanchas de rescate y coordinan con la CONANP y la SEMARNAT para emergencias ambientales.`,
  },
  {
    q: "¿Cómo debo prepararme ante un huracán en Yucatán?",
    a: `Sigue siempre las instrucciones de <strong>Protección Civil Yucatán</strong> (999 930 3200) y el <strong>Sistema Meteorológico Nacional</strong>. Ante alerta de huracán: refuerza puertas y ventanas, almacena agua y alimentos para al menos 72 horas, carga medicamentos esenciales, identifica el refugio temporal más cercano, y aleja objetos del exterior que puedan convertirse en proyectiles. Marca el <strong>911</strong> solo ante emergencia real durante el evento; las líneas deben mantenerse libres para despachar recursos. Recuerda que en zonas costeras bajas como Progreso o Celestún, las marejadas de tormenta pueden inundar en minutos.`,
  },
];

