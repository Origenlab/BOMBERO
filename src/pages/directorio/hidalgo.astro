  { name: "Directorio de Bomberos", url: "/directorio" },
  { name: "Hidalgo",               url: "/directorio/hidalgo" },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Hidalgo, México",
  "numberOfItems": estacionesHidalgo.length,
  "itemListElement": estacionesHidalgo.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Hidalgo",
