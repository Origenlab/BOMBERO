---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-campeche";

const slug = "estacion-bomberos-escarcega";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Campeche",
  slug: "campeche",
  siglas: "CAM",
  poblacion: "1 millón",
  municipios: 13,
};

const estadosVecinos = [
  { nombre: "Yucatán", slug: "yucatan" },
  { nombre: "Quintana Roo", slug: "quintana-roo" },
  { nombre: "Tabasco", slug: "tabasco" },
  { nombre: "Chiapas", slug: "chiapas" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1970 para rescate vehicular pesado en la Carretera Federal 186 de Escárcega",
    badge: "NFPA 1970",
    title: "Traje Estructural NFPA 1970",
    text: `Certificación NFPA 1970 para los 35 elementos del nudo carretero más crítico del sureste mexicano: rescate en accidentes de tráiler de 40 toneladas con carga general, combustibles o materiales peligrosos en tránsito entre el Golfo de México y el Caribe, e incendios en autobuses de pasajeros de la ruta Villahermosa-Cancún.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1970 para rescate vehicular de alta energía en carreteras federales de Escárcega",
    badge: "NFPA 1970",
    title: "Casco Estructural NFPA 1970",
    text: `Resistencia certificada para operaciones en cabinas de tráiler aplastadas y vehículos volcados de alta velocidad en las carreteras federales 186 y 261, donde los accidentes con energía cinética de camiones de 80 km/h generan deformaciones estructurales complejas que requieren equipo hidráulico de extricación prolongado.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1970 para rescate vehicular pesado y operaciones en zona selvática de Escárcega",
    badge: "NFPA 1970",
    title: "Guantes Estructurales NFPA 1970",
    text: `Resistencia mecánica para operaciones con tijeras y separadores hidráulicos Holmatro en rescate de atrapados en cabinas de tractor-trailer y resistencia al calor para incendios en motores diesel de vehículos pesados. Compatibles con guantes de trabajo para labores de desmonte en cortafuegos de incendio forestal.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1970 para operaciones en carretera y selva en Escárcega Campeche",
    badge: "NFPA 1970",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para asfalto de carretera federal con fluidos de motor y combustible derramado, y agarre en terreno selvático húmedo de la zona de transición selva-sabana de Escárcega. Certificadas NFPA 1970 para el rango de emergencias carreteras y forestales del cruce más transitado del sureste.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>El Cruce donde Confluyen Quintana Roo, Tabasco, Yucatán y Campeche: 35 Elementos para Rescate Vehicular Pesado en la Ruta Villahermosa-Cancún, la Estación del Tren Maya y Selva en Transición</h2>
    <p>
      La <strong>Estación de Bomberos de Escárcega</strong>, ubicada en Calle 25 esquina Calle
      30, Centro, opera en el punto de confluencia de cuatro estados del sureste mexicano.
      Escárcega es donde la Carretera Federal 186 —que conecta Villahermosa con Chetumal y
      Cancún, una de las rutas de carga más transitadas del país— cruza perpendicularmente con
      la Federal 261 que sube hacia Mérida. Este nudo carretero registra flujo constante de
      tráileres de 40 toneladas, autobuses de pasajeros de larga distancia y vehículos de
      turismo que cruzan la Península de Yucatán. Con 35 elementos activos, unidad de rescate
      pesado industrial y tiempo de respuesta de 6 a 12 minutos en zona urbana, esta estación
      es la única barrera de emergencias en un radio de 150 km en tres de las cuatro
      direcciones del cruce.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Escárcega?</h3>
    <p>
      Para emergencias en Escárcega, la Carretera Federal 186 (hacia Chetumal o Villahermosa),
      la Federal 261 (hacia Mérida o Campeche) o la Estación del Tren Maya, marca el
      <strong>911</strong>. En accidentes con vehículos de carga con materiales peligrosos,
      el despacho activa protocolo HAZMAT desde la Estación Central de Campeche como
      refuerzo. Contacto directo: 982 824 0066. Los tiempos de 15 a 30 minutos en carretera
      reflejan la velocidad de respuesta real en un territorio sin otra estación de bomberos
      a menos de dos horas.
    </p>

    <h3>Carretera 186 Chetumal-Villahermosa: La Arteria de Carga del Sureste Mexicano</h3>
    <p>
      La Carretera Federal 186 es la vía de comunicación que une los estados petroleros del
      Golfo con la costa caribeña, y por ella transitan cientos de tráileres diarios con
      carga general, material de construcción para proyectos del sureste y combustibles
      líquidos hacia las terminales de distribución de Campeche y Quintana Roo. Los
      accidentes con tráileres volcados generan escenarios de alta complejidad: cabinas
      aplastadas con conductores atrapados, derrames de carga en la calzada y riesgo de
      incendio del tanque de diesel. La unidad de rescate pesado de esta estación tiene
      equipo hidráulico de extricación con apertura de hasta 65 toneladas de fuerza,
      diseñado para los vehículos más grandes de la ruta.
    </p>

    <h3>Tren Maya: La Estación Ferroviaria más Austral de Campeche en el Proyecto más Costoso de México</h3>
    <p>
      La Estación de Escárcega del Tren Maya —el proyecto de infraestructura más costoso
      en la historia de México con inversión superior a 300,000 millones de pesos— es
      un punto de parada del tramo 6 (Palenque-Cancún), con 400 km de vía. Una emergencia
      en tren ferroviario de pasajeros —descarrilamiento, incendio de vagón, accidente en
      cruce a nivel— es cualitativamente distinta a un accidente carretero: mayor cantidad
      de pasajeros simultáneos, vagones sellados que complican el rescate, energía de
      tracción eléctrica en algunas secciones y velocidades de hasta 160 km/h en
      tramos de vía nueva. El personal ha recibido capacitación específica para emergencias
      ferroviarias en coordinación con los operadores del proyecto.
    </p>

    <h3>Selva en Transición: Incendios Forestales en el Umbral entre Sabana y Selva Baja</h3>
    <p>
      El entorno de Escárcega es una zona de transición ecológica entre la selva tropical
      subperennifolia que domina al sur y la sabana de palmar al norte. Esta transición
      crea condiciones de riesgo de incendio forestal distintas a cada zona: la selva baja
      seca tiene alta inflamabilidad en temporada seca (febrero-abril), mientras que la
      sabana se incendia con quemas agrícolas que se descontrolan durante vientos del norte.
      La unidad forestal todoterreno permite acceso a brechas de vegetación donde las
      autobombas convencionales no pueden operar, actuando como primer control mientras
      CONAFOR moviliza brigadas desde bases regionales.
    </p>

    <h3>Cobertura hacia 4 Estados: El Mayor Radio de Acción de Campeche en Ausencia de Refuerzos</h3>
    <p>
      La posición geográfica de Escárcega significa que en cualquier accidente a más de 20 km
      del cruce, la estación opera sin posibilidad de refuerzo en menos de 90 minutos.
      Las comunidades agrícolas de Candelaria al sureste, las rancherías del municipio de
      Champotón al norte y los ejidos de la zona chicle al sur dependen exclusivamente
      de esta estación como primera respuesta. El sistema de comunicaciones de largo alcance
      y los radios satelitales permiten coordinación con comunidades sin cobertura celular.
      Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1970</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
