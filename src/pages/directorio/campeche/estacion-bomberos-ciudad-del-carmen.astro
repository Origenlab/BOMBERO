---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-campeche";

const slug = "estacion-bomberos-ciudad-del-carmen";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Campeche",
  slug: "campeche",
  siglas: "CAM",
  poblacion: "1 millón",
  municipios: 13,
};

const estadosVecinos = [
  { nombre: "Yucatán", slug: "yucatan" },
  { nombre: "Quintana Roo", slug: "quintana-roo" },
  { nombre: "Tabasco", slug: "tabasco" },
  { nombre: "Chiapas", slug: "chiapas" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 certificado para incendios en plataformas petroleras de la Sonda de Campeche",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 —exigida por contrato en operaciones coordinadas con PEMEX y contratistas internacionales— para los 92 elementos que operan en la capital petrolera de México. El traje debe resistir exposición a hidrocarburos fraccionados, humo denso de incendio de crudo y radiación térmica en incendios de tanques de almacenamiento de la Sonda de Campeche.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 con integración de comunicaciones para operaciones offshore en la Sonda de Campeche",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia certificada para operaciones en plataformas marinas con ruido industrial de fondo y requerimiento de comunicación simultánea con el Coordinador de Emergencias Offshore. Compatible con los sistemas de comunicaciones marítimas VHF que esta estación usa en coordinación con las brigadas privadas de PEMEX Exploración y Producción.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 con resistencia a hidrocarburos para emergencias en la industria petrolera",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia química al crudo, gas condensado y solventes aromáticos (xileno, tolueno) presentes en las operaciones de la Sonda de Campeche. Esta estación mantiene certificación HAZMAT Nivel Técnico para hidrocarburos, el nivel de especialización más alto alcanzado por un cuerpo municipal de bomberos en México.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para operaciones en plataformas marinas y muelles petroleros de Ciudad del Carmen",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante certificada para superficies metálicas de cubierta de plataforma con condensación marina, tablones de muelle con aceite residual y pavimento de zona industrial con derrames de fluidos de proceso. La isla de Carmen —conectada al continente solo por los puentes Zacatal y La Unidad— hace de la preparación del equipo personal una exigencia sin margen.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>La Capital Petrolera de México Requiere los 92 Elementos más Especializados del Sureste: HAZMAT Nivel Técnico, Cañones de Espuma de 100 Metros y Coordinación con 200+ Plataformas Marinas de la Sonda de Campeche</h2>
    <p>
      La <strong>Estación de Bomberos de Ciudad del Carmen</strong>, ubicada en Calle 31 por 20,
      Centro, es la instalación de bomberos de mayor especialización industrial del sureste mexicano.
      Ciudad del Carmen es una isla de 32 km de largo por 8 de ancho conectada al continente
      solo por los puentes Zacatal —3.2 km, el tercero más largo de México— y La Unidad —3.8 km—,
      y es la base de operaciones terrestre para la Sonda de Campeche: el campo petrolero que
      en su pico histórico de 2004 llegó a producir 2.1 millones de barriles diarios,
      representando más del 60% de la producción nacional de hidrocarburos. Con 92 elementos
      activos, certificación HAZMAT Nivel Técnico, cañones de espuma AFFF de 100 metros de
      alcance y 2 lanchas de rescate de alta velocidad, esta estación tiene el perfil operativo
      más exigente de toda la región.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Ciudad del Carmen?</h3>
    <p>
      Para emergencias en Ciudad del Carmen, la Zona Industrial, el Puerto Comercial, los puentes
      Zacatal y La Unidad o la Laguna de Términos, marca el <strong>911</strong>. Para
      incidentes offshore en la Sonda de Campeche, la coordinación se activa a través de PEMEX
      Exploración y Producción, que gestiona el puente aéreo desde los helipuertos de la ciudad.
      Contacto directo: 938 382 5050. El tiempo de respuesta terrestre es de 5 a 10 minutos;
      las operaciones offshore requieren coordinación adicional con helicópteros de PEMEX.
    </p>

    <h3>Sonda de Campeche: El Mayor Campo Petrolero del Hemisferio Occidental en su Pico</h3>
    <p>
      La Sonda de Campeche, descubierta en los años 70 y cuyo yacimiento estrella —Cantarell—
      fue encontrado formalmente en 1976 por el pescador Rudesindo Cantarell, produjo en 2004
      la cifra récord de 2.1 millones de barriles diarios, posicionando a México como el
      quinto productor mundial de petróleo. Más de 200 plataformas marinas operan
      simultáneamente en aguas de entre 30 y 3,500 metros de profundidad. Un incidente mayor
      en plataforma —como el incendio de la Unidad Habitacional de Abkatún-Alfa en 2015,
      que dejó 4 trabajadores muertos— exige respuesta coordinada entre las brigadas privadas
      de la plataforma, PEMEX, la Armada de México y esta estación como primer recurso
      terrestre especializado en hidrocarburos.
    </p>

    <h3>HAZMAT Nivel Técnico: La Certificación más Alta del Sureste para Hidrocarburos</h3>
    <p>
      El nivel técnico de HAZMAT —según la clasificación NFPA 472— es el más alto que puede
      alcanzar un cuerpo de bomberos sin ser una unidad especializada de respuesta industrial.
      Permite identificación de materiales por análisis instrumental, intervención ofensiva
      con trajes encapsulados Nivel A y gestión de incidentes complejos con múltiples zonas
      de contaminación. Para la industria del petróleo y gas, este nivel es el mínimo exigible
      en cualquier empresa contratista de PEMEX que opera en la Sonda. Ciudad del Carmen es
      el único municipio de Campeche con esta certificación activa y los equipos de laboratorio
      móvil para sostenerla operativamente.
    </p>

    <h3>Los Puentes Zacatal y La Unidad: El Riesgo de Aislamiento Total en Huracán</h3>
    <p>
      La condición de isla de Ciudad del Carmen tiene una vulnerabilidad estructural que define
      la planificación de emergencias: si un huracán de categoría 3 o superior daña los dos
      puentes simultáneamente, la isla queda sin comunicación terrestre. El huracán Dean (2007)
      estuvo a menos de 100 km al pasar al sur del municipio, con efectos que alcanzaron la
      isla. El protocolo de huracán de esta estación contempla la posibilidad de operar en
      aislamiento total por 72 horas: reservas de combustible, agua potable, alimentos y
      equipos médicos suficientes para sostener operaciones sin apoyo externo. Esto incluye
      la coordinación previa de la evacuación de 20,000 trabajadores petroleros de las
      plataformas marinas antes del impacto.
    </p>

    <h3>Laguna de Términos: Área Natural Protegida con Emergencias en Ecosistema de Manglar</h3>
    <p>
      La Laguna de Términos, protegida como Área de Protección de Flora y Fauna desde 1994
      con 706,147 hectáreas, rodea la isla de Carmen por el norte y el oriente. Un derrame
      de hidrocarburos que alcance la laguna —uno de los ecosistemas de manglar más productivos
      del Golfo de México— tiene consecuencias ambientales de décadas. La estación mantiene
      equipos de contención de derrames en agua, barreras absorbentes y coordinación con
      PROFEPA y la CONANP para respuesta ambiental de primera hora en incidentes que
      amenacen la Laguna de Términos. En <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
