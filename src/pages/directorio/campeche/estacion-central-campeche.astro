---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-campeche";

const slug = "estacion-central-campeche";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Campeche",
  slug: "campeche",
  siglas: "CAM",
  poblacion: "1 millón",
  municipios: 13,
};

const estadosVecinos = [
  { nombre: "Yucatán", slug: "yucatan" },
  { nombre: "Quintana Roo", slug: "quintana-roo" },
  { nombre: "Tabasco", slug: "tabasco" },
  { nombre: "Chiapas", slug: "chiapas" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1970 para incendios en edificios coloniales de cantera del siglo XVII en Campeche",
    badge: "NFPA 1970",
    title: "Traje Estructural NFPA 1970",
    text: `Certificación NFPA 1970 para los 78 elementos que operan en el único centro histórico amurallado del continente americano declarado Patrimonio UNESCO. La cantera rosa de los edificios coloniales —que data del siglo XVII— es una roca calcárea que puede fragmentarse con explosividad cuando recibe agua a alta presión en estado de calentamiento extremo, exigiendo técnicas de combate específicas.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1970 para operaciones en bóvedas coloniales y baluartes del siglo XVII en Campeche",
    badge: "NFPA 1970",
    title: "Casco Estructural NFPA 1970",
    text: `Resistencia certificada para operaciones en techos de bóveda de cañón corrido de los edificios coloniales de Campeche, cuyo sistema constructivo de arcos de mampostería tiene un modo de colapso distinto al concreto: el arco puede ceder de manera abrupta sin señales previas cuando la clave pierde continuidad por el calor.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1970 para rescate en estructuras patrimoniales del Centro Histórico de Campeche",
    badge: "NFPA 1970",
    title: "Guantes Estructurales NFPA 1970",
    text: `Compatibilidad con equipos de rescate manual en estructuras de mampostería histórica y resistencia para operaciones de rescate acuático en el Golfo de México. Las calles estrechas del siglo XVIII del Centro Histórico exigen trabajo manual frecuente que las autobombas no pueden alcanzar.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1970 para pavimentos coloniales y malecón del Golfo en Campeche",
    badge: "NFPA 1970",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para adoquines de cantera mojada del Centro Histórico —con alta probabilidad de escurrimientos durante lluvias tropicales— y para el Malecón del Golfo de México. Certificadas NFPA 1970 para el entorno operativo más patrimonialmente sensible del sureste mexicano.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>78 Elementos en la Única Ciudad Amurallada del Continente: Incendios en Cantera del Siglo XVII, 8 Baluartes Patrimonio UNESCO y la Memoria de 4 Siglos de Piratería en el Golfo de México</h2>
    <p>
      La <strong>Estación Central de Bomberos de San Francisco de Campeche</strong>, fundada
      el 22 de agosto de 1921 en Av. Resurgimiento 120, Santa Ana, protege la única ciudad histórica
      amurallada del continente americano declarada Patrimonio de la Humanidad por UNESCO en 1999.
      Con 78 elementos activos, 11 unidades —incluyendo escalera telescópica de 32 metros, unidad
      HAZMAT con trajes Nivel A, sistema de cámaras térmicas FLIR y unidad de mando móvil con
      comunicaciones satelitales— y tiempo de respuesta de 4 a 8 minutos, esta estación opera en
      un escenario sin equivalente en México: edificios de cantera rosa del siglo XVII, calles de
      5 metros de ancho y 8 baluartes de mampostería que definen una geometría urbana diseñada
      para resistir cañonazos, no para facilitar la entrada de autobombas modernas.
    </p>

    <h3>¿Cómo Llamar a la Estación Central de Bomberos de San Francisco de Campeche?</h3>
    <p>
      Para emergencias en el Centro Histórico, los baluartes, el Malecón del Golfo o cualquier
      barrio de la ciudad, marca el <strong>911</strong>. El despacho de esta estación coordina la
      respuesta metropolitana y activa los protocolos de emergencia para el Centro Histórico
      UNESCO con la coordinación del INAH en incidentes que afecten edificios catalogados.
      Contacto directo: 981 811 3636. El tiempo de respuesta de 4 a 8 minutos aplica al área
      central; las calles del Primer Cuadro pueden exigir reposicionamiento de unidades por las
      dimensiones históricas del trazado urbano.
    </p>

    <h3>Cantera Rosa del Siglo XVII: El Material que Define el Mayor Desafío Técnico</h3>
    <p>
      La cantera calcárea de la que están construidos los edificios del Centro Histórico de
      Campeche no solo es bella: es un material que reacciona de manera impredecible al fuego
      prolongado y al agua a presión. La roca calcárea calentada a temperaturas superiores a
      700°C sufre calcificación parcial —conversión de carbonato de calcio en óxido de calcio—
      que debilita su estructura interna y puede generar fragmentación explosiva al contacto
      con agua fría de las mangueras. El protocolo de esta estación para incendios en edificios
      coloniales incluye una fase de evaluación térmica con cámaras FLIR antes de iniciar el
      ataque con agua, una precaución que ninguna otra estación urbana de México necesita de
      forma rutinaria.
    </p>

    <h3>8 Baluartes y 2.5 km de Muralla: El Legado de los Ataques Piratas que Forjó la Ciudad</h3>
    <p>
      Campeche construyó sus murallas y 8 baluartes entre 1686 y 1704 como respuesta directa
      a los ataques piratas que asolaron la ciudad durante el siglo XVII. El más devastador
      ocurrió en febrero de 1663, cuando el pirata Laurens de Graaf (Lorencillo) incendió el
      pueblo y asesinó o esclavizó a casi toda la población. Esa historia de destrucción por
      fuego explica por qué Campeche construyó las únicas murallas continuas de América
      continental. Hoy, esos mismos baluartes que protegieron de piratas son los que el
      personal de esta estación debe proteger del fuego: el Baluarte de San Carlos (actual
      Museo de la Ciudad), el de la Soledad (Museo de Estelas Mayas) y el de Santiago
      (Jardín Botánico) son edificaciones del siglo XVII que no pueden perderse.
    </p>

    <h3>Huracanes del Golfo de México: Base de Operaciones para Emergencias Estatales</h3>
    <p>
      Campeche es la primera línea de impacto de los huracanes que se forman en el Caribe y
      cruzan la Península de Yucatán, o que se desarrollan directamente en el Golfo de México.
      El huracán Isidore (2002) tocó tierra en Telchac Puerto, Yucatán, pero sus bandas
      exteriores inundaron Ciudad del Carmen con más de 300 mm de lluvia en 24 horas. El
      huracán Dean (2007) categoría 5 impactó la Península de Yucatán con vientos de 285 km/h.
      Esta estación mantiene un protocolo de activación preventiva que inicia 48 horas antes
      del impacto proyectado: refuerzo de guardias, preposicionamiento de equipos y
      coordinación con Protección Civil estatal.
    </p>

    <h3>Coordinación INAH para Edificios Catalogados: Operaciones que no Pueden Dañar el Patrimonio</h3>
    <p>
      El INAH tiene catalogados más de 1,200 edificios en el Centro Histórico de Campeche,
      lo que significa que prácticamente cualquier incendio en el primer cuadro involucra
      un inmueble de valor patrimonial federal. El protocolo de coordinación con el INAH
      establece que el personal de emergencias documente fotográficamente el estado previo
      y posterior de los elementos patrimoniales afectados, y que las técnicas de combate
      minimicen el daño a fachadas, puertas de madera del siglo XVIII y elementos decorativos
      de cantera. Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1970</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica y certificado de laboratorio incluidos.
    </p>
  </Fragment>
</EstacionLayout>
