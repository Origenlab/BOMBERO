---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-campeche";

const slug = "estacion-bomberos-champoton";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Campeche",
  slug: "campeche",
  siglas: "CAM",
  poblacion: "1 millón",
  municipios: 13,
};

const estadosVecinos = [
  { nombre: "Yucatán", slug: "yucatan" },
  { nombre: "Quintana Roo", slug: "quintana-roo" },
  { nombre: "Tabasco", slug: "tabasco" },
  { nombre: "Chiapas", slug: "chiapas" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para incendios en embarcaciones camaroneras y procesadoras de Champotón",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 28 elementos que protegen el principal puerto camaronero de Campeche: incendios en motores diesel de embarcaciones, en plantas procesadoras de mariscos con almacenes de amoníaco para refrigeración industrial y en galerones de almacenamiento de redes impregnadas con conservantes.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para rescate acuático en el Río Champotón y el Golfo de México",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia certificada para operaciones de rescate en la desembocadura del Río Champotón, donde la confluencia de agua dulce y agua marina del Golfo crea corrientes de fondo irregulares. En emergencias de embarcación pesquera, la operación en lancha de rescate con oleaje de viento del norte exige protección a impacto en caso de golpe de mar.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para operaciones en flota camaronera y rescate costero en Champotón",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia mecánica para manejo de redes metálicas de arrastre, cables y maquinaria de winch en embarcaciones camaroneras durante rescates, y resistencia química para emergencias con amoníaco de sistemas de refrigeración de procesadoras de camarón de exportación.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para operaciones en muelle pesquero y playa del Golfo en Champotón",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela antiderrapante para tablones de madera de muelle con escamas de pescado y humedad constante, arena de playa del Golfo y pavimento de la zona procesadora con agua de lavado industrial. Certificadas NFPA 1971 para el entorno operativo portuario-pesquero del municipio campechano con mayor frente de costa.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>El Puerto de la Primera Derrota de la Conquista: 28 Elementos en la Costa donde los Mayas Rechazaron a Hernández de Córdoba en 1517, Capital Camaronera del Golfo y Puerta de los Huracanes</h2>
    <p>
      La <strong>Estación de Bomberos de Champotón</strong>, ubicada en Calle 28 s/n, Centro,
      protege una costa cargada de historia y de riesgo simultáneo. Champotón —llamada
      "la novia del mar" por sus habitantes— fue escenario en marzo de 1517 de la Batalla
      de Champotón, donde los guerreros mayas bajo el mando del cacique Mochcouoh derrotaron
      decisivamente la expedición de Francisco Hernández de Córdoba: el propio Hernández
      resultó herido de muerte y murió a su regreso a Cuba. Fue la primera victoria militar
      de los pueblos americanos frente a la conquista española. Cinco siglos después, con
      28 elementos activos, 5 unidades y tiempo de respuesta de 5 a 10 minutos, esta
      estación protege el principal puerto camaronero del Golfo de Campeche y una costa
      que recibe el impacto directo de los huracanes formados en el Mar Caribe.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Champotón?</h3>
    <p>
      Para emergencias en el Centro de Champotón, el Puerto Pesquero, el Río Champotón,
      la Playa o la Carretera Costera 180, marca el <strong>911</strong>. El despacho
      coordina esta estación con la Central de Campeche para incidentes que requieran
      refuerzos especializados. Contacto directo: 982 828 0038. En emergencias marítimas
      activas en el Golfo, el despacho coordina simultáneamente con la Capitanía de Puerto
      y la Armada de México.
    </p>

    <h3>Flota Camaronera: Incendios en Embarcaciones de 20 Metros con Diesel y Amoniaco</h3>
    <p>
      La flota camaronera de Champotón opera con embarcaciones de 18 a 25 metros de eslora
      con tanques de diesel de 8,000 a 15,000 litros y equipos de pesca de arrastre con
      winches de acero de alta tensión. Un incendio de motor en estas embarcaciones puede
      alcanzar el tanque de combustible en minutos si no se controla desde el inicio. Las
      plantas procesadoras en tierra tienen sistemas de refrigeración industrial con amoníaco
      anhidro —el mismo gas que en concentración de 25 ppm es ya peligroso para la salud—
      para el mantenimiento de temperatura en la cadena de frío del camarón de exportación.
      La estación tiene procedimiento específico de evacuación perimetral de 300 metros
      para fugas de amoníaco en zona procesadora.
    </p>

    <h3>Río Champotón y Laguna de Términos: Dos Ecosistemas Acuáticos de Alta Complejidad</h3>
    <p>
      El Río Champotón es uno de los pocos ríos navegables de la costa del Golfo de México
      en Campeche, con caudal constante que ha alimentado la cultura maya desde hace más de
      2,000 años. La desembocadura del río en el Golfo crea una zona de confluencia con
      sedimentación dinámica que cambia el perfil de fondo cada temporada de lluvias.
      Las emergencias de embarcación —motores averiados, encallamiento, persona al agua—
      en el tramo final del río antes de la desembocadura son los rescates acuáticos más
      frecuentes de esta estación. La lancha de 18 pies está diseñada para operar tanto
      en el río como en la costa del Golfo con oleaje de hasta 1.5 metros.
    </p>

    <h3>Huracanes e Inundaciones: La Costa de la Temporada Ciclónica del Golfo de México</h3>
    <p>
      La Carretera Costera 180 que une Campeche con Champotón corre a menos de 500 metros
      del mar en sus tramos más expuestos, y la marejada ciclónica de un huracán de
      categoría 2 o superior puede cruzar la carretera e inundar las comunidades costeras
      del municipio. El huracán Isidore (septiembre 2002), aunque tocó tierra en Yucatán,
      causó inundaciones de hasta 2 metros en localidades costeras de Champotón por el
      oleaje y las lluvias asociadas. La estación mantiene un mapa actualizado de zonas
      de inundación costera para activar evacuaciones preventivas antes del impacto de
      fenómenos tropicales.
    </p>

    <h3>Protección del Patrimonio Natural: Playas de Anidación de Tortuga Marina</h3>
    <p>
      Las playas de Champotón son zona de anidación de tortuga carey y tortuga blanca,
      con protección federal bajo la NOM-059-SEMARNAT. Los incendios de vegetación costera
      —frecuentes en la temporada seca de febrero a abril— amenazan directamente los
      nidos en las dunas. Esta estación coordina con la CONANP y los campamentos tortugueros
      para activar protocolos de protección de nidadas durante operaciones de combate de
      incendio en zona de playa. La gestión del fuego en litoral con anidación activa es
      un procedimiento que pocas estaciones de bomberos de México tienen que implementar.
      Se distribuye
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
