---

import EstacionLayout from "@layouts/EstacionLayout.astro";
import { getEstacionBySlug, getEstacionesCercanas } from "@data/estaciones-campeche";

const slug = "estacion-bomberos-calkini";
const estacion = getEstacionBySlug(slug);

if (!estacion) {
  return Astro.redirect("/404");
}

const estacionesCercanas = getEstacionesCercanas(slug, 3);

const estado = {
  nombre: "Campeche",
  slug: "campeche",
  siglas: "CAM",
  poblacion: "1 millón",
  municipios: 13,
};

const estadosVecinos = [
  { nombre: "Yucatán", slug: "yucatan" },
  { nombre: "Quintana Roo", slug: "quintana-roo" },
  { nombre: "Tabasco", slug: "tabasco" },
  { nombre: "Chiapas", slug: "chiapas" },
];

const eppCards = [
  {
    image: "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-01.avif",
    imageAlt: "Traje Estructural NFPA 1971 para emergencias en talleres artesanales y haciendas históricas de Calkiní",
    badge: "NFPA 1971",
    title: "Traje Estructural NFPA 1971",
    text: `Certificación NFPA 1971 para los 22 elementos que protegen la zona artesanal más valiosa del norte de Campeche: incendios en talleres de tejido de palma jipi japa con aceites naturales altamente inflamables, en bodegas de henequén seco de las haciendas del siglo XIX y en iglesias coloniales con estructuras de madera de cientos de años.`,
    href: "/productos/trajes-para-bomberos/",
    linkLabel: "Ver Trajes para Bombero",
  },
  {
    image: "/images/directorio/casco-bombero-proteccion-cabeza-01.avif",
    imageAlt: "Casco NFPA 1971 para incendios en haciendas henequeneras y espacios subterráneos de Calkiní",
    badge: "NFPA 1971",
    title: "Casco Estructural NFPA 1971",
    text: `Resistencia certificada para operaciones en las estructuras de las haciendas henequeneras del siglo XIX —con techos de bóveda de cañón similar al Centro Histórico de Campeche— y para el acceso en emergencias a las cuevas subterráneas donde los artesanos de Becal trabajan el jipi japa en condiciones de alta humedad.`,
    href: "/productos/cascos-para-bomberos/",
    linkLabel: "Ver Cascos para Bombero",
  },
  {
    image: "/images/directorio/guantes-bombero-resistentes-01.avif",
    imageAlt: "Guantes NFPA 1971 para rescate vehicular en la Carretera 180 Camino Real de Calkiní",
    badge: "NFPA 1971",
    title: "Guantes Estructurales NFPA 1971",
    text: `Resistencia mecánica para rescate vehicular en la Carretera Federal 180 —el antiguo Camino Real colonial que unía Campeche con Mérida— donde el tráfico de camiones entre las dos capitales estatales genera accidentes de alta energía en un tramo con curvas de visibilidad reducida.`,
    href: "/productos/guantes-para-bomberos/",
    linkLabel: "Ver Guantes para Bombero",
  },
  {
    image: "/images/directorio/botas-bombero-proteccion-01.avif",
    imageAlt: "Botas NFPA 1971 para terreno de zona henequenera y comunidades mayas de Calkiní",
    badge: "NFPA 1971",
    title: "Botas Estructurales de Cuero",
    text: `Suela de agarre para terreno de milpa maya con suelo calizo pedregoso, pisos de hacienda con tierra apisonada del siglo XIX y caminos de terracería hacia comunidades hablantes de maya en el interior del municipio. Certificadas NFPA 1971 para el entorno agrícola-patrimonial del norte de Campeche.`,
    href: "/productos/botas-para-bomberos/",
    linkLabel: "Ver Botas para Bombero",
  },
];
---

<EstacionLayout
  estacion={estacion}
  estado={estado}
  estadosVecinos={estadosVecinos}
  estacionesCercanas={estacionesCercanas}
  eppCards={eppCards}
>
  <Fragment slot="seo-content">
    <h2>22 Elementos en el Municipio de los Sombreros que se Tejen Bajo Tierra: Becal, las Cuevas de Jipi Japa, Haciendas Henequeneras del Siglo XIX y el Camino Real Colonial hacia Mérida</h2>
    <p>
      La <strong>Estación de Bomberos de Calkiní</strong>, ubicada en Calle 18 s/n, Centro,
      protege el rincón más singular de la artesanía mesoamericana del norte de Campeche.
      A 25 km de Calkiní se encuentra Becal —la capital de los sombreros jipi japa— donde
      artesanas y artesanos tejen en cuevas subterráneas excavadas bajo sus propias casas
      para aprovechar la humedad natural del subsuelo calizo y mantener flexible la fibra
      de palma. Los sombreros de Becal —exportados a Estados Unidos, Europa y Japón
      como uno de los productos artesanales más reconocidos de México— se tejen en un
      entorno que combina combustibilidad de materiales naturales con espacios confinados
      subterráneos. Con 22 elementos activos y tiempo de respuesta de 5 a 10 minutos
      en zona urbana, esta estación opera en el municipio fronterizo entre Campeche y
      Yucatán con mayor densidad de patrimonio cultural inmaterial.
    </p>

    <h3>¿Cómo Llamar a la Estación de Bomberos de Calkiní?</h3>
    <p>
      Para emergencias en Calkiní, Becal, Dzitbalché, Santa Cruz, Nunkiní o cualquier
      comunidad del municipio, marca el <strong>911</strong>. El personal de esta estación
      habla español y maya, lo que facilita la comunicación en las 18 comunidades del
      municipio donde el maya yucateco es lengua predominante. Contacto directo: 996 963 0033.
      Los tiempos de 15 a 25 minutos para comunidades rurales reflejan las distancias reales
      en un municipio de 2,096 km².
    </p>

    <h3>Becal y las Cuevas de Jipi Japa: Un Espacio Confinado con Riesgo de Incendio Específico</h3>
    <p>
      Las cuevas de trabajo de Becal son excavaciones de 1.5 a 3 metros de profundidad bajo
      las viviendas, ventiladas únicamente por una entrada estrecha. La fibra de palma
      jipi japa seca que no se está trabajando, los aceites naturales de tratamiento y
      los humos de las velas que se usaban históricamente para alumbrado hacen de estos
      espacios un entorno con alta carga combustible en espacio confinado. Un incendio
      en una cueva de Becal exige una técnica de intervención distinta a cualquier
      emergencia urbana convencional: acceso restringido, escasa ventilación natural y
      riesgo de afectación a la vivienda construida sobre la cueva.
    </p>

    <h3>Haciendas Henequeneras del Siglo XIX: El Patrimonio Agroindustrial del Norte de Campeche</h3>
    <p>
      El norte de Campeche y el sur de Yucatán concentran haciendas henequeneras construidas
      durante el auge del "oro verde" —la fibra de agave sisal usada para cuerdas y sacos—
      entre 1880 y 1940. Estas haciendas tienen cascos patronales de mampostería con
      elementos ornamentales de estuco, maquinaria desfibriladora histórica de hierro
      fundido y bodegas de henequén seco de alta inflamabilidad. Varias de estas haciendas
      han sido rehabilitadas como hoteles boutique en el corredor Calkiní-Hecelchakán,
      incrementando la exposición al riesgo de incendio con huéspedes que no conocen
      las particularidades del edificio histórico.
    </p>

    <h3>Comunidades Mayas: Atención de Emergencias en Lengua Maya Yucateca</h3>
    <p>
      El municipio de Calkiní tiene una de las tasas más altas de hablantes de maya yucateco
      de Campeche: más del 40% de la población usa el maya como primera lengua en las
      comunidades del interior. En una emergencia con víctimas que solo hablan maya,
      la capacidad de comunicación directa del personal —sin intérprete— puede ser
      determinante para entender la situación: la ubicación de otras personas en el
      inmueble, la naturaleza del material incendiado o la condición médica del afectado.
      La estación mantiene al menos un elemento con competencia comunicativa en maya
      en cada guardia de 24 horas.
    </p>

    <h3>Carretera 180 Camino Real: El Corredor Colonial que une dos Capitales Estatales</h3>
    <p>
      La Carretera Federal 180 sigue el trazo del antiguo Camino Real colonial que unía
      Mérida con Campeche desde el siglo XVI —la misma ruta por la que viajaban frailes,
      comerciantes y funcionarios de la Nueva España. Hoy es la carretera de mayor flujo
      entre las dos capitales estatales, con tráfico de camiones de carga, autobuses y
      vehículos particulares. Los accidentes en el tramo Calkiní-Hecelchakán son frecuentes
      por la combinación de velocidad alta, curvas de visibilidad limitada y ganado suelto
      en brechas adyacentes. En <a href="/">BOMBERO.MX</a> distribuimos
      <a href="/productos/trajes-para-bomberos/">trajes NFPA 1971</a>,
      <a href="/productos/cascos-para-bomberos/">cascos</a>,
      <a href="/productos/guantes-para-bomberos/">guantes</a> y
      <a href="/productos/botas-para-bomberos/">botas certificadas</a>.
      <a href="/cotizar/">Solicita cotización</a> con ficha técnica incluida.
    </p>
  </Fragment>
</EstacionLayout>
