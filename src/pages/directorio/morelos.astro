---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesMorelos, getMunicipios, ESTADISTICAS_MORELOS } from "@data/estaciones-morelos";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estadosVecinos = getEstadosVecinos("morelos");

const municipios = getMunicipios();

const canonical = "https://bombero.mx/directorio/morelos/";

// ── Comparativa regional ───────────────────────────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Metropolitana Cuernavaca",
    municipiosZona: ["Cuernavaca", "Temixco"],
    cobertura: "Total",
    chip: "total",
    perfil: "Capital del estado, 50+ barrancas urbanas, Palacio de Cortés (1535), turismo de fin de semana.",
  },
  {
    nombre: "Zona Industrial CIVAC",
    municipiosZona: ["Jiutepec"],
    cobertura: "Total",
    chip: "total",
    perfil: "~160 empresas desde 1966, HAZMAT farmacéutico y automotriz, Nissan Mexicana.",
  },
  {
    nombre: "Altos de Morelos",
    municipiosZona: ["Tepoztlán"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Pueblos Mágicos Tepoztlán y Tlayacapan, rescate de montaña, incendios forestales.",
  },
  {
    nombre: "Valle de Cuautla",
    municipiosZona: ["Cuautla", "Oaxtepec", "Yautepec", "Axochiapan"],
    cobertura: "Alta",
    chip: "alta",
    perfil: "Segunda ciudad, balnearios termales, epicentro sismo 19S 2017, agroquímicos.",
  },
  {
    nombre: "Haciendas del Sur",
    municipiosZona: ["Jojutla", "Zacatepec de Hidalgo", "Puente de Ixtla"],
    cobertura: "Media",
    chip: "media",
    perfil: "Zona cañera, ingenios azucareros, zona más dañada sismo 2017, Xochicalco UNESCO.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesMorelos.filter((e) => z.municipiosZona.includes(e.ciudad ?? ""));
  return {
    ...z,
    nEst: est.length,
  };
});

// ── Schemas estructurados ───────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Estaciones de Bomberos en Morelos, México",
  "description": `Directorio completo de las ${estacionesMorelos.length} estaciones de bomberos en Morelos. Protección para Cuernavaca, Cuautla, Tepoztlán, zona industrial CIVAC, Xochicalco UNESCO y 2 millones de habitantes a 85 km de CDMX. Emergencias 911.`,
  "numberOfItems": estacionesMorelos.length,
  "itemListElement": estacionesMorelos.map((e, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "FireStation",
      "name": e.nombre,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.ciudad,
        "addressRegion": "Morelos",
        "addressCountry": "MX",
      },
      "telephone": e.telefono,
      "url": `https://bombero.mx/directorio/morelos/${e.slug}`,
    }
  }))
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Bomberos en Morelos: estaciones, historia y servicios de emergencia",
  "description": "Guía de los cuerpos de bomberos de Morelos: historia (Cuernavaca 1943, Cuautla 1958), infraestructura en 6 zonas operativas, funciones, retos y directorio de estaciones con teléfonos directos.",
  "about": [
    "Heroico Cuerpo de Bomberos de Cuernavaca",
    "Bomberos de Cuautla",
    "Protección Civil Morelos",
    "Servicios de emergencia",
  ],
  "inLanguage": "es-MX",
  "image": "https://bombero.mx/api/og/estado/morelos.svg",
  "author":    { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "publisher": { "@type": "Organization", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
  "mainEntityOfPage": canonical,
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": canonical,
  "url": canonical,
  "name": "Estaciones de Bomberos en Morelos",
  "description": `Directorio verificado de estaciones de bomberos en los municipios de Morelos, con teléfonos, cobertura, funciones e historia de los cuerpos de bomberos del estado.`,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "BOMBERO.MX", "url": "https://bombero.mx/" },
  "about": { "@type": "GovernmentOrganization", "name": "Heroico Cuerpo de Bomberos de Cuernavaca" },
  "primaryImageOfPage": "https://bombero.mx/api/og/estado/morelos.svg",
  "dateModified": DIRECTORIO_VERIFICADO_ISO,
};

const jsonLd = [itemListSchema, articleSchema, collectionPageSchema];

// ── FAQs únicas de Morelos (≥10) ──────────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencia para llamar a los bomberos en Morelos?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas a través del C5 de Morelos. La llamada se enruta a la estación con menor tiempo de respuesta. En Cuernavaca el promedio es de <strong>4 a 7 minutos</strong>; en zonas de sierra o corredor carretero puede extenderse. También puedes llamar directamente a la Estación Central de Cuernavaca: <strong>(777) 312-3636</strong>.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Morelos?",
    a: `Este directorio registra <strong>${estacionesMorelos.length} estaciones de bomberos</strong> distribuidas en los principales municipios del estado, organizadas en 6 zonas operativas: Zona Metropolitana Cuernavaca, Zona Industrial CIVAC, Altos de Morelos, Valle de Cuautla, Haciendas del Sur y Corredor Norte CDMX. Las corporaciones principales son el Heroico Cuerpo de Bomberos de Cuernavaca y el Heroico Cuerpo de Bomberos de Cuautla.`,
  },
  {
    q: "¿Cuándo se fundó el Heroico Cuerpo de Bomberos de Cuernavaca?",
    a: `El <strong>Heroico Cuerpo de Bomberos de Cuernavaca</strong> fue fundado en <strong>1943</strong>, siendo el más antiguo del estado de Morelos. El de Cuautla, la segunda ciudad más importante, fue fundado en <strong>1958</strong>. En México, el primer cuerpo de bomberos del país se estableció el <strong>22 de agosto de 1873 en Veracruz</strong>, fecha que se conmemora como el Día del Bombero.`,
  },
  {
    q: "¿Cómo respondieron los bomberos al sismo del 19 de septiembre de 2017 en Morelos?",
    a: `El sismo del 19 de septiembre de 2017 (Mw 7.1, epicentro en Axochiapan, Morelos) causó <strong>74 muertos y más de 23,000 viviendas dañadas</strong> en el estado. Jojutla fue el municipio más afectado, con 356 casas colapsadas. Los bomberos de Morelos operaron en coordinación con brigadas de rescate nacionales durante días, atendiendo derrumbes en edificaciones con mampostería antigua y rescate simultáneo en barrancas con escombros en caída libre. La experiencia del 19S reforzó los protocolos de búsqueda y rescate urbano (USAR) del estado.`,
  },
  {
    q: "¿Qué hace especial a la zona industrial CIVAC para los bomberos de Morelos?",
    a: `La Ciudad Industrial del Valle de Cuernavaca (CIVAC), fundada en 1966 en Jiutepec, concentra alrededor de <strong>160 empresas</strong>, incluyendo fabricantes de productos farmacéuticos, automotrices (Nissan Mexicana) y química industrial. La estación de CIVAC trata cualquier incendio en instalación farmacéutica como <strong>emergencia HAZMAT de inicio</strong>, porque los solventes de síntesis —como la dimetilformamida o el diclorometano— producen gases tóxicos al arder con perfiles muy distintos al humo de un incendio convencional.`,
  },
  {
    q: "¿Qué son las barrancas de Cuernavaca y por qué representan un riesgo específico?",
    a: `Cuernavaca está atravesada por <strong>más de 50 barrancas</strong> de entre 10 y 40 metros de profundidad, resultado de la erosión de la capa de toba volcánica. En ellas se ha edificado informalmente, se han tendido cables eléctricos y se han vertido escombros. El rescate en una barranca urbana no es rescate en montaña: los bomberos deben identificar y aislar cables activos, anclar en infraestructura urbana y coordinar con la CFE. Un sismo puede además derribar estructuras sobre la barranca mientras se trabaja en el fondo.`,
  },
  {
    q: "¿Cuáles son los riesgos de la Autopista del Sol para los bomberos de Morelos?",
    a: `La Autopista del Sol (95D) asciende desde CDMX hasta 3,000 msnm cerca de Huitzilac antes de descender a Cuernavaca. El tramo alto concentra <strong>bancos de niebla orográfica</strong> en temporada de lluvias que reducen la visibilidad a 20–30 metros. Los conductores de CDMX no anticipan el cambio de condiciones; los frenos se enfrían al ascender y el agarre de los neumáticos cae justo cuando la visibilidad desaparece. La estación de Huitzilac mantiene unidad de rescate vehicular pesada durante fines de semana y puentes.`,
  },
  {
    q: "¿Cómo atienden los bomberos las emergencias en los balnearios de Cuautla?",
    a: `El Valle de Cuautla concentra más de 30 balnearios y parques acuáticos que reciben millones de visitantes al año, con picos de <strong>5,000 a 15,000 personas en un solo día</strong> en Semana Santa. Los bomberos de Cuautla preposicionan unidades en los accesos de los principales balnearios —no dentro de los parques— para mantener abiertos los cuellos de botella en caso de evacuación masiva. El agua termal con azufre y carbonatos interfiere con la eficacia del cloro, lo que da un perfil médico distinto al casi-ahogamiento en piscina convencional.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos de Morelos?",
    a: `Combate de <strong>incendios estructurales, forestales y agrícolas</strong>; <strong>rescate vehicular</strong> en la Autopista del Sol y carreteras federales; <strong>atención prehospitalaria</strong>; <strong>búsqueda y rescate urbano (USAR)</strong> en derrumbes; <strong>materiales peligrosos (HAZMAT)</strong> en la zona industrial CIVAC; <strong>rescate de montaña</strong> en el cerro del Tepozteco y Lagunas de Zempoala; <strong>rescate acuático</strong> en balnearios y ríos; y <strong>prevención e inspecciones</strong>. La emergencia se coordina siempre a través del <strong>911</strong>.`,
  },
  {
    q: "¿Es peligroso subir al cerro del Tepozteco? ¿Qué hacen los bomberos si me pierdo?",
    a: `El cerro del Tepozteco eleva la pirámide prehispánica a unos 600 metros sobre el pueblo. El sendero puede ser exigente en calor y en temporada de lluvias con barro. Si un excursionista cae, se extravía o requiere atención médica, los <strong>bomberos de Tepoztlán</strong> coordinan el rescate de montaña con técnicas verticales y búsqueda activa en la sierra. Registra tu ruta, lleva agua y teléfono cargado, y avisa a alguien antes de subir.`,
  },
  {
    q: "¿Qué es Xochicalco y por qué es relevante para los bomberos de Morelos?",
    a: `La Zona Arqueológica de Xochicalco es <strong>Patrimonio Mundial UNESCO desde 1999</strong>. Su observatorio astronómico es una cámara subterránea excavada en roca volcánica con una sola entrada y sin ventilación mecánica, donde la luz solar entra por un ducto hexagonal en el solsticio. Para los bomberos, una emergencia de rescate en ese espacio es una <strong>operación en espacio confinado</strong> con riesgo de atmósfera deficiente en oxígeno, lo que requiere equipo SCBA y protocolos específicos.`,
  },
  {
    q: "¿Cómo puedo prevenir emergencias si visito Morelos de fin de semana?",
    a: `Si visitas la Autopista del Sol, <strong>reduce velocidad en el tramo de Huitzilac</strong> ante niebla o lluvia. En los balnearios, supervisa a menores en albercas y conoce la ubicación del salvavidas. En el Tepozteco, lleva agua, calzado adecuado y teléfono cargado. Ante cualquier emergencia, marca el <strong>911</strong>; el C5 de Morelos atiende las 24 horas. Conserva el teléfono directo de la estación más cercana a tu destino.`,
  },
];

