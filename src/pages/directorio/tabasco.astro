// ─── FAQs específicas de Tabasco (≥10) ───────────────────────────────────────
const faqsEstado = [
  {
    q: "¿Cuál es el número de emergencias para llamar a los bomberos en Tabasco?",
    a: `Marca el <strong>911</strong>, número único de emergencias que opera las 24 horas a través del Centro Estatal de Emergencias. La llamada se enruta a la estación más cercana. Para contacto directo: Bomberos Villahermosa <strong>993 315 3700</strong>, Bomberos Paraíso <strong>933 333 3900</strong>, Bomberos Cárdenas <strong>937 372 0600</strong>. En los Pantanos de Centla y comunidades fluviales sin carretera, la activación incluye la flota de lanchas y coordinación con la Armada de México.`,
  },
  {
    q: "¿Cuántas estaciones de bomberos hay en Tabasco?",
    a: `El H. Cuerpo de Bomberos de Tabasco opera <strong>${totalEstaciones} estaciones</strong> distribuidas en los <strong>${totalMunicipios} municipios</strong> de este directorio, con presencia en la capital Villahermosa, la zona petrolera (Paraíso, Cunduacán, Macuspana), la Chontalpa (Cárdenas, Comalcalco), los Pantanos de Centla y la región del Usumacinta (Tenosique, Balancán, Emiliano Zapata, Tacotalpa, Jalapa).`,
  },
  {
    q: "¿Cuándo se fundó el primer cuerpo de bomberos de México y cómo se relaciona con Tabasco?",
    a: `El <strong>primer cuerpo de bomberos de México</strong> se fundó el <strong>22 de agosto de 1873</strong> en el puerto de Veracruz. Esa fecha se conmemora cada año como el <strong>Día del Bombero en México</strong>. Tabasco, como estado del sureste, desarrolló posteriormente sus propias corporaciones municipales, siendo Villahermosa la que concentra la estación central y el mayor número de personal del estado.`,
  },
  {
    q: "¿Por qué Tabasco es el estado con mayor riesgo de inundaciones en México?",
    a: `Tabasco combina tres factores que ningún otro estado replica en la misma intensidad: está ubicado en la <strong>llanura aluvial más baja del país</strong>, recibe las cuencas de los ríos <strong>Grijalva y Usumacinta</strong> —los dos más caudalosos de México—, y registra precipitaciones anuales de entre 1,500 y 4,000 mm. En octubre-noviembre de 2007, en solo 5 días cayó el <strong>46% de la precipitación anual</strong>, los ríos se desbordaron y el agua afectó alrededor del <strong>80% del territorio tabasqueño</strong>, con más de un millón de personas afectadas.`,
  },
  {
    q: "¿Qué pasó con los bomberos de Tabasco durante la inundación de 2007?",
    a: `La inundación de octubre-noviembre de 2007 fue la mayor catástrofe hídrica de México en el siglo XXI hasta ese momento. Los bomberos respondieron a incendios estructurales en colonias inundadas <strong>llegando en lancha</strong>, con sus propias estaciones bajo el agua y los camiones inmovilizados. Esa experiencia definió los protocolos actuales de <strong>modo anfibio</strong>: rescate acuático permanente en todas las unidades y flotillas de lanchas en cada estación. En 2020, las lluvias asociadas a frentes fríos inundaron nuevamente el estado, afectando a más de 302,000 personas.`,
  },
  {
    q: "¿Qué es la Refinería Olmeca Dos Bocas y cuál es el riesgo para los bomberos?",
    a: `La <strong>Refinería Olmeca</strong>, ubicada en Paraíso sobre el Golfo de México, tiene una capacidad diseñada de <strong>340,000 barriles diarios</strong>. Su operación implica riesgos HAZMAT de máximo nivel: unidades de proceso a alta temperatura, líneas de <strong>H₂S</strong> (gas sulfhídrico) en concentraciones letales, tanques de almacenamiento de crudo, y la particularidad costera de que el viento marino puede arrastrar nubes de gas hacia zonas habitadas. La brigada HAZMAT de la estación de Paraíso opera con detectores de H₂S de lectura continua y protocolos diferenciados según la dirección del viento.`,
  },
  {
    q: "¿Qué son los Pantanos de Centla y qué desafíos representan para los bomberos?",
    a: `Los <strong>Pantanos de Centla</strong> son la Reserva de la Biósfera de humedales más grande del sureste mexicano, con <strong>302,706 hectáreas</strong> inscritas como sitio <strong>RAMSAR</strong> en 1995. El territorio es completamente fluvial: canales, lagunas, manglares y ciénagas donde el barro puede tener 1 a 3 metros antes de encontrar tierra firme. La visibilidad bajo el agua es mínima y no hay carreteras en gran parte del área. Los bomberos de Centla operan en lanchas y coordinan con la Armada de México y la CONANP.`,
  },
  {
    q: "¿Qué servicios prestan los bomberos en Tabasco?",
    a: `Combate de <strong>incendios estructurales</strong>, <strong>HAZMAT industrial</strong> (petroleo, H₂S, amoniaco), <strong>rescate acuático</strong> en inundaciones e ríos, <strong>rescate fluvial</strong> en el Grijalva y el Usumacinta, <strong>ARFF</strong> en el aeropuerto Carlos Rovirosa Pérez, atención prehospitalaria, rescate vehicular, control de fugas de gas, incendios en cañaverales y selva, y rescate espeleológico en las Grutas de Coconá y Villa Luz (Tacotalpa).`,
  },
  {
    q: "¿Los servicios de los bomberos de Tabasco tienen costo?",
    a: `Las emergencias que comprometen la <strong>vida o la integridad</strong> —incendios, rescates, inundaciones, fugas de gas— se atienden de forma <strong>gratuita</strong>. Algunos servicios secundarios pueden tener cuota de recuperación. La atención de emergencia nunca se condiciona a un pago. Para toda emergencia llama al <strong>911</strong>.`,
  },
  {
    q: "¿Por qué Tabasco tiene tantas instalaciones de PEMEX y qué riesgo implican?",
    a: `PEMEX opera en <strong>14 de los 17 municipios</strong> de Tabasco, con instalaciones que ocupan más de 12,000 hectáreas y una red de ductos de crudo y gas que recorre la llanura aluvial. Las líneas corren bajo suelos inundables: en una crecida sostenida, la erosión puede exponer un ducto, romperlo por fatiga mecánica y generar un derrame de hidrocarburo sobre agua en movimiento que viaja kilómetros antes de que llegue el primer bombero. Por eso las estaciones de Macuspana y Cárdenas preposicionan barreras flotantes de contención.`,
  },
  {
    q: "¿Cómo prevenir incendios y emergencias en el hogar en Tabasco?",
    a: `Revisa periódicamente las instalaciones de <strong>gas</strong> (mangueras, reguladores) y la <strong>instalación eléctrica</strong>. En temporada de lluvias, ten un <strong>plan de evacuación</strong> claro si vives en zona inundable: identifica la ruta de salida y el punto de reunión. Instala <strong>detectores de humo</strong> y ten un extintor vigente. Si detectas fuga de gas: no acciones interruptores, cierra la llave de paso, ventila y sal del inmueble. Siempre llama al <strong>911</strong>.`,
  },
  {
    q: "¿Qué hace especial al aeropuerto de Villahermosa para los bomberos?",
    a: `El <strong>Aeropuerto Internacional Carlos A. Rovirosa Pérez</strong> opera con categoría <strong>ARFF Categoría 6 ICAO</strong> y es el principal hub aéreo del sureste petrolero: concentra una alta frecuencia de vuelos del sector energético (PEMEX, contratistas) además del tráfico regular. La estación aeroportuaria tiene tiempo de respuesta de <strong>3 minutos</strong> (estándar ICAO) a cualquier punto de pistas y plataformas, con camiones Oshkosh Striker de espuma AFFF.`,
  },
];

