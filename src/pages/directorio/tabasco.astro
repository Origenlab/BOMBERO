  heroImage="/images/directorio/estacion-bomberos-selva-01.avif"
  heroImageAlt="Estación de Bomberos en Tabasco"
  heroCaption="H. Cuerpo de Bomberos · Tabasco"
  title={`Bomberos en ${estado} | ${estacionesTabasco.length} Estaciones | Directorio Oficial Distribuidores EPP`}
  description={`${estacionesTabasco.length} estaciones en Tabasco — incendio+inundación simultáneos, Refinería Olmeca Dos Bocas 340K bbl y Pantanos de Centla RAMSAR. Emergencias: 911.`}
  keywords={keywords}
  canonical={`https://bombero.mx/directorio/${slug}/`}
  estado={estado}
  sigla={sigla}
  slug={slug}
  totalEstaciones={estacionesTabasco.length}
  totalMunicipios={getMunicipios().length}
  habitantes="2.4M+"
