    "Protección Civil Tabasco",
    "Rescate acuático Grijalva Usumacinta",
    "HAZMAT industria petrolera PEMEX",
    "Refinería Olmeca Dos Bocas",
  ],
  inLanguage: "es-MX",
  image: "https://bombero.mx/api/og/estado/tabasco.svg",
  author:    { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  publisher: { "@type": "Organization", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  dateModified: DIRECTORIO_VERIFICADO_ISO,
