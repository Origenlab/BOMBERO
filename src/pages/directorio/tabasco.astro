  inLanguage: "es-MX",
  isPartOf: { "@type": "WebSite", name: "BOMBERO.MX", url: "https://bombero.mx/" },
  about: { "@type": "GovernmentOrganization", name: "H. Cuerpo de Bomberos de Tabasco" },
