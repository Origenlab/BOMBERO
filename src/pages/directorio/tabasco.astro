// ─── Schema.org JSON-LD ───────────────────────────────────────────────────────
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Estaciones de Bomberos en ${estado}, México`,
  description: `Directorio verificado de las ${totalEstaciones} estaciones del H. Cuerpo de Bomberos de Tabasco. Villahermosa, Paraíso-Dos Bocas (Refinería Olmeca), Macuspana, Cárdenas, Comalcalco. Petróleo PEMEX, inundaciones Grijalva-Usumacinta, Pantanos de Centla RAMSAR. Emergencias: 911.`,
  numberOfItems: estacionesTabasco.length,
  itemListElement: estacionesTabasco.map((e, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "FireStation",
      name: e.nombre,
      address: {
        "@type": "PostalAddress",
        streetAddress: e.direccion,
        addressLocality: e.municipio,
        addressRegion: estado,
        addressCountry: "MX",
      },
      telephone: e.telefono,
      url: `https://bombero.mx/directorio/${slug}/${e.slug}`,
    },
  })),
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "Bomberos en Tabasco: estaciones, historia e infraestructura de emergencia",
  description: "Guía del H. Cuerpo de Bomberos de Tabasco: inundaciones 2007 y 2020, Refinería Olmeca Dos Bocas, PEMEX, Pantanos de Centla RAMSAR, ríos Grijalva-Usumacinta. Directorio de estaciones con teléfonos.",
