---

import DirectorioEstadoLayout from "@layouts/DirectorioEstadoLayout.astro";
import { estacionesTabasco, getMunicipios, ESTADISTICAS_TABASCO } from "@data/estaciones-tabasco";
import { getEstadosVecinos } from "@data/estados-vecinos";
import { DIRECTORIO_VERIFICADO_ISO } from "@data/directorio-stats";

const estado = "Tabasco";
const sigla  = "TAB";
const slug   = "tabasco";

const canonical = "https://bombero.mx/directorio/tabasco/";

// ─── Estadísticas del directorio ─────────────────────────────────────────────
const municipios      = getMunicipios();
const totalEstaciones = estacionesTabasco.length;
const totalMunicipios = municipios.length;
const totalBomberos   = estacionesTabasco.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0);
const totalUnidades   = estacionesTabasco.reduce((s, e) => s + (e.unidades ?? 0), 0);

// ─── Comparativa regional (zonas) ────────────────────────────────────────────
const zonasDef = [
  {
    nombre: "Zona Centro — Villahermosa",
    municipios_: ["Centro"],
    cobertura: "Total", chip: "total",
    perfil: "Capital, aeropuerto, coordinación estatal PEMEX, Laguna de las Ilusiones.",
  },
  {
    nombre: "Zona Petrolera — Paraíso/Cunduacán",
    municipios_: ["Paraíso", "Cunduacán", "Macuspana"],
    cobertura: "Alta", chip: "alta",
    perfil: "Refinería Olmeca Dos Bocas, complejos petroquímicos y campos gasíferos PEMEX.",
  },
  {
    nombre: "Región Chontalpa",
    municipios_: ["Cárdenas", "Comalcalco", "Jalpa de Méndez", "Nacajuca", "Huimanguillo"],
    cobertura: "Alta", chip: "alta",
    perfil: "Agroindustria cañera y cacaotera, llanura inundable de alta frecuencia.",
  },
  {
    nombre: "Pantanos y Costa — Delta",
    municipios_: ["Centla"],
    cobertura: "Media", chip: "media",
    perfil: "Reserva Biósfera Pantanos de Centla RAMSAR, delta Grijalva-Usumacinta, Golfo de México.",
  },
  {
    nombre: "Región Ríos — Usumacinta",
    municipios_: ["Tenosique", "Emiliano Zapata", "Balancán", "Jalapa", "Jalpa", "Tacotalpa"],
    cobertura: "Baja", chip: "baja",
    perfil: "Frontera Guatemala, rescate fluvial Usumacinta, selva tropical y Sierra de Tabasco.",
  },
];

const zonas = zonasDef.map((z) => {
  const est = estacionesTabasco.filter((e) => z.municipios_.includes(e.municipio ?? ''));
  return {
    ...z,
    nEst:  est.length,
    nPers: est.reduce((s, e) => s + (e.personalActivo ?? e.personal ?? 0), 0),
    nUni:  est.reduce((s, e) => s + (e.unidades ?? 0), 0),
  };
});

// ─── Imágenes Hero ────────────────────────────────────────────────────────────
const heroThumbs = [
  { src: "/images/directorio/estacion-bomberos-selva-01.avif",           alt: "Bomberos de Tabasco en rescate acuático por inundación",         label: "Respuesta Rápida"  },
  { src: "/images/directorio/central-despacho-bomberos-mexicano-turno-01.avif", alt: "Bombero mexicano en turno de guardia en Tabasco",         label: "Guardia de Turno"  },
  { src: "/images/directorio/estacion-bomberos-inundaciones-01.avif",    alt: "Lancha de rescate en Pantanos de Centla",                        label: "Servicio 24/7"     },
];

// ─── Galería ──────────────────────────────────────────────────────────────────
const galleryImages = [
  { src: "/images/directorio/estacion-bomberos-petrolera-01.avif",   alt: "Emergencia HAZMAT en instalaciones PEMEX Tabasco",       label: "HAZMAT Petrolero"         },
  { src: "/images/directorio/estacion-bomberos-inundaciones-01.avif",alt: "Evacuación durante inundación del Grijalva Tabasco",     label: "Rescate en Inundación"    },
