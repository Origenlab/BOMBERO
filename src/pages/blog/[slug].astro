---

import BlogLayout from "@layouts/BlogLayout.astro";
import { articulosData, getArticuloSlugs, getArticulo, getAllArticulos } from "@data/blog-articulos";
import { getProductosRelacionados, getCTAInline } from "@data/blog-productos-map";
import { prepararArticulo, tocHtml } from "@utils/blog-enhance";


export function getStaticPaths() {
  return getArticuloSlugs().map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const articulo = getArticulo(slug as string);

if (!articulo) {
  return Astro.redirect("/404");
}


// Pipeline de homologación editorial: TOC + anchors + imágenes + tablas/FAQ extra + FAQ schema
const ctaInline = getCTAInline(slug as string);
const preparado = prepararArticulo(slug as string, articulo, ctaInline);
const contenidoHTML = tocHtml(preparado.toc) + preparado.html;
const faqSchema = preparado.faqSchema;

const breadcrumb = [
  { label: "Blog", href: "/blog/" },
  { label: articulo.titulo },
];


const allArticulos = getAllArticulos();
const catsList = [
  { label: "Normativas", slug: "normativas" },
  { label: "Mantenimiento", slug: "mantenimiento" },
  { label: "Técnicas", slug: "tecnicas" },
  { label: "Industrial", slug: "industrial" },
  { label: "Forestales", slug: "forestales" },
  { label: "Equipo", slug: "equipo" },
];

const categorias = catsList.map((cat) => ({
  label: cat.label,
  href: `/blog/categoria/${cat.slug}`,
  count: allArticulos.filter((a) => a.categoria.toLowerCase() === cat.label.toLowerCase()).length,
}));

const articulosPopulares = [
  { label: "NFPA 1971: Guía Completa", href: "/blog/nfpa-1971-guia-completa/" },
  { label: "Mantenimiento SCBA", href: "/blog/mantenimiento-scba/" },
  { label: "Rescate Vehicular", href: "/blog/rescate-vehicular-tecnicas/" },
  { label: "EPP para Brigadas", href: "/blog/brigadas-industriales-epp/" },
];

// Productos relacionados dinámicos según el artículo
const productosRelacionadosData = getProductosRelacionados(slug as string);
const productosRelacionados = productosRelacionadosData.map(p => ({
  label: p.label,
  href: p.href,
}));

const directorioLinks = [
  { label: "Ciudad de México", href: "/directorio/ciudad-de-mexico/" },
  { label: "Jalisco", href: "/directorio/jalisco/" },
  { label: "Nuevo León", href: "/directorio/nuevo-leon/" },
];


const otrosArticulos = getAllArticulos()
  .filter((a) => a.slug !== slug)
  .slice(0, 3)
  .map((a) => ({
    title: a.titulo,
    excerpt: a.excerpt,
    href: `/blog/${a.slug}`,
    image: a.imagen,
    categoria: a.categoria,
  }));
---

<BlogLayout
  title={`${articulo.titulo} | Blog BOMBERO.MX`}
  description={articulo.excerpt}
  keywords={articulo.tags}
  canonical={`/blog/${slug}/`}
  image={articulo.imagen}
  pubDate={articulo.pubDate}
  breadcrumb={breadcrumb}
  heroBadge={`Blog · ${articulo.categoria}`}
  heroTitle={articulo.titulo}
  heroExcerpt={articulo.excerpt}
  heroImage={articulo.imagen}
  autor={articulo.autor}
  autorRol={articulo.autorRol}
  tags={articulo.tags}
  categorias={categorias}
  articulosPopulares={articulosPopulares}
  productosRelacionados={productosRelacionados}
  directorioLinks={directorioLinks}
  relacionados={otrosArticulos}
>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <Fragment set:html={contenidoHTML} />
</BlogLayout>

<style is:global>
  .toc-box {
    background: var(--color-bg-alt, #f6f8fa);
    border: 1px solid var(--color-border, #e1e6eb);
    border-left: 4px solid var(--color-primary, #c8102e);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 0 0 2rem;
  }
  .toc-box__title {
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0 0 0.6rem;
    color: var(--color-heading, #1a1d20);
  }
  .toc-box__list {
    margin: 0;
    padding-left: 1.1rem;
    columns: 2;
    column-gap: 2rem;
  }
  .toc-box__list .toc-item {
    margin: 0.3rem 0;
    font-size: 0.93rem;
    line-height: 1.4;
    break-inside: avoid;
  }
  .toc-box__list .toc-item--h3 {
    list-style: circle;
    margin-left: 1rem;
    font-size: 0.88rem;
    opacity: 0.9;
  }
  .toc-box a {
    text-decoration: none;
  }
  .toc-box a:hover {
    text-decoration: underline;
  }
  @media (max-width: 640px) {
    .toc-box__list { columns: 1; }
  }
  .articulo-figure {
    margin: 2rem 0;
  }
  .articulo-figure img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
  }
  .articulo-figure figcaption {
    font-size: 0.85rem;
    color: var(--color-text-muted, #5c6670);
    margin-top: 0.5rem;
    text-align: center;
  }
  .blog-article__content h2[id],
  .blog-article__content h3[id] {
    scroll-margin-top: 96px;
  }
</style>
