---

import PageLayout from "@layouts/PageLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import Pagination from "@components/Pagination.astro";
import BlogSearch from "@components/BlogSearch.astro";
import HeroSection from "@components/HeroSection.astro";
import { cdnW } from "@lib/cdn";
import { getAllArticulos } from "@data/blog-articulos";
import QuickNav from "@components/QuickNav.astro";


const ARTICLES_PER_PAGE = 9;
const currentPage = 1;


const allArticulos = getAllArticulos();
const totalPages = Math.ceil(allArticulos.length / ARTICLES_PER_PAGE);
const articulos = allArticulos.slice(0, ARTICLES_PER_PAGE);

// Calcular tiempo de lectura aproximado (200 palabras/min)
function readingTime(content: string): number {
  const words = content.trim().split(/\s+/).length;
  return Math.max(3, Math.ceil(words / 200));
}


const catsList = [
  { label: "Normativas", slug: "normativas" },
  { label: "Mantenimiento", slug: "mantenimiento" },
  { label: "Técnicas", slug: "tecnicas" },
  { label: "Industrial", slug: "industrial" },
  { label: "Forestales", slug: "forestales" },
  { label: "Equipo", slug: "equipo" },
];

const categorias = catsList.map((cat) => ({
  ...cat,
  count: allArticulos.filter((a) => a.categoria.toLowerCase() === cat.label.toLowerCase()).length,
}));

const breadcrumb = [
  { label: "Blog" },
];

const articulosCdn = articulos.map(a => ({
  ...a,
  imagen: cdnW(a.imagen, 600),
  readMin: readingTime(a.contenido),
}));
---

<PageLayout
  quickNav={false}
  title="Artículos para Bomberos en México — Guías NFPA, EPP y Rescate"
  description="Artículos para bomberos en México: NFPA 1971/1977, EPP, SCBA y rescate. Verificado por especialistas con 15 años en corporaciones de bomberos."
  keywords={["artículos para bomberos", "guías NFPA 1971", "normativas bomberos México", "mantenimiento EPP bomberos", "técnicas rescate bomberos"]}
  canonical="https://bombero.mx/blog/"
>

  <Breadcrumb items={breadcrumb} />




  <HeroSection
    badge="6 Categorías · 50+ Artículos Técnicos · NFPA y Rescate"
    title={`Artículos para <span class="hero__title-highlight">Bomberos</span> en México`}
    subtitle="Guías técnicas de NFPA 1971/1977, mantenimiento de SCBA, rescate vehicular y forestal — redactadas con base en 15 años de trabajo directo con cuerpos de bomberos en los 32 estados."
    blocks={[
      { title: "Normativas NFPA Aplicadas a México", text: "La edición 2024 de <strong>NFPA 1971</strong> y la 2022 de <strong>NFPA 1977</strong> son los estándares de referencia para EPP estructural y forestal en México. Cada artículo traduce el lenguaje técnico de la norma a requisitos operativos concretos: qué ensayos exige cada certificación, qué significa <strong>TPP ≥35 cal/cm²</strong> en operación interior y qué cambia entre ediciones para quien ya tiene equipo certificado con una versión anterior." },
      { title: "Guías de Campo: de la Norma a la Operación Real", text: "En 15 años distribuyendo equipo certificado a cuerpos municipales en los <strong>32 estados</strong> documentamos los errores más frecuentes: traje NFPA 1971 con casco de edición incompatible, <strong>SCBA</strong> con servicio vencido, guantes de rescate técnico usados en interior estructural. Cada guía parte de incidentes reales, no de descripciones de catálogo." }
    ]}
  />

  <QuickNav pool="blog" count={7} />





  <div class="blog-index-layout">
    <div class="container blog-index-layout__inner">


      <div class="blog-index-main">

        <SectionHeader
          label="Últimos Artículos"
          title="Guías Técnicas para Bomberos y Brigadas"
          description="NFPA 1971/1977/1981, SCBA, rescate vehicular y forestal — artículos especializados para cuerpos de bomberos, brigadas industriales y protección civil en México."
        >
          <p>En 15 años distribuyendo equipo certificado NFPA a cuerpos municipales en los <strong>32 estados</strong>, hemos documentado los errores más frecuentes en campo: traje certificado con casco de edición incompatible, <strong>SCBA</strong> con fecha de servicio vencida, guantes de rescate técnico usados en operación interior estructural. Cada artículo parte de incidentes reales, no de descripciones de catálogo.</p>
          <p>El contenido está organizado en seis categorías operativas: <strong>normativas NFPA 1971/1977/1981</strong>, mantenimiento de EPP, técnicas de rescate vehicular y forestal, y selección de equipo para estaciones municipales, brigadas industriales y equipos de protección civil.</p>
        </SectionHeader>

        <div class="blog-grid" id="articulos">
          {articulosCdn.map((articulo, idx) => (
            <article class={`blog-card ${idx === 0 ? "blog-card--featured" : ""}`}>
              <a href={`/blog/${articulo.slug}/`} class="blog-card__link" aria-label={articulo.titulo}>
                <div class="blog-card__img-wrap">
                  <img
                    src={articulo.imagen}
                    alt={articulo.titulo}
                    loading={idx < 3 ? "eager" : "lazy"}
                    decoding="async"
                    width="600"
                    height="338"
                    class="blog-card__img"
                  />
                  <div class="blog-card__overlay"></div>
                  <span class="blog-card__badge">
                    <span class="blog-card__badge-dot"></span>
                    {articulo.categoria}
                  </span>
                  {idx === 0 && (
                    <span class="blog-card__feat">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2l2.39 7.36H22l-6.18 4.49L18.21 21 12 16.49 5.79 21l2.39-7.15L2 9.36h7.61z"/>
                      </svg>
                      Destacado
                    </span>
                  )}
                </div>
                <div class="blog-card__body">
                  <div class="blog-card__meta">
                    <span class="blog-card__meta-item">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                      </svg>
                      {articulo.readMin} min lectura
                    </span>
                    <span class="blog-card__meta-sep" aria-hidden="true">·</span>
                    <span class="blog-card__meta-item">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                        <path d="M20 7h-7M14 17H4M17 3l4 4-4 4M7 13l-4 4 4 4"/>
                      </svg>
                      {articulo.tags.length} temas
                    </span>
                  </div>
                  <h2 class="blog-card__title">{articulo.titulo}</h2>
                  <p class="blog-card__excerpt">{articulo.excerpt}</p>
                  <div class="blog-card__tags">
                    {articulo.tags.slice(0, 3).map((tag) => (
                      <span class="blog-card__tag">{tag}</span>
                    ))}
                  </div>
                  <div class="blog-card__footer">
                    <div class="blog-card__author">
                      <span class="blog-card__avatar" aria-hidden="true">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                          <circle cx="12" cy="7" r="4"/>
                        </svg>
                      </span>
                      <span class="blog-card__author-name">{articulo.autor}</span>
                    </div>
                    <span class="blog-card__cta">
                      Leer
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>


        {totalPages > 1 && (
          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            baseUrl="/blog/"
          />
        )}

      </div>


      <aside class="blog-index-sidebar">


        <div class="sb-card sb-card--search">
          <h3 class="sb-card__title sb-card__title--dark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            Buscar
          </h3>
          <BlogSearch />
          <a href="/blog/rss.xml" class="sb-rss-link" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
            Suscríbete al RSS
          </a>
        </div>


        <div class="sb-card sb-card--cta">
          <h3 class="sb-card__title">Catálogo de Productos</h3>
          <p class="sb-card__text">Equipo certificado NFPA listo para envío a toda la República.</p>
          <a href="/productos/" class="sb-cta-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            Ver Productos
          </a>
          <div class="sb-card__contacts">
            <a href="https://wa.me/525570081816" target="_blank" rel="noopener noreferrer" class="sb-contact sb-contact--wa">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>


        <div class="sb-card">
          <h3 class="sb-card__title sb-card__title--dark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            Categorías
          </h3>
          <ul class="sb-cats">
            {categorias.map((cat) => (
              <li class="sb-cat">
                <a href={`/blog/categoria/${cat.slug}/`} class="sb-cat__link">
                  <span class="sb-cat__label">{cat.label}</span>
                  <span class="sb-cat__count">{cat.count}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>


        <div class="sb-card">
          <h3 class="sb-card__title sb-card__title--dark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            Productos Destacados
          </h3>
          <ul class="sb-links">
            <li><a href="/productos/trajes-para-bomberos/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Trajes Estructurales
            </a></li>
            <li><a href="/productos/cascos-para-bomberos/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Cascos NFPA
            </a></li>
            <li><a href="/productos/capuchas-para-bomberos/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Capuchas NFPA
            </a></li>
            <li><a href="/productos/guantes-para-bomberos/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Guantes Estructurales
            </a></li>
            <li><a href="/productos/botas-para-bomberos/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Botas de Cuero
            </a></li>
          </ul>
          <a href="/productos/" class="sb-see-all">Ver catálogo completo →</a>
        </div>


        <div class="sb-card">
          <h3 class="sb-card__title sb-card__title--dark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Directorio de Bomberos
          </h3>
          <ul class="sb-links">
            <li><a href="/directorio/ciudad-de-mexico/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Ciudad de México
            </a></li>
            <li><a href="/directorio/jalisco/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Jalisco
            </a></li>
            <li><a href="/directorio/nuevo-leon/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Nuevo León
            </a></li>
            <li><a href="/directorio/veracruz/" class="sb-link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              Veracruz
            </a></li>
          </ul>
          <a href="/directorio/" class="sb-see-all">Ver directorio completo →</a>
        </div>

      </aside>
    </div>
  </div>




  <section class="epp-section">
    <div class="container">
      <SectionHeader
        label="Equipo Complementario"
        title="Completa tu EPP de Bombero"
        description="El traje es solo el comienzo. Equipa a tu personal con el sistema de protección completo."
      >
        <p>Un sistema de EPP completo requiere que traje, casco, guantes y botas sean compatibles y cumplan la misma edición de norma <strong>NFPA</strong>. El traje estructural NFPA 1971 debe usarse con casco estructural NFPA 1971, guantes estructurales, botas de cuero certificadas y <strong>SCBA autónomo</strong> para garantizar protección integral en cada operación.</p>
        <p>El sistema de protección personal completo está disponible de una sola fuente: cascos para bombero, guantes, botas certificadas NFPA y SCBA, con certificado ISO/IEC 17025 por número de lote para los <strong>32 estados de México</strong>.</p>
      </SectionHeader>

      <div class="epp-grid">

        <article class="epp-card">
          <div class="epp-card__img-wrap">
            <img src={cdnW("/images/cascos-para-bomberos/casco-bombero-arff-aeroportuario-01.avif", 400)} alt="Casco para bombero certificado NFPA" width="400" height="225" loading="lazy" class="epp-card__img" />
          </div>
          <div class="epp-card__body">
            <h3 class="epp-card__title">Cascos para Bombero</h3>
            <ul class="epp-card__list">
              <li><a href="/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/">Casco Estructural NFPA 1971</a></li>
              <li><a href="/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/">Casco Forestal NFPA 1977</a></li>
              <li><a href="/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/">Casco de Rescate NFPA 1951</a></li>
              <li><a href="/productos/cascos-para-bomberos/casco-hazmat-quimico/">Casco HAZMAT Químico</a></li>
            </ul>
            <a href="/productos/cascos-para-bomberos/" class="epp-card__link">Cascos para Bombero</a>
          </div>
        </article>


        <article class="epp-card">
          <div class="epp-card__img-wrap">
            <img src={cdnW("/images/guantes-para-bomberos/guante-bombero-estructural-nfpa-1971-01.avif", 400)} alt="Guantes profesionales para bomberos certificados NFPA" width="400" height="225" loading="lazy" class="epp-card__img" />
          </div>
          <div class="epp-card__body">
            <h3 class="epp-card__title">Guantes para Bombero</h3>
            <ul class="epp-card__list">
              <li><a href="/productos/guantes-para-bomberos/estructurales/">Guantes Estructurales</a></li>
              <li><a href="/productos/guantes-para-bomberos/rescate/">Guantes de Rescate / Extricación</a></li>
              <li><a href="/productos/guantes-para-bomberos/hazmat/">Guantes HAZMAT</a></li>
              <li><a href="/productos/guantes-para-bomberos/forestales/">Guantes Forestales</a></li>
            </ul>
            <a href="/productos/guantes-para-bomberos/" class="epp-card__link">Guantes para Bombero</a>
          </div>
        </article>


        <article class="epp-card">
          <div class="epp-card__img-wrap">
            <img src={cdnW("/images/botas-para-bomberos/bota-bombero-producto-caucho-par-estudio-04.avif", 400)} alt="Botas premium para bomberos certificadas NFPA" width="400" height="225" loading="lazy" class="epp-card__img" />
          </div>
          <div class="epp-card__body">
            <h3 class="epp-card__title">Botas para Bombero</h3>
            <ul class="epp-card__list">
              <li><a href="/productos/botas-para-bomberos/estructural/">Bota Estructural (Cuero)</a></li>
              <li><a href="/productos/botas-para-bomberos/caucho/">Bota de Caucho (HAZMAT)</a></li>
              <li><a href="/productos/botas-para-bomberos/forestal/">Bota Forestal</a></li>
            </ul>
            <a href="/productos/botas-para-bomberos/" class="epp-card__link">Botas para Bombero</a>
          </div>
        </article>


        <article class="epp-card">
          <div class="epp-card__img-wrap">
            <img src={cdnW("/images/capucha-para-bombero/capucha-bombero-producto-pbi-gold-estudio-frontal-01.avif", 400)} alt="Capuchas para Bombero" width="400" height="225" loading="lazy" class="epp-card__img" />
          </div>
          <div class="epp-card__body">
            <h3 class="epp-card__title">Capuchas para Bombero</h3>
            <ul class="epp-card__list">
              <li><a href="/productos/capuchas-para-bomberos/nomex/">Capucha Nomex® Estructural</a></li>
              <li><a href="/productos/capuchas-para-bomberos/pbi/">Capucha PBI Gold® Premium</a></li>
              <li><a href="/productos/capuchas-para-bomberos/particulada/">Capucha Particulada PM2.5</a></li>
              <li><a href="/productos/gafas-para-bomberos/">Gafas y Protección Visual</a></li>
            </ul>
            <a href="/productos/capuchas-para-bomberos/" class="epp-card__link">Capuchas para Bombero</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <CTABanner
    title="Explora Nuestro Catálogo Completo"
    desc="Más de 500 productos certificados NFPA listos para envío inmediato a toda la República."
    btnText="Ver Productos NFPA"
    btnHref="/productos/"
  />

</PageLayout>

<style>

  .blog-index-layout {
    background:
      radial-gradient(ellipse 80% 40% at 50% 0%, rgba(220, 38, 38, 0.04), transparent 60%),
      var(--color-smoke-50);
    padding: var(--space-16) 0 var(--space-20);
    position: relative;
  }

  .blog-index-layout::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-smoke-200), transparent);
  }

  .blog-index-layout__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: var(--space-10);
    align-items: start;
  }

  .blog-index-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    min-width: 0;
  }


  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .blog-card {
    background: white;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid var(--color-smoke-100);
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 2px 4px rgba(15, 23, 42, 0.02);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.35s ease,
                border-color 0.3s ease;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .blog-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, transparent 60%, rgba(220, 38, 38, 0.25));
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .blog-card:hover {
    transform: translateY(-6px);
