---

import PageLayout from "@layouts/PageLayout.astro";
import QuickNav from "@components/QuickNav.astro";
import HeroSection from "@components/HeroSection.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  /* Estas rutas tienen página .astro dedicada (src/pages/<slug>/index.astro)
     que toma precedencia; generar también la versión .md duplicaba el build
     de cada una (la estática gana, pero se construían dos veces). 2026-06-10 */
  const STATIC_OVERRIDES = new Set(["contacto", "cotizar", "nosotros"]);
  return pages
    .filter((page) => !STATIC_OVERRIDES.has(page.slug))
    .map((page) => ({
      params: { slug: page.slug },
      props: page,
    }));
}

const page = Astro.props;
const { Content } = await page.render();
---

<PageLayout
  quickNav={false}
  title={page.data.title}
  description={page.data.description}
  image={page.data.image}
  noindex={page.data.noindex}
>

  {page.data.hero && (
    <>
      <HeroSection
        badge={page.data.hero.badge ?? "EPP Certificado"}
        title={page.data.hero.title}
        subtitle={page.data.hero.description ?? ""}
        blocks={page.data.hero.blocks ?? undefined}
      >
        {(page.data.hero.primaryCTA || page.data.hero.secondaryCTA) && (
          <div slot="left-extra" class="page-hero__actions">
            {page.data.hero.primaryCTA && (
              <a href={page.data.hero.primaryCTA.href} class="btn btn--primary">
                {page.data.hero.primaryCTA.label}
              </a>
            )}
            {page.data.hero.secondaryCTA && (
              <a href={page.data.hero.secondaryCTA.href} class="btn btn--ghost">
                {page.data.hero.secondaryCTA.label}
              </a>
            )}
          </div>
        )}
      </HeroSection>
      <QuickNav pool="info" count={7} />
    </>
  )}


  <section class="section">
    <div class="container container--narrow prose">
      <Content />
    </div>
  </section>
</PageLayout>

<style>
  .page-hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }
</style>
