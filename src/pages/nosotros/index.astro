        </div>
        <div class="cobertura__stat">
          <div class="cobertura__stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
          </div>
          <div class="cobertura__stat-content">
            <span class="cobertura__stat-number">Rastreo</span>
            <span class="cobertura__stat-label">En Tiempo Real</span>
          </div>
        </div>
        <div class="cobertura__stat">
          <div class="cobertura__stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div class="cobertura__stat-content">
            <span class="cobertura__stat-number">100%</span>
            <span class="cobertura__stat-label">Embalaje Certificado</span>
          </div>
        </div>
      </div>


      <div class="cobertura__regions">
        <div class="cobertura__region">
          <h3 class="cobertura__region-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Centro
          </h3>
          <ul class="cobertura__cities">
            <li>Ciudad de México</li>
            <li>Estado de México</li>
