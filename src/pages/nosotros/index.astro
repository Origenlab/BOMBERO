---
/**
 * ─── BOMBERO.MX ───
 * Nosotros — Página institucional profesional
 * Muestra historia, misión, catálogo completo, sectores, certificaciones y cobertura
 */
import PageLayout from "@layouts/PageLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import Certifications from "@components/Certifications.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import Testimonials from "@components/Testimonials.astro";
import CTABanner from "@components/CTABanner.astro";
import { SITE } from "@data/site";
import { productCategories } from "@data/navigation";

// Imágenes para cada categoría del catálogo
const categoryImages: Record<string, string> = {
  "Trajes de Bombero": "/images/trajes-para-bombero/traje-bombero-estructural-nfpa-1971-modelo-frontal-07.avif",
  "Cascos para Bombero": "/images/cascos-para-bomberos/casco-bombero-profesional-03.avif",
  "Guantes para Bombero": "/images/guantes-para-bomberos/guante-bombero-combate-incendio-manguera-01.avif",
  "Botas para Bombero": "/images/botas-para-bomberos/bota-bombero-profesional-05.avif",
  "Capuchas y Monjas": "/images/capucha-para-bombero/capucha-bombero-estacion-nomex-blanca-profesional-01.avif",
  "Gafas y Protección Visual": "/images/gafas-para-bomberos/gafas-bombero-goggle-casco-rescate-estacion-01.avif",
};

const timeline = [
  { year: "2010", title: "Fundación", desc: "Iniciamos operaciones en Ciudad de México como distribuidores especializados en equipo de protección personal para bomberos, con un compromiso firme de ofrecer exclusivamente productos certificados NFPA." },
  { year: "2014", title: "Cobertura Nacional", desc: "Expandimos nuestra red logística a los 32 estados de la República Mexicana, estableciendo alianzas con las principales marcas mundiales de equipo contra incendios." },
  { year: "2018", title: "+500 Estaciones Atendidas", desc: "Alcanzamos la marca de 500 estaciones de bomberos, protección civil y brigadas industriales equipadas con nuestros productos certificados." },
  { year: "2024", title: "Catálogo Digital", desc: "Lanzamos BOMBERO.MX como plataforma digital integral con directorio nacional de estaciones de bomberos, catálogo técnico y asesoría en línea para toda la República." },
];

const valores = [
  { icon: "certificate", title: "Misión", image: "/images/trajes-para-bombero/bombera-profesional-traje-estructural-estacion-01.avif", description: "Proveer equipo de protección personal certificado que salve vidas. Cada producto que distribuimos cumple con los estándares más exigentes porque la seguridad de los bomberos de México no es negociable." },
  { icon: "goggles", title: "Visión", image: "/images/trajes-para-bombero/bombera-cdmx-retrato-casco-amarillo-01.avif", description: "Ser el distribuidor de referencia en equipamiento para bomberos en Latinoamérica, reconocidos por nuestra calidad, servicio técnico y compromiso con la seguridad de quienes nos protegen." },
  { icon: "shield", title: "Compromiso", image: "/images/trajes-para-bombero/certificacion-nfpa-1971-tejido-nomex-goretex-01.avif", description: "Trabajamos exclusivamente con marcas líderes mundiales — MSA, Honeywell, Globe, Bullard — garantizando que cada pieza de equipo proteja al máximo a quien la utiliza." },
  { icon: "users", title: "Innovación", image: "/images/trajes-para-bombero/chaqueton-bombero-goretex-sistema-3-capas-detalle-01.avif", description: "Incorporamos continuamente las tecnologías más avanzadas en protección contra incendios: materiales PBI, membranas GORE-TEX, cámaras térmicas FLIR y sistemas SCBA de última generación." },
];

const sectores = [
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`, title: "Bomberos Municipales", desc: "Equipo estructural completo NFPA 1971 para cuerpos de bomberos en los 32 estados de México." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>`, title: "Protección Civil", desc: "EPP certificado para unidades de rescate, atención a desastres y coordinación de emergencias." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v16z"/></svg>`, title: "Brigadas Industriales", desc: "Equipo NOM-002-STPS para brigadas contra incendio en plantas, fábricas y centros de trabajo." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>`, title: "Aeropuertos ARFF", desc: "Trajes y cascos ARFF especializados para servicios de rescate y extinción de incendios aeroportuarios." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`, title: "PEMEX / CFE / Energía", desc: "Equipo HAZMAT y trajes de aproximación para la industria petrolera, gas y generación eléctrica." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14"/><path d="M2 20h20"/><path d="M14 12h.01"/></svg>`, title: "Hospitales y Salud", desc: "Extintores certificados NOM, señalización y planes de evacuación para el sector salud." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>`, title: "Hotelería y Turismo", desc: "Sistemas contra incendio, capacitación de brigadas y equipo de primera respuesta para hoteles y resorts." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, title: "Centros Comerciales", desc: "Extintores, gabinetes hidrantes, rociadores y equipo de evacuación para plazas y centros comerciales." },
];

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.organization.name,
  legalName: SITE.organization.legalName,
  url: SITE.url,
  logo: `${SITE.url}${SITE.organization.logo}`,
  foundingDate: SITE.organization.foundingDate,
  numberOfEmployees: { "@type": "QuantitativeValue", minValue: 50, maxValue: 100 },
  address: {
    "@type": "PostalAddress",
    streetAddress: "Av. Tamaulipas 150, Piso 13",
    addressLocality: "Ciudad de México",
    addressRegion: "CDMX",
    postalCode: "06140",
    addressCountry: "MX",
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: SITE.contact.phone,
    contactType: "sales",
    areaServed: "MX",
    availableLanguage: "es",
  },
  sameAs: SITE.organization.sameAs,
};
---

<PageLayout
  title="Nosotros | Distribuidor de Equipo para Bomberos | BOMBERO.MX"
  description="Conoce BOMBERO.MX: +15 años como distribuidor líder de equipo para bomberos en México. Trajes NFPA, cascos, guantes, botas, SCBA y herramientas certificadas. Cobertura en los 32 estados."
  jsonLd={[organizationJsonLd]}
>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- BREADCRUMB -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <Breadcrumb items={[{ label: "Nosotros" }]} />

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- HERO SECTION -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          Desde 2010 &middot; Distribuidores Autorizados NFPA
        </div>

        <h1 class="hero__title">
          Distribuidor Líder de Equipo para
          <span class="hero__title-highlight">Bomberos</span>
          en México
        </h1>

        <p class="hero__subtitle">
          Más de 15 años equipando estaciones de bomberos, protección civil y brigadas industriales
          en toda la República Mexicana con equipo de protección personal certificado NFPA.
        </p>

        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-number">+15</span>
            <span class="hero__stat-label">Años de experiencia</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-number">+500</span>
            <span class="hero__stat-label">Estaciones equipadas</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-number">32</span>
            <span class="hero__stat-label">Estados cubiertos</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-number">5</span>
            <span class="hero__stat-label">Certificaciones</span>
          </div>
        </div>

        <div class="hero__actions">
          <a href="/cotizar/" class="btn btn--primary btn--lg">
            <span>Solicitar Cotización</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/productos/" class="btn btn--ghost btn--lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
            <span>Explorar Catálogo</span>
          </a>
        </div>
      </div>

      <div class="hero__seo">
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Quiénes Somos: Distribuidores Autorizados NFPA en México</h2>
          <p class="hero__seo-text">
            <strong>BOMBERO.MX</strong> es el <strong>distribuidor líder de equipo de protección personal para bomberos</strong> en México. Desde 2010 trabajamos con las marcas más reconocidas del mundo — <strong>MSA, Honeywell, Globe, Bullard</strong> — para ofrecer <strong>trajes estructurales NFPA 1971</strong>, <strong>equipos SCBA</strong>, <strong>cascos certificados</strong>, <strong>guantes</strong>, <strong>botas</strong> y <strong>herramientas de rescate</strong> a cuerpos de bomberos, protección civil y brigadas industriales en los 32 estados.
          </p>
        </div>
        <div class="hero__seo-block">
          <h2 class="hero__seo-title">Compromiso con la Seguridad de los Bomberos de México</h2>
          <p class="hero__seo-text">
            Cada producto en nuestro catálogo cumple con certificaciones <strong>NFPA, UL, EN e ISO</strong>. Ofrecemos <strong>asesoría técnica sin costo</strong>, documentación completa para licitaciones gubernamentales, envíos express a <strong>CDMX, Monterrey, Guadalajara</strong> y toda la República. Nuestro compromiso: que cada bombero de México cuente con el equipo que merece para proteger a su comunidad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- NUESTRA HISTORIA -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="historia section">
    <div class="container">
      <SectionHeader
        label="Nuestra Historia"
        title="Más de 15 Años Protegiendo a Quienes Nos Protegen"
        description="Desde nuestra fundación en 2010, hemos crecido hasta convertirnos en el distribuidor de equipo para bomberos más confiable de México."
      >
        <p>
          Lo que comenzó como una distribuidora especializada en <strong>equipo de protección personal para bomberos</strong> en Ciudad de México, hoy es una operación con <strong>cobertura en los 32 estados</strong> de la República. Hemos equipado más de <strong>500 estaciones de bomberos</strong>, unidades de protección civil y brigadas industriales con productos certificados <strong>NFPA</strong>.
        </p>
        <p>
          Nuestro directorio nacional conecta a más de <strong>670 estaciones de bomberos</strong> en todo el país, proporcionando información de contacto y localización actualizada para emergencias.
        </p>
      </SectionHeader>

      <div class="timeline">
        {timeline.map((item) => (
          <div class="timeline__item">
            <div class="timeline__year">{item.year}</div>
            <div class="timeline__body">
              <h3 class="timeline__title">{item.title}</h3>
              <p class="timeline__desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- MISIÓN Y VALORES -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="valores section">
    <div class="container">
      <SectionHeader
        label="Misión y Valores"
        title="Los Principios que Nos Guían"
        description="Cada decisión en BOMBERO.MX está orientada por un propósito claro: proteger la vida de quienes arriesgan la suya para protegernos."
      >
        <p>
          Nuestros valores no son solo palabras — son el <strong>estándar con el que medimos cada decisión</strong>. Desde la selección de proveedores hasta el servicio post-venta, cada acción refleja nuestro compromiso con la <strong>seguridad de los bomberos de México</strong>.
        </p>
        <p>
          Creemos que quienes arriesgan su vida para proteger a otros merecen el <strong>mejor equipo disponible</strong>, sin excepciones ni compromisos. Esa convicción guía todo lo que hacemos.
        </p>
      </SectionHeader>

      <div class="valores__grid">
        {valores.map((v) => (
          <CategoryCard
            title={v.title}
            icon={v.icon}
            image={v.image}
            description={v.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- CATÁLOGO COMPLETO -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="catalogo section">
    <div class="container">
      <SectionHeader
        label="Catálogo de Productos"
        title="Equipo Certificado para Cada Necesidad"
        description="Distribuimos 11 líneas de equipo de protección personal y herramientas contra incendios con certificaciones NFPA, UL, EN y NOM."
      >
        <p>
          Nuestro catálogo abarca desde <strong>trajes estructurales NFPA 1971</strong> hasta <strong>cámaras térmicas FLIR</strong>, cubriendo todas las necesidades de equipamiento para bomberos, protección civil y brigadas industriales. Cada producto incluye ficha técnica, certificaciones y asesoría especializada sin costo.
        </p>
        <p>
          Trabajamos con <strong>MSA, Honeywell, Globe, Bullard, HAIX, Pro-Tech</strong> y otras marcas líderes mundiales. Disponibilidad inmediata y envíos a los <strong>32 estados de México</strong>.
        </p>
      </SectionHeader>

      <div class="catalogo__grid">
        {productCategories.map((cat) => (
          <CategoryCard
            title={cat.label}
            icon={cat.icon}
            image={categoryImages[cat.label]}
            badge={cat.children ? `${cat.children.length} productos` : undefined}
            items={cat.children?.map(child => ({ label: child.label, href: child.href }))}
            href={cat.href}
            buttonText={cat.label}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- SECTORES QUE ATENDEMOS -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="sectores section">
    <div class="container">
      <SectionHeader
        label="Sectores que Atendemos"
        title="Equipo Especializado para Cada Sector"
        description="Desde estaciones de bomberos municipales hasta brigadas industriales de PEMEX, equipamos a quienes protegen a México."
      >
        <p>
          Cada sector tiene <strong>necesidades específicas de protección contra incendios</strong>. En BOMBERO.MX entendemos esas diferencias y ofrecemos el <strong>equipo certificado adecuado</strong> para cada tipo de operación, desde combate estructural hasta rescate aeroportuario ARFF.
        </p>
        <p>
          Nuestro equipo técnico proporciona <strong>asesoría personalizada</strong> para determinar el equipamiento óptimo según el tipo de riesgo, normativa aplicable y presupuesto disponible.
        </p>
      </SectionHeader>

      <div class="sectores__grid">
        {sectores.map((s) => (
          <div class="sectores__card">
            <div class="sectores__icon">
              <Fragment set:html={s.icon} />
            </div>
            <h3 class="sectores__title">{s.title}</h3>
            <p class="sectores__desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- CERTIFICACIONES -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <Certifications />

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- POR QUÉ ELEGIRNOS -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <WhyChooseUs />

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- COBERTURA NACIONAL -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <section class="cobertura section">
    <div class="container">
      <SectionHeader
        label="Cobertura Nacional"
        title="Envíos a los 32 Estados de México"
        description="Logística especializada en equipo contra incendios con entregas express en las principales ciudades del país."
      >
        <p>
          Nuestra red logística garantiza entregas <strong>en 24-48 horas</strong> a las principales ciudades de México. Coordinamos recepciones directas en <strong>estaciones de bomberos</strong> y centros de trabajo con embalaje reforzado y rastreo en tiempo real.
        </p>
        <p>
          Atendemos <strong>licitaciones gubernamentales</strong>, compras directas y proyectos de equipamiento integral. Cotizaciones sin compromiso para cualquier volumen.
        </p>
      </SectionHeader>

      <!-- Stats Bar -->
      <div class="cobertura__stats">
        <div class="cobertura__stat">
          <div class="cobertura__stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="cobertura__stat-content">
            <span class="cobertura__stat-number">32</span>
            <span class="cobertura__stat-label">Estados Cubiertos</span>
          </div>
        </div>
        <div class="cobertura__stat">
          <div class="cobertura__stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="cobertura__stat-content">
            <span class="cobertura__stat-number">24-48h</span>
            <span class="cobertura__stat-label">Entrega Express</span>
          </div>
        </div>
        <div class="cobertura__stat">
          <div class="cobertura__stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
          </div>
          <div class="cobertura__stat-content">
            <span class="cobertura__stat-number">Rastreo</span>
            <span class="cobertura__stat-label">En Tiempo Real</span>
          </div>
        </div>
        <div class="cobertura__stat">
          <div class="cobertura__stat-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div class="cobertura__stat-content">
            <span class="cobertura__stat-number">100%</span>
            <span class="cobertura__stat-label">Embalaje Certificado</span>
          </div>
        </div>
      </div>

      <!-- Regiones -->
      <div class="cobertura__regions">
        <div class="cobertura__region">
          <h3 class="cobertura__region-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Centro
          </h3>
          <ul class="cobertura__cities">
            <li>Ciudad de México</li>
            <li>Estado de México</li>
            <li>Puebla</li>
            <li>Querétaro</li>
            <li>Morelos</li>
            <li>Tlaxcala</li>
            <li>Hidalgo</li>
          </ul>
        </div>
        <div class="cobertura__region">
          <h3 class="cobertura__region-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Norte
          </h3>
          <ul class="cobertura__cities">
            <li>Nuevo León</li>
            <li>Chihuahua</li>
            <li>Coahuila</li>
            <li>Tamaulipas</li>
            <li>Durango</li>
            <li>Sonora</li>
            <li>Baja California</li>
          </ul>
        </div>
        <div class="cobertura__region">
