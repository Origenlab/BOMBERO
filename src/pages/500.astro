---
/**
 * --- 500 Page ---
 * Custom server error page with helpful messaging.
 */
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title="Error del servidor" description="Ha ocurrido un error en el servidor. Por favor intenta de nuevo." noindex>
  <section class="error-page section">
    <div class="container" style="text-align: center;">
      <p class="error-page__code">500</p>
      <h1 class="error-page__title">Error del servidor</h1>
      <p class="error-page__description">
        Lo sentimos, ha ocurrido un error inesperado. Nuestro equipo ha sido notificado
        y estamos trabajando para solucionarlo.
      </p>
      <div class="error-page__actions">
        <a href="/" class="btn btn--primary">Volver al inicio</a>
        <a href="/contacto/" class="btn btn--secondary">Contactar soporte</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .error-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .error-page__code {
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 800;
    color: var(--color-fire-200);
    line-height: 1;
  }

  .error-page__title {
    font-size: var(--text-3xl);
    margin-block: var(--space-md);
  }

  .error-page__description {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    margin-block-end: var(--space-xl);
    max-width: 45ch;
    margin-inline: auto;
  }

  .error-page__actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn--secondary {
    background: transparent;
    border: 2px solid var(--color-fire-600);
    color: var(--color-fire-600);
  }

  .btn--secondary:hover {
    background: var(--color-fire-50);
  }
</style>
