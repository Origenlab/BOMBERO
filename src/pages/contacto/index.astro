<script define:vars={{ whatsappNumber: "525560348981" }}>
  (function() {
    const form = document.getElementById('whatsapp-form');
    if (!form) return;

    function getEl(id) { return document.getElementById(id); }

    function setErr(groupId, errId, msg) {
      const g = getEl(groupId); const s = getEl(errId);
      if (g) { g.classList.add('form-group--error'); g.classList.remove('form-group--ok'); }
      if (s) { s.textContent = msg; s.hidden = false; }
      const inp = g && g.querySelector('input,textarea');
      if (inp) inp.setAttribute('aria-invalid','true');
    }
    function clearErr(groupId, errId) {
      const g = getEl(groupId); const s = getEl(errId);
      if (g) g.classList.remove('form-group--error');
      if (s) { s.hidden = true; s.textContent = ''; }
      const inp = g && g.querySelector('input,textarea');
      if (inp) inp.removeAttribute('aria-invalid');
    }
    function markOk(groupId) {
      const g = getEl(groupId);
      if (g) g.classList.add('form-group--ok');
    }

    function validateNombre() {
      const v = (getEl('ctc-nombre') || {}).value || '';
      if (!v.trim()) { setErr('ctc-g-nombre','ctc-e-nombre','Ingresa tu nombre.'); return false; }
      clearErr('ctc-g-nombre','ctc-e-nombre'); markOk('ctc-g-nombre'); return true;
    }
    function validateMensaje() {
      const v = (getEl('ctc-mensaje') || {}).value || '';
      if (!v.trim()) { setErr('ctc-g-mensaje','ctc-e-mensaje','Cuéntanos en qué podemos ayudarte.'); return false; }
      if (v.trim().length < 10) { setErr('ctc-g-mensaje','ctc-e-mensaje','Por favor sé un poco más específico.'); return false; }
      clearErr('ctc-g-mensaje','ctc-e-mensaje'); markOk('ctc-g-mensaje'); return true;
    }

    // blur
    const nEl = getEl('ctc-nombre');
    const mEl = getEl('ctc-mensaje');
    if (nEl) {
      nEl.addEventListener('blur', validateNombre);
      nEl.addEventListener('input', () => clearErr('ctc-g-nombre','ctc-e-nombre'));
    }
    if (mEl) {
      mEl.addEventListener('blur', validateMensaje);
      mEl.addEventListener('input', () => clearErr('ctc-g-mensaje','ctc-e-mensaje'));
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const ok = [validateNombre(), validateMensaje()].every(Boolean);
      if (!ok) {
        const first = form.querySelector('.form-group--error input, .form-group--error textarea');
        if (first) first.scrollIntoView({ behavior:'smooth', block:'nearest' });
        return;
      }

      const btn  = getEl('ctc-btn');
      const txt  = getEl('ctc-text');
      const icon = getEl('ctc-icon');

      btn.disabled = true;
      icon.style.opacity = '0.5';
      txt.textContent = 'Abriendo WhatsApp…';

      const nombre  = getEl('ctc-nombre').value.trim();
      const empresa = getEl('ctc-empresa').value.trim();
      const mensaje = getEl('ctc-mensaje').value.trim();

      let texto = `*Mensaje desde BOMBERO.MX*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      if (empresa) texto += `*Empresa/Estación:* ${empresa}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(texto)}`;
      const opened = window.open(url, '_blank', 'noopener,noreferrer');
      if (!opened) window.location.href = url;

      setTimeout(function() {
        btn.disabled = false;
        icon.style.opacity = '';
        txt.textContent = 'Enviar por WhatsApp';
      }, 3000);
    });
  })();
</script>
