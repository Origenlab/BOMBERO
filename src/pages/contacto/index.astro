---

import PageLayout from "@layouts/PageLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import CTABanner from "@components/CTABanner.astro";
import HeroSection from "@components/HeroSection.astro";
import FAQQuote from "@components/FAQQuote.astro";
import { SITE } from "@config/site";
import QuickNav from "@components/QuickNav.astro";

const contactChannels = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    title: "Teléfono",
    value: SITE.contact.phone,
    href: `tel:${SITE.contact.phone.replace(/\s/g, '')}`,
    action: "Llamar ahora",
    highlight: false,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
    title: "WhatsApp",
    value: SITE.contact.whatsapp,
    href: `https://wa.me/${SITE.contact.whatsapp.replace(/\D/g, '')}?text=Hola%2C%20me%20interesa%20información%20sobre%20equipo%20para%20bomberos`,
    action: "Enviar mensaje",
    highlight: true,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    title: "Correo Electrónico",
    value: SITE.contact.email,
    href: `mailto:${SITE.contact.email}`,
    action: "Enviar correo",
    highlight: false,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "Horario de Atención",
    value: "Lunes a Viernes",
    subvalue: "09:00 - 18:00 hrs",
    href: null,
    action: null,
    highlight: false,
  },
];

const services = [
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`, title: "Cotizaciones", desc: "Especificación técnica NFPA con edición vigente, certificado de laboratorio por número de lote y carta de distribución autorizada del fabricante. Respuesta en menos de 24 hrs hábiles." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, title: "Asesoría Técnica", desc: "Diagnóstico de riesgo operativo: qué norma NFPA aplica, qué edición está vigente y qué ensayos exige. Sin costo y sin compromiso de compra." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>`, title: "Envíos Nacionales", desc: "Entrega con número de guía en tiempo real. 24–48 hrs a las principales ciudades; cobertura en los 32 estados con entrega directa en tu estación o planta industrial." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`, title: "Licitaciones", desc: "Más de 200 procesos LAASSP completados: especificación técnica NFPA, partidas CUCOP, cartas de garantía y actas de entrega con carta de distribución del fabricante." },
];

const faqs = [
  { icon: "truck", title: "¿Cuál es el tiempo de entrega?", image: "/images/directorio/camion-bomberos-equipado-01.avif", description: "Para productos en stock, el tiempo de entrega es de 24-48 horas en las principales ciudades. Equipos especializados o pedidos grandes pueden requerir 2-4 semanas." },
  { icon: "certificate", title: "¿Ofrecen factura fiscal?", image: "/images/directorio/centro-mando-bomberos-01.avif", description: "Sí, emitimos factura CFDI 4.0 con todos los requisitos fiscales para deducción de impuestos y procesos de licitación." },
  { icon: "shield", title: "¿Tienen garantía los productos?", image: "/images/directorio/equipo-proteccion-bomberos-01.avif", description: "Todos nuestros productos cuentan con garantía del fabricante. Los plazos varían según el tipo de equipo, desde 1 año hasta garantía de por vida en algunos casos." },
  { icon: "clock", title: "¿Hacen envíos a toda la República?", image: "/images/directorio/estacion-bomberos-profesional-01.avif", description: "Sí, tenemos cobertura en los 32 estados de México. Coordinamos entregas directas en estaciones de bomberos y centros de trabajo." },
];

const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  mainEntity: {
    "@type": "Organization",
    name: SITE.organization.name,
    telephone: SITE.contact.phone,
    email: SITE.contact.email,
    address: {
      "@type": "PostalAddress",
      streetAddress: "Av. Tamaulipas 150, Piso 13",
      addressLocality: "Ciudad de México",
      addressRegion: "CDMX",
      postalCode: "06140",
      addressCountry: "MX",
    },
    openingHours: "Mo-Fr 09:00-18:00",
  },
};
---

<PageLayout
  quickNav={false}
  title="Cotización de Equipo para Bomberos en México | Asesoría NFPA"
  description="Cotización de equipo para bomberos en México: respuesta en menos de 24 hrs. Distribuidores autorizados MSA, Honeywell. Asesoría técnica NFPA sin costo."
  keywords={[
    "cotización equipo para bomberos México",
    "distribuidor autorizado equipo bomberos México",
    "asesoría técnica NFPA sin costo",
    "cotizar equipo bomberos NFPA",
    "distribuidor equipo bomberos contacto",
    "comprar equipo bomberos México",
  ]}
  canonical="https://bombero.mx/contacto/"
  jsonLd={[contactJsonLd]}
>




  <Breadcrumb items={[{ label: "Contacto" }]} />




  <HeroSection
    badge="Distribuidores Autorizados · Respuesta en 24 hrs · 32 Estados"
    title={`Solicita Cotización de <span class="hero__title-highlight">Equipo para Bomberos</span> en México`}
    subtitle="Distribuidores autorizados MSA, Honeywell, Globe y Bullard en los 32 estados. Cotización técnica con especificación NFPA y certificado de laboratorio por número de lote. Respuesta en menos de 24 hrs hábiles."
  >
    <div slot="right">
      <div class="hero__cards">
        {contactChannels.map((channel) => (
          <div class={`contact-card ${channel.highlight ? 'contact-card--highlight' : ''}`}>
            <div class="contact-card__icon">
              <Fragment set:html={channel.icon} />
            </div>
            <div class="contact-card__content">
              <span class="contact-card__title">{channel.title}</span>
              <span class="contact-card__value">{channel.value}</span>
              {channel.subvalue && <span class="contact-card__subvalue">{channel.subvalue}</span>}
            </div>
            {channel.href && (
              <a href={channel.href} class={`contact-card__btn ${channel.highlight ? 'btn btn--primary' : 'btn btn--ghost'}`}>
                {channel.action}
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </HeroSection>

  <QuickNav pool="info" count={7} />





  <section class="servicios section">
    <div class="container">
      <SectionHeader
        label="¿Cómo Podemos Ayudarte?"
        title="De la Consulta a la Entrega Documentada"
        description="Desde el diagnóstico de riesgo operativo hasta la entrega con número de guía — sin intermediarios, directo del fabricante."
      >
        <p>
          Desde la especificación técnica correcta (qué norma <strong>NFPA</strong>, qué edición, qué ensayo) hasta la entrega en tu estación documentando cada paso: cotización con <strong>partidas CUCOP</strong> para licitaciones formales, <strong>certificado de laboratorio acreditado (UL, Intertek, SEI) por número de lote</strong>, y carta de distribución autorizada de <strong>MSA, Honeywell, Globe o Bullard</strong> según la línea solicitada.
        </p>
      </SectionHeader>

      <div class="servicios__grid">
        {services.map((service) => (
          <div class="servicios__card">
            <div class="servicios__icon">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="servicios__title">{service.title}</h3>
            <p class="servicios__desc">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>




  <section class="ubicacion section">
    <div class="container">
      <SectionHeader
        label="Nuestra Oficina"
        title="Ubicación en Ciudad de México"
        description="Oficina central en Col. Condesa, CDMX — con cita previa para revisión de equipo en físico y asesoría técnica presencial."
      >
        <p>
          Atendemos toda la República Mexicana desde nuestra oficina en Condesa, CDMX. Para cuerpos de bomberos y brigadas industriales en <strong>CDMX y Zona Metropolitana</strong>, el asesor se desplaza a tu estación sin costo — para revisar el EPP existente contra los criterios de retiro <strong>NFPA 1851</strong> o presentar catálogo de trajes, SCBA y cascos en físico.
        </p>
      </SectionHeader>

      <div class="ubicacion__content">
        <div class="ubicacion__info">
          <div class="ubicacion__address">
            <div class="ubicacion__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h3 class="ubicacion__title">Dirección</h3>
              <p class="ubicacion__text">
                Av. Tamaulipas 150, Piso 13<br>
                Col. Condesa, Cuauhtémoc<br>
                06140, Ciudad de México
              </p>
            </div>
          </div>

          <div class="ubicacion__details">
            <div class="ubicacion__detail">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <strong>Horario</strong>
                <span>Lunes a Viernes, 09:00 - 18:00</span>
              </div>
            </div>
            <div class="ubicacion__detail">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div>
                <strong>Teléfono</strong>
                <span>{SITE.contact.phone}</span>
              </div>
            </div>
            <div class="ubicacion__detail">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <div>
                <strong>Correo</strong>
                <span>{SITE.contact.email}</span>
              </div>
            </div>
          </div>

          <a href={`https://wa.me/${SITE.contact.whatsapp.replace(/\D/g, '')}?text=Hola%2C%20quiero%20agendar%20una%20visita`} class="btn btn--primary ubicacion__btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            <span>Agendar Visita</span>
          </a>
        </div>

        <div class="ubicacion__form">
          <h3 class="ubicacion__form-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            Envíanos un mensaje
          </h3>
          <form id="whatsapp-form" class="ubicacion__form-fields" novalidate>
            <div class="form-group" id="ctc-g-nombre">
              <label for="ctc-nombre">Nombre <span class="form-req" aria-hidden="true">*</span></label>
              <input type="text" id="ctc-nombre" name="nombre" placeholder="Tu nombre completo" required autocomplete="name" aria-required="true" aria-describedby="ctc-e-nombre" />
              <span id="ctc-e-nombre" class="form-field-error" role="alert" aria-live="polite" hidden></span>
            </div>
            <div class="form-group" id="ctc-g-empresa">
              <label for="ctc-empresa">Empresa / Estación</label>
              <input type="text" id="ctc-empresa" name="empresa" placeholder="Ej: Bomberos Municipales de..." autocomplete="organization" />
            </div>
            <div class="form-group" id="ctc-g-mensaje">
              <label for="ctc-mensaje">¿En qué podemos ayudarte? <span class="form-req" aria-hidden="true">*</span></label>
              <textarea id="ctc-mensaje" name="mensaje" rows="3" placeholder="Cuéntanos sobre tu proyecto de equipamiento..." required aria-required="true" aria-describedby="ctc-e-mensaje"></textarea>
              <span id="ctc-e-mensaje" class="form-field-error" role="alert" aria-live="polite" hidden></span>
            </div>
            <button type="submit" id="ctc-btn" class="btn btn--whatsapp">
              <svg id="ctc-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <span id="ctc-text">Enviar por WhatsApp</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>




  <section class="faq section">
    <div class="container">
      <SectionHeader
        label="Preguntas Frecuentes"
        title="Tiempos, Garantías y Proceso sin Rodeos"
        description="Cómo trabajamos en cada etapa: cotización, entrega, seguimiento de pedido y resolución de garantías con el fabricante."
      >
        <p>
          ¿No encuentras lo que buscas? Escríbenos por WhatsApp al <strong>+52 55 6034 8981</strong> especificando el tipo de equipo (traje estructural, SCBA, casco, rescate técnico, ARFF o HAZMAT) — conectamos directamente con el asesor especializado en esa línea, no con ventas general.
        </p>
      </SectionHeader>

      <div class="faq__grid">
        {faqs.map((faq) => (
          <CategoryCard
            title={faq.title}
            icon={faq.icon}
            image={faq.image}
            description={faq.description}
          />
        ))}
      </div>
    </div>
  </section>




  <FAQQuote
    title="Contacto y soporte — sin rodeos"
    description="Horarios reales, tiempos de respuesta, cómo llegar a un asesor técnico, seguimiento de pedidos y qué pasa cuando algo falla. Todo lo que necesitas saber sobre cómo trabajamos."
    items={[
      {
        question: "¿Cuál es el horario real de atención y qué pasa fuera de horario?",
        answer: "Atención estándar: Lunes a Viernes 9:00–18:00 hrs, Sábados 9:00–14:00 hrs (hora CDMX). Fuera de esos horarios, el WhatsApp +52 55 6034 8981 es monitoreado por al menos un asesor para emergencias de equipamiento: si tu cuerpo de bomberos perdió equipo crítico en operación y necesitas reposición urgente, escríbenos aunque sean las 10 de la noche. Para cotizaciones estándar y consultas técnicas no urgentes, respondemos en la siguiente jornada hábil.",
      },
      {
        question: "¿Cómo llegó a un asesor técnico que conozca NFPA, no solo ventas?",
        answer: "Escríbenos por WhatsApp al +52 55 6034 8981 especificando la categoría de equipo (traje estructural/SCBA/rescate técnico/ARFF/HAZMAT/forestal). Con eso conectamos directamente con el asesor especializado en esa línea, no con un ejecutivo de ventas genérico. Para consultas técnicas detalladas (selección de traje por TPP/THL, mantenimiento NFPA 1851, especificación para licitación), escríbenos a ventas.bomberosmx@gmail.com con toda la descripción — respondemos con análisis técnico verificable, no con folleto de producto.",
      },
      {
        question: "¿Tienen atención presencial y pueden visitar mi instalación?",
        answer: "Nuestras oficinas están en Av. Tamaulipas 150, Piso 13, Col. Condesa, CDMX 06140 — atención con cita previa (coordina por WhatsApp o correo). Para visitas a tu estación o planta industrial en CDMX y Zona Metropolitana, desplazamos al asesor sin costo: presentación de catálogo en físico, demostración de equipo y evaluación de EPP existente. Para instituciones fuera del Valle de México, coordinamos visita según el tamaño del proyecto.",
      },
      {
        question: "¿Cómo hago seguimiento a mi pedido después de confirmarlo?",
        answer: "Al confirmar el pedido recibes número de orden y cronograma de entrega por escrito. Al salir del almacén: número de guía de paquetería con enlace de rastreo en tiempo real. Para pedidos institucionales (cuerpos de bomberos, gobierno, industria) asignamos un contacto de referencia que responde por WhatsApp cualquier consulta sobre el estado del pedido — desde la confirmación hasta la firma de recepción. Los pedidos con más de 5 partidas o más de $50,000 MXN tienen seguimiento activo sin que tengas que preguntarlo.",
      },
      {
        question: "¿Qué hago si el equipo entregado tiene un defecto de fábrica?",
        answer: "Escríbenos de inmediato por WhatsApp con el número de pedido, fotos del defecto y descripción. Gestionamos el reporte directamente con el fabricante (MSA, Honeywell, Globe, Bullard, Cairns, Holmatro) en menos de 48 hrs hábiles. Para defectos de fábrica confirmados, reemplazamos la pieza sin costo adicional ni burocracia — la garantía del fabricante corre a través de nosotros. No devolverás el producto a otro país ni gestionarás el caso con el fabricante directamente; somos el punto de contacto y resolución.",
      },
      {
        question: "¿Pueden auditar el estado del EPP actual de mi estación?",
        answer: "Sí. La auditoría de EPP es un servicio técnico que realizamos sin costo para cuerpos de bomberos y brigadas industriales. Evaluamos el inventario existente contra los criterios de retiro de la NFPA 1851 (trajes, cascos, botas, capuchas, guantes) y NFPA 1852 (SCBA): fecha de fabricación, estado visual, historial de exposición y resultado de inspección. El reporte identifica qué equipo está en condición de retiro obligatorio, qué necesita reparación y qué puede continuar en servicio. Esto es especialmente útil para justificar partidas presupuestales de renovación ante las autoridades municipales o directores de planta.",
      },
      {
        question: "¿Cuánto tarda una cotización y qué formato tiene?",
        answer: "Respuesta en menos de 24 hrs hábiles (solicitudes antes de las 14:00 hrs se procesan el mismo día). La cotización incluye: precio unitario y total con IVA, descripción técnica del producto con norma NFPA y edición, certificado de laboratorio acreditado (UL/Intertek/SEI) del producto específico, disponibilidad en inventario, tiempo estimado de entrega, y carta de distribución autorizada del fabricante. Para licitaciones formales también incluimos el formato en Word/Excel con partidas CUCOP y el texto de especificación técnica correcto. Todo en PDF o formato que el área de compras requiera.",
      },
      {
        question: "¿Ofrecen alianzas comerciales o distribución regional para otros estados?",
        answer: "Evaluamos casos específicos. Escríbenos a ventas.bomberosmx@gmail.com con asunto 'Alianza Comercial' describiendo: estado de operación, perfil de clientes (cuerpos de bomberos, industria, gobierno), volumen mensual estimado y experiencia previa en venta de EPP o equipo de emergencias. No buscamos revendedores de catálogo — buscamos socios con conocimiento del sector y cartera activa en su región. La evaluación tarda máximo 5 días hábiles.",
      },
    ]}
  />

  <CTABanner
