<script define:vars={{ whatsappNumber: "5520780102" }}>
  document.getElementById('whatsapp-form')?.addEventListener('submit', function(e) {
    e.preventDefault();

    const nombre = document.getElementById('nombre').value.trim();
    const empresa = document.getElementById('empresa').value.trim();
    const mensaje = document.getElementById('mensaje').value.trim();

    let textoWhatsApp = `Hola, soy ${nombre}`;
    if (empresa) {
      textoWhatsApp += ` de ${empresa}`;
    }
    textoWhatsApp += `.%0A%0A${mensaje}`;

    const url = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(textoWhatsApp).replace(/%20/g, '%20')}`;
    window.open(url, '_blank');
  });
</script>
