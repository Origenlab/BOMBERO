---

import PageLayout from "@layouts/PageLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import CTABanner from "@components/CTABanner.astro";
import { SITE } from "@data/site";

const contactChannels = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    title: "Teléfono",
    value: SITE.contact.phone,
    href: `tel:${SITE.contact.phone.replace(/\s/g, '')}`,
    action: "Llamar ahora",
    highlight: false,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
    title: "WhatsApp",
    value: SITE.contact.whatsapp,
    href: `https://wa.me/${SITE.contact.whatsapp.replace(/\D/g, '')}?text=Hola%2C%20me%20interesa%20información%20sobre%20equipo%20para%20bomberos`,
    action: "Enviar mensaje",
    highlight: true,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    title: "Correo Electrónico",
    value: SITE.contact.email,
    href: `mailto:${SITE.contact.email}`,
    action: "Enviar correo",
    highlight: false,
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "Horario de Atención",
    value: "Lunes a Viernes",
    subvalue: "09:00 - 18:00 hrs",
    href: null,
    action: null,
    highlight: false,
  },
];

const services = [
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`, title: "Cotizaciones", desc: "Presupuestos detallados para equipamiento completo de estaciones y brigadas." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, title: "Asesoría Técnica", desc: "Expertos en normativa NFPA para selección de equipo según tus necesidades." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>`, title: "Envíos Nacionales", desc: "Entrega en 24-48 horas a las principales ciudades de México." },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`, title: "Licitaciones", desc: "Documentación completa para procesos de compra gubernamental." },
];

const faqs = [
  { icon: "truck", title: "¿Cuál es el tiempo de entrega?", image: "/images/directorio/camion-bomberos-equipado-01.avif", description: "Para productos en stock, el tiempo de entrega es de 24-48 horas en las principales ciudades. Equipos especializados o pedidos grandes pueden requerir 2-4 semanas." },
  { icon: "certificate", title: "¿Ofrecen factura fiscal?", image: "/images/directorio/centro-mando-bomberos-01.avif", description: "Sí, emitimos factura CFDI 4.0 con todos los requisitos fiscales para deducción de impuestos y procesos de licitación." },
  { icon: "shield", title: "¿Tienen garantía los productos?", image: "/images/directorio/equipo-proteccion-bomberos-01.avif", description: "Todos nuestros productos cuentan con garantía del fabricante. Los plazos varían según el tipo de equipo, desde 1 año hasta garantía de por vida en algunos casos." },
  { icon: "clock", title: "¿Hacen envíos a toda la República?", image: "/images/directorio/estacion-bomberos-profesional-01.avif", description: "Sí, tenemos cobertura en los 32 estados de México. Coordinamos entregas directas en estaciones de bomberos y centros de trabajo." },
];

const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  mainEntity: {
    "@type": "Organization",
    name: SITE.organization.name,
    telephone: SITE.contact.phone,
    email: SITE.contact.email,
    address: {
      "@type": "PostalAddress",
      streetAddress: "Av. Tamaulipas 150, Piso 13",
      addressLocality: "Ciudad de México",
      addressRegion: "CDMX",
      postalCode: "06140",
      addressCountry: "MX",
    },
    openingHours: "Mo-Fr 09:00-18:00",
  },
};
---

<PageLayout
  title="Contacto | Cotizaciones y Asesoría | BOMBERO.MX"
  description="Contacta a BOMBERO.MX para cotizaciones de equipo para bomberos. Teléfono, WhatsApp y correo. Asesoría técnica gratuita y envíos a los 32 estados de México."
  keywords={[
    "contacto bombero mx",
    "cotización equipo bomberos",
    "teléfono equipo bomberos México",
    "asesoría equipo NFPA",
    "distribuidor equipo bomberos contacto",
  ]}
  canonical="https://bombero.mx/contacto/"
  jsonLd={[contactJsonLd]}
>




  <Breadcrumb items={[{ label: "Contacto" }]} />




  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid"></div>
    </div>

    <div class="container hero__container">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          Respuesta en menos de 24 horas
        </div>

        <h1 class="hero__title">
          ¿Necesitas <span class="hero__title-highlight">Equipar</span> tu Estación?
        </h1>

        <p class="hero__subtitle">
          Nuestro equipo de especialistas está listo para ayudarte a seleccionar el equipo de protección adecuado para tu cuerpo de bomberos, brigada industrial o unidad de protección civil.
        </p>

        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-number">+500</span>
            <span class="hero__stat-label">Estaciones atendidas</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-number">32</span>
            <span class="hero__stat-label">Estados cubiertos</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-number">15+</span>
            <span class="hero__stat-label">Años de experiencia</span>
          </div>
        </div>
      </div>


      <div class="hero__cards">
        {contactChannels.map((channel) => (
          <div class={`contact-card ${channel.highlight ? 'contact-card--highlight' : ''}`}>
            <div class="contact-card__icon">
              <Fragment set:html={channel.icon} />
            </div>
            <div class="contact-card__content">
              <span class="contact-card__title">{channel.title}</span>
              <span class="contact-card__value">{channel.value}</span>
              {channel.subvalue && <span class="contact-card__subvalue">{channel.subvalue}</span>}
            </div>
            {channel.href && (
              <a href={channel.href} class={`contact-card__btn ${channel.highlight ? 'btn btn--primary' : 'btn btn--ghost'}`}>
                {channel.action}
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>




  <section class="servicios section">
    <div class="container">
      <SectionHeader
        label="¿Cómo Podemos Ayudarte?"
        title="Servicios de Atención"
        description="Nuestro equipo está preparado para asistirte en cada etapa del proceso de equipamiento."
      >
        <p>
          Desde la <strong>selección inicial del equipo</strong> hasta la <strong>entrega en tu estación</strong>, te acompañamos en todo momento. Contamos con especialistas certificados en normativa <strong>NFPA, UL y NOM</strong> para garantizar que recibas el equipo adecuado.
        </p>
      </SectionHeader>

      <div class="servicios__grid">
        {services.map((service) => (
          <div class="servicios__card">
            <div class="servicios__icon">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="servicios__title">{service.title}</h3>
            <p class="servicios__desc">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>




  <section class="ubicacion section">
    <div class="container">
      <SectionHeader
        label="Nuestra Oficina"
        title="Ubicación en Ciudad de México"
        description="Visítanos en nuestras oficinas centrales en la Col. Condesa para una atención personalizada."
      >
        <p>
          Aunque atendemos a <strong>toda la República Mexicana</strong>, nuestra oficina central se encuentra en la Ciudad de México. Agenda una cita para revisar productos y recibir asesoría presencial.
        </p>
      </SectionHeader>

      <div class="ubicacion__content">
        <div class="ubicacion__info">
          <div class="ubicacion__address">
            <div class="ubicacion__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h3 class="ubicacion__title">Dirección</h3>
              <p class="ubicacion__text">
                Av. Tamaulipas 150, Piso 13<br>
                Col. Condesa, Cuauhtémoc<br>
                06140, Ciudad de México
              </p>
            </div>
          </div>

          <div class="ubicacion__details">
            <div class="ubicacion__detail">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <strong>Horario</strong>
                <span>Lunes a Viernes, 09:00 - 18:00</span>
              </div>
            </div>
            <div class="ubicacion__detail">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div>
                <strong>Teléfono</strong>
                <span>{SITE.contact.phone}</span>
              </div>
            </div>
            <div class="ubicacion__detail">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <div>
                <strong>Correo</strong>
                <span>{SITE.contact.email}</span>
              </div>
            </div>
          </div>

          <a href={`https://wa.me/${SITE.contact.whatsapp.replace(/\D/g, '')}?text=Hola%2C%20quiero%20agendar%20una%20visita`} class="btn btn--primary ubicacion__btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            <span>Agendar Visita</span>
          </a>
        </div>

        <div class="ubicacion__form">
          <h3 class="ubicacion__form-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            Envíanos un mensaje
          </h3>
          <form id="whatsapp-form" class="ubicacion__form-fields">
            <div class="form-group">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label for="empresa">Empresa / Estación</label>
              <input type="text" id="empresa" name="empresa" placeholder="Ej: Bomberos Municipales de..." />
            </div>
            <div class="form-group">
              <label for="mensaje">¿En qué podemos ayudarte?</label>
              <textarea id="mensaje" name="mensaje" rows="3" placeholder="Cuéntanos sobre tu proyecto de equipamiento..." required></textarea>
            </div>
            <button type="submit" class="btn btn--whatsapp">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Enviar por WhatsApp
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>




  <section class="faq section">
    <div class="container">
      <SectionHeader
        label="Preguntas Frecuentes"
        title="Resolvemos tus Dudas"
        description="Las preguntas más comunes sobre nuestros servicios de equipamiento para bomberos."
      >
        <p>
          ¿No encuentras lo que buscas? <strong>Contáctanos directamente</strong> por WhatsApp o teléfono y nuestro equipo te asistirá de inmediato con cualquier duda sobre productos, envíos o cotizaciones.
        </p>
      </SectionHeader>

      <div class="faq__grid">
        {faqs.map((faq) => (
          <CategoryCard
            title={faq.title}
            icon={faq.icon}
            image={faq.image}
            description={faq.description}
          />
        ))}
      </div>
    </div>
  </section>




  <CTABanner
    title="¿Listo para Cotizar?"
    desc="Solicita una cotización sin compromiso. Asesoría técnica gratuita para tu proyecto de equipamiento."
    btnText="Solicitar Cotización"
    btnHref="/cotizar/"
    whatsapp={true}
  />
</PageLayout>

<style>

  .hero {
    position: relative;
    background: var(--color-smoke-950);
    overflow: hidden;
    padding: var(--space-8) 0 var(--space-12);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(220, 38, 38, 0.15), transparent),
      radial-gradient(ellipse 60% 50% at 100% 80%, rgba(220, 38, 38, 0.08), transparent);
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .hero__container {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .hero__content {
    text-align: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: rgba(220, 38, 38, 0.15);
    border: 1px solid rgba(220, 38, 38, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-fire-400);
    margin-bottom: var(--space-4);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-ember-500);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero__title {
    font-size: clamp(1.75rem, 6vw, 2.5rem);
    font-weight: 800;
    line-height: 1.15;
    color: #ffffff;
    margin-bottom: var(--space-4);
  }

  .hero__title-highlight {
    background: var(--gradient-fire);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: var(--text-base);
    color: var(--color-smoke-300);
    line-height: 1.6;
    margin-bottom: var(--space-6);
    max-width: 540px;
    margin-inline: auto;
  }

  .hero__stats {
    display: flex;
    justify-content: center;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .hero__stat {
    text-align: center;
  }

  .hero__stat-number {
    display: block;
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-fire-400);
    line-height: 1;
  }

  .hero__stat-label {
    display: block;
    font-size: 10px;
    color: var(--color-smoke-400);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-1);
  }


  .hero__cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-xl);
    transition: all 0.2s ease;
  }

  .contact-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .contact-card--highlight {
    background: rgba(37, 211, 102, 0.1);
    border-color: rgba(37, 211, 102, 0.3);
  }

  .contact-card--highlight:hover {
    background: rgba(37, 211, 102, 0.15);
  }

  .contact-card__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
  }

  .contact-card--highlight .contact-card__icon {
    background: rgba(37, 211, 102, 0.2);
  }

  .contact-card__icon :global(svg) {
    width: 22px;
    height: 22px;
    stroke: var(--color-smoke-300);
  }

  .contact-card--highlight .contact-card__icon :global(svg) {
    stroke: #25D366;
  }

  .contact-card__content {
    flex: 1;
    min-width: 0;
  }

  .contact-card__title {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-smoke-400);
    margin-bottom: 2px;
  }

  .contact-card__value {
    display: block;
    font-size: var(--text-base);
    font-weight: 700;
    color: #ffffff;
  }

  .contact-card__subvalue {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-smoke-400);
  }

  .contact-card__btn {
    flex-shrink: 0;
    font-size: var(--text-xs);
    padding: var(--space-2) var(--space-3);
  }


  .servicios {
    padding: var(--space-12) 0;
    background: var(--color-smoke-50);
  }

  .servicios__grid {
    display: grid;
    grid-template-columns: 1fr;
