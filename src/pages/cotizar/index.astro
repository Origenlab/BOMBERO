<script define:vars={{ whatsappNumber: "5520780102" }}>
  document.getElementById('cotizar-form')?.addEventListener('submit', function(e) {
    e.preventDefault();

    const nombre = document.getElementById('nombre').value.trim();
    const empresa = document.getElementById('empresa').value.trim();
    const estado = document.getElementById('estado').value.trim();
    const productos = document.getElementById('productos').value.trim();

    let textoWhatsApp = `*SOLICITUD DE COTIZACIÓN*%0A%0A`;
    textoWhatsApp += `*Nombre:* ${nombre}%0A`;
    if (empresa) {
      textoWhatsApp += `*Empresa/Estación:* ${empresa}%0A`;
    }
    if (estado) {
      textoWhatsApp += `*Estado:* ${estado}%0A`;
    }
    textoWhatsApp += `%0A*Productos requeridos:*%0A${productos}`;

    const url = `https://wa.me/${whatsappNumber}?text=${textoWhatsApp}`;
    window.open(url, '_blank');
  });
</script>
