          title="Tecnología y Detección"
          badge="3 productos"
          image="/images/directorio/detector-multigas-hazmat-01.avif"
          href="/productos/tecnologia/"
          buttonText="Ver Tecnología"
          description="Cámaras termográficas TIC, detectores multigas y drones de reconocimiento para operaciones tácticas de alta exigencia."
          items={[
            { label: "Cámara Termográfica TIC",      href: "/productos/tecnologia/" },
            { label: "Detector de Gas Multigas",     href: "/productos/tecnologia/" },
            { label: "Dron de Reconocimiento",       href: "/productos/tecnologia/" },
          ]}
