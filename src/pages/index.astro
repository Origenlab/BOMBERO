          href="/productos/capuchas-para-bomberos/"
          buttonText="Ver Capuchas"
          description="Capuchas Nomex®, PBI Gold® y con protección particulada certificadas NFPA 1971. Protección 360° del cuello y zona facial."
          items={[
            { label: "Capucha Nomex®",                       href: "/productos/capuchas-para-bomberos/nomex/" },
            { label: "Capucha PBI Gold®",                    href: "/productos/capuchas-para-bomberos/pbi/" },
            { label: "Capucha con Protección Particulada",   href: "/productos/capuchas-para-bomberos/particulada/" },
          ]}
        />

        <CategoryCard
          title="Gafas y Protección Visual"
          badge="2 productos"
          image="/images/gafas-para-bomberos/gafas-bombero-producto-goggle-lente-espejo-premium-01.avif"
          href="/productos/gafas-para-bomberos/"
          buttonText="Ver Gafas"
          description="Goggles antipolvo, antiesquirlas y antiimpacto compatibles con SCBA y cascos NFPA. Policarbonato ANSI Z87.1."
          items={[
            { label: "Goggle de Bombero Premium",       href: "/productos/gafas-para-bomberos/goggle/" },
            { label: "Gafas de Seguridad Antiimpacto",  href: "/productos/gafas-para-bomberos/seguridad/" },
          ]}
        />

        <CategoryCard
          title="Extintores"
          badge="4 productos"
          image="/images/directorio/bombero-mexicano-retrato-incendio-01.avif"
          href="/productos/extintores/"
          buttonText="Ver Extintores"
          description="Extintores certificados NOM-100 en todas las clases: PQS, CO₂, espuma AFFF y halotron. Para industria y uso doméstico."
          items={[
            { label: "Extintor PQS — Polvo Químico Seco",    href: "/productos/extintores/" },
            { label: "Extintor CO₂ — Dióxido de Carbono",   href: "/productos/extintores/" },
            { label: "Extintor Espuma AFFF",                 href: "/productos/extintores/" },
            { label: "Extintor Halotron — Limpio",           href: "/productos/extintores/" },
          ]}
        />

        <CategoryCard
          title="HAZMAT y CBRN"
          badge="3 productos"
          image="/images/directorio/descontaminacion-hazmat-01.avif"
          href="/productos/hazmat/"
          buttonText="Ver HAZMAT"
          description="Trajes Nivel A y B encapsulados, kits de descontaminación y protección CBRN para respuesta a emergencias químicas."
          items={[
            { label: "Traje HAZMAT Nivel A Encapsulado",     href: "/productos/trajes-para-bomberos/traje-hazmat/nivel-a/" },
            { label: "Traje HAZMAT Nivel B",                 href: "/productos/trajes-para-bomberos/traje-hazmat/nivel-b/" },
            { label: "Kit Descontaminación Rápida",          href: "/productos/hazmat/" },
          ]}
        />

        <CategoryCard
          title="Equipo Contra Incendios"
          badge="4 productos"
          image="/images/directorio/sistema-espuma-incendios-01.avif"
          href="/productos/equipo-contra-incendios/"
          buttonText="Ver Equipo ECI"
          description="Mangueras, lanzas de ataque, gabinetes y accesorios para sistemas fijos y autobomba. Certificados NOM y NFPA."
          items={[
            { label: "Manguera contra Incendio NFPA",  href: "/productos/equipo-contra-incendios/" },
            { label: "Lanza de Ataque Ajustable",      href: "/productos/equipo-contra-incendios/" },
            { label: "Gabinete contra Incendio NOM",   href: "/productos/equipo-contra-incendios/" },
            { label: "Hidrante y Accesorios",          href: "/productos/equipo-contra-incendios/" },
          ]}
        />

        <CategoryCard
          title="Rescate Vertical y Arneses"
          badge="4 productos"
          image="/images/directorio/equipo-rescate-vertical-01.avif"
          href="/productos/rescate-vertical/"
          buttonText="Ver Arneses"
          description="Arneses técnicos, sistemas de descenso/ascenso y equipo de rescate en altura certificados NFPA 1983. Petzl, CMC y Yates."
          items={[
            { label: "Arnés de Rescate Técnico NFPA 1983", href: "/productos/rescate-vertical/" },
            { label: "Sistema Descenso Controlado",         href: "/productos/rescate-vertical/" },
            { label: "Polipasto y Sistemas de Izaje",       href: "/productos/rescate-vertical/" },
            { label: "Cuerdas y Accesorios de Rescate",    href: "/productos/rescate-vertical/" },
          ]}
