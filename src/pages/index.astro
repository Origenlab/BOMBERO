          href="/productos/botas-para-bomberos/"
          buttonText="Ver Botas"
          description="Botas de cuero NFPA 1971, caucho HAZMAT y forestal con suela Vibram®. Puntera composite, impermeables, resistentes al calor."
          items={[
            { label: "Bota Estructural — Cuero",      href: "/productos/botas-para-bomberos/estructural/" },
            { label: "Bota de Caucho HAZMAT",         href: "/productos/botas-para-bomberos/caucho/" },
            { label: "Bota Forestal NFPA 1977",       href: "/productos/botas-para-bomberos/forestal/" },
          ]}
        />

        <CategoryCard
          title="Equipo Forestal"
          badge="5 productos"
          image="/images/accion/bomberos-accion-incendio-estructural.avif"
          href="/productos/forestales/"
          buttonText="Ver Equipo Forestal"
          description="Equipo certificado NFPA 1977 y CONAFOR para brigadas contra incendios forestales. Fustas, mochilas y protección completa."
          items={[
            { label: "Traje Forestal NFPA 1977",      href: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/" },
            { label: "Casco Forestal NFPA 1977",      href: "/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/" },
            { label: "Guantes Forestales Nomex®",     href: "/productos/guantes-para-bomberos/forestales/" },
            { label: "Bota Forestal Vibram®",         href: "/productos/botas-para-bomberos/forestal/" },
          ]}
        />

        <CategoryCard
          title="Herramientas de Rescate"
          badge="4 productos"
          image="/images/directorio/equipo-rescate-tecnico-01.avif"
          href="/productos/herramientas-rescate/"
          buttonText="Ver Herramientas"
          description="Herramientas hidráulicas Jaws of Life®, cizallas USAR y sets completos certificados NFPA 1936. Holmatro y Genesis."
          items={[
            { label: "Cizalla Hidráulica de Rescate", href: "/productos/herramientas-rescate/" },
            { label: "Expansor / Separador USAR",     href: "/productos/herramientas-rescate/" },
            { label: "Combo Cizalla + Expansor",      href: "/productos/herramientas-rescate/" },
            { label: "Herramientas Manuales Rescate", href: "/productos/herramientas-rescate/" },
          ]}
        />

        <CategoryCard
          title="Tecnología y Detección"
          badge="3 productos"
          image="/images/directorio/detector-multigas-hazmat-01.avif"
          href="/productos/tecnologia/"
          buttonText="Ver Tecnología"
          description="Cámaras termográficas TIC, detectores multigas y drones de reconocimiento para operaciones tácticas de alta exigencia."
          items={[
            { label: "Cámara Termográfica TIC",      href: "/productos/tecnologia/" },
            { label: "Detector de Gas Multigas",     href: "/productos/tecnologia/" },
            { label: "Dron de Reconocimiento",       href: "/productos/tecnologia/" },
