          description="Trajes de inmersión, chalecos salvavidas, tablas de rescate y equipos swift water para brigadas de rescate en agua."
          items={[
            { label: "Traje de Inmersión / Neopreno",      href: "/productos/rescate-acuatico/" },
            { label: "Chaleco Salvavidas NFPA Rescate",    href: "/productos/rescate-acuatico/" },
