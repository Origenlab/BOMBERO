---

import PageLayout from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import Testimonials from "@components/Testimonials.astro";
import CompanyInfo from "@components/CompanyInfo.astro";
import FAQ from "@components/FAQ.astro";
import QuoteForm from "@components/QuoteForm.astro";
import CTABanner from "@components/CTABanner.astro";
import StatesDirectory from "@components/StatesDirectory.astro";
import { breadcrumbJsonLd } from "@utils/seo";

const homeJsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "https://bombero.mx/" },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Categorías de Equipo para Bomberos",
    description: "Catálogo de equipo certificado NFPA para bomberos en México",
    numberOfItems: 13,
    itemListElement: [
      { "@type": "ListItem", position: 1,  name: "Trajes para Bomberos",     url: "https://bombero.mx/productos/trajes-para-bomberos/" },
      { "@type": "ListItem", position: 2,  name: "Cascos para Bomberos",     url: "https://bombero.mx/productos/cascos-para-bomberos/" },
      { "@type": "ListItem", position: 3,  name: "Guantes para Bomberos",    url: "https://bombero.mx/productos/guantes-para-bomberos/" },
      { "@type": "ListItem", position: 4,  name: "Botas para Bomberos",      url: "https://bombero.mx/productos/botas-para-bomberos/" },
      { "@type": "ListItem", position: 5,  name: "SCBA",                     url: "https://bombero.mx/productos/scba/" },
      { "@type": "ListItem", position: 6,  name: "Equipo Forestal",          url: "https://bombero.mx/productos/forestales/" },
      { "@type": "ListItem", position: 7,  name: "Herramientas de Rescate",  url: "https://bombero.mx/productos/herramientas-rescate/" },
      { "@type": "ListItem", position: 8,  name: "Tecnología",               url: "https://bombero.mx/productos/tecnologia/" },
      { "@type": "ListItem", position: 9,  name: "Capuchas para Bomberos",   url: "https://bombero.mx/productos/capuchas-para-bomberos/" },
      { "@type": "ListItem", position: 10, name: "Gafas para Bomberos",      url: "https://bombero.mx/productos/gafas-para-bomberos/" },
      { "@type": "ListItem", position: 11, name: "Extintores",               url: "https://bombero.mx/productos/extintores/" },
      { "@type": "ListItem", position: 12, name: "HAZMAT",                   url: "https://bombero.mx/productos/hazmat/" },
      { "@type": "ListItem", position: 13, name: "Equipo Contra Incendios",  url: "https://bombero.mx/productos/equipo-contra-incendios/" },
    ],
  },
];
---

<PageLayout
  title="Equipo para Bomberos México | NFPA | BOMBERO.MX"
  description="BOMBERO.MX — Distribuidor líder de equipo para bomberos en México. Trajes estructurales NFPA 1971, SCBA, cascos, guantes, botas y herramientas de rescate. Marcas MSA, Honeywell, Globe y Bullard. Envíos a los 32 estados."
  keywords={[
    "equipo para bomberos México",
    "venta equipo bomberos NFPA",
    "trajes bombero NFPA 1971",
    "distribuidor equipo bomberos México",
    "cascos bombero certificados",
    "SCBA bomberos México",
    "EPP bomberos México",
    "equipo protección personal bomberos",
  ]}
  canonical="https://bombero.mx/"
  jsonLd={homeJsonLd}
>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__gradient"></div>
      <div class="hero__grid-lines"></div>
      <div class="hero__glow hero__glow--1"></div>
      <div class="hero__glow hero__glow--2"></div>
    </div>

    <div class="container hero__container">

      <!-- Col 1: Contenido principal -->
      <div class="hero__content">

        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          Distribuidores Autorizados NFPA · México
        </div>

        <h1 class="hero__title">
          Venta de Equipo<br/>para
          <span class="hero__title-highlight">Bomberos</span><br/>
          en México
        </h1>

        <p class="hero__subtitle">
          El distribuidor #1 de equipo de protección para bomberos en toda la República. Trajes
          estructurales, SCBA, cascos y herramientas certificadas NFPA con envío a los 32 estados.
        </p>

        <!-- CTAs -->
        <div class="hero__actions">
          <a href="/productos/" class="btn btn--primary btn--lg">
            <span>Explorar catálogo</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/cotizar/" class="btn btn--ghost btn--lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <span>Solicitar cotización</span>
          </a>
          <a href="https://wa.me/525520780102?text=Hola%2C%20quiero%20cotizar%20equipo%20NFPA%20para%20bomberos"
             target="_blank" rel="noopener"
             class="btn btn--wa btn--lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
