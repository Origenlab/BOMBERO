---

import PageLayout from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import Testimonials from "@components/Testimonials.astro";
import CompanyInfo from "@components/CompanyInfo.astro";
import FAQQuote from "@components/FAQQuote.astro";
import CTABanner from "@components/CTABanner.astro";
import StatesDirectory from "@components/StatesDirectory.astro";
import QuickNav from "@components/QuickNav.astro";
import HeroSection from "@components/HeroSection.astro";
import { breadcrumbJsonLd } from "@utils/seo";

const homeJsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "https://bombero.mx/" },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Categorías de Equipo para Bomberos",
    description: "Catálogo de equipo certificado NFPA para bomberos en México",
    numberOfItems: 16,
    itemListElement: [
      { "@type": "ListItem", position: 1,  name: "Trajes para Bomberos",     url: "https://bombero.mx/productos/trajes-para-bomberos/" },
      { "@type": "ListItem", position: 2,  name: "Cascos para Bomberos",     url: "https://bombero.mx/productos/cascos-para-bomberos/" },
      { "@type": "ListItem", position: 3,  name: "Guantes para Bomberos",    url: "https://bombero.mx/productos/guantes-para-bomberos/" },
      { "@type": "ListItem", position: 4,  name: "Botas para Bomberos",      url: "https://bombero.mx/productos/botas-para-bomberos/" },
      { "@type": "ListItem", position: 5,  name: "SCBA",                     url: "https://bombero.mx/productos/scba/" },
      { "@type": "ListItem", position: 6,  name: "Equipo Forestal",          url: "https://bombero.mx/productos/forestales/" },
      { "@type": "ListItem", position: 7,  name: "Herramientas de Rescate",  url: "https://bombero.mx/productos/herramientas-rescate/" },
      { "@type": "ListItem", position: 8,  name: "Tecnología",               url: "https://bombero.mx/productos/tecnologia/" },
      { "@type": "ListItem", position: 9,  name: "Capuchas para Bomberos",   url: "https://bombero.mx/productos/capuchas-para-bomberos/" },
      { "@type": "ListItem", position: 10, name: "Gafas para Bomberos",      url: "https://bombero.mx/productos/gafas-para-bomberos/" },
      { "@type": "ListItem", position: 11, name: "Extintores",               url: "https://bombero.mx/productos/extintores/" },
      { "@type": "ListItem", position: 12, name: "HAZMAT",                   url: "https://bombero.mx/productos/hazmat/" },
      { "@type": "ListItem", position: 13, name: "Equipo Contra Incendios",  url: "https://bombero.mx/productos/equipo-contra-incendios/" },
      { "@type": "ListItem", position: 14, name: "Rescate Vertical",         url: "https://bombero.mx/productos/rescate-vertical/" },
      { "@type": "ListItem", position: 15, name: "Rescate Acuático",         url: "https://bombero.mx/productos/rescate-acuatico/" },
      { "@type": "ListItem", position: 16, name: "Equipo Médico EMS",        url: "https://bombero.mx/productos/equipo-medico/" },
    ],
  },
];
---

<PageLayout
  quickNav={false}
  title="Equipo para bomberos | venta de equipos para bomberos | bombero"
  description="Equipo para bomberos certificado NFPA en México: trajes estructurales, SCBA MSA, cascos, guantes y botas. Distribuidor autorizado en los 32 estados. Desde 2010."
  keywords={[
    "equipo para bomberos México",
    "venta equipo bomberos NFPA",
    "trajes bombero NFPA 1971",
    "distribuidor equipo bomberos México",
    "cascos bombero certificados",
    "SCBA bomberos México",
    "EPP bomberos México",
    "equipo protección personal bomberos",
  ]}
  canonical="https://bombero.mx/"
  jsonLd={homeJsonLd}
>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════ -->
  <HeroSection
    badge="Distribuidores Autorizados NFPA · México"
    title={`Equipo para <span class="hero__title-highlight">Bomberos</span><br/>en México`}
    subtitle="En 15 años hemos equipado más de 500 estaciones en toda la República. Asesoría técnica, certificados de laboratorio y envío a los 32 estados incluidos en cada pedido."
    blocks={[
      { title: "Distribuidores certificados NFPA desde 2010", text: "Hemos equipado más de 500 <strong>estaciones de bomberos</strong> en los 32 estados, desde cuerpos municipales con presupuesto ajustado hasta brigadas industriales de PEMEX y CFE. Distribuimos directo de <strong>MSA, Honeywell, Globe y Bullard</strong>: los fabricantes que certifican con <strong>NFPA 1971, 1977 y 1981</strong>. Cada pedido incluye ficha técnica y certificado de laboratorio del producto." },
      { title: "Por qué los jefes de cuerpo nos contactan antes de abrir una licitación", text: "Comprar EPP certificado involucra jefes de cuerpo, protección civil municipal y, en muchos casos, un proceso de adquisición pública. Asesoramos desde la especificación técnica hasta la documentación que necesita el área de compras. Si el proveedor anterior entregó equipo sin <strong>NFPA 1971</strong> versión vigente, lo detectamos antes de que llegue a campo. Por eso nos buscan estaciones en Pachuca, Guadalajara, Monterrey, Puebla y CDMX." }
    ]}
  >
    <div slot="left-extra" class="hero__home-ctas">
      <a href="/productos/" class="btn btn--primary btn--lg">
        Ver catálogo completo
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="https://wa.me/525570081816?text=Hola%2C%20necesito%20cotizar%20equipo%20para%20bomberos" class="btn btn--whatsapp-hero" rel="noopener noreferrer" target="_blank">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Cotizar por WhatsApp
      </a>
    </div>
  </HeroSection>


  <!-- ═══ QUICK NAV — componente reusable ═════════════════════════════ -->
  <QuickNav pool="home" count={7} />


  <!-- ═══ SECTORES — acceso rápido por tipo de operación ══════════════ -->
  <section class="sectores">
    <div class="container">
      <p class="sectores__label">¿A qué sector perteneces?</p>
      <div class="sectores__grid">
        <a href="/cotizar/?sector=municipal" class="sectores__card">
          <div class="sectores__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div class="sectores__body">
            <h3 class="sectores__title">Cuerpos Municipales</h3>
            <p class="sectores__desc">Trajes, SCBA, cascos y EPP completo. Asesoría en licitaciones y fondos FORTASEG.</p>
          </div>
          <span class="sectores__arrow">→</span>
        </a>
        <a href="/cotizar/?sector=industrial" class="sectores__card">
          <div class="sectores__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <div class="sectores__body">
            <h3 class="sectores__title">Brigadas Industriales</h3>
            <p class="sectores__desc">EPP certificado NOM-017/NFPA para PEMEX, CFE, refinerías y plantas petroquímicas.</p>
          </div>
          <span class="sectores__arrow">→</span>
        </a>
        <a href="/cotizar/?sector=arff" class="sectores__card">
          <div class="sectores__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.7 11.89a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.11h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div class="sectores__body">
            <h3 class="sectores__title">ARFF — Aeroportuario</h3>
            <p class="sectores__desc">Trajes aluminizados, cascos ARFF y equipo certificado NFPA 1971/FAA para aeropuertos.</p>
          </div>
          <span class="sectores__arrow">→</span>
        </a>
        <a href="/cotizar/?sector=proteccion-civil" class="sectores__card">
          <div class="sectores__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="sectores__body">
            <h3 class="sectores__title">Protección Civil</h3>
            <p class="sectores__desc">Equipo de rescate técnico, HAZMAT y EPP para dependencias de PC municipales y estatales.</p>
          </div>
          <span class="sectores__arrow">→</span>
        </a>
      </div>
    </div>
  </section>


  <!-- ═══ CATÁLOGO EPP — 13 categorías ══════════════════════════════════ -->
  <section class="epp section" id="catalogo">
    <div class="container">

      <SectionHeader
        label="Catálogo de Productos"
        title="Equipo de Protección Personal para Bomberos"
        description="13 categorías de equipo certificado NFPA. Todo lo que tu estación necesita en un solo proveedor."
      >
        <p>
          En <strong>BOMBERO.MX</strong> somos distribuidores autorizados de las mejores marcas de
          <strong>equipo de protección personal para bomberos</strong> en México. Cada producto de nuestro
          catálogo cumple con las certificaciones <strong>NFPA 1971, NFPA 1977</strong> y normativas
          internacionales, garantizando la máxima seguridad para el personal de primera respuesta.
        </p>
        <p>
          Trabajamos con estaciones de bomberos, protección civil y brigadas industriales en los
          <strong>32 estados de la República Mexicana</strong>. Fichas técnicas y certificados de laboratorio
          disponibles para cada producto.
        </p>
      </SectionHeader>

      <div class="epp__grid">

        <CategoryCard
          title="Trajes de Bombero"
          badge="5 productos"
          image="/images/trajes-para-bombero/bunker-gear-bombero-camion-estacion-01.avif"
          href="/productos/trajes-para-bomberos/"
          buttonText="Ver Trajes"
          description="Trajes estructurales, forestales, ARFF y HAZMAT. Nomex®, PBI Gold® y Gore-Tex®. Certificación NFPA 1971 / 1977."
          items={[
            { label: "Traje Estructural NFPA 1971",   href: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/" },
            { label: "Traje Forestal NFPA 1977",      href: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/" },
            { label: "Traje ARFF Aeroportuario",      href: "/productos/trajes-para-bomberos/traje-arff-aeroportuario/" },
            { label: "Traje de Aproximación",         href: "/productos/trajes-para-bomberos/traje-aproximacion/" },
            { label: "Traje HAZMAT Nivel A / B",      href: "/productos/trajes-para-bomberos/traje-hazmat/" },
          ]}
        />

        <CategoryCard
          title="Cascos para Bomberos"
          badge="6 productos"
          image="/images/cascos-para-bomberos/casco-bombero-arff-aeroportuario-01.avif"
          href="/productos/cascos-para-bomberos/"
          buttonText="Ver Cascos"
          description="Cascos estructurales, forestales, ARFF y rescate técnico. Bullard, Cairns, MSA. NFPA 1971 / 1977 / 1951."
          items={[
            { label: "Casco Estructural NFPA 1971",   href: "/productos/cascos-para-bomberos/casco-estructural-nfpa-1971/" },
            { label: "Casco Forestal NFPA 1977",      href: "/productos/cascos-para-bomberos/casco-forestal-nfpa-1977/" },
            { label: "Casco de Rescate NFPA 1951",    href: "/productos/cascos-para-bomberos/casco-rescate-tecnico-nfpa-1951/" },
            { label: "Casco HAZMAT Químico",          href: "/productos/cascos-para-bomberos/casco-hazmat-quimico/" },
          ]}
        />

        <CategoryCard
