        <span class="brands__sep">·</span>
        <span class="brands__name">Honeywell</span>
        <span class="brands__sep">·</span>
        <span class="brands__name">Globe</span>
        <span class="brands__sep">·</span>
        <span class="brands__name">Bullard</span>
        <span class="brands__sep">·</span>
        <span class="brands__name">Cairns</span>
        <span class="brands__sep">·</span>
        <span class="brands__name">Lion Apparel</span>
        <span class="brands__sep">·</span>
        <span class="brands__name">Holmatro</span>
