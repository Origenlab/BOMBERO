---

import PageLayout from "@layouts/PageLayout.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import WhyChooseUs from "@components/WhyChooseUs.astro";
import Testimonials from "@components/Testimonials.astro";
import CompanyInfo from "@components/CompanyInfo.astro";
import FAQQuote from "@components/FAQQuote.astro";
import CTABanner from "@components/CTABanner.astro";
import StatesDirectory from "@components/StatesDirectory.astro";
import QuickNav from "@components/QuickNav.astro";
import HeroSection from "@components/HeroSection.astro";
import { breadcrumbJsonLd } from "@utils/seo";

const homeJsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "https://bombero.mx/" },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Categorías de Equipo para Bomberos",
    description: "Catálogo de equipo certificado NFPA para bomberos en México",
    numberOfItems: 13,
    itemListElement: [
      { "@type": "ListItem", position: 1,  name: "Trajes para Bomberos",     url: "https://bombero.mx/productos/trajes-para-bomberos/" },
      { "@type": "ListItem", position: 2,  name: "Cascos para Bomberos",     url: "https://bombero.mx/productos/cascos-para-bomberos/" },
      { "@type": "ListItem", position: 3,  name: "Guantes para Bomberos",    url: "https://bombero.mx/productos/guantes-para-bomberos/" },
      { "@type": "ListItem", position: 4,  name: "Botas para Bomberos",      url: "https://bombero.mx/productos/botas-para-bomberos/" },
      { "@type": "ListItem", position: 5,  name: "SCBA",                     url: "https://bombero.mx/productos/scba/" },
      { "@type": "ListItem", position: 6,  name: "Equipo Forestal",          url: "https://bombero.mx/productos/forestales/" },
      { "@type": "ListItem", position: 7,  name: "Herramientas de Rescate",  url: "https://bombero.mx/productos/herramientas-rescate/" },
      { "@type": "ListItem", position: 8,  name: "Tecnología",               url: "https://bombero.mx/productos/tecnologia/" },
      { "@type": "ListItem", position: 9,  name: "Capuchas para Bomberos",   url: "https://bombero.mx/productos/capuchas-para-bomberos/" },
      { "@type": "ListItem", position: 10, name: "Gafas para Bomberos",      url: "https://bombero.mx/productos/gafas-para-bomberos/" },
      { "@type": "ListItem", position: 11, name: "Extintores",               url: "https://bombero.mx/productos/extintores/" },
      { "@type": "ListItem", position: 12, name: "HAZMAT",                   url: "https://bombero.mx/productos/hazmat/" },
      { "@type": "ListItem", position: 13, name: "Equipo Contra Incendios",  url: "https://bombero.mx/productos/equipo-contra-incendios/" },
    ],
  },
];
---

<PageLayout
  quickNav={false}
  title="Equipo para Bomberos México | NFPA | BOMBERO.MX"
  description="BOMBERO.MX — Distribuidor líder de equipo para bomberos en México. Trajes estructurales NFPA 1971, SCBA, cascos, guantes, botas y herramientas de rescate. Marcas MSA, Honeywell, Globe y Bullard. Envíos a los 32 estados."
  keywords={[
    "equipo para bomberos México",
    "venta equipo bomberos NFPA",
    "trajes bombero NFPA 1971",
    "distribuidor equipo bomberos México",
    "cascos bombero certificados",
    "SCBA bomberos México",
    "EPP bomberos México",
    "equipo protección personal bomberos",
  ]}
  canonical="https://bombero.mx/"
  jsonLd={homeJsonLd}
>

  <!-- ═══ HERO ═══════════════════════════════════════════════════════════ -->
  <HeroSection
    badge="Distribuidores Autorizados NFPA · México"
    title={`Venta de Equipo<br/>para <span class="hero__title-highlight">Bomberos</span><br/>en México`}
    subtitle="Distribuidor líder de equipo certificado NFPA para bomberos en México. Trajes estructurales, SCBA, cascos, botas y herramientas de rescate. Enviamos a los 32 estados."
    blocks={[
      { title: "Equipo NFPA para bomberos en México — distribuidores desde 2010", text: "En 15 años hemos equipado más de 500 <strong>estaciones de bomberos</strong> en los 32 estados, desde cuerpos municipales con presupuesto ajustado hasta brigadas industriales de PEMEX y CFE. Distribuimos directo de <strong>MSA, Honeywell, Globe y Bullard</strong>: los fabricantes que certifican con <strong>NFPA 1971, 1977 y 1981</strong>. Cada pedido incluye ficha técnica y certificado de laboratorio del producto." },
      { title: "Por qué los cuerpos de bomberos nos eligen como proveedor", text: "Comprar <strong>equipo de bomberos</strong> involucra jefes de cuerpo, protección civil municipal y, en muchos casos, una licitación pública. Asesoramos desde la especificación técnica hasta la documentación que necesita el área de compras. Si el proveedor anterior entregó equipo sin <strong>NFPA 1971</strong> versión vigente, lo detectamos antes de que llegue a campo. Por eso nos buscan estaciones en Pachuca, Guadalajara, Monterrey, Puebla y CDMX." }
    ]}
  />


  <!-- ═══ QUICK NAV — componente reusable ═════════════════════════════ -->
  <QuickNav pool="home" count={7} />


  <!-- ═══ CATÁLOGO EPP — 13 categorías ══════════════════════════════════ -->
  <section class="epp section" id="catalogo">
    <div class="container">

      <SectionHeader
        label="Catálogo de Productos"
        title="Equipo de Protección Personal para Bomberos"
        description="13 categorías de equipo certificado NFPA. Todo lo que tu estación necesita en un solo proveedor."
      >
        <p>
          En <strong>BOMBERO.MX</strong> somos distribuidores autorizados de las mejores marcas de
          <strong>equipo de protección personal para bomberos</strong> en México. Cada producto de nuestro
          catálogo cumple con las certificaciones <strong>NFPA 1971, NFPA 1977</strong> y normativas
          internacionales, garantizando la máxima seguridad para el personal de primera respuesta.
        </p>
        <p>
          Trabajamos con estaciones de bomberos, protección civil y brigadas industriales en los
          <strong>32 estados de la República Mexicana</strong>. Fichas técnicas y certificados de laboratorio
          disponibles para cada producto.
        </p>
      </SectionHeader>

      <div class="epp__grid">

        <CategoryCard
          title="Trajes de Bombero"
          badge="5 productos"
          image="/images/trajes-para-bombero/bunker-gear-bombero-camion-estacion-01.avif"
          href="/productos/trajes-para-bomberos/"
          buttonText="Ver Trajes"
          description="Trajes estructurales, forestales, ARFF y HAZMAT. Nomex®, PBI Gold® y Gore-Tex®. Certificación NFPA 1971 / 1977."
