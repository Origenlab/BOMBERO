---

import SEOHead from "@components/SEOHead.astro";
import JsonLd from "@components/JsonLd.astro";
import WhatsAppFloat from "@components/WhatsAppFloat.astro";
import BackToTop from "@components/BackToTop.astro";
import { SITE, type SEOProps } from "@data/site";
import { organizationJsonLd, websiteJsonLd, localBusinessJsonLd } from "@utils/seo";
import "@styles/global.css";

type Props = SEOProps & {
  jsonLd?: Record<string, unknown>[];
};

const { jsonLd = [], ...seoProps } = Astro.props;

// Always include Organization + WebSite + LocalBusiness structured data
const allJsonLd = [organizationJsonLd(), websiteJsonLd(), localBusinessJsonLd(), ...jsonLd];
---

<!doctype html>
<html lang={SITE.language} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />


    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#dc2626" />
    <meta name="msapplication-TileColor" content="#dc2626" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <!-- Preconnect a CDN de imágenes (LCP -100ms) -->
    <link rel="preconnect" href="https://emwn2f4rcov.exactdn.com" crossorigin />
    <link rel="dns-prefetch" href="https://emwn2f4rcov.exactdn.com" />

    <!-- Preconnect a analytics no críticos (sin crossorigin para reducir handshakes) -->
    <link rel="dns-prefetch" href="https://app.rybbit.io" />
    <link rel="dns-prefetch" href="https://app.truconversion.com" />

    <!-- Hint para enlace LLM emergente (consumido por crawlers GEO) -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM index" />

    <!-- Preload critical fonts (400=body, 700=headings) -->
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />

    <SEOHead {...seoProps} />


    {allJsonLd.map((data) => <JsonLd data={data} />)}





    <!-- Analytics & heatmaps cargados tras hidratación para no bloquear LCP -->
    <script type="module">
      // Esperar a que el navegador esté libre para cargar analítica + heatmap.
      // Cae a setTimeout(2000) en navegadores sin requestIdleCallback.
      const loadAnalytics = () => {
        if (window.__bomberoAnalyticsLoaded) return;
        window.__bomberoAnalyticsLoaded = true;

        // Rybbit (web analytics)
        const rybbit = document.createElement("script");
        rybbit.src = "https://app.rybbit.io/api/script.js";
        rybbit.dataset.siteId = "1353eff32e78";
        rybbit.defer = true;
        document.head.appendChild(rybbit);

        // TruConversion (heatmap + session replay) — solo en producción
        if (location.hostname !== "localhost" && location.hostname !== "127.0.0.1") {
          window._tip = window._tip || [];
          const tc = document.createElement("script");
          tc.async = true;
          tc.id = "ti-js";
          tc.src = location.protocol + "//app.truconversion.com/ti-js/62699/64664.js";
          document.head.appendChild(tc);
        }
      };

      if ("requestIdleCallback" in window) {
        requestIdleCallback(loadAnalytics, { timeout: 3000 });
      } else {
        setTimeout(loadAnalytics, 2000);
      }
    </script>
    <!--
      ExactDN runtime fallback.
      cdnW() ya resuelve la URL en build para casi todas las imágenes,
      pero quedan algunas plantillas del sitio (homepage, productos
      legacy, blog) con <img src="/images/..."> sin transformar. Este
      MutationObserver las redirige al CDN antes del primer paint y
      reemplaza el setSrc-en-DOMContentLoaded original (que causaba CLS
      y doble fetch).
    -->
    <script is:inline>
      (function () {
        if (location.hostname === "localhost" || location.hostname === "127.0.0.1") return;
        var CDN = "https://emwn2f4rcov.exactdn.com";
        function rewrite(img) {
          if (!img || img.dataset.cdnDone === "1") return;
          var src = img.getAttribute("src");
          if (src && src.charAt(0) === "/" && src.indexOf("/images/") === 0) {
            img.setAttribute("src", CDN + src);
          }
          img.dataset.cdnDone = "1";
        }
        // Observador para imágenes añadidas antes del primer paint
        try {
          var mo = new MutationObserver(function (muts) {
            for (var i = 0; i < muts.length; i++) {
              var m = muts[i];
              for (var j = 0; j < m.addedNodes.length; j++) {
                var n = m.addedNodes[j];
                if (n && n.nodeType === 1) {
                  if (n.tagName === "IMG") rewrite(n);
                  else if (n.querySelectorAll) {
                    var qs = n.querySelectorAll("img");
                    for (var k = 0; k < qs.length; k++) rewrite(qs[k]);
                  }
                }
              }
            }
          });
          mo.observe(document.documentElement, { childList: true, subtree: true });
          // Detener observación cuando DOM esté listo
          document.addEventListener("DOMContentLoaded", function () {
            var imgs = document.querySelectorAll("img");
            for (var i = 0; i < imgs.length; i++) rewrite(imgs[i]);
            mo.disconnect();
          });
        } catch (e) {
          // Fallback silencioso
        }
      })();
    </script>
  </head>

  <body>

    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <slot />


    <WhatsAppFloat />


    <BackToTop />
  </body>
</html>
