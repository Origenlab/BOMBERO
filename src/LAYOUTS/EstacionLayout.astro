---

import PageLayout from "@layouts/PageLayout.astro";
import CTABanner from "@components/CTABanner.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import FAQDirectorio from "@components/directorio/FAQDirectorio.astro";
import FAQQuote from "@components/FAQQuote.astro";
import VerifiedBadge from "@components/directorio/VerifiedBadge.astro";
import StationCTA from "@components/directorio/StationCTA.astro";
import StationDeepLinks from "@components/directorio/StationDeepLinks.astro";
import QuickNav from "@components/QuickNav.astro";
import { cdnW } from "@utils/cdn";
import HeroSection from "@components/HeroSection.astro";
import { truncateMetaDescription } from "@utils/seo";
import { enrichEstacion } from "@utils/estacion-enrich";
import { getProductosRelacionadosEstacion } from "@data/directorio-productos-map";
import { DIRECTORIO_VERIFICADO_ISO, DIRECTORIO_VERIFICADO_LEGIBLE } from "@data/directorio-stats";

// Interfaz de la estación (campos opcionales tienen fallbacks en el layout)
interface Estacion {
  slug: string;
  nombre: string;
  nombreCorto?: string;
  descripcion?: string;
  ciudad: string;
  municipio?: string;
  direccion: string;
  colonia?: string;
  codigoPostal?: string;
  telefono: string;
  email?: string;
  horario: string;
  coordenadas?: { lat: number; lng: number };
  servicios: string[];
  especialidades?: string[];
  zonasCobertura?: string[];
  cobertura?: string[];
  equipamiento?: string[];
  unidadesDisponibles?: string[];
  personal?: number;
  personalActivo?: number;
  unidades?: number;
  tiempoRespuesta?: string;
  historia?: string;
}

interface Estado {
  nombre: string;
  slug: string;
  siglas: string;
  poblacion?: string;
  municipios?: number;
}

interface EstacionCercana {
  slug: string;
  nombreCorto?: string;
  nombre?: string;
  municipio?: string;
  ciudad?: string;
}

interface EstadoVecino {
  nombre: string;
  slug: string;
}

interface EPPCard {
  image: string;
  imageAlt: string;
  badge: string;
  title: string;
  text: string;
  href: string;
  linkLabel: string;
}

interface Props {
  estacion: Estacion;
  estado: Estado;
  estadosVecinos: EstadoVecino[];
  estacionesCercanas: EstacionCercana[];
  eppCards: EPPCard[];
}

const { estacion: estacionRaw, estado, estadosVecinos, estacionesCercanas, eppCards } = Astro.props;

// Enriquecimiento no destructivo: rellena campos derivados faltantes
// (descripción, especialidades, horario, codigoPostal) sin inventar datos duros.
// Aplica a las 722 estaciones del directorio desde un solo punto.
const estacion = enrichEstacion(estacionRaw, estado.nombre);

// CDN: transformar URLs de imágenes
const eppCardsCdn = eppCards.map(c => ({ ...c, image: cdnW(c.image, 400) }));

// Variables derivadas
const ubicacion = estacion.municipio ?? estacion.ciudad;
const ubicacionCorta = estacion.ciudad ?? estacion.municipio; // Preferir ciudad (más corta) para títulos
const nombreCortoDisplay = estacion.nombreCorto ?? estacion.nombre;
const colonia = estacion.colonia ?? '';
const zonasCobertura = estacion.zonasCobertura ?? estacion.cobertura ?? [];
const telefonoLink = estacion.telefono.replace(/\s/g, '');

// Productos relacionados (dinámicos según servicios/especialidades de la estación)
const productosRelacionados = getProductosRelacionadosEstacion(
  estacion.servicios,
  estacion.especialidades ?? [],
  5,
);

// Normalización de campos (soporta ambos esquemas de datos del directorio)
const personalNum = estacion.personalActivo ?? estacion.personal;
const unidadesNum = estacion.unidades ?? estacion.unidadesDisponibles?.length;
const especialidades = estacion.especialidades ?? [];
const totalServicios = estacion.servicios.length;

// Tabla comparativa: servicio operativo → EPP/equipo certificado NFPA requerido
const matrizEquipoNFPA = [
  { servicio: "Incendio estructural / urbano", equipo: "Traje estructural, casco, guantes y botas", norma: "NFPA 1971", href: "/productos/trajes-para-bomberos/" },
  { servicio: "Entrada a atmósfera con humo", equipo: "Equipo de respiración autónoma (SCBA)", norma: "NFPA 1981", href: "/productos/scba/" },
  { servicio: "Rescate vehicular / extricación", equipo: "Guantes de rescate y herramienta hidráulica", norma: "NFPA 1951 / EN 388", href: "/productos/guantes-para-bomberos/" },
  { servicio: "Incendio forestal (wildland)", equipo: "Traje y casco forestal ligero", norma: "NFPA 1977", href: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/" },
  { servicio: "Materiales peligrosos (HAZMAT)", equipo: "Traje encapsulado nivel A/B y guantes químicos", norma: "NFPA 1991 / 1992", href: "/productos/trajes-para-bomberos/traje-hazmat/" },
  { servicio: "Atención prehospitalaria", equipo: "Guantes de bioseguridad y equipo médico", norma: "NFPA 1999", href: "/productos/equipo-medico/" },
];

// Tabla comparativa: niveles de protección por tipo de traje (referencia técnica estándar)
const nivelesProteccion = [
  { tipo: "Traje estructural", norma: "NFPA 1971", proteccion: "Térmica alta (TPP ≥ 35) + barrera de humedad", uso: "Incendios estructurales y urbanos", href: "/productos/trajes-para-bomberos/traje-estructural-nfpa-1971/" },
  { tipo: "Traje de aproximación", norma: "Proximity", proteccion: "Radiación térmica muy alta (capa aluminizada)", uso: "Fuegos de combustible y radiación intensa", href: "/productos/trajes-para-bomberos/traje-aproximacion/" },
  { tipo: "Traje forestal", norma: "NFPA 1977", proteccion: "Resistencia a la llama, ligero y transpirable", uso: "Incendios forestales y de pastizal", href: "/productos/trajes-para-bomberos/traje-forestal-nfpa-1977/" },
  { tipo: "Traje HAZMAT", norma: "NFPA 1991 / 1992", proteccion: "Barrera química, encapsulado nivel A/B", uso: "Materiales peligrosos y derrames", href: "/productos/trajes-para-bomberos/traje-hazmat/" },
];

// Tabla de referencia: normas NFPA aplicables al equipo de bomberos
const normasNFPA = [
  { norma: "NFPA 1971", alcance: "Protección estructural integral: traje, casco, capucha, guantes y botas." },
  { norma: "NFPA 1981", alcance: "Equipo de respiración autónoma (SCBA) de presión positiva." },
  { norma: "NFPA 1977", alcance: "Ropa y equipo para combate de incendios forestales (wildland)." },
  { norma: "NFPA 1951", alcance: "Protección para operaciones de rescate técnico y urbano." },
  { norma: "NFPA 1991 / 1992", alcance: "Trajes encapsulados contra materiales peligrosos (HAZMAT)." },
];

// Pasos GEO/HowTo: cómo reportar una emergencia
const pasosEmergencia = [
  { titulo: "Marca el 911", detalle: `Desde cualquier teléfono en ${ubicacion}. La llamada es gratuita y se enruta a la estación más cercana.` },
  { titulo: "Indica la dirección exacta", detalle: "Calle, número, colonia y referencias visibles del lugar del incidente." },
  { titulo: "Describe la emergencia", detalle: "Tipo de evento (incendio, fuga, rescate), número de personas y si hay lesionados." },
  { titulo: "No cuelgues", detalle: "Sigue las indicaciones del operador hasta que confirme la salida de la unidad." },
  { titulo: "Ponte a salvo", detalle: "Evacúa si existe riesgo, no regreses por objetos y espera a los bomberos en un punto seguro." },
];

// Recomendaciones de prevención (lista de interés)
const recomendacionesPrevencion = [
  "Instala detectores de humo y revísalos cada seis meses.",
  "Mantén un extintor certificado NOM vigente y accesible en casa o negocio.",
  "No sobrecargues contactos eléctricos ni uses extensiones dañadas.",
  "Define y practica una ruta de evacuación con tu familia o personal.",
  "Almacena líquidos inflamables lejos de fuentes de calor y fuera del alcance de menores.",
  `Guarda el teléfono de ${nombreCortoDisplay} (${estacion.telefono}) y el 911 a la mano.`,
];

// URLs y SEO
const mapUrl = `https://www.google.com/maps/search/${encodeURIComponent(estacion.nombre + ' ' + estacion.direccion + ' ' + colonia + ' ' + ubicacion + ' ' + estado.nombre)}`;
const canonical = `https://bombero.mx/directorio/${estado.slug}/${estacion.slug}`;
const seoKeywords = [
  `bomberos ${ubicacion.toLowerCase()}`,
  `estacion de bomberos ${ubicacion.toLowerCase()}`,
  `telefono bomberos ${ubicacion.toLowerCase()}`,
  `bomberos ${estado.nombre.toLowerCase()}`,
  "estaciones de bomberos en mexico",
];

const stationSummary = estacion.descripcion || `Estación de bomberos en ${ubicacion}.`;
const seoDescription = truncateMetaDescription(
  `${stationSummary} Tel: ${estacion.telefono}. ${ubicacion}, ${estado.nombre}.`,
  155,
);

// Schema.org JSON-LD — FireStation + EmergencyService (mejor cobertura semántica)
const stationJsonLd = {
  "@context": "https://schema.org",
  "@type": ["FireStation", "EmergencyService"],
  name: estacion.nombre,
  alternateName: nombreCortoDisplay,
  description: estacion.descripcion,
  url: canonical,
  telephone: estacion.telefono,
  email: estacion.email,
  dateModified: DIRECTORIO_VERIFICADO_ISO,
  openingHours: "Mo-Su 00:00-23:59",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    opens: "00:00",
    closes: "23:59",
  },
  address: {
    "@type": "PostalAddress",
    streetAddress: [estacion.direccion, estacion.colonia].filter(Boolean).join(", "),
    addressLocality: estacion.ciudad,
    addressRegion: estado.nombre,
    postalCode: estacion.codigoPostal,
    addressCountry: "MX",
  },
  geo: estacion.coordenadas
    ? {
        "@type": "GeoCoordinates",
        latitude: estacion.coordenadas.lat,
        longitude: estacion.coordenadas.lng,
      }
    : undefined,
  areaServed: {
    "@type": "City",
    name: ubicacion,
    containedInPlace: { "@type": "AdministrativeArea", name: estado.nombre },
  },
  contactPoint: {
    "@type": "ContactPoint",
    telephone: estacion.telefono,
    contactType: "Emergency",
    availableLanguage: ["es-MX", "es"],
    areaServed: ubicacion,
  },
  knowsAbout: estacion.servicios,
  numberOfEmployees: personalNum
    ? { "@type": "QuantitativeValue", value: personalNum }
    : undefined,
  makesOffer: estacion.servicios.map((s) => ({
    "@type": "Offer",
    itemOffered: { "@type": "Service", name: s, areaServed: ubicacion },
  })),
  parentOrganization: {
    "@type": "GovernmentOrganization",
    name: `H. Cuerpo de Bomberos de ${ubicacion}`,
    areaServed: { "@type": "City", name: ubicacion },
  },
  mainEntityOfPage: canonical,
  isPartOf: {
    "@type": "WebSite",
    name: "BOMBERO.MX — Directorio Nacional de Bomberos",
    url: "https://bombero.mx/directorio/",
  },
  publisher: {
    "@type": "Organization",
    name: "BOMBERO.MX",
    url: "https://bombero.mx/",
    logo: {
      "@type": "ImageObject",
      url: "https://bombero.mx/apple-touch-icon.png",
    },
  },
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".est-hero__title", ".est-hero__desc", ".est-hero__card-body"],
  },
};

// HowTo (GEO): protocolo de reporte de emergencia
const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: `Cómo reportar una emergencia a los bomberos en ${ubicacion}`,
  description: `Pasos para solicitar el servicio de bomberos en ${ubicacion}, ${estado.nombre}, a través del 911 o de ${nombreCortoDisplay}.`,
  totalTime: "PT2M",
  step: pasosEmergencia.map((p, i) => ({
    "@type": "HowToStep",
    position: i + 1,
    name: p.titulo,
    text: p.detalle,
  })),
};

// ItemList (GEO): estaciones de bomberos cercanas
const itemListJsonLd = estacionesCercanas.length
  ? {
      "@context": "https://schema.org",
      "@type": "ItemList",
      name: `Otras estaciones de bomberos en ${estado.nombre}`,
      numberOfItems: estacionesCercanas.length,
      itemListElement: estacionesCercanas.map((e, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: e.nombreCorto ?? e.nombre,
        url: `https://bombero.mx/directorio/${estado.slug}/${e.slug}/`,
      })),
    }
  : null;

const jsonLdGraph = [stationJsonLd, howToJsonLd, ...(itemListJsonLd ? [itemListJsonLd] : [])];

// Índice de contenidos (jump-links) — solo secciones presentes en la página
const indiceSecciones = [
  { id: "ficha-tecnica", label: "Ficha técnica" },
  { id: "servicios", label: "Servicios" },
  { id: "equipo-nfpa", label: "Equipo NFPA" },
  ...(especialidades.length ? [{ id: "especialidades", label: "Especialidades" }] : []),
  { id: "cobertura", label: "Cobertura" },
  { id: "protocolo-emergencia", label: "Emergencias" },
  ...(estacionesCercanas.length ? [{ id: "estaciones-cercanas", label: "Estaciones cercanas" }] : []),
  { id: "verificacion", label: "Verificación" },
];

// Chips de datos clave — solo valores reales o derivados de datos existentes
const datosClave = [
  { valor: String(totalServicios), label: "Servicios" },
  { valor: String(especialidades.length), label: "Especialidades" },
  ...(personalNum ? [{ valor: String(personalNum), label: "Elementos" }] : []),
  ...(unidadesNum ? [{ valor: String(unidadesNum), label: "Unidades" }] : []),
  { valor: "24/7", label: "Disponibilidad" },
  { valor: "911", label: "Emergencias" },
];

---

<PageLayout
  title={`${estacion.nombre} — Teléfono y Dirección Bomberos ${ubicacionCorta}, ${estado.nombre} | BOMBERO.MX`}
  description={seoDescription}
  keywords={seoKeywords}
  canonical={canonical}
  image={`/api/og/estacion/${estado.slug}/${estacion.slug}.svg`}
  modifiedTime={DIRECTORIO_VERIFICADO_ISO}
  jsonLd={jsonLdGraph}
>

  <Breadcrumb items={[
    { label: "Directorio", href: "/directorio/" },
    { label: estado.nombre, href: `/directorio/${estado.slug}/` },
    { label: nombreCortoDisplay },
  ]} />


  <HeroSection
    badge={`${ubicacion} · ${estado.nombre}`}
    title={estacion.nombre}
    subtitle={estacion.descripcion ?? `Estación de bomberos en ${ubicacion}, ${estado.nombre}.`}
  >
    <div slot="left-extra" class="est-hero__actions">
      <a href={`tel:${telefonoLink}`} class="est-hero__btn est-hero__btn--primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72"/>
        </svg>
        <span>Llamar: {estacion.telefono}</span>
      </a>
      <a href={mapUrl} target="_blank" rel="noopener noreferrer" class="est-hero__btn est-hero__btn--secondary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>Ver en Google Maps</span>
      </a>
    </div>
    <div slot="right" class="est-hero__card">
      <div class="est-hero__card-header">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 21h18"/>
          <path d="M5 21V7l8-4 8 4v14"/>
          <path d="M9 21v-4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4"/>
        </svg>
        <span>Información de Contacto</span>
      </div>
      <div class="est-hero__card-body">
        <div class="est-hero__info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <div>
            <strong>Dirección</strong>
            <span>{estacion.direccion}, {estacion.colonia}, CP {estacion.codigoPostal}</span>
          </div>
        </div>
        <div class="est-hero__info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72"/>
          </svg>
          <div>
            <strong>Teléfono</strong>
            <a href={`tel:${telefonoLink}`}>{estacion.telefono}</a>
          </div>
        </div>
        <div class="est-hero__info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07"/>
          </svg>
          <div>
            <strong>Emergencias</strong>
            <a href="tel:911" class="est-hero__emergency">911</a>
          </div>
        </div>
        {estacion.tiempoRespuesta && (
          <div class="est-hero__info-row">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <div>
              <strong>Tiempo de Respuesta</strong>
              <span>{estacion.tiempoRespuesta}</span>
            </div>
          </div>
        )}
        <div class="est-hero__info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <div>
            <strong>Municipio</strong>
            <span>{ubicacion}, {estado.nombre}</span>
          </div>
        </div>
      </div>
    </div>
  </HeroSection>


  <section class="est-main">

  <QuickNav pool="estacion" count={7} />

    <div class="container">
      <div class="est-main__grid">

        <div class="est-main__content">

          <nav class="est-toc" aria-label="Índice de la página">
            <span class="est-toc__label">En esta página</span>
            <ul class="est-toc__list">
              {indiceSecciones.map((s) => (
                <li><a href={`#${s.id}`}>{s.label}</a></li>
              ))}
            </ul>
          </nav>

          <div class="est-keyfacts" aria-label="Datos clave de la estación">
            {datosClave.map((d) => (
              <div class="est-keyfacts__item">
                <span class="est-keyfacts__value">{d.valor}</span>
                <span class="est-keyfacts__label">{d.label}</span>
              </div>
            ))}
          </div>

          <article class="est-section" id="ficha-tecnica">
            <h2 class="est-section__title">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18M9 21V9"/>
              </svg>
              Ficha Técnica: {nombreCortoDisplay}
            </h2>
            <p class="est-section__intro">
              Datos oficiales verificados de la <strong>estación de bomberos en {ubicacion}, {estado.nombre}</strong>.
              Información de contacto, ubicación y capacidad operativa actualizada a {DIRECTORIO_VERIFICADO_LEGIBLE}.
            </p>
            <div class="est-table-wrap">
              <table class="est-keyvalue">
                <tbody>
                  <tr>
                    <th scope="row">Nombre de la estación</th>
                    <td>{estacion.nombre}</td>
                  </tr>
                  <tr>
                    <th scope="row">Ciudad / Municipio</th>
                    <td>{ubicacion}, {estado.nombre}</td>
                  </tr>
                  <tr>
                    <th scope="row">Dirección</th>
                    <td>{estacion.direccion}{colonia ? `, ${colonia}` : ''}{estacion.codigoPostal ? `, C.P. ${estacion.codigoPostal}` : ''}</td>
                  </tr>
                  <tr>
                    <th scope="row">Teléfono directo</th>
                    <td><a href={`tel:${telefonoLink}`}>{estacion.telefono}</a></td>
                  </tr>
                  <tr>
                    <th scope="row">Emergencias</th>
                    <td><a href="tel:911">911</a> — número único nacional, 24/7</td>
                  </tr>
                  <tr>
                    <th scope="row">Horario de atención</th>
                    <td>{estacion.horario}</td>
                  </tr>
                  {estacion.tiempoRespuesta && (
                    <tr>
                      <th scope="row">Tiempo de respuesta</th>
                      <td>{estacion.tiempoRespuesta}</td>
                    </tr>
                  )}
                  <tr>
                    <th scope="row">Servicios de emergencia</th>
                    <td>{totalServicios} servicios operativos</td>
                  </tr>
                  {especialidades.length > 0 && (
                    <tr>
                      <th scope="row">Especialidades</th>
                      <td>{especialidades.length} áreas especializadas</td>
                    </tr>
                  )}
                  {personalNum && (
                    <tr>
                      <th scope="row">Personal operativo</th>
                      <td>{personalNum} elementos</td>
                    </tr>
                  )}
                  {unidadesNum && (
                    <tr>
                      <th scope="row">Unidades</th>
                      <td>{unidadesNum} unidades operativas</td>
                    </tr>
                  )}
                  {estacion.coordenadas && (
                    <tr>
                      <th scope="row">Coordenadas GPS</th>
                      <td>{estacion.coordenadas.lat}, {estacion.coordenadas.lng}</td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          </article>

          <article class="est-section" id="servicios">
            <h2 class="est-section__title">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
              </svg>
              Servicios de Emergencia
            </h2>
            <p class="est-section__intro">
              La <strong>{nombreCortoDisplay}</strong> ofrece los siguientes servicios de emergencia
              a los habitantes de <strong>{ubicacion}</strong> y zonas aledañas en {estado.nombre}:
            </p>
            <ul class="est-services">
