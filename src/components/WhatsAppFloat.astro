---

import { SITE } from "@data/site";

interface Props {
  message?: string;
  position?: "left" | "right";
  showText?: boolean;
  pulse?: boolean;
}

const {
  message = "Hola, me interesa información sobre equipo para bomberos",
  position = "right",
  showText = true,
  pulse = true,
} = Astro.props;

const encodedMessage = encodeURIComponent(message);
const whatsappUrl = `https://wa.me/${SITE.contact.whatsapp}?text=${encodedMessage}`;

const buttonClasses = [
  "whatsapp-float",
  `whatsapp-float--${position}`,
  pulse && "whatsapp-float--pulse",
].filter(Boolean).join(" ");
---

<a
  href={whatsappUrl}
  class={buttonClasses}
  aria-label="Contactar por WhatsApp"
  target="_blank"
  rel="noopener noreferrer"
  data-whatsapp-cta="flotante"
  onclick="if(typeof _tip!=='undefined'){_tip.push(['track','WhatsApp Click',{source:'flotante'}])};if(typeof rybbit!=='undefined'){rybbit.track('whatsapp_click',{source:'flotante'})}"
>
  {showText && (
    <span class="whatsapp-float__text">
      ¿Necesitas ayuda?
    </span>
  )}
  <span class="whatsapp-float__icon">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </span>
</a>

<style>


  .whatsapp-float {
    position: fixed;
    bottom: calc(var(--space-6) + var(--safe-bottom, 0px));
    display: flex;
    align-items: center;
    gap: var(--space-3);
    z-index: var(--z-fixed);
    text-decoration: none;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    touch-action: manipulation;
  }

  .whatsapp-float--right {
    right: calc(var(--space-6) + var(--safe-right, 0px));
    flex-direction: row;
  }

  .whatsapp-float--left {
    left: calc(var(--space-6) + var(--safe-left, 0px));
    flex-direction: row-reverse;
  }


  .whatsapp-float__icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: #25D366;
    border-radius: 50%;
    color: white;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
    transition: background var(--transition-base), transform var(--transition-base);
    /* Promote to own layer for compositor animation */
    will-change: transform;
  }

  /* Pulse ring via pseudo-element — runs on compositor (transform + opacity only) */
  .whatsapp-float--pulse .whatsapp-float__icon::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(37, 211, 102, 0.4);
    z-index: -1;
    animation: whatsapp-pulse 2s infinite;
    will-change: transform, opacity;
  }

  .whatsapp-float:hover .whatsapp-float__icon {
    background: #128C7E;
    transform: scale(1.1);
  }

  @keyframes whatsapp-pulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    70% {
      transform: scale(1.5);
      opacity: 0;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  .whatsapp-float:hover .whatsapp-float__icon::after {
    animation: none;
  }


  .whatsapp-float__text {
    padding: var(--space-3) var(--space-4);
    background: white;
    color: var(--color-smoke-800);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    white-space: nowrap;
    opacity: 0;
    transform: translateX(10px);
    transition: all var(--transition-base);
    pointer-events: none;
  }

  .whatsapp-float--left .whatsapp-float__text {
    transform: translateX(-10px);
  }

  .whatsapp-float:hover .whatsapp-float__text {
    opacity: 1;
    transform: translateX(0);
  }


  .whatsapp-float:active .whatsapp-float__icon {
    transform: scale(0.95);
    background: #128C7E;
  }

  @media (max-width: 768px) {
    .whatsapp-float {
      bottom: calc(var(--space-4) + var(--safe-bottom, 0px));
    }

    .whatsapp-float--right {
      right: calc(var(--space-4) + var(--safe-right, 0px));
    }

    .whatsapp-float--left {
      left: calc(var(--space-4) + var(--safe-left, 0px));
    }

    .whatsapp-float__icon {
      width: 56px;
      height: 56px;
    }

    .whatsapp-float__text {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .whatsapp-float__icon {
      width: 52px;
      height: 52px;
    }

    .whatsapp-float__icon svg {
      width: 24px;
      height: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float--pulse .whatsapp-float__icon {
      animation: none;
    }
  }
</style>
