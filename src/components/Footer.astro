</footer>

<style>

  .bmx-ft {
    background: linear-gradient(180deg, #050810 0%, #0a0f1a 100%);
    color: var(--ink-muted);
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.6;
    padding-bottom: var(--safe-bottom, 0px);
    width: 100%;
    position: relative;
    border-top: 1px solid var(--hairline);
  }

  /* Línea técnica roja superior del footer */
  .bmx-ft::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--color-ember-600) 25%, var(--color-ember-600) 75%, transparent 100%);
    opacity: 0.5;
  }

  /* Grid técnico sutil de fondo */
  .bmx-ft::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.03) 1px, transparent 1px);
    background-size: 64px 64px;
    pointer-events: none;
  }

  .bmx-ft > * {
    position: relative;
    z-index: 1;
  }

  .bmx-ft-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--container-padding-wide);
  }


  .bmx-ft-main {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 40px 0 32px;
    border-bottom: 1px solid #1a1a1a;
  }


  .bmx-ft-brand {
    text-align: center;
  }

  .bmx-ft-logo {
    display: inline-block;
    font-size: 28px;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
  }

  .bmx-ft-logo span { color: #dc2626; }

  .bmx-ft-slogan {
    font-size: 13px;
    font-style: italic;
    color: #555;
    margin: 6px 0 12px;
  }

  .bmx-ft-desc {
    font-size: 12px;
    color: #666;
    line-height: 1.7;
    margin: 0 0 20px;
    max-width: 300px;
    margin-inline: auto;
  }

  .bmx-ft-stats {
    display: flex;
    justify-content: center;
    gap: 24px;
    padding-top: 16px;
    border-top: 1px solid #1a1a1a;
  }

  .bmx-ft-stats div {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bmx-ft-stats strong {
    font-size: 22px;
    font-weight: 900;
    color: #dc2626;
  }

  .bmx-ft-stats span {
    font-size: 9px;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }


  .bmx-ft-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    text-align: center;
  }

  .bmx-ft-nav div {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .bmx-ft-nav__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0 0 8px;
    padding-bottom: 10px;
    position: relative;
    display: inline-block;
  }

  .bmx-ft-nav__label::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 24px;
    height: 2px;
    background: var(--color-ember-600);
  }

  .bmx-ft-nav a {
    font-size: 12.5px;
    color: var(--ink-subtle);
    text-decoration: none;
    padding: 4px 0;
    min-height: var(--touch-target-min);
    display: flex;
    align-items: center;
    touch-action: manipulation;
    transition: color 0.15s ease, transform 0.15s ease;
    position: relative;
  }

  .bmx-ft-nav a:hover {
    color: var(--ink-strong);
    transform: translateX(2px);
  }

  .bmx-ft-nav a:active { color: var(--color-ember-500); }

  .bmx-ft-address {
    font-size: 11px;
    color: #555;
    line-height: 1.6;
    margin-top: 8px;
  }


  .bmx-ft-states {
    padding: 24px 0;
    border-bottom: 1px solid #1a1a1a;
  }

  .bmx-ft-states__label {
    font-size: 10px;
    font-weight: 700;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 16px;
    text-align: center;
  }

  .bmx-ft-states-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px 12px;
    text-align: center;
  }

  .bmx-ft-states-grid a {
    font-size: 11px;
    color: #666;
    text-decoration: none;
    padding: 8px 4px;
    min-height: var(--touch-target-min);
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: manipulation;
    transition: color 0.15s ease;
  }

  .bmx-ft-states-grid a:active {
    color: #dc2626;
  }


  .bmx-ft-certs {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 20px 0;
    border-bottom: 1px solid #1a1a1a;
    text-align: center;
  }

  .bmx-ft-certs-group {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px;
  }

  .bmx-ft-certs-label {
    font-size: 9px;
    color: #444;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: 100%;
    margin-bottom: 4px;
  }

  .bmx-ft-certs-group span:not(.bmx-ft-certs-label) {
    padding: 4px 8px;
    background: #151515;
    border: 1px solid #252525;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    color: #999;
  }


  .bmx-ft-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 20px 0;
    text-align: center;
  }

  .bmx-ft-bottom p {
    font-size: 11px;
    color: #444;
    margin: 0;
  }

  .bmx-ft-legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .bmx-ft-legal a {
    font-size: 11px;
    color: #555;
    text-decoration: none;
    padding: 4px 8px;
    min-height: var(--touch-target-min);
    display: flex;
    align-items: center;
    touch-action: manipulation;
    transition: color 0.15s ease;
  }

  .bmx-ft-legal a:active { color: #fff; }


  @media (min-width: 640px) {
    .bmx-ft-inner {
      padding: 0 24px;
    }

    .bmx-ft-main {
      padding: 48px 0 40px;
      gap: 40px;
    }

    .bmx-ft-logo {
      font-size: 32px;
    }

    .bmx-ft-desc {
      font-size: 13px;
      max-width: 360px;
    }

    .bmx-ft-nav {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 32px;
    }

    .bmx-ft-states-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .bmx-ft-certs {
      flex-direction: row;
      justify-content: center;
      gap: 24px;
    }

    .bmx-ft-certs-label {
      width: auto;
      margin-bottom: 0;
    }

    .bmx-ft-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }


  @media (min-width: 768px) {
    .bmx-ft-nav {
      grid-template-columns: repeat(3, 1fr);
    }

    .bmx-ft-states-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .bmx-ft-nav a,
    .bmx-ft-states-grid a,
    .bmx-ft-legal a {
      min-height: auto;
      padding: 0;
    }
  }


  @media (min-width: 1024px) {
    .bmx-ft-main {
      display: grid;
      grid-template-columns: 300px 1fr;
      gap: 64px;
      padding: 64px 0 48px;
    }

    .bmx-ft-brand {
      text-align: left;
    }

    .bmx-ft-desc {
      margin-inline: 0;
    }

    .bmx-ft-stats {
      justify-content: flex-start;
    }

    .bmx-ft-stats div {
      align-items: flex-start;
    }

    .bmx-ft-nav {
      grid-template-columns: repeat(5, 1fr);
      gap: 32px;
      text-align: left;
    }

    .bmx-ft-nav div {
      align-items: flex-start;
    }

    .bmx-ft-nav__label {
      display: block;
    }

    .bmx-ft-states-grid {
      grid-template-columns: repeat(6, 1fr);
      text-align: left;
    }

    .bmx-ft-states-grid a {
      justify-content: flex-start;
    }

    .bmx-ft-certs {
      justify-content: space-between;
    }

    @media (hover: hover) {
      .bmx-ft-nav a:hover { color: #fff; }
      .bmx-ft-states-grid a:hover { color: #dc2626; }
      .bmx-ft-legal a:hover { color: #fff; }
    }
  }


  @media (min-width: 1200px) {
    .bmx-ft-main {
      grid-template-columns: 320px 1fr;
    }

    .bmx-ft-states-grid {
      grid-template-columns: repeat(8, 1fr);
    }
  }
</style>
