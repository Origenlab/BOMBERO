---
/**
 * EmergencyNumbersBar.astro
 * ──────────────────────────────────────────────────────────────────
 * Barra horizontal con los principales teléfonos de emergencia del
 * estado. Pensada para colocarse justo bajo el hero del estado.
 *
 * Recibe la lista de números (label + number). El primer ítem se
 * destaca visualmente como "emergencia primaria" (usualmente 911 o
 * comandancia central).
 * ──────────────────────────────────────────────────────────────────
 */

interface EmergencyNumber {
  label: string;
  number: string;
}

interface Props {
  estado: string;
  numbers: EmergencyNumber[];
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  estado,
  numbers,
  ctaHref = "#listado-estaciones",
  ctaLabel = "Ver todas las estaciones",
} = Astro.props;
---

<aside class="emn" aria-label={`Números de emergencia en ${estado}`}>
  <div class="container">
    <div class="emn__wrap">
      <div class="emn__intro">
        <svg class="emn__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72" />
        </svg>
        <div>
          <p class="emn__title">Emergencias en {estado}</p>
          <p class="emn__sub">Llama directo — operan 24/7</p>
        </div>
      </div>

      <ul class="emn__list">
        {numbers.map((n, i) => (
          <li class={`emn__item ${i === 0 ? "emn__item--primary" : ""}`}>
            <a href={`tel:${n.number.replace(/\s/g, "")}`}>
              <span class="emn__num">{n.number}</span>
              <span class="emn__lab">{n.label}</span>
            </a>
          </li>
        ))}
      </ul>

      <a class="emn__cta" href={ctaHref}>
        {ctaLabel}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</aside>

<style>
  .emn {
    background: linear-gradient(135deg, #dc2626, #f97316);
    color: white;
    padding: 0.9rem 0;
    position: relative;
    z-index: 5;
  }

  .emn__wrap {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
  }

  .emn__intro {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .emn__icon {
    background: rgba(255,255,255,0.18);
    border-radius: 12px;
    padding: 0.45rem;
    box-sizing: content-box;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .emn__title {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 800;
    line-height: 1.15;
  }

  .emn__sub {
    margin: 0;
    font-size: 0.74rem;
    color: rgba(255,255,255,0.78);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .emn__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    scrollbar-width: thin;
  }

  .emn__item a {
    display: inline-flex;
    flex-direction: column;
    line-height: 1.1;
    padding: 0.45rem 0.9rem;
    background: rgba(0,0,0,0.18);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 9999px;
    color: white;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .emn__item a:hover {
    background: rgba(0,0,0,0.32);
  }

  .emn__item--primary a {
    background: white;
    color: #b91c1c;
    border-color: white;
    font-weight: 800;
  }

  .emn__num {
    font-size: 0.95rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }

  .emn__lab {
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.85;
  }

  .emn__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 1rem;
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 9999px;
    color: white;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .emn__cta:hover {
    background: rgba(0,0,0,0.42);
  }

  @media (max-width: 920px) {
    .emn__wrap {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
    .emn__cta {
      justify-self: start;
    }
  }
</style>
