---
/**
 * StationCTA.astro
 * ──────────────────────────────────────────────────────────────────
 * CTA contextual para fichas de estación.
 * - Cotización con pre-fill del contexto (estación, estado, municipio)
 * - WhatsApp con mensaje listo
 * - Tracker UTM por estación para medir conversiones
 *
 * Cumple Sprint 9 del plan: convertir tráfico SEO del directorio en
 * leads B2G (procurement municipal de EPP NFPA).
 * ──────────────────────────────────────────────────────────────────
 */

interface Props {
  estacionNombre: string;
  estado: string;
  municipio: string;
  estadoSlug: string;
  estacionSlug: string;
}

const { estacionNombre, estado, municipio, estadoSlug, estacionSlug } = Astro.props;

// UTM tracking para distinguir leads originados en cada ficha
const utm = `utm_source=directorio&utm_medium=estacion&utm_campaign=${encodeURIComponent(estadoSlug)}_${encodeURIComponent(estacionSlug)}`;

const cotizarHref = `/cotizar/?${utm}&estacion=${encodeURIComponent(estacionNombre)}&estado=${encodeURIComponent(estado)}&municipio=${encodeURIComponent(municipio)}`;

const waMsg = encodeURIComponent(
  `Hola BOMBERO.MX, soy de ${municipio}, ${estado}. Me interesa cotizar equipo NFPA para la ${estacionNombre}. ¿Pueden ayudarme?`,
);
const waHref = `https://wa.me/525570081816?text=${waMsg}`;

const phoneHref = `tel:+525570081816`;
---

<section class="station-cta" aria-labelledby="station-cta-title">
  <div class="container">
    <div class="station-cta__card">
      <div class="station-cta__top">
        <span class="station-cta__badge">Procurement B2G · Estaciones de bomberos</span>
        <h2 id="station-cta-title" class="station-cta__title">
          ¿Necesitas equipar a la <strong>{estacionNombre}</strong>?
        </h2>
        <p class="station-cta__desc">
          BOMBERO.MX es distribuidor autorizado de equipo certificado <strong>NFPA</strong>.
          Atendemos compras directas, licitaciones municipales y donativos del patronato en
          <strong> {municipio}, {estado}</strong>. Stock inmediato de trajes 1971, cascos,
          SCBA, guantes y herramientas de rescate.
        </p>
      </div>

      <div class="station-cta__points">
        <div class="station-cta__point">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <div>
            <strong>Cotización en 24 hrs</strong>
            <span>Ficha técnica + certificado de laboratorio incluidos</span>
          </div>
        </div>
        <div class="station-cta__point">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <div>
            <strong>Licitaciones gubernamentales</strong>
            <span>Documentación lista para procesos SAT, FERTA, OPME</span>
          </div>
        </div>
        <div class="station-cta__point">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <div>
            <strong>Envío a todo {estado}</strong>
            <span>Flete cubierto en pedidos &gt; $50,000 MXN</span>
          </div>
        </div>
      </div>

      <div class="station-cta__actions">
        <a class="station-cta__btn station-cta__btn--primary" href={cotizarHref}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
          </svg>
          Cotizar para la {estacionNombre.slice(0, 28)}{estacionNombre.length > 28 ? "…" : ""}
        </a>
        <a class="station-cta__btn station-cta__btn--whatsapp" href={waHref} rel="noopener" target="_blank">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634L4.04 20.13l3.114-.937zM17.443 14.96c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.149-.173.198-.297.297-.495.099-.198.05-.371-.025-.52-.075-.149-.668-1.611-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.371-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.073.149.198 2.095 3.2 5.076 4.487.71.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.288.173-1.413z"/>
          </svg>
          WhatsApp directo
        </a>
        <a class="station-cta__btn station-cta__btn--ghost" href={phoneHref}>
          Llamar 55 7008 1816
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .station-cta {
    padding: var(--space-12, 3rem) 0;
    background: var(--color-smoke-50, #fafafa);
  }

  .station-cta__card {
    background: linear-gradient(135deg, #ffffff 0%, #fff9f6 100%);
    border: 1px solid rgba(220, 38, 38, 0.16);
    border-radius: var(--radius-2xl, 1.25rem);
    box-shadow: 0 12px 38px -12px rgba(220, 38, 38, 0.18);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    position: relative;
    overflow: hidden;
  }

  .station-cta__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 110% -10%, rgba(220, 38, 38, 0.08), transparent 40%),
      radial-gradient(circle at -10% 110%, rgba(249, 115, 22, 0.06), transparent 40%);
    pointer-events: none;
  }

  .station-cta__top {
    max-width: 720px;
    position: relative;
  }

  .station-cta__badge {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    background: rgba(220, 38, 38, 0.1);
    color: #b91c1c;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.9rem;
  }

  .station-cta__title {
    margin: 0 0 0.65rem;
    font-size: clamp(1.4rem, 3vw, 1.95rem);
    font-weight: 800;
    color: #111;
    letter-spacing: -0.02em;
  }

  .station-cta__title strong {
    color: #b91c1c;
  }

  .station-cta__desc {
    color: #444;
    line-height: 1.65;
    font-size: 0.98rem;
    margin: 0;
  }

  .station-cta__desc strong {
    color: #111;
  }

  .station-cta__points {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1.75rem 0;
    position: relative;
  }

  .station-cta__point {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    padding: 0.85rem 1rem;
    background: white;
    border: 1px solid #eee;
    border-radius: 0.75rem;
  }

  .station-cta__point svg {
    color: #16a34a;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .station-cta__point strong {
    display: block;
    font-size: 0.92rem;
    color: #111;
    margin-bottom: 0.15rem;
  }

  .station-cta__point span {
    display: block;
    font-size: 0.82rem;
    color: #666;
    line-height: 1.45;
  }

  .station-cta__actions {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    position: relative;
  }

  .station-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.4rem;
    border-radius: 9999px;
    text-decoration: none;
    font-size: 0.93rem;
    font-weight: 700;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .station-cta__btn:hover {
    transform: translateY(-2px);
  }

  .station-cta__btn--primary {
    background: linear-gradient(135deg, #dc2626, #f97316);
    color: white;
    box-shadow: 0 8px 22px -8px rgba(220, 38, 38, 0.5);
  }

  .station-cta__btn--whatsapp {
    background: #25d366;
    color: white;
  }

  .station-cta__btn--whatsapp:hover {
    background: #1ebe5a;
  }

  .station-cta__btn--ghost {
    background: white;
    color: #111;
    border: 1px solid #ddd;
  }

  .station-cta__btn--ghost:hover {
    border-color: #b91c1c;
    color: #b91c1c;
  }

  @media (max-width: 760px) {
    .station-cta__points {
      grid-template-columns: 1fr;
    }

    .station-cta__btn {
      flex: 1 1 100%;
      justify-content: center;
    }
  }
</style>
