---
/**
 * VerifiedBadge.astro
 * ──────────────────────────────────────────────────────────────────
 * Bloque de confianza editorial: fecha de verificación + CTA para
 * reportar errores. Refuerza EEAT (Trustworthiness) y abre canal de
 * mejora de datos.
 *
 * Atributo `dateModified` también está en el JSON-LD del layout,
 * pero este bloque lo expone visualmente — clave para AI overviews
 * y para los usuarios finales.
 * ──────────────────────────────────────────────────────────────────
 */

interface Props {
  estado?: string;
  fecha: string;
  totalEstaciones?: number;
}

const { estado, fecha, totalEstaciones } = Astro.props;
const scope = estado ?? "directorio nacional";
const reportSubject = encodeURIComponent(`[Reporte de dato] Directorio — ${scope}`);
const reportBody = encodeURIComponent(
  `Hola,

Quiero reportar un dato del directorio:

URL: (pega aquí la URL de la página)
Estación / municipio:
Dato a corregir:
Información correcta:
Fuente / referencia (opcional):

Gracias.`,
);
---

<section class="verified" aria-label="Información de verificación editorial">
  <div class="container">
    <div class="verified__wrap">
      <div class="verified__main">
        <svg class="verified__shield" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
          <polyline points="9 12 11 14 15 10" />
        </svg>
        <div class="verified__text">
          <h3 class="verified__title">Datos verificados editorialmente</h3>
          <p class="verified__desc">
            {totalEstaciones ? (
              <><strong>{totalEstaciones} estaciones</strong> de {scope} verificadas en la última auditoría editorial del <time datetime="2026-05-30">{fecha}</time>.</>
            ) : (
              <>Información del {scope} verificada en la última auditoría editorial del <time datetime="2026-05-30">{fecha}</time>.</>
            )}
            Los teléfonos y direcciones se cotejan contra las fuentes oficiales de cada
            <strong> H. Cuerpo de Bomberos</strong> y de Protección Civil estatal.
          </p>
        </div>
      </div>

      <div class="verified__actions">
        <a
          class="verified__btn verified__btn--report"
          href={`mailto:ventas.bomberosmx@gmail.com?subject=${reportSubject}&body=${reportBody}`}
          rel="nofollow"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
          Reportar dato erróneo
        </a>
        <a class="verified__btn verified__btn--ghost" href="mailto:ventas.bomberosmx@gmail.com?subject=Alta%20en%20el%20directorio">
          Soy bombero / quiero aparecer
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .verified {
    padding: var(--space-10, 2.5rem) 0;
    background: linear-gradient(135deg, #0e1a14, #0b1410);
    color: white;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .verified__wrap {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: center;
  }

  .verified__main {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
  }

  .verified__shield {
    flex-shrink: 0;
    color: #4ade80;
    background: rgba(74, 222, 128, 0.12);
    padding: 0.5rem;
    border-radius: 12px;
    box-sizing: content-box;
    width: 28px;
    height: 28px;
  }

  .verified__title {
    margin: 0 0 0.4rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: white;
    letter-spacing: -0.005em;
  }

  .verified__desc {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.78);
    max-width: 720px;
  }

  .verified__desc strong {
    color: white;
  }

  .verified__desc time {
    color: #4ade80;
    font-weight: 700;
  }

  .verified__actions {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex-shrink: 0;
  }

  .verified__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.1rem;
    border-radius: 9999px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    white-space: nowrap;
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .verified__btn:hover {
    transform: translateY(-1px);
  }

  .verified__btn--report {
    background: #dc2626;
    color: white;
  }

  .verified__btn--report:hover {
    background: #b91c1c;
  }

  .verified__btn--ghost {
    background: rgba(255,255,255,0.08);
    color: white;
    border: 1px solid rgba(255,255,255,0.14);
  }

  .verified__btn--ghost:hover {
    background: rgba(255,255,255,0.14);
  }

  @media (max-width: 760px) {
    .verified__wrap {
      grid-template-columns: 1fr;
    }

    .verified__actions {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .verified__btn {
      flex: 1 1 auto;
      justify-content: center;
    }
  }
</style>
