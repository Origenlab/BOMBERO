---
/**
 * ProductSidebar.astro — Sidebar de 11 widgets para páginas L3 de categoría.
 * ───────────────────────────────────────────────────────────────────────
 * Widgets COMPARTIDOS (idénticos en todas las categorías), horneados aquí:
 *   W4  CTA "¿Necesitas Asesoría?"  (texto y mensaje WA configurables)
 *   W7  EPP Complementario
 *   W8  ¿Por qué BOMBERO.MX?
 *   W9  Más Categorías
 *   W10 Contacto Directo
 * Widgets POR CATEGORÍA (vía props):
 *   W1 tipos · W2 specs · W3 normas · W5 materiales · W6 marcas · W11 recursos
 *
 * El CSS vive en src/styles/product-l3.css (importado por ProductCategoryLayout).
 */

type Color = "ember" | "fire" | "smoke" | "neutral";

interface Tipo { href: string; label: string; badge?: string; badgeColor?: Color; dot?: Color; active?: boolean }
interface Spec { value: string; unit: string; label: string }
interface Norma { code: string; color?: Color; desc: string }
interface Material { name: string; desc: string }
interface Marca { name: string; sub: string }
interface Recurso { label: string; text: string; href: string }

interface Props {
  ariaLabel?: string;
  tiposTitle: string;
  tipos: Tipo[];
  specsTitle?: string;
  specs: Spec[];
  normasTitle?: string;
  normas: Norma[];
  materialesTitle?: string;
  materiales: Material[];
  marcasTitle?: string;
  marcas: Marca[];
  recursosTitle?: string;
  recursos: Recurso[];
  ctaTitle?: string;
  ctaText: string;
  waMsg: string;
}

const {
  ariaLabel = "Navegación de la categoría",
  tiposTitle,
  tipos,
  specsTitle = "Especificaciones Clave",
  specs,
  normasTitle = "Normas NFPA Aplicables",
  normas,
  materialesTitle = "Materiales Certificados",
  materiales,
  marcasTitle = "Marcas Distribuidas",
  marcas,
  recursosTitle = "Guías y Recursos",
  recursos,
  ctaTitle = "¿Necesitas Asesoría?",
  ctaText,
  waMsg,
} = Astro.props;

const waHref = `https://wa.me/525570081816?text=${encodeURIComponent(waMsg)}`;
---

<aside class="page-sidebar" aria-label={ariaLabel}>
  <div class="sidebar-sticky">

    <!-- ══ W1: Tipos ══ -->
    <div class="sb-widget">
      <div class="sb-widget__header">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="sb-widget__title">{tiposTitle}</span>
      </div>
      <nav class="sb-widget__body" aria-label={tiposTitle}>
        {tipos.map((t) => (
          <a href={t.href} class={`sb-link${t.active ? " sb-link--active" : ""}`}>
            <span class={`sb-link__dot sb-link__dot--${t.dot ?? "ember"}`}></span>
            <span class="sb-link__text">{t.label}{t.badge && <span class={`sb-link__badge${t.badgeColor && t.badgeColor !== "ember" ? ` sb-link__badge--${t.badgeColor}` : ""}`}>{t.badge}</span>}</span>
            <svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        ))}
      </nav>
    </div>

    <!-- ══ W2: Especificaciones Clave ══ -->
    <div class="sb-widget sb-widget--specs">
      <div class="sb-widget__header sb-widget__header--light">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon sb-widget__icon--dark"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
        <span class="sb-widget__title sb-widget__title--dark">{specsTitle}</span>
      </div>
      <div class="sb-specs-grid">
        {specs.map((s) => (
          <div class="sb-spec">
            <span class="sb-spec__value">{s.value}</span>
            <span class="sb-spec__unit">{s.unit}</span>
            <span class="sb-spec__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ══ W3: Normas NFPA Aplicables ══ -->
    <div class="sb-widget">
      <div class="sb-widget__header">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        <span class="sb-widget__title">{normasTitle}</span>
      </div>
      <div class="sb-widget__body sb-norms">
        {normas.map((n) => (
          <div class="sb-norm">
            <span class={`sb-norm__code sb-norm__code--${n.color ?? "ember"}`}>{n.code}</span>
            <span class="sb-norm__desc">{n.desc}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ══ W4: CTA Principal (compartido) ══ -->
    <div class="sb-cta">
      <div class="sb-cta__icon">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </div>
      <h3 class="sb-cta__title">{ctaTitle}</h3>
      <p class="sb-cta__text">{ctaText}</p>
      <a href="/cotizar/" class="sb-cta__btn">Cotizar sin costo</a>
      <a href={waHref} target="_blank" rel="noopener noreferrer" class="sb-cta__whatsapp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        WhatsApp directo
      </a>
    </div>

    <!-- ══ W5: Materiales Certificados ══ -->
    <div class="sb-widget">
      <div class="sb-widget__header sb-widget__header--light">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon sb-widget__icon--dark"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        <span class="sb-widget__title sb-widget__title--dark">{materialesTitle}</span>
      </div>
      <div class="sb-widget__body sb-materials">
        {materiales.map((m) => (
          <div class="sb-material">
            <span class="sb-material__name">{m.name}</span>
            <span class="sb-material__desc">{m.desc}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ══ W6: Marcas Distribuidas ══ -->
    <div class="sb-widget">
      <div class="sb-widget__header">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        <span class="sb-widget__title">{marcasTitle}</span>
      </div>
      <div class="sb-widget__body sb-brands">
        {marcas.map((b) => (
          <div class="sb-brand"><span class="sb-brand__dot"></span><div><span class="sb-brand__name">{b.name}</span><span class="sb-brand__sub">{b.sub}</span></div></div>
        ))}
      </div>
    </div>

    <!-- ══ W7: EPP Complementario (compartido) ══ -->
    <div class="sb-widget">
      <div class="sb-widget__header">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span class="sb-widget__title">EPP Complementario</span>
      </div>
      <nav class="sb-widget__body" aria-label="Equipo complementario">
        <a href="/productos/cascos-para-bomberos/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12h2c0-4.42 3.58-8 8-8s8 3.58 8 8h2c0-5.52-4.48-10-10-10z"/><rect x="2" y="12" width="20" height="4" rx="1"/></svg></span>Cascos para Bombero<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/botas-para-bomberos/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 14h7V6h4l3 4v4H3v0z"/><path d="M3 14v4h14v-4"/></svg></span>Botas para Bombero<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/guantes-para-bomberos/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg></span>Guantes para Bombero<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/capuchas-para-bomberos/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/></svg></span>Capuchas para Bombero<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/gafas-para-bomberos/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="15" r="4"/><circle cx="18" cy="15" r="4"/><path d="M14 15a2 2 0 0 0-2-2 2 2 0 0 0-2 2"/><path d="M2.5 13 5 7c.7-1.3 1.4-2 3-2h8c1.6 0 2.3.7 3 2l2.5 6"/></svg></span>Gafas y Goggles<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/scba/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a5 5 0 0 1 5 5v6H7V7a5 5 0 0 1 5-5z"/><rect x="3" y="13" width="18" height="8" rx="2"/></svg></span>SCBA / ERA Autónomo<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
      </nav>
    </div>

    <!-- ══ W8: ¿Por qué BOMBERO.MX? (compartido) ══ -->
    <div class="sb-widget sb-widget--why">
      <div class="sb-widget__header sb-widget__header--light">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon sb-widget__icon--dark"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span class="sb-widget__title sb-widget__title--dark">¿Por qué BOMBERO.MX?</span>
      </div>
      <div class="sb-widget__body sb-why">
        <div class="sb-why__item"><svg class="sb-why__check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>+15 años de experiencia en EPP bomberos</span></div>
        <div class="sb-why__item"><svg class="sb-why__check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Envío a los <strong>32 estados</strong> de México</span></div>
        <div class="sb-why__item"><svg class="sb-why__check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Asesoría técnica sin costo</span></div>
        <div class="sb-why__item"><svg class="sb-why__check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Certificados NFPA con laboratorio acreditado</span></div>
        <div class="sb-why__item"><svg class="sb-why__check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Documentación para licitaciones públicas</span></div>
        <div class="sb-why__item"><svg class="sb-why__check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Especificaciones técnicas EPP completo</span></div>
        <div class="sb-why__item"><svg class="sb-why__check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg><span>Respuesta a cotización en menos de 24 h</span></div>
      </div>
    </div>

    <!-- ══ W9: Más Categorías (compartido) ══ -->
    <div class="sb-widget">
      <div class="sb-widget__header">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        <span class="sb-widget__title">Más Categorías</span>
      </div>
      <nav class="sb-widget__body" aria-label="Otras categorías">
        <a href="/productos/equipo-contra-incendios/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg></span>Equipo Contra Incendios<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/herramientas-rescate/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></span>Herramientas de Rescate<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/hazmat/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>Equipos HAZMAT<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/rescate-vertical/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg></span>Rescate Vertical<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/rescate-acuatico/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12h20M2 12c0-5.5 4.5-10 10-10s10 4.5 10 10"/><path d="M2 12c0 5.5 4.5 10 10 10s10-4.5 10-10"/></svg></span>Rescate Acuático<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/extintores/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9a6 6 0 1 1 12 0c0 4-4 7-6 11C10 16 6 13 6 9z"/><circle cx="12" cy="9" r="2"/></svg></span>Extintores<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/equipo-medico/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span>Equipo Médico<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/forestales/" class="sb-link"><span class="sb-link__icon-wrap"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8C8 10 5.9 16.17 3.82 22H2v-8.5c0-3.04 2.46-5.5 5.5-5.5C10.97 8 12 10.97 12 10.97S13.03 8 16.5 8H17z"/></svg></span>Equipo Forestal<svg class="sb-link__arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg></a>
        <a href="/productos/" class="sb-link sb-link--all">Ver todos los productos →</a>
      </nav>
    </div>

    <!-- ══ W10: Contacto Directo (compartido) ══ -->
    <div class="sb-widget sb-widget--contact">
      <div class="sb-widget__header sb-widget__header--light">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="sb-widget__icon sb-widget__icon--dark"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.42 2 2 0 0 1 3.57 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.7 16z"/></svg>
        <span class="sb-widget__title sb-widget__title--dark">Contacto Directo</span>
      </div>
