---

import TopBar from "./TopBar.astro";
import Nav from "./Nav.astro";
import Logo from "./Logo.astro";
import { SITE } from "@data/site";
import { productCategories, secondaryCategories } from "@data/navigation";

interface Props {
  variant?: "default" | "transparent" | "dark";
  sticky?: boolean;
}

const { variant = "default", sticky = true } = Astro.props;

const headerClasses = [
  "header",
  `header--${variant}`,
  sticky && "header--sticky",
].filter(Boolean).join(" ");

// Iconos para menú móvil
const icons: Record<string, string> = {
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  helmet: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>`,
  gloves: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 11V6a2 2 0 0 0-4 0v4M14 10V4a2 2 0 0 0-4 0v6M10 10V6a2 2 0 0 0-4 0v8"/></svg>`,
  boot: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18M19 21v-4H5v4M19 17V9a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v8"/></svg>`,
  hood: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a8 8 0 0 0-8 8v4a8 8 0 0 0 16 0v-4a8 8 0 0 0-8-8z"/></svg>`,
  goggles: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="12" r="3"/><circle cx="17" cy="12" r="3"/><path d="M10 12h4"/></svg>`,
  lungs: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 4v16M8 4h8"/></svg>`,
  fire: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
  tools: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  camera: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`,
  extinguisher: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="7" y="4" width="10" height="16" rx="2"/><path d="M12 4v4M7 12h10"/></svg>`,
};

const allCategories = [...productCategories, ...secondaryCategories];
---


<TopBar />


<header class={headerClasses} role="banner">
  <div class="container header__inner">

    <Logo />


    <nav class="header__nav" id="main-nav" aria-label="Navegación principal">
      <Nav />
    </nav>


    <div class="header__actions">

      <a
        href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa información sobre equipo para bomberos`}
        class="header__whatsapp"
        aria-label="Contactar por WhatsApp"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>


      <a href="/cotizar/" class="header__cta">
        <span>Cotizar</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>


      <button
        class="header__toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
        type="button"
      >
        <span class="header__toggle-bar" aria-hidden="true"></span>
        <span class="header__toggle-bar" aria-hidden="true"></span>
        <span class="header__toggle-bar" aria-hidden="true"></span>
      </button>
    </div>
  </div>


  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__inner">

      <nav class="mobile-menu__nav" aria-label="Navegación móvil">
        <a href="/" class="mobile-menu__link">Inicio</a>


        <div class="mobile-menu__accordion">
          <button class="mobile-menu__accordion-btn" type="button" aria-expanded="false">
            <span>Productos</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </button>
          <div class="mobile-menu__accordion-content">
            <div class="mobile-menu__categories">
              {allCategories.map((cat) => (
                <a href={cat.href} class="mobile-menu__category">
                  <span class="mobile-menu__category-icon" set:html={icons[cat.icon ?? "fire"]} />
                  <span class="mobile-menu__category-name">{cat.label}</span>
                </a>
              ))}
            </div>
            <a href="/productos/" class="mobile-menu__all-products">
              Ver todos los productos
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>

        <a href="/directorio/" class="mobile-menu__link">Directorio</a>
        <a href="/blog/" class="mobile-menu__link">Blog</a>
        <a href="/nosotros/" class="mobile-menu__link">Nosotros</a>
        <a href="/contacto/" class="mobile-menu__link">Contacto</a>
      </nav>


      <div class="mobile-menu__cta">
        <a href="/cotizar/" class="mobile-menu__cta-btn mobile-menu__cta-btn--primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 12h6M12 9v6"/>
            <circle cx="12" cy="12" r="10"/>
          </svg>
          Solicitar Cotización
        </a>
        <a
          href={`https://wa.me/${SITE.contact.whatsapp}`}
          class="mobile-menu__cta-btn mobile-menu__cta-btn--secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>


      <div class="mobile-menu__contact">
        <a href={`tel:${SITE.contact.phoneRaw}`} class="mobile-menu__contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {SITE.contact.phoneTollFree}
        </a>
        <a href={`mailto:${SITE.contact.email}`} class="mobile-menu__contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          {SITE.contact.email}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.querySelector(".header__toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const header = document.querySelector(".header");

  toggle?.addEventListener("click", () => {
    const isExpanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isExpanded));
    mobileMenu?.setAttribute("aria-hidden", String(isExpanded));
    mobileMenu?.classList.toggle("mobile-menu--open");
    header?.classList.toggle("header--menu-open");
    document.body.style.overflow = isExpanded ? "" : "hidden";
  });

  // Accordion functionality
  const accordionBtns = document.querySelectorAll(".mobile-menu__accordion-btn");
  accordionBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      const isExpanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!isExpanded));
      btn.closest(".mobile-menu__accordion")?.classList.toggle("is-open");
    });
  });

  // Close menu when clicking outside
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest(".header") && mobileMenu?.classList.contains("mobile-menu--open")) {
      toggle?.setAttribute("aria-expanded", "false");
      mobileMenu?.setAttribute("aria-hidden", "true");
      mobileMenu?.classList.remove("mobile-menu--open");
      header?.classList.remove("header--menu-open");
      document.body.style.overflow = "";
    }
  });

  // Close menu on escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && mobileMenu?.classList.contains("mobile-menu--open")) {
      toggle?.setAttribute("aria-expanded", "false");
      mobileMenu?.setAttribute("aria-hidden", "true");
      mobileMenu?.classList.remove("mobile-menu--open");
      header?.classList.remove("header--menu-open");
      document.body.style.overflow = "";
    }
  });

  // Header scroll effect
  let lastScroll = 0;
  window.addEventListener("scroll", () => {
    const currentScroll = window.pageYOffset;
    if (currentScroll > 100) {
      header?.classList.add("header--scrolled");
    } else {
      header?.classList.remove("header--scrolled");
    }
    lastScroll = currentScroll;
  });
</script>

<style>


  .header {
    position: relative;
    background: #ffffff;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-smoke-100);
  }

  .header--sticky {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
  }

  .header--scrolled {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border-bottom-color: transparent;
  }

  .header--transparent {
    background: transparent;
    position: absolute;
    width: 100%;
    left: 0;
    top: 0;
    border-bottom-color: transparent;
  }

  .header--dark {
    background: var(--color-smoke-900);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }


  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }


  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .header__whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: #25D366;
    border-radius: var(--radius-lg);
    color: white;
    transition: all 0.15s ease;
  }

  .header__whatsapp:hover {
    background: #128C7E;
    transform: scale(1.05);
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--gradient-fire);
    color: white;
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    border-radius: var(--radius-lg);
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(220, 38, 38, 0.25);
  }

  .header__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.35);
  }

  .header__cta svg {
    transition: transform 0.2s ease;
  }

  .header__cta:hover svg {
    transform: translateX(2px);
  }


  .header__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    border-radius: var(--radius-lg);
    transition: background 0.15s ease;
  }

  .header__toggle:hover {
    background: var(--color-smoke-100);
  }

  .header__toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-smoke-700);
    border-radius: 2px;
    transition: all 0.2s ease;
    transform-origin: center;
  }

  .header__toggle[aria-expanded="true"] .header__toggle-bar:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .header__toggle[aria-expanded="true"] .header__toggle-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .header__toggle[aria-expanded="true"] .header__toggle-bar:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }



  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: #ffffff;
    z-index: calc(var(--z-header) - 1);
    padding-top: 120px;
    opacity: 0;
    visibility: hidden;
    transform: translateX(100%);
    transition: all 0.3s ease;
  }

  .mobile-menu--open {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
  }

  .mobile-menu__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-4) var(--container-padding);
    overflow-y: auto;
    gap: var(--space-6);
  }


  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__link {
    display: flex;
    align-items: center;
    padding: var(--space-4) 0;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-smoke-800);
    text-decoration: none;
    border-bottom: 1px solid var(--color-smoke-100);
    transition: color 0.15s ease;
  }

  .mobile-menu__link:hover {
    color: var(--color-fire-600);
  }


  .mobile-menu__accordion {
    border-bottom: 1px solid var(--color-smoke-100);
  }

  .mobile-menu__accordion-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-4) 0;
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-smoke-800);
  }

  .mobile-menu__accordion-btn svg {
    transition: transform 0.2s ease;
    color: var(--color-smoke-400);
  }

  .mobile-menu__accordion.is-open .mobile-menu__accordion-btn svg {
    transform: rotate(180deg);
  }

  .mobile-menu__accordion-content {
    display: none;
    padding-bottom: var(--space-4);
  }

  .mobile-menu__accordion.is-open .mobile-menu__accordion-content {
    display: block;
  }

  .mobile-menu__categories {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  .mobile-menu__category {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--color-smoke-50);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .mobile-menu__category:hover {
    background: var(--color-fire-50);
  }

  .mobile-menu__category-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-fire-600);
  }

  .mobile-menu__category-icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  .mobile-menu__category-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-smoke-800);
    line-height: 1.2;
  }

  .mobile-menu__all-products {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    padding: var(--space-3);
    background: var(--color-fire-50);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-fire-600);
    text-decoration: none;
  }

  .mobile-menu__all-products:hover {
    background: var(--color-fire-100);
  }


  .mobile-menu__cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mobile-menu__cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mobile-menu__cta-btn--primary {
    background: var(--gradient-fire);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(220, 38, 38, 0.25);
  }

  .mobile-menu__cta-btn--primary:hover {
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.35);
  }

  .mobile-menu__cta-btn--secondary {
    background: #25D366;
    color: #ffffff;
  }

  .mobile-menu__cta-btn--secondary:hover {
    background: #128C7E;
  }


  .mobile-menu__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-smoke-100);
    margin-top: auto;
  }

  .mobile-menu__contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-smoke-600);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .mobile-menu__contact-item:hover {
    color: var(--color-fire-600);
  }

  .mobile-menu__contact-item svg {
    flex-shrink: 0;
    color: var(--color-smoke-400);
  }



  @media (max-width: 1024px) {
    .header__cta span {
      display: none;
    }

    .header__cta {
      width: 40px;
      height: 40px;
      padding: 0;
      justify-content: center;
    }

    .header__cta svg {
      margin: 0;
    }
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
    }

    .header__toggle {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }

    .header__whatsapp {
      display: none;
    }

    .header--menu-open {
      position: fixed;
      width: 100%;
    }
  }
</style>
