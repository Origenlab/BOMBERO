---

import { mainNav, productCategories, secondaryCategories } from "@data/navigation";

const currentPath = Astro.url.pathname;

// Iconos SVG para categorías
const icons: Record<string, string> = {
  shield: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  helmet: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  gloves: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>`,
  boot: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18"/><path d="M19 21v-4H5v4"/><path d="M19 17V9a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v8"/><path d="M7 7V4a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v3"/></svg>`,
  hood: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a8 8 0 0 0-8 8v4a8 8 0 0 0 16 0v-4a8 8 0 0 0-8-8z"/><path d="M12 18v4"/><circle cx="12" cy="10" r="3"/></svg>`,
  goggles: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="12" r="3"/><circle cx="17" cy="12" r="3"/><path d="M10 12h4"/><path d="M4 12H2"/><path d="M22 12h-2"/></svg>`,
  lungs: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.081 20C2.5 20 2 16.5 2 14c0-3 1-6.5 4-7.5 1-.33 1.5-1 1.5-2 0-.17.01-.33.03-.5"/><path d="M17.92 20C21.5 20 22 16.5 22 14c0-3-1-6.5-4-7.5-1-.33-1.5-1-1.5-2 0-.17-.01-.33-.03-.5"/><path d="M12 4v16"/><path d="M8 4h8"/></svg>`,
  fire: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
  tools: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  camera: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`,
  extinguisher: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 2v2"/><path d="M14 2v2"/><rect x="7" y="4" width="10" height="16" rx="2"/><path d="M12 4v4"/><path d="M7 12h10"/></svg>`,
  forest: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L4 12h4v8h8v-8h4L12 2z"/></svg>`,
  hazmat: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  rope: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20"/><path d="M8 6c0 0 2-2 4-2s4 2 4 2"/><path d="M8 10c0 0 2-2 4-2s4 2 4 2"/><path d="M8 14c0 0 2-2 4-2s4 2 4 2"/><circle cx="12" cy="20" r="2"/></svg>`,
  water: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  medical: `<svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>`,
};
---

<nav class="nav" aria-label="Navegación principal">
  <ul class="nav__list">
    {mainNav.map((item) => {
      const isProducts = item.label === "Productos";
      const isActive = item.href === "/"
        ? currentPath === "/"
        : currentPath === item.href || currentPath.startsWith(item.href);

      return (
        <li class:list={["nav__item", { "nav__item--mega": isProducts }]}>
          <a
            href={item.href}
            class:list={["nav__link", { "nav__link--active": isActive }]}
            aria-current={currentPath === item.href ? "page" : undefined}
            aria-expanded={isProducts ? "false" : undefined}
            aria-haspopup={isProducts ? "true" : undefined}
          >
            {item.label}
            {isProducts && (
              <svg aria-hidden="true" class="nav__chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            )}
          </a>

          {}
          {isProducts && (
            <div class="mega" role="dialog" aria-label="Menú de productos">
              <div class="mega__container">
                <div class="mega__main">

                  {/* Sección 1: EPP */}
                  <p class="mega__section-title">Equipo de Protección Personal</p>
                  <div class="mega__grid">
                    {productCategories.map((cat) => (
                      <div class="mega__category">
                        <a href={cat.href} class="mega__category-header">
                          <span class="mega__icon" set:html={icons[cat.icon ?? "shield"]} />
                          <div class="mega__category-info">
                            <span class="mega__category-name">
                              {cat.label}
                              {cat.badge && <span class="mega__badge">{cat.badge}</span>}
                            </span>
                            <span class="mega__category-desc">{cat.description}</span>
                          </div>
                        </a>
                        {cat.children && cat.children.length > 0 && (
                          <ul class="mega__sublist">
                            {cat.children.slice(0, 4).map((sub) => (
                              <li><a href={sub.href} class="mega__sublink">{sub.label}</a></li>
                            ))}
                            {cat.children.length > 4 && (
                              <li>
                                <a href={cat.href} class="mega__sublink mega__sublink--more">Ver todos →</a>
                              </li>
                            )}
                          </ul>
                        )}
                      </div>
                    ))}
                  </div>

                  {/* Divisor */}
                  <div class="mega__divider" />

                  {/* Sección 2: Especializados */}
                  <p class="mega__section-title">Equipos Especializados</p>
                  <div class="mega__grid">
                    {secondaryCategories.map((cat) => (
                      <div class="mega__category">
                        <a href={cat.href} class="mega__category-header">
                          <span class="mega__icon" set:html={icons[cat.icon ?? "tools"]} />
                          <div class="mega__category-info">
                            <span class="mega__category-name">{cat.label}</span>
                            <span class="mega__category-desc">{cat.description}</span>
                          </div>
                        </a>
                        {cat.children && cat.children.length > 0 && (
                          <ul class="mega__sublist">
                            {cat.children.slice(0, 4).map((sub) => (
                              <li><a href={sub.href} class="mega__sublink">{sub.label}</a></li>
                            ))}
                            {cat.children.length > 4 && (
                              <li>
                                <a href={cat.href} class="mega__sublink mega__sublink--more">Ver todos →</a>
                              </li>
                            )}
                          </ul>
                        )}
                      </div>
                    ))}
                  </div>

                  {/* Footer del mega menu */}
                  <div class="mega__footer">
                    <a href="/productos/" class="mega__footer-link">
                      Ver catálogo completo — 16 categorías →
                    </a>
                  </div>

                </div>
              </div>
            </div>
          )}
        </li>
      );
    })}
  </ul>
</nav>

<style>


  .nav {
    position: relative;
  }

  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__item {
    position: relative;
  }

  .nav__item--mega {
    position: static;
  }

  .nav__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-smoke-700);
    text-decoration: none;
    border-radius: var(--radius-lg);
    white-space: nowrap;
    position: relative;
    transition: color 0.15s ease, background 0.15s ease;
  }

  /* Indicador underline animado */
  .nav__link::after {
    content: '';
    position: absolute;
    bottom: 3px;
    left: 50%;
    right: 50%;
    height: 2px;
    background: var(--color-ember-500);
    border-radius: 2px;
    transition: left 0.2s ease, right 0.2s ease;
    pointer-events: none;
  }

  .nav__link:hover {
    color: var(--color-smoke-900);
    background: var(--color-smoke-50);
  }

  .nav__link:hover::after {
    left: var(--space-3);
    right: var(--space-3);
  }

  .nav__link--active {
    color: var(--color-fire-700);
    background: var(--color-fire-50);
  }

  .nav__link--active::after {
    left: var(--space-3);
    right: var(--space-3);
    background: var(--color-fire-600);
  }

  .nav__chevron {
    flex-shrink: 0;
    transition: transform 0.2s cubic-bezier(0.4,0,0.2,1);
  }

  .nav__item--mega:hover .nav__chevron,
  .nav__item--mega:focus-within .nav__chevron,
  .nav__item--mega.is-open .nav__chevron {
    transform: rotate(180deg);
  }



  .mega {
    position: absolute;
    top: 100%;
    left: 50%;
    width: min(1200px, 96vw);
    background: #ffffff;
    border-radius: var(--radius-xl);
    box-shadow:
      0 4px 6px -1px rgba(0,0,0,0.04),
      0 20px 40px -12px rgba(0,0,0,0.14),
      0 0 0 1px rgba(0,0,0,0.05);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(-50%) translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 1000;
    margin-top: var(--space-2);
    will-change: opacity, transform;
  }

  /* Flecha decorativa */
  .mega::before {
    content: "";
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: #ffffff;
    border-left: 1px solid rgba(0,0,0,0.05);
    border-top: 1px solid rgba(0,0,0,0.05);
  }

  /* Zona de hover invisible que evita que se cierre el mega al mover
     el cursor entre el link y el panel (gap de margin-top) */
  .mega::after {
    content: "";
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 12px;
  }

  .nav__item--mega:hover .mega,
  .nav__item--mega:focus-within .mega,
  .nav__item--mega.is-open .mega {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .mega__container {
    display: block;
  }

  .mega__main {
    padding: var(--space-6);
  }

  .mega__divider {
    height: 1px;
    background: var(--color-smoke-100);
    margin: var(--space-5) 0 var(--space-4);
  }

  .mega__footer {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-smoke-100);
    text-align: center;
  }

  .mega__footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-fire-600);
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--color-fire-50);
    border: 1px solid var(--color-fire-100);
    transition: background 0.15s;
  }

  .mega__footer-link:hover {
    background: var(--color-fire-100);
  }

  .mega__section-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-smoke-600);
    margin-bottom: var(--space-4);
    padding-left: calc(var(--space-2) + 10px);
    border-left: 3px solid var(--color-ember-500);
    line-height: 1.4;
  }

  /* La segunda sección de especializado tiene borde azul */
  .mega__section-title + .mega__grid + .mega__divider + .mega__section-title,
  .mega__divider + .mega__section-title {
    border-left-color: #3b82f6;
  }

  .mega__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3) var(--space-4);
  }


  .mega__category {
    display: flex;
    flex-direction: column;
  }

  .mega__category-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3);
    border-radius: var(--radius-lg);
    text-decoration: none;
  }

  .mega__category-header:hover {
    background: var(--color-smoke-50);
  }

  .mega__icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-fire-50);
    border-radius: var(--radius-md);
    color: var(--color-fire-600);
  }

  .mega__icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .mega__category-header:hover .mega__icon {
    background: var(--color-fire-100);
  }

  .mega__category-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .mega__category-name {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-smoke-900);
    line-height: 1.3;
  }

  .mega__badge {
    display: inline-flex;
    padding: 2px 6px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-fire-700);
    background: var(--color-fire-100);
    border-radius: var(--radius-sm);
  }

  .mega__category-desc {
    font-size: 12px;
    color: var(--color-smoke-500);
    line-height: 1.4;
  }


  .mega__sublist {
    list-style: none;
    margin: 0;
    padding: 0 0 0 calc(36px + var(--space-3));
    display: flex;
    flex-direction: column;
  }

  .mega__sublink {
    display: block;
    padding: 5px var(--space-3);
    font-size: 13px;
    color: var(--color-smoke-600);
    text-decoration: none;
    border-radius: var(--radius-md);
  }

  .mega__sublink:hover {
    color: var(--color-fire-600);
    background: var(--color-fire-50);
  }

  .mega__sublink--more {
    color: var(--color-fire-600);
    font-weight: 500;
  }



  /* El mega ahora es más ancho para acomodar 4 columnas */
  @media (max-width: 1300px) {
    .mega {
      width: min(1050px, 97vw);
    }
    .mega__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 1100px) {
    .mega {
      width: min(900px, 97vw);
    }
    .mega__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {

    .nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav__link {
      padding: var(--space-3) var(--space-4);
      font-size: var(--text-base);
      border-radius: 0;
      justify-content: space-between;
    }

    .nav__link--active {
      background: transparent;
      border-left: 3px solid var(--color-fire-600);
      padding-left: calc(var(--space-4) - 3px);
    }

    .mega {
      position: static;
      transform: none;
      width: 100%;
      border-radius: 0;
      box-shadow: none;
      margin-top: 0;
      opacity: 1;
      visibility: visible;
      display: none;
      background: var(--color-smoke-50);
    }

    .mega::before {
      display: none;
    }

    .nav__item--mega:hover .mega,
    .nav__item--mega:focus-within .mega,
    .nav__item--mega.is-open .mega {
      display: block;
    }

    .mega__main {
      padding: var(--space-4);
    }

    .mega__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }

    .mega__category-header {
      padding: var(--space-2);
    }

    .mega__sublist {
      padding-left: calc(36px + var(--space-2));
    }

    .nav__chevron {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .mega__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const megaItems = document.querySelectorAll('.nav__item--mega');

  // Toggle en móvil por clic / en desktop por teclado
  megaItems.forEach(item => {
    const link = item.querySelector<HTMLAnchorElement>('.nav__link');
    if (!link) return;

    // Móvil: clic en el link abre el mega (en desktop el :hover ya lo hace)
    link.addEventListener('click', (e) => {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        const open = item.classList.toggle('is-open');
        link.setAttribute('aria-expanded', String(open));
      }
    });

    // Desktop teclado: Enter / Space abren/cierran
    link.addEventListener('keydown', (e) => {
      if (window.innerWidth > 768 && (e.key === 'Enter' || e.key === ' ')) {
        e.preventDefault();
        const open = item.classList.toggle('is-open');
        link.setAttribute('aria-expanded', String(open));
      }
    });
  });

  // Escape cierra el mega en desktop
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      megaItems.forEach(item => {
        item.classList.remove('is-open');
        const link = item.querySelector<HTMLAnchorElement>('.nav__link');
        if (link) link.setAttribute('aria-expanded', 'false');
      });
    }
  });

  // Clic fuera cierra el mega en desktop
  document.addEventListener('click', (e) => {
    if (window.innerWidth <= 768) return;
    const target = e.target as Element | null;
    megaItems.forEach(item => {
      if (target && !item.contains(target)) {
        item.classList.remove('is-open');
        const link = item.querySelector<HTMLAnchorElement>('.nav__link');
        if (link) link.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
