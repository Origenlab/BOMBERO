---

import SectionHeader from "./SectionHeader.astro";
import CategoryCard from "./CategoryCard.astro";

interface Props {
  images?: string[];
}

const { images } = Astro.props;

const defaultImages = [
  "/images/directorio/simulacro-bomberos-profesional-01.avif",
  "/images/directorio/equipo-proteccion-bomberos-01.avif",
  "/images/directorio/central-despacho-bomberos-monitores-mapa-01.avif",
  "/images/directorio/vestidor-bomberos-cascos-bandera-mexico-01.avif",
  "/images/directorio/estacion-bomberos-bahia-camiones-frontal-01.avif",
  "/images/directorio/bombero-profesional-closeup-servicio-01.avif",
];

const cardImages = defaultImages.map((defaultImage, index) => images?.[index] ?? defaultImage);
---

<section class="why-choose" id="por-que-elegirnos">
  <div class="container">

    <SectionHeader
      label="Por qué confiar en BOMBERO.MX"
      title="Tu Proveedor de Equipo para Bomberos en México"
      description="Distribuidor especializado en equipo de protección personal para bomberos con cobertura nacional, asesoría técnica y disponibilidad inmediata de las mejores marcas del mundo."
    >
      <p>
        La selección de un proveedor de <strong>equipo para bomberos</strong> impacta directamente en la seguridad
        del personal de primera respuesta. En <strong>BOMBERO.MX</strong> combinamos la distribución de las
        marcas líderes mundiales —MSA, Honeywell, Globe, Bullard— con conocimiento técnico del mercado mexicano.
      </p>
      <p>
        Operamos desde Ciudad de México con capacidad de envío a los <strong>32 estados de la República</strong>.
        Nuestro inventario permanente reduce tiempos de entrega, mientras que el equipo técnico proporciona
        asesoría personalizada para equipar estaciones de bomberos, brigadas industriales y unidades de
        protección civil de cualquier tamaño.
      </p>
    </SectionHeader>


    <div class="why-choose__grid">
      <CategoryCard
        title="Experiencia Comprobada"
        icon="certificate"
        image={cardImages[0]}
        description="Más de 500 estaciones de bomberos equipadas en México. Proveedor de confianza para Protección Civil estatal, brigadas de PEMEX, CFE y empresas del sector industrial. Casos de éxito documentados y referencias verificables."
      />
      <CategoryCard
        title="Marcas Líderes Mundiales"
        icon="shield"
        image={cardImages[1]}
        description="Distribuidores autorizados de MSA, Honeywell, Globe, Bullard, Cairns, Lion y Holmatro. Equipos de protección personal fabricados bajo los más altos estándares internacionales. Autenticidad garantizada con números de serie verificables."
      />
      <CategoryCard
        title="Asesoría Técnica Gratuita"
        icon="headphones"
        image={cardImages[2]}
        description="Especialistas certificados en normativa NFPA y equipamiento contra incendios. Elaboramos especificaciones técnicas, comparativos de productos y recomendaciones personalizadas según el tipo de riesgo. Apoyo en procesos de licitación pública."
      />
      <CategoryCard
        title="Stock Permanente"
        icon="clock"
        image={cardImages[3]}
        description="Inventario activo de los productos más demandados: trajes estructurales, cascos, guantes, botas y SCBA en tallas estándar. Disponibilidad inmediata sin tiempos de espera. Equipos especializados bajo pedido con tiempos garantizados."
      />
      <CategoryCard
        title="Logística Nacional"
        icon="truck"
        image={cardImages[4]}
        description="Red de distribución optimizada para equipo contra incendios. Entregas coordinadas directamente en estaciones, dependencias gubernamentales e instalaciones industriales. Embalaje especializado y seguro de envío incluido."
      />
      <CategoryCard
        title="Ejecutivo de Cuenta Asignado"
        icon="users"
        image={cardImages[5]}
        description="Un solo contacto para todas tus necesidades. Seguimiento personalizado desde la cotización hasta la entrega. Recordatorios de mantenimiento, renovación de equipos y acceso prioritario a nuevos productos y promociones."
      />
    </div>
  </div>
</section>

<style>


  .why-choose {
    padding: var(--space-12) 0;
    background: white;
  }


  .why-choose__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }


  @media (min-width: 640px) {
    .why-choose {
      padding: var(--space-16) 0;
    }

    .why-choose__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
  }


  @media (min-width: 1024px) {
    .why-choose {
      padding: var(--space-20) 0;
    }

    .why-choose__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }
</style>
