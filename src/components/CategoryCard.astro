---
import { cdnW, cdnSrcset } from "@utils/cdn";

interface CardItem {
  label: string;
  href: string;
}

interface Props {
  title:       string;
  badge?:      string;
  items?:      CardItem[];
  href?:       string;
  buttonText?: string;
  icon?:       string;
  image?:      string;
  description?: string;
}

const {
  title,
  badge,
  items = [],
  href,
  buttonText,
  icon = "shield",
  image,
  description,
} = Astro.props;

const imageCdn = image ? cdnW(image, 480) : undefined;

const normalizeInternalPath = (value: string) =>
  value.startsWith("http")
    ? value
    : (value.startsWith("/") ? value : `/${value}`).replace(/\/{2,}/g, "/");

const normalizedHref     = href  ? normalizeInternalPath(href)  : undefined;
const normalizedItems    = items.map(item => ({ ...item, href: normalizeInternalPath(item.href) }));

const icons: Record<string, string> = {
  shield:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>`,
  helmet:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v2z"/><path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"/><path d="M4 15v-3a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v3"/></svg>`,
  boot:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 21h10"/><path d="M12 21V11"/><path d="M6 11V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v6"/><path d="M5 11h14l-2 10H7l-2-10z"/></svg>`,
  glove:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 11V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>`,
  hood:       `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="5"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2"/></svg>`,
  goggles:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="12" r="4"/><circle cx="18" cy="12" r="4"/><path d="M10 12h4"/><path d="M2 12h0"/><path d="M22 12h0"/></svg>`,
  certificate:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>`,
  truck:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>`,
};
---

<article class="cat-card">

  <!-- Imagen / Placeholder -->
  <a href={normalizedHref || "#"} class="cat-card__media" tabindex="-1" aria-hidden="true">
    {imageCdn ? (
      <img
        src={imageCdn}
        srcset={image ? cdnSrcset(image, [240, 360, 480]) : undefined}
        sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 25vw"
        alt={title}
        width="480"
        height="320"
        loading="lazy"
        decoding="async"
        class="cat-card__img"
      />
    ) : (
      <div class="cat-card__icon-wrap">
        <Fragment set:html={icons[icon] || icons.shield} />
      </div>
    )}

    <!-- Overlay gradiente inferior -->
    <div class="cat-card__overlay" aria-hidden="true"></div>

    <!-- Badges sobre la imagen -->
    <div class="cat-card__badges">
      {badge && <span class="cat-card__badge-count">{badge}</span>}
      <span class="cat-card__badge-nfpa">NFPA</span>
    </div>
  </a>

  <!-- Contenido -->
  <div class="cat-card__body">

    <h3 class="cat-card__title">
      {normalizedHref
        ? <a href={normalizedHref}>{title}</a>
        : title
      }
    </h3>

    {description && <p class="cat-card__desc">{description}</p>}

    {normalizedItems.length > 0 && (
      <ul class="cat-card__list">
        {normalizedItems.map(item => (
          <li class="cat-card__list-item">
            <a href={item.href} class="cat-card__list-link">
              <svg class="cat-card__list-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M9 18l6-6-6-6"/>
              </svg>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    )}

    {normalizedHref && (
      <a href={normalizedHref} class="cat-card__cta">
        {buttonText || "Ver productos"}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    )}

  </div>
</article>

<style>
/* ── Card contenedor ───────────────────────────────────────────── */
.cat-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid var(--color-smoke-200);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  height: 100%;
}

@media (hover: hover) {
  .cat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    border-color: var(--color-fire-300);
  }
  .cat-card:hover .cat-card__img {
    transform: scale(1.04);
  }
}

/* ── Media (imagen) ────────────────────────────────────────────── */
.cat-card__media {
  display: block;
  position: relative;
  aspect-ratio: 3 / 2;
  background: linear-gradient(135deg, var(--color-smoke-900) 0%, var(--color-smoke-800) 100%);
  overflow: hidden;
  text-decoration: none;
  flex-shrink: 0;
}

.cat-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}

/* Ícono placeholder cuando no hay imagen */
.cat-card__icon-wrap {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cat-card__icon-wrap :global(svg) {
  width: 56px;
  height: 56px;
  stroke: rgba(255,255,255,0.2);
}

/* Gradiente overlay inferior */
.cat-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 40%,
    rgba(15,23,42,0.55) 100%
  );
  pointer-events: none;
}

/* ── Badges ────────────────────────────────────────────────────── */
.cat-card__badges {
  position: absolute;
  top: 12px;
  left: 12px;
  right: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  pointer-events: none;
}

.cat-card__badge-count {
  background: rgba(15,23,42,0.75);
  backdrop-filter: blur(6px);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 4px 10px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.12);
}

.cat-card__badge-nfpa {
  background: var(--color-fire-600);
  color: #fff;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.08em;
  padding: 4px 9px;
  border-radius: 999px;
}

/* ── Cuerpo ────────────────────────────────────────────────────── */
.cat-card__body {
  display: flex;
  flex-direction: column;
  padding: 18px 20px 20px;
  flex: 1;
  gap: 10px;
}

.cat-card__title {
  font-size: 1rem;
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-smoke-900);
  margin: 0;
}
.cat-card__title a {
  color: inherit;
  text-decoration: none;
  transition: color 0.15s;
}
@media (hover: hover) {
  .cat-card__title a:hover { color: var(--color-fire-600); }
}

.cat-card__desc {
  font-size: 0.78rem;
  color: var(--color-smoke-500);
  line-height: 1.55;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Lista de productos ────────────────────────────────────────── */
.cat-card__list {
  list-style: none;
  padding: 0;
  margin: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--color-smoke-100);
  padding-top: 10px;
  gap: 2px;
}

.cat-card__list-link {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 0;
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--color-smoke-600);
  text-decoration: none;
  line-height: 1.3;
  transition: color 0.15s, gap 0.15s;
  border-radius: 4px;
}

.cat-card__list-arrow {
  flex-shrink: 0;
  color: var(--color-fire-500);
  opacity: 0.6;
  transition: opacity 0.15s, transform 0.15s;
}

@media (hover: hover) {
  .cat-card__list-link:hover {
    color: var(--color-fire-700);
    gap: 9px;
  }
  .cat-card__list-link:hover .cat-card__list-arrow {
    opacity: 1;
    transform: translateX(2px);
  }
}

/* ── CTA ───────────────────────────────────────────────────────── */
.cat-card__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: auto;
  padding: 10px 16px;
  background: var(--color-smoke-900);
  color: #fff;
  font-size: 0.78rem;
  font-weight: 700;
  text-decoration: none;
  border-radius: 10px;
  transition: background 0.15s, gap 0.15s;
  letter-spacing: 0.01em;
}

@media (hover: hover) {
  .cat-card__cta:hover {
    background: var(--color-fire-600);
    gap: 12px;
  }
}
.cat-card__cta svg { flex-shrink: 0; transition: transform 0.15s; }
@media (hover: hover) {
  .cat-card__cta:hover svg { transform: translateX(3px); }
}
</style>
